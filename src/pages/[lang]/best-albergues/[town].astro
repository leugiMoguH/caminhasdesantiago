---
import MainLayout from '../../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { buildClusterGraph } from '../../../lib/clusterSchema';
import {
  UI,
  LANGS,
  townPath,
  stagePath,
  hubPath,
  bestAlberguesPath,
  coastalWhereToStayPath,
  essentialNav,
  i18nUrlsFor,
  type Lang,
} from '../../../lib/clusterRoutes';
import { bookingSearch } from '../../../lib/booking';
import StayCard from '../../../components/StayCard.astro';
import TrustBadge from '../../../components/TrustBadge.astro';
import { pilgrimNote } from '../../../lib/pilgrimNotes';

type Link = { url: string; label: string };
type Acc = {
  name: string;
  type: string;
  beds?: number;
  priceEUR?: string;
  openSeason?: string;
  url?: string;
  highlight?: Record<Lang, string>;
  bookable?: boolean;
};

export async function getStaticPaths() {
  const [towns, stages] = await Promise.all([
    getCollection('towns', (e) => e.data.sourceVerified),
    getCollection('stages', (e) => e.data.sourceVerified),
  ]);
  const stageById = new Map(stages.map((s) => [s.id, s]));
  // Only towns that actually have ranked accommodation become comparison pages.
  return towns
    .filter((t) => t.data.accommodations.length > 0)
    .flatMap((town) =>
      LANGS.map((lang) => {
        const d = town.data;
        const st = stageById.get(d.onStageSlug);
        const stage: Link | null = st
          ? { url: stagePath(lang, d.onStageSlug), label: st.data.i18n[lang].h1 }
          : null;
        return { params: { lang, town: town.id }, props: { lang, data: d, stage } };
      }),
    );
}

const { lang, data, stage } = Astro.props as { lang: Lang; data: any; stage: Link | null };
const ui = UI[lang];
const slug = Astro.params.town as string;
const PAGE_PATH = bestAlberguesPath(lang, slug);
const i18nUrls = i18nUrlsFor(bestAlberguesPath, slug);

const accs: Acc[] = data.accommodations;
const count = accs.length;
const priceNum = (a: Acc): number => {
  const m = a.priceEUR ? a.priceEUR.match(/\d+/) : null;
  return m ? parseInt(m[0], 10) : Number.POSITIVE_INFINITY;
};
const cheapestIdx = accs.reduce((best, a, i) => (priceNum(a) < priceNum(accs[best]) ? i : best), 0);
const fromPrice = Math.min(...accs.map(priceNum).filter((n) => Number.isFinite(n)));

// ── Localized strings ────────────────────────────────────────────────────────
const L = {
  en: {
    h1: `Best albergues in ${data.name}`,
    metaTitle: `The ${count} Best Albergues in ${data.name} (2026) — Compared for Pilgrims`,
    metaDescription: `The ${count} pilgrim albergues in ${data.name} on the Portuguese Camino, ranked and compared — beds, prices from €${fromPrice}, booking and who each suits. Updated 2026.`,
    intro: `${data.name} has ${count} pilgrim ${count === 1 ? 'albergue' : 'albergues'} on the Portuguese Camino, with dorm beds from about €${fromPrice}. Below they are compared on price, beds, season and booking, so you can pick the right one for tonight.`,
    lowest: 'Lowest price',
    books: 'Takes reservations',
    firstcome: 'First-come',
    chooseH: 'How to choose',
    chooseB: 'Public (municipal/Xunta) albergues are the cheapest but first-come — arrive early in summer. Private albergues cost a little more but take reservations, so they are the safer bet if you walk late or want certainty. Book a private bed ahead from May to October.',
    compare: `Compare all ${data.name} stays on Booking.com`,
    relatedH: 'Plan your stop',
    townGuide: `${data.name} pilgrim guide`,
    whereStay: 'Where to stay on the Coastal Camino',
    faqH: ui.faqHeading,
    crumbStay: 'Where to stay',
  },
  es: {
    h1: `Mejores albergues en ${data.name}`,
    metaTitle: `Los ${count} Mejores Albergues en ${data.name} (2026) — Comparados para Peregrinos`,
    metaDescription: `Los ${count} albergues de peregrinos en ${data.name} en el Camino Portugués, clasificados y comparados: plazas, precios desde ${fromPrice} €, reserva y a quién conviene cada uno. Actualizado 2026.`,
    intro: `${data.name} tiene ${count} ${count === 1 ? 'albergue' : 'albergues'} de peregrinos en el Camino Portugués, con plazas en litera desde unos ${fromPrice} €. Abajo se comparan por precio, plazas, temporada y reserva para que elijas el adecuado para esta noche.`,
    lowest: 'Precio más bajo',
    books: 'Admite reserva',
    firstcome: 'Por orden de llegada',
    chooseH: 'Cómo elegir',
    chooseB: 'Los albergues públicos (municipales/Xunta) son los más baratos pero por orden de llegada: llega temprano en verano. Los privados cuestan algo más pero admiten reserva, así que son la opción más segura si caminas hasta tarde o quieres certeza. Reserva una plaza privada con antelación de mayo a octubre.',
    compare: `Compara todos los alojamientos en ${data.name} en Booking.com`,
    relatedH: 'Planifica tu parada',
    townGuide: `Guía de peregrinos de ${data.name}`,
    whereStay: 'Dónde dormir en el Camino de la Costa',
    faqH: ui.faqHeading,
    crumbStay: 'Dónde dormir',
  },
  pt: {
    h1: `Melhores albergues em ${data.name}`,
    metaTitle: `Os ${count} Melhores Albergues em ${data.name} (2026) — Comparados para Peregrinos`,
    metaDescription: `Os ${count} albergues de peregrinos em ${data.name} no Caminho Português, classificados e comparados: camas, preços desde ${fromPrice} €, reserva e a quem convém cada um. Atualizado 2026.`,
    intro: `${data.name} tem ${count} ${count === 1 ? 'albergue' : 'albergues'} de peregrinos no Caminho Português, com camas em beliche desde cerca de ${fromPrice} €. Abaixo são comparados por preço, camas, época e reserva para escolheres o certo para esta noite.`,
    lowest: 'Preço mais baixo',
    books: 'Aceita reserva',
    firstcome: 'Por ordem de chegada',
    chooseH: 'Como escolher',
    chooseB: 'Os albergues públicos (municipais/Xunta) são os mais baratos mas por ordem de chegada: chega cedo no verão. Os privados custam um pouco mais mas aceitam reserva, por isso são a aposta mais segura se caminhas até tarde ou queres certeza. Reserva uma cama privada com antecedência de maio a outubro.',
    compare: `Compara todos os alojamentos em ${data.name} no Booking.com`,
    relatedH: 'Planeia a tua paragem',
    townGuide: `Guia de peregrinos de ${data.name}`,
    whereStay: 'Onde ficar no Caminho da Costa',
    faqH: ui.faqHeading,
    crumbStay: 'Onde ficar',
  },
}[lang];

// CTR title variation (A/B-style across pages, stable per town): each town gets
// one of three high-CTR patterns — price anchor + an emotional/synonym trigger
// (best / cheapest / where to sleep, albergues / hostels). Deterministic by slug
// so the title is consistent between builds but differs page-to-page (less
// templated, captures synonym queries without extra URLs).
const titleIdx = [...slug].reduce((s, c) => s + c.charCodeAt(0), 0) % 3;
const titlePatterns: Record<Lang, ((n: number, name: string, p: number) => string)[]> = {
  en: [
    (n, name, p) => `The ${n} Best Albergues in ${name} (2026) — Pilgrim Beds from €${p}`,
    (n, name, p) => `Cheapest Albergues in ${name} (2026): ${n} Pilgrim Hostels from €${p}`,
    (n, name, p) => `Where to Sleep in ${name}: ${n} Best Pilgrim Albergues from €${p} (2026)`,
  ],
  es: [
    (n, name, p) => `Los ${n} Mejores Albergues en ${name} (2026) — Plazas desde ${p} €`,
    (n, name, p) => `Albergues más Baratos en ${name} (2026): ${n} Hostales de Peregrinos desde ${p} €`,
    (n, name, p) => `Dónde Dormir en ${name}: ${n} Mejores Albergues de Peregrinos desde ${p} € (2026)`,
  ],
  pt: [
    (n, name, p) => `Os ${n} Melhores Albergues em ${name} (2026) — Camas desde ${p} €`,
    (n, name, p) => `Albergues mais Baratos em ${name} (2026): ${n} Hostels de Peregrinos desde ${p} €`,
    (n, name, p) => `Onde Dormir em ${name}: ${n} Melhores Albergues de Peregrinos desde ${p} € (2026)`,
  ],
};
const singularTitle: Record<Lang, (name: string, p: number) => string> = {
  en: (name, p) => `Where to Stay in ${name} (2026): Best Pilgrim Albergue from €${p}`,
  es: (name, p) => `Dónde Dormir en ${name} (2026): Mejor Albergue de Peregrinos desde ${p} €`,
  pt: (name, p) => `Onde Ficar em ${name} (2026): Melhor Albergue de Peregrinos desde ${p} €`,
};
const metaTitle =
  count === 1 ? singularTitle[lang](data.name, fromPrice) : titlePatterns[lang][titleIdx](count, data.name, fromPrice);

const stayHub = coastalWhereToStayPath(lang);
const guide = townPath(lang, slug);
const hub = hubPath(lang);
// Internal-link flow (Phase 5 STEP 4) — guide + two logistics pages.
const essentials = essentialNav(lang);
// Monetization framing (Phase 5 STEP 3).
const pickLead: Record<Lang, string> = {
  en: 'These are the stays most pilgrims actually choose — here’s how to pick yours.',
  es: 'Estos son los alojamientos que la mayoría de los peregrinos elige — así eliges el tuyo.',
  pt: 'Estes são os alojamentos que a maioria dos peregrinos escolhe — eis como escolher o teu.',
};
const availabilityNudge: Record<Lang, string> = {
  en: 'Check availability early — the best options go first.',
  es: 'Comprueba la disponibilidad pronto — las mejores opciones vuelan.',
  pt: 'Confirma a disponibilidade cedo — as melhores opções vão primeiro.',
};

const breadcrumb = [
  { name: ui.home, item: `/${lang}/` },
  { name: ui.routeHub, item: hub },
  { name: L.crumbStay, item: stayHub },
  { name: L.h1, item: PAGE_PATH },
];
const faq = data.i18n[lang].faq ?? [];
const graph = buildClusterGraph({
  lang,
  pagePath: PAGE_PATH,
  title: metaTitle,
  description: L.metaDescription,
  breadcrumb,
  entity: {
    '@type': 'ItemList',
    name: L.h1,
    numberOfItems: count,
    itemListElement: accs.map((a, i) => ({ '@type': 'ListItem', position: i + 1, name: a.name })),
  },
  faq,
  dateModified: data.lastVerified,
});
const compareHref = bookingSearch(data.name, `wtsg-bestalb-${lang}-${slug}-compare`);
---

<MainLayout title={metaTitle} description={L.metaDescription} lang={lang} schemaType="none" i18nUrls={i18nUrls}>
  <script type="application/ld+json" set:html={JSON.stringify(graph).replace(/</g, '\\u003c')} />

  <div class="bg-gradient-to-br from-forest-800 to-forest-950 text-white">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <nav aria-label="Breadcrumb" class="mb-5">
        <ol class="flex flex-wrap items-center gap-2 text-sm text-forest-100">
          <li><a href={`/${lang}/`} class="text-slate-300 hover:text-white no-underline hover:underline">{ui.home}</a></li>
          <li aria-hidden="true" class="text-forest-600">›</li>
          <li><a href={hub} class="text-slate-300 hover:text-white no-underline hover:underline">{ui.routeHub}</a></li>
          <li aria-hidden="true" class="text-forest-600">›</li>
          <li><a href={stayHub} class="text-slate-300 hover:text-white no-underline hover:underline">{L.crumbStay}</a></li>
          <li aria-hidden="true" class="text-forest-600">›</li>
          <li aria-current="page" class="text-white font-medium">{data.name}</li>
        </ol>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold mb-4 tracking-tight text-white">{L.h1}</h1>
      <p class="text-forest-100 text-base leading-relaxed max-w-2xl">{L.intro}</p>
      <TrustBadge lang={lang} variant="dark" class="mt-5" />
      <!-- Standardized CTA: intro -->
      <div data-aff-pos="intro" class="mt-6">
        <a href={compareHref} rel="nofollow noopener noreferrer sponsored" target="_blank" class="inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-earth-500 to-earth-600 px-5 py-3 text-sm font-bold text-white no-underline shadow-md transition-all hover:from-earth-600 hover:to-earth-700">
          {L.compare}
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12 space-y-10">
    <!-- Ranked comparison (card layout, primary highlighted) -->
    <section data-aff-pos="mid">
      <p class="text-slate-600 leading-relaxed mb-4">{pickLead[lang]}</p>
      <ol class="space-y-4">
        {accs.map((a, i) => (
          <StayCard lang={lang} acc={a} rank={i + 1} primary={i === 0} lowest={i === cheapestIdx} note={pilgrimNote(a, lang)} />
        ))}
      </ol>
      <p class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-earth-800">
        <span aria-hidden="true">⚡</span> {availabilityNudge[lang]}
      </p>
      <div class="mt-2">
        <a href={compareHref} rel="nofollow noopener noreferrer sponsored" target="_blank" class="inline-flex items-center gap-1.5 text-sm font-semibold text-earth-700 hover:underline no-underline">
          {L.compare}
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </section>

    <!-- How to choose -->
    <section class="bg-slate-50 border border-slate-200 rounded-2xl p-6">
      <h2 class="text-base font-bold text-forest-900 mb-2">{L.chooseH}</h2>
      <p class="text-sm text-slate-700 leading-relaxed">{L.chooseB}</p>
    </section>

    <!-- Internal links -->
    <section class="bg-forest-50 border border-forest-200 rounded-2xl p-6">
      <h2 class="text-base font-bold text-forest-900 mb-3">{L.relatedH}</h2>
      <ul class="space-y-2 text-sm">
        <li><a href={guide} class="text-forest-700 hover:underline no-underline font-medium">{L.townGuide}</a></li>
        {stage && <li><a href={stage.url} class="text-forest-700 hover:underline no-underline font-medium">{stage.label}</a></li>}
        <li><a href={stayHub} class="text-forest-700 hover:underline no-underline font-medium">{L.whereStay}</a></li>
        {essentials.map((e) => (
          <li><a href={e.url} class="text-forest-700 hover:underline no-underline font-medium">{e.label}</a></li>
        ))}
      </ul>
    </section>

    <!-- FAQ -->
    {faq.length > 0 && (
      <section>
        <h2 class="text-2xl font-bold text-forest-900 mb-5 tracking-tight">{L.faqH}</h2>
        <div class="space-y-3">
          {faq.map((f: { q: string; a: string }) => (
            <details class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
              <summary class="px-6 py-4 font-semibold text-forest-900 cursor-pointer">{f.q}</summary>
              <div class="px-6 pb-5 text-sm text-slate-700 leading-relaxed border-t border-slate-100 pt-3">{f.a}</div>
            </details>
          ))}
        </div>
      </section>
    )}

    <!-- Standardized CTA: end -->
    <aside data-aff-pos="end" class="bg-forest-800 text-white rounded-2xl p-6 flex flex-col sm:flex-row sm:items-center gap-4">
      <p class="flex-1 text-sm text-forest-50 leading-relaxed font-medium">{L.intro}</p>
      <a href={compareHref} rel="nofollow noopener noreferrer sponsored" target="_blank" class="inline-flex shrink-0 items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-earth-500 to-earth-600 px-5 py-3 text-sm font-bold text-white no-underline shadow-md transition-all hover:from-earth-600 hover:to-earth-700">
        {L.compare}
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
    </aside>

    <p class="text-xs text-slate-500">{ui.sourcesNote}: {data.sources.join(' · ')}</p>
  </div>
</MainLayout>
