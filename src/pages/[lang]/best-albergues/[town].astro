---
// Consolidated (2026-06-29): every town on the route has ≤2 albergues, so this
// standalone "best albergues" comparison duplicated the destino/[town]
// accommodations section (same StayCards + FAQ) — thin/near-duplicate pages that
// diluted the new domain's quality signal. These URLs now 301-redirect to the
// town guide, which carries the same (and richer) albergue info and already
// targets the "albergues in <town>" query in its title.
import { getCollection } from 'astro:content';
import { LANGS, townPath, type Lang } from '../../../lib/clusterRoutes';

export async function getStaticPaths() {
  const towns = await getCollection('towns', (e) => e.data.sourceVerified);
  return towns.flatMap((town) =>
    LANGS.map((lang) => ({ params: { lang, town: town.id }, props: { lang, town: town.id } })),
  );
}

const { lang, town } = Astro.props as { lang: Lang; town: string };
return Astro.redirect(townPath(lang, town), 301);
---
