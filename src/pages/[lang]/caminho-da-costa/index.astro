---
import MainLayout from '../../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { buildClusterGraph } from '../../../lib/clusterSchema';
import {
  UI,
  LANGS,
  hubPath,
  stagePath,
  townPath,
  bestAlberguesPath,
  logisticsPath,
  ferryPath,
  coastalWhereToStayPath,
  bestStagesToSleepPath,
  cheapestAlberguesPath,
  i18nUrlsFor,
  SITE_URL,
  type Lang,
} from '../../../lib/clusterRoutes';

export async function getStaticPaths() {
  const [stages, logistics, towns] = await Promise.all([
    getCollection('stages', (e) => e.data.sourceVerified),
    getCollection('logistics', (e) => e.data.sourceVerified),
    getCollection('towns', (e) => e.data.sourceVerified),
  ]);
  const ordered = stages.sort((a, b) => a.data.order - b.data.order);
  const lastmod = ordered.reduce((m, s) => (s.data.lastVerified > m ? s.data.lastVerified : m), '');
  // Towns sorted along the route (by their stage order) so the hub links every
  // town + its albergues comparison directly — keeps crawl depth at 1 hop.
  const stageOrder = (slug: string): number =>
    stages.find((s) => s.id === slug)?.data.order ?? 999;
  const townsSorted = [...towns].sort(
    (a, b) => stageOrder(a.data.onStageSlug) - stageOrder(b.data.onStageSlug),
  );
  return LANGS.map((lang) => ({
    params: { lang },
    props: {
      lang,
      lastmod,
      stages: ordered.map((s) => ({
        url: stagePath(lang, s.id),
        label: s.data.i18n[lang].h1,
        distanceKm: s.data.distanceKm,
        difficulty: s.data.difficulty,
      })),
      logistics: logistics.map((l) => ({ url: logisticsPath(lang, l.id), label: l.data.i18n[lang].h1 })),
      towns: townsSorted.map((tn) => ({
        url: townPath(lang, tn.id),
        label: tn.data.name,
        bestAlb: tn.data.accommodations.length > 0 ? bestAlberguesPath(lang, tn.id) : null,
      })),
    },
  }));
}

type StageCard = { url: string; label: string; distanceKm: number; difficulty: 'easy' | 'moderate' | 'hard' };
type Link = { url: string; label: string };
type TownLink = { url: string; label: string; bestAlb: string | null };
const { lang, stages, logistics, towns, lastmod } = Astro.props as { lang: Lang; stages: StageCard[]; logistics: Link[]; towns: TownLink[]; lastmod: string };
const ui = UI[lang];
const PAGE_PATH = hubPath(lang);
const i18nUrls = { en: `${SITE_URL}${hubPath('en')}`, es: `${SITE_URL}${hubPath('es')}`, pt: `${SITE_URL}${hubPath('pt')}` };

const title =
  lang === 'en'
    ? 'Portuguese Coastal Camino — North Cluster Guide (Viana to Galicia, 2026)'
    : lang === 'es'
      ? 'Camino Portugués de la Costa — Guía del Tramo Norte (Viana a Galicia, 2026)'
      : 'Caminho Português da Costa — Guia do Troço Norte (Viana à Galiza, 2026)';
const description = ui.routeHubTagline;

const breadcrumb = [
  { name: ui.home, item: `/${lang}/` },
  { name: ui.routeHub, item: PAGE_PATH },
];
const graph = buildClusterGraph({
  lang,
  pagePath: PAGE_PATH,
  title,
  description,
  breadcrumb,
  entity: {
    '@type': 'ItemList',
    name: ui.routeHub,
    itemListElement: stages.map((s, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: s.label,
      url: `${SITE_URL}${s.url}`,
    })),
  },
  dateModified: lastmod,
});
const ferry = ferryPath(lang);
const stayHub = coastalWhereToStayPath(lang);
const bestStages = bestStagesToSleepPath(lang);
const cheapest = cheapestAlberguesPath(lang);
const planStay = {
  en: { h: 'Where to stay', stay: 'Where to stay on the Coastal Camino — best towns & albergues', stages: 'Best stages to sleep — how to break the route', cheap: 'Cheapest albergues — budget beds from €10' },
  es: { h: 'Dónde dormir', stay: 'Dónde dormir en el Camino de la Costa — mejores pueblos y albergues', stages: 'Mejores etapas para dormir — cómo partir la ruta', cheap: 'Albergues más baratos — plazas desde 10 €' },
  pt: { h: 'Onde ficar', stay: 'Onde ficar no Caminho da Costa — melhores vilas e albergues', stages: 'Melhores etapas para dormir — como partir o percurso', cheap: 'Albergues mais baratos — camas desde 10 €' },
}[lang];
const townsUI = {
  en: { h: 'Towns on the route', sub: 'Guide, services and where to sleep in each town', alb: 'Best albergues' },
  es: { h: 'Pueblos de la ruta', sub: 'Guía, servicios y dónde dormir en cada pueblo', alb: 'Mejores albergues' },
  pt: { h: 'Localidades do percurso', sub: 'Guia, serviços e onde ficar em cada localidade', alb: 'Melhores albergues' },
}[lang];
---

<MainLayout title={title} description={description} lang={lang} schemaType="none" i18nUrls={i18nUrls}>
  <script type="application/ld+json" set:html={JSON.stringify(graph).replace(/</g, '\\u003c')} />

  <div class="bg-gradient-to-br from-slate-800 via-slate-800 to-forest-950 text-white">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-14 md:py-20">
      <nav aria-label="Breadcrumb" class="mb-5">
        <ol class="flex items-center gap-2 text-sm text-slate-400">
          <li><a href={`/${lang}/`} class="text-slate-300 hover:text-white no-underline hover:underline">{ui.home}</a></li>
          <li aria-hidden="true" class="text-slate-600">›</li>
          <li aria-current="page" class="text-slate-200 font-medium">{ui.routeHub}</li>
        </ol>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold mb-4 tracking-tight text-white">{ui.routeHub}</h1>
      <p class="text-slate-300 text-base leading-relaxed max-w-2xl">{ui.routeHubTagline}</p>
    </div>
  </div>

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12 space-y-10">
    <section>
      <h2 class="text-2xl font-bold text-forest-900 mb-5 tracking-tight">{ui.stagesHeading}</h2>
      <div class="space-y-3">
        {stages.map((s) => (
          <a href={s.url} class="flex items-center justify-between gap-4 bg-white border border-slate-200 rounded-2xl p-5 no-underline hover:border-forest-300 shadow-sm">
            <span class="font-semibold text-forest-800">{s.label}</span>
            <span class="text-xs text-slate-500 shrink-0">{s.distanceKm} km · {ui.difficultyLabel[s.difficulty]}</span>
          </a>
        ))}
      </div>
    </section>

    {towns.length > 0 && (
      <section>
        <h2 class="text-2xl font-bold text-forest-900 mb-1 tracking-tight">{townsUI.h}</h2>
        <p class="text-sm text-slate-600 mb-5">{townsUI.sub}</p>
        <div class="grid gap-3 sm:grid-cols-2">
          {towns.map((tn) => (
            <div class="flex items-center justify-between gap-3 bg-white border border-slate-200 rounded-2xl p-4 shadow-sm">
              <a href={tn.url} class="font-semibold text-forest-800 no-underline hover:underline">{tn.label}</a>
              {tn.bestAlb && (
                <a href={tn.bestAlb} class="text-xs font-medium text-earth-700 no-underline hover:underline shrink-0">{townsUI.alb} →</a>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    <section class="bg-forest-50 border border-forest-200 rounded-2xl p-6">
      <h2 class="text-base font-bold text-forest-900 mb-3">{planStay.h}</h2>
      <ul class="space-y-2 text-sm">
        <li><a href={stayHub} class="text-forest-700 hover:underline no-underline font-medium">{planStay.stay}</a></li>
        <li><a href={cheapest} class="text-forest-700 hover:underline no-underline font-medium">{planStay.cheap}</a></li>
        <li><a href={bestStages} class="text-forest-700 hover:underline no-underline font-medium">{planStay.stages}</a></li>
      </ul>
    </section>

    <section class="bg-forest-50 border border-forest-200 rounded-2xl p-6">
      <h2 class="text-base font-bold text-forest-900 mb-3">{ui.logisticsHeading}</h2>
      <ul class="space-y-2 text-sm">
        {logistics.map((x) => (
          <li><a href={x.url} class="text-forest-700 hover:underline no-underline font-medium">{x.label}</a></li>
        ))}
        <li><a href={ferry} class="text-forest-700 hover:underline no-underline font-medium">{ui.crossingLink}</a></li>
      </ul>
    </section>
  </div>
</MainLayout>
