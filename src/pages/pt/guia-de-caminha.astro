---
import MainLayout from '../../layouts/MainLayout.astro';
import PhotoFigure from '../../components/PhotoFigure.astro';
import torrePhoto from '../../assets/photos/caminha-torre-relogio.jpg';

const SITE_URL = 'https://waytosantiagoguide.com';

const clusters = [
  {
    id: 'alojamento',
    label: 'Alojamento',
    href: '/pt/caminha/onde-ficar/',
    icon: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12V7a2 2 0 012-2h14a2 2 0 012 2v5M3 12v5a1 1 0 001 1h16a1 1 0 001-1v-5M3 12h18M7 12V9h4v3"/></svg>`,
  },
  {
    id: 'comida',
    label: 'Onde Comer',
    href: '/pt/caminha/onde-comer/',
    icon: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2v20"/><path stroke-linecap="round" stroke-linejoin="round" d="M8 2c0 4 4 4 4 8s-4 4-4 8"/><path stroke-linecap="round" stroke-linejoin="round" d="M16 2v6a2 2 0 004 0V2M18 8v14"/></svg>`,
  },
  {
    id: 'ferry',
    label: 'Ferry e Logística',
    href: '/pt/caminha/ferry-e-logistica/',
    icon: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M22 18H2l4-8h12l4 8z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 2v8"/></svg>`,
  },
  {
    id: 'servicos',
    label: 'Serviços Úteis',
    href: '/pt/caminha/servicos-uteis/',
    icon: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
  },
];

const faqItems = [
  {
    q: 'Onde fica Caminha no Caminho de Santiago?',
    a: 'Caminha é a última vila portuguesa do Caminho de Santiago da Costa (Caminho da Costa), situada na foz do rio Minho, 24 km a norte de Viana do Castelo. Fica mesmo em frente a A Guarda, Galiza (Espanha), e os peregrinos atravessam de barco para continuar para norte rumo a Santiago de Compostela.',
  },
  {
    q: 'Como atravessam os peregrinos de Caminha para Espanha?',
    a: 'Os peregrinos atravessam o Minho de táxi fluvial licenciado — cerca de 10 minutos sobre a água, €6 por pessoa (€7–8 com bicicleta). Vários serviços operam diariamente, entre eles Taxi Boat Peregrinos (cerca de 30 em 30 minutos, abr–out), Xacobeo Transfer (cerca de hora a hora, reserva online, todo o ano), Taxi Mar Caminha e Popeye the Sailor Man. O antigo ferry Santa Rita de Cássia parou em 2020 devido ao assoreamento da foz e será desmantelado; está anunciado um novo ferry municipal para o verão de 2026, mas ainda não opera. Se não houver barco, apanhe o comboio para Valença e atravesse a pé a ponte Tui–Valença.',
  },
  {
    q: 'Há albergue municipal em Caminha?',
    a: 'Sim. O Albergue Municipal de Peregrinos de Caminha fica no centro, a poucos minutos do cais. Apenas admissão direta (abre às 14:00), exige credencial do peregrino válida e funciona por ordem de chegada, com um máximo de 2 noites consecutivas. Os albergues privados (Albergue Santiago, Bom Caminha) reservam-se com antecedência no Booking.com.',
  },
  {
    q: 'Que serviços para peregrinos há em Caminha antes de atravessar?',
    a: 'Caminha tem um sistema rotativo de farmácia de serviço — só uma farmácia abre por dia; pergunte no seu albergue qual está de serviço. As lojas de equipamento ficam no centro histórico. O Multibanco fica perto da Praça do Conselho. Emergências: 112.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SITE_URL}/#organization`,
      name: 'Way to Santiago Guide',
      url: SITE_URL,
      logo: { '@type': 'ImageObject', url: `${SITE_URL}/logo.png` },
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE_URL}/#website`,
      url: SITE_URL,
      name: 'Way to Santiago Guide',
    },
    {
      '@type': 'WebPage',
      '@id': `${SITE_URL}/pt/guia-de-caminha/#webpage`,
      url: `${SITE_URL}/pt/guia-de-caminha/`,
      name: 'Guia de Caminha no Caminho de Santiago da Costa — Alojamento, Comida, Ferry e Serviços',
      description: 'Guia completo do peregrino para Caminha no Caminho de Santiago da Costa. A travessia do rio, onde dormir, onde comer e serviços para peregrinos — tudo verificado e num só lugar.',
      inLanguage: 'pt-PT',
      isPartOf: { '@id': `${SITE_URL}/#website` },
      about: { '@id': `${SITE_URL}/#organization` },
      breadcrumb: { '@id': `${SITE_URL}/pt/guia-de-caminha/#breadcrumb` },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${SITE_URL}/pt/guia-de-caminha/#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Início', item: `${SITE_URL}/pt/` },
        { '@type': 'ListItem', position: 2, name: 'Guia de Caminha', item: `${SITE_URL}/pt/guia-de-caminha/` },
      ],
    },
    {
      '@type': 'TouristDestination',
      '@id': `${SITE_URL}/pt/guia-de-caminha/#destination`,
      name: 'Caminha',
      description: 'Histórica vila fronteiriça do norte de Portugal no Caminho de Santiago da Costa (Caminho da Costa). Os peregrinos atravessam o rio Minho de táxi fluvial até A Guarda, Espanha. Última etapa portuguesa antes da Galiza.',
      url: `${SITE_URL}/pt/guia-de-caminha/`,
      touristType: 'Peregrino',
      geo: { '@type': 'GeoCoordinates', latitude: 41.8772, longitude: -8.8389 },
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Caminha',
        addressRegion: 'Viana do Castelo',
        postalCode: '4910',
        addressCountry: 'PT',
      },
      includesAttraction: [
        {
          '@type': 'TouristAttraction',
          '@id': `${SITE_URL}/en/caminha/ferry-and-logistics/#ferry`,
          name: 'Travessia Caminha–A Guarda — rio Minho',
        },
      ],
      containedInPlace: { '@type': 'Country', name: 'Portugal' },
    },
    {
      '@type': 'FAQPage',
      '@id': `${SITE_URL}/pt/guia-de-caminha/#faq`,
      mainEntityOfPage: { '@id': `${SITE_URL}/pt/guia-de-caminha/#webpage` },
      mainEntity: faqItems.map((item) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: { '@type': 'Answer', text: item.a },
      })),
    },
  ],
};
---

<MainLayout
  title="Guia de Caminha no Caminho de Santiago da Costa — Alojamento, Comida, Ferry e Serviços"
  description="Guia completo do peregrino para Caminha no Caminho de Santiago da Costa. A travessia do rio, onde dormir, onde comer e serviços — tudo verificado e num só lugar."
  lang="pt"
  schemaType="none"
>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

  <!-- ── HERO ──────────────────────────────────────────────────────────────────── -->
  <div class="bg-gradient-to-b from-forest-50 to-white border-b border-forest-100/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <nav aria-label="Trilho de navegação" class="mb-5">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/pt/" class="hover:text-forest-700 no-underline hover:underline transition-colors">Início</a></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li aria-current="page" class="text-slate-700 font-medium">Guia de Caminha</li>
        </ol>
      </nav>

      <p class="text-earth-600 text-xs font-bold uppercase tracking-widest mb-3">
        Caminho de Santiago · Rota da Costa · Caminha, Portugal
      </p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-forest-900 mb-4 tracking-tight leading-tight max-w-3xl">
        Caminha — O Guia Completo do Caminho da Costa
      </h1>
      <p class="text-slate-600 max-w-2xl text-base leading-relaxed mb-8">
        A última vila portuguesa antes de Espanha. A travessia do rio, alojamento, restauração e serviços para peregrinos — tudo verificado para o Caminho da Costa.
      </p>

      <dl class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {[
          { value: '~10 min', label: 'Barco para Espanha' },
          { value: '€6', label: 'Tarifa do táxi fluvial' },
          { value: '24 km', label: 'De Viana do Castelo' },
          { value: 'Diário', label: 'Travessias de táxi fluvial' },
        ].map(({ value, label }) => (
          <div class="bg-white border border-forest-100 rounded-2xl px-4 py-4 text-center shadow-sm">
            <dt class="text-xl font-bold text-forest-700">{value}</dt>
            <dd class="text-xs text-slate-500 mt-0.5">{label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>

  <!-- Foto de Caminha -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pt-8">
    <PhotoFigure
      src={torrePhoto}
      alt="A Torre do Relógio medieval de Caminha sobre o centro histórico"
      caption="A Torre do Relógio — emblema de Caminha no centro histórico"
      loading="eager"
      class="!my-0"
    />
  </div>

  <!-- ── NAVEGAÇÃO POR CLUSTERS ────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-4 border-b border-slate-100">
    <div class="flex flex-wrap gap-2">
      {clusters.map((c) => (
        <a href={`#cluster-${c.id}`} class="inline-flex items-center gap-1.5 bg-white border border-forest-200 text-forest-800 text-xs font-medium px-3.5 py-2 rounded-full hover:bg-forest-50 hover:border-forest-300 no-underline transition-all duration-200 shadow-sm">
          {c.label}
        </a>
      ))}
    </div>
  </div>

  <!-- ── AVISO DE ASSOREAMENTO ─────────────────────────────────────────────────── -->
  <div class="bg-gradient-to-r from-amber-600 to-orange-600 text-white" role="alert">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-3 flex items-center gap-3">
      <svg class="h-5 w-5 shrink-0 text-white/90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
      </svg>
      <p class="text-sm text-white/95 leading-relaxed">
        <strong>Risco de assoreamento:</strong> a travessia de Caminha pode ser suspensa sem aviso por <em>assoreamento</em>. Confirme o estado na véspera.
        <a href="/pt/caminha/ferry-e-logistica/" class="underline font-semibold ml-1 hover:text-white/80">Mais detalhes →</a>
      </p>
    </div>
  </div>

  <!-- ── SECÇÕES DE CLUSTERS ───────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-14 space-y-16">

    <!-- CLUSTER A: Alojamento -->
    <section id="cluster-alojamento" aria-labelledby="cluster-alojamento-heading">
      <div class="flex items-center gap-3 mb-6">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-forest-100 border border-forest-200 text-forest-700">
          <Fragment set:html={clusters[0].icon} />
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-forest-600">Cluster A</p>
          <h2 id="cluster-alojamento-heading" class="text-2xl font-bold text-forest-900 tracking-tight">Alojamento em Caminha</h2>
        </div>
      </div>
      <p class="text-slate-600 text-sm leading-relaxed mb-6 max-w-2xl">
        Três zonas de alojamento na Rota da Costa: Caminha (ponto de travessia, a maioria dos albergues), Vila Praia de Âncora (8 km a sul, hotéis de praia) e Seixas (freguesia em rota, alojamento junto à praia). O albergue municipal é só admissão direta a partir das 14:00 — as opções privadas reservam-se com antecedência.
      </p>
      <a
        href="/pt/caminha/onde-ficar/"
        class="group inline-flex items-center gap-3 bg-gradient-to-br from-forest-800 to-forest-950 text-white rounded-2xl px-7 py-4 no-underline shadow-xl hover:shadow-2xl hover:-translate-y-0.5 transition-all duration-200 font-bold"
      >
        <svg class="h-5 w-5 text-earth-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12V7a2 2 0 012-2h14a2 2 0 012 2v5M3 12v5a1 1 0 001 1h16a1 1 0 001-1v-5M3 12h18M7 12V9h4v3"/>
        </svg>
        Onde Ficar — Todas as Opções
        <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
      <div class="mt-4 flex flex-wrap gap-4 text-sm">
        <a href="/pt/caminha/vila-praia-de-ancora/" class="text-forest-700 hover:underline no-underline font-medium flex items-center gap-1">Vila Praia de Âncora <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></a>
        <a href="/pt/caminha/seixas/" class="text-forest-700 hover:underline no-underline font-medium flex items-center gap-1">Seixas <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></a>
      </div>
    </section>

    <hr class="border-slate-100" />

    <!-- CLUSTER B: Comida -->
    <section id="cluster-comida" aria-labelledby="cluster-comida-heading">
      <div class="flex items-center gap-3 mb-6">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-earth-100 border border-earth-200 text-earth-700">
          <Fragment set:html={clusters[1].icon} />
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-earth-600">Cluster B</p>
          <h2 id="cluster-comida-heading" class="text-2xl font-bold text-forest-900 tracking-tight">Onde Comer em Caminha</h2>
        </div>
      </div>
      <p class="text-slate-600 text-sm leading-relaxed mb-6 max-w-2xl">
        Restaurantes em Caminha e Vila Praia de Âncora. Menus de peregrino (menú do peregrino) ao almoço por €8–12, com entrada, prato principal e vinho da casa. Marisco atlântico fresco no percurso até ao cais. Pastelarias abertas desde as 07:00 para as saídas antes do barco. Seixas não tem restaurantes — os peregrinos vão a pé a Caminha (~15 min).
      </p>
      <a
        href="/pt/caminha/onde-comer/"
        class="group inline-flex items-center gap-3 bg-gradient-to-br from-earth-700 to-earth-900 text-white rounded-2xl px-7 py-4 no-underline shadow-xl hover:shadow-2xl hover:-translate-y-0.5 transition-all duration-200 font-bold"
      >
        <svg class="h-5 w-5 text-earth-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 2v20"/><path stroke-linecap="round" stroke-linejoin="round" d="M8 2c0 4 4 4 4 8s-4 4-4 8"/><path stroke-linecap="round" stroke-linejoin="round" d="M16 2v6a2 2 0 004 0V2M18 8v14"/>
        </svg>
        Onde Comer — Todos os Restaurantes
        <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
    </section>

    <hr class="border-slate-100" />

    <!-- CLUSTER C: Ferry -->
    <section id="cluster-ferry" aria-labelledby="cluster-ferry-heading">
      <div class="flex items-center gap-3 mb-6">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-slate-100 border border-slate-200 text-slate-700">
          <Fragment set:html={clusters[2].icon} />
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-slate-500">Cluster C</p>
          <h2 id="cluster-ferry-heading" class="text-2xl font-bold text-forest-900 tracking-tight">Ferry e Logística</h2>
        </div>
      </div>
      <p class="text-slate-600 text-sm leading-relaxed mb-6 max-w-2xl">
        A travessia do rio Minho entre Caminha (Portugal) e A Guarda (Espanha) é um curto trajeto de barco — e um possível problema logístico de um dia inteiro quando o estuário assoreia. Cobre os táxis fluviais diários (€6, ~10 min) que substituíram o ferry Santa Rita de Cássia suspenso, os dois operadores e como reservar, a armadilha do fuso horário Portugal–Espanha e a alternativa terrestre pela ponte Valença–Tui. Para o contexto da rota, a credencial e o planeamento sazonal, consulte o <a href="/pt/caminha/guia-do-peregrino/" class="text-forest-700 hover:underline no-underline font-medium">guia do peregrino da Rota da Costa</a>.
      </p>
      <a
        href="/pt/caminha/ferry-e-logistica/"
        class="group inline-flex items-center gap-3 bg-gradient-to-br from-slate-800 to-slate-900 text-white rounded-2xl px-7 py-4 no-underline shadow-xl hover:shadow-2xl hover:-translate-y-0.5 transition-all duration-200 font-bold"
      >
        <svg class="h-5 w-5 text-earth-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M22 18H2l4-8h12l4 8z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 2v8"/>
        </svg>
        Ferry e Logística — Guia Completo
        <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
    </section>

    <hr class="border-slate-100" />

    <!-- CLUSTER D: Serviços -->
    <section id="cluster-servicos" aria-labelledby="cluster-servicos-heading">
      <div class="flex items-center gap-3 mb-6">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-slate-100 border border-slate-200 text-slate-700">
          <Fragment set:html={clusters[3].icon} />
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-slate-500">Cluster D</p>
          <h2 id="cluster-servicos-heading" class="text-2xl font-bold text-forest-900 tracking-tight">Serviços para Peregrinos</h2>
        </div>
      </div>
      <p class="text-slate-600 text-sm leading-relaxed mb-6 max-w-2xl">
        Infraestrutura prática para a última etapa portuguesa: farmácia de serviço rotativa (só uma farmácia abre por dia — a <em>farmácia de serviço</em>), lojas de equipamento e botas no centro histórico, Multibanco perto da Praça do Conselho e contactos de emergência, incluindo o SNS24 e o posto de turismo de Caminha.
      </p>
      <a
        href="/pt/caminha/servicos-uteis/"
        class="group inline-flex items-center gap-3 bg-gradient-to-br from-slate-600 to-slate-900 text-white rounded-2xl px-7 py-4 no-underline shadow-xl hover:shadow-2xl hover:-translate-y-0.5 transition-all duration-200 font-bold"
      >
        <svg class="h-5 w-5 text-slate-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
        </svg>
        Serviços — Farmácias, Equipamento e Multibanco
        <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
    </section>

  </div>

  <!-- ── SOBRE CAMINHA ─────────────────────────────────────────────────────────── -->
  <section class="bg-forest-50 border-y border-forest-100">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-14">
      <div class="max-w-3xl">
        <h2 class="text-2xl sm:text-3xl font-bold text-forest-900 mb-5">Sobre Caminha no Caminho da Costa</h2>
        <div class="space-y-4 text-slate-700 text-base leading-relaxed">
          <p>
            Caminha (cerca de 7.000 habitantes) situa-se na confluência dos rios Coura e Minho, em frente à vila espanhola de A Guarda. As suas muralhas do século XIV, a torre do relógio fortificada e a elegante Praça do Conselho fazem dela uma das paragens mais distintivas do Caminho Português da Costa.
          </p>
          <p>
            Para os peregrinos que percorrem o <strong>Caminho da Costa</strong>, Caminha marca a transição de Portugal para a Galiza. A travessia do rio —um trajeto curto mas memorável de cerca de 10 minutos de barco— liga as duas margens há séculos; hoje faz-se de táxi fluvial licenciado enquanto se aguarda um novo ferry municipal. Depois de atravessar, os peregrinos continuam para norte por A Guarda ao longo da costa galega rumo a Santiago de Compostela.
          </p>
          <p>
            É uma paragem prática para passar a noite antes da travessia, com albergue municipal de peregrinos, albergues privados, pensões e restaurantes suficientes para recuperar da longa etapa costeira desde Viana do Castelo (24 km).
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FAQ ───────────────────────────────────────────────────────────────────── -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-14" aria-labelledby="guide-faq-heading">
    <h2 id="guide-faq-heading" class="text-2xl font-bold text-forest-900 mb-6 tracking-tight">Perguntas Frequentes</h2>
    <div class="space-y-3 max-w-3xl">
      {faqItems.map((item) => (
        <details class="group bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
          <summary class="flex items-center justify-between gap-4 px-6 py-4 cursor-pointer hover:bg-forest-50/50 transition-colors list-none">
            <span class="text-sm font-semibold text-forest-900 leading-snug">{item.q}</span>
            <svg class="h-5 w-5 text-slate-400 shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 pb-5 pt-1 text-sm text-slate-700 leading-relaxed border-t border-slate-100">
            {item.a}
          </div>
        </details>
      ))}
    </div>
  </section>

</MainLayout>
