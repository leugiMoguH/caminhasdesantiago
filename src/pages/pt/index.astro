---
import MainLayout from '../../layouts/MainLayout.astro';
---
<MainLayout
  title="Guia de Caminha — Caminho de Santiago Rota Costeira"
  description="Guia independente para peregrinos e viajantes na Rota Costeira do Caminho de Santiago em Caminha, Portugal."
  lang="pt"
  schemaType="webpage"
>
  <div class="bg-gradient-to-b from-forest-50 to-white">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-20">
      <h1 class="text-3xl sm:text-4xl font-bold text-forest-900 mb-4 tracking-tight">Guia de Caminha</h1>
      <p class="text-slate-600 max-w-2xl text-base leading-relaxed mb-8">
        Guia independente para peregrinos e viajantes na Rota Costeira do Caminho de Santiago através de Caminha, Vila Praia de Âncora e Seixas, Portugal.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/pt/caminha/onde-ficar/" class="inline-flex items-center gap-2 bg-forest-700 hover:bg-forest-800 text-white font-semibold text-sm px-5 py-3 rounded-xl no-underline transition-colors">
          Onde Ficar
        </a>
        <a href="/pt/caminha/onde-comer/" class="inline-flex items-center gap-2 bg-earth-500 hover:bg-earth-600 text-white font-semibold text-sm px-5 py-3 rounded-xl no-underline transition-colors">
          Onde Comer
        </a>
        <a href="/en/caminha/ferry-and-logistics/" class="inline-flex items-center gap-2 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 font-semibold text-sm px-5 py-3 rounded-xl no-underline transition-colors">
          Ferry e Logística
        </a>
      </div>
    </div>
  </div>
</MainLayout>
