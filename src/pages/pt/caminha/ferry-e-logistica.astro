---
import MainLayout from '../../../layouts/MainLayout.astro';
import PhotoFigure from '../../../components/PhotoFigure.astro';
import { bookingSearch } from '../../../lib/booking';
import assoreamentoPhoto from '../../../assets/photos/caminha-rio-assoreamento.jpg';
import { getEntry } from 'astro:content';
import { buildFerryGraph } from '../../../lib/ferrySchema';

const LANG = 'pt' as const;
const PAGE_PATH = '/pt/caminha/ferry-e-logistica/';

// Single source of truth — all ferry facts come from src/content/crossing/ferry.yml
const entry = await getEntry('crossing', 'caminha-a-guarda');
const f = entry!.data;
const t = f.i18n[LANG];

const ol = t.operatorLabels;
const operadores = f.scheduledOperators.map((op) => ({
  nome: op.name,
  frequencia: ol[op.frequency] ?? op.frequency,
  horario: op.hours,
  preco: `€${op.adultEUR}`,
  bicicleta: `€${op.bikeEUR}`,
  reserva: ol[op.booking] ?? op.booking,
  telefone: op.phone,
  url: op.url,
}));
const alternativaComboio = t.trainDetour.map((r) => ({ de: r.from, para: r.to, duracao: r.duration, tarifaAprox: r.fare, frequencia: r.frequency }));
const faqItems = t.faq.map((x) => ({ pergunta: x.q, resposta: x.a }));
const fares = f.officialFerry.fares.map((row) => ({
  tipo: t.fareLabels[row.key],
  preco: row.priceEUR === 0 ? 'Gratuito' : `€${row.priceEUR.toFixed(2).replace('.', ',')}`,
  nota: t.fareNotes[row.key],
}));

const FACT_ICONS = [
  `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
];
const keyFacts = t.keyFacts.map((kf, i) => ({ icon: FACT_ICONS[i], value: kf.value, label: kf.label }));

const ferryGraph = buildFerryGraph(f, LANG, PAGE_PATH);
---
<MainLayout
  title={t.metaTitle}
  description={t.metaDescription}
  lang="pt"
  schemaType="none"
>

    <!-- JSON-LD: generated from ferry.yml (single source of truth) -->
  <script type="application/ld+json" set:html={JSON.stringify(ferryGraph)} />

  <div class="bg-gradient-to-br from-slate-800 via-slate-800 to-forest-950 text-white">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <nav aria-label="Rasto de navegação" class="mb-5">
        <ol class="flex items-center gap-2 text-sm text-slate-400">
          <li><a href="/pt/" class="hover:text-white no-underline hover:underline transition-colors">Início</a></li>
          <li aria-hidden="true" class="text-slate-600">›</li>
          <li><span class="text-slate-500">Caminha</span></li>
          <li aria-hidden="true" class="text-slate-600">›</li>
          <li aria-current="page" class="text-slate-200 font-medium">Ferry e Logística</li>
        </ol>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold mb-4 text-white tracking-tight">Caminha → A Guarda: Ferry e Táxi Fluvial — O Que Funciona em 2026</h1>
      <p class="text-slate-300 max-w-2xl text-base leading-relaxed">
        A travessia do rio Minho entre Caminha (Portugal) e A Guarda (Espanha) funciona diariamente. Dois serviços de táxi fluvial licenciados substituíram o antigo ferry: há partidas de 30 em 30 minutos na época alta, a viagem demora cerca de 10 minutos e está previsto um novo ferry municipal para o verão de 2026. Esta página cobre operadores, preços, reservas e a alternativa terrestre.
      </p>

      <div class="mt-8 grid grid-cols-2 sm:grid-cols-4 gap-4">
        {keyFacts.map(({ icon, value, label }) => (
          <div class="bg-white/10 backdrop-blur-sm border border-white/10 rounded-2xl p-4 text-center hover:bg-white/15 transition-colors">
            <div class="flex justify-center mb-2 text-earth-400" aria-hidden="true" set:html={icon} />
            <div class="text-lg font-bold text-white">{value}</div>
            <div class="text-xs text-slate-400 mt-0.5">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    
  </div>
  

  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

      <div class="lg:col-span-2 space-y-10">

        <!-- Disclaimer -->
        <div class="bg-amber-50 border border-amber-300/70 rounded-2xl p-5 flex gap-4 shadow-sm">
          <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-amber-100 border border-amber-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
          </div>
          <div>
            <h2 class="font-bold text-amber-900 mb-1.5">Verificado em junho de 2026</h2>
            <p class="text-sm text-amber-800 leading-relaxed">
              Os horários dos operadores refletem a temporada de 2026 e variam com a maré e o tempo. <strong>Confirme as partidas do dia diretamente com o operador antes da travessia</strong> — por telefone, online ou no cais. Este site é operado de forma independente e não aceita qualquer responsabilidade por travessias perdidas.
            </p>
          </div>
        </div>

        <!-- Operadores -->
        <section id="operators">
          <h2 class="text-2xl font-bold text-forest-900 mb-2 tracking-tight">Quem Opera a Travessia Hoje</h2>
          <p class="text-slate-600 text-sm mb-5 leading-relaxed">
            Dois serviços de táxi fluvial licenciados operam a travessia Caminha–A Guarda diariamente. Os meses mais fiáveis são de abril a outubro; fora dessa janela há menos partidas e cancelam-se com mais facilidade devido ao tempo. Os barcos são pequenos — por vezes cerca de seis passageiros — por isso reserve com antecedência nos meses de maior procura.
          </p>
          <div class="overflow-x-auto rounded-2xl border border-slate-200 shadow-sm">
            <table class="w-full text-sm">
              <caption class="sr-only">Operadores de táxi fluvial na travessia Caminha–A Guarda</caption>
              <thead>
                <tr class="bg-forest-900 text-white">
                  <th scope="col" class="text-left px-5 py-3.5 font-semibold text-xs uppercase tracking-wider">Operador</th>
                  <th scope="col" class="text-left px-5 py-3.5 font-semibold text-xs uppercase tracking-wider">Frequência</th>
                  <th scope="col" class="text-left px-5 py-3.5 font-semibold text-xs uppercase tracking-wider">Horário</th>
                  <th scope="col" class="text-left px-5 py-3.5 font-semibold text-xs uppercase tracking-wider">Preço</th>
                  <th scope="col" class="text-left px-5 py-3.5 font-semibold text-xs uppercase tracking-wider">Com bicicleta</th>
                  <th scope="col" class="text-left px-5 py-3.5 font-semibold text-xs uppercase tracking-wider">Reserva</th>
                </tr>
              </thead>
              <tbody>
                {operadores.map((row, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-slate-50/70'}>
                    <td class="px-5 py-3 font-medium text-slate-800">
                      {row.url ? <a href={row.url} rel="noopener" target="_blank" class="text-forest-700 hover:underline no-underline font-semibold">{row.nome}</a> : row.nome}
                    </td>
                    <td class="px-5 py-3 text-slate-700">{row.frequencia}</td>
                    <td class="px-5 py-3 font-mono text-slate-700 text-sm">{row.horario}</td>
                    <td class="px-5 py-3 font-mono font-bold text-forest-700">{row.preco}</td>
                    <td class="px-5 py-3 font-mono text-slate-700">{row.bicicleta}</td>
                    <td class="px-5 py-3 text-slate-600 text-xs">
                      {row.reserva}
                      {row.telefone && <a href={`tel:${row.telefone}`} class="block text-forest-700 font-semibold no-underline hover:underline mt-0.5">{row.telefone}</a>}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="mt-3 text-xs text-slate-500">
            Os barcos funcionam com a hora portuguesa. A Espanha está uma hora à frente — uma partida às 10:00 chega por volta das 11:10 hora local espanhola. Os horários ajustam-se à maré; os operadores publicam as partidas do dia nos seus sites e no cais.
          </p>
        </section>

        <!-- Novo ferry oficial -->
        <section id="new-ferry">
          <h2 class="text-2xl font-bold text-forest-900 mb-2 tracking-tight">Novo Ferry Oficial (Verão 2026)</h2>
          <div class="bg-forest-50 border border-forest-200 rounded-2xl p-5 text-sm text-slate-700 leading-relaxed space-y-3">
            <p>
              A Câmara Municipal de Caminha anunciou um <strong>novo ferry municipal para o verão de 2026</strong>: uma embarcação de calado reduzido com capacidade para cerca de <strong>50–60 passageiros</strong>, concebida para a foz assoreada que tirou de serviço o barco antigo. O município orçamentou a reparação do cais e a dragagem (~€30.000–40.000).
            </p>
            <p>
              <strong>Estado: anunciado, ainda não operacional.</strong> O ferry histórico, o <em>Santa Rita de Cássia</em>, parou em 2020 e será desmantelado. Até o novo barco entrar em serviço, os táxis fluviais da tabela acima são a travessia em funcionamento.
            </p>
          </div>
        </section>

        <!-- Fares -->
        <section>
          <h2 class="text-2xl font-bold text-forest-900 mb-5 tracking-tight">Tarifas Históricas do Ferry Oficial (Referência)</h2>
          <p class="text-slate-600 text-sm mb-4 leading-relaxed">
            Apenas como referência — eram as tarifas do Santa Rita de Cássia antes de o navio parar em 2020. Os preços atuais do táxi fluvial estão na tabela de operadores acima. As tarifas do novo ferry de 2026 ainda não foram anunciadas.
          </p>
          <div class="overflow-x-auto rounded-2xl border border-slate-200 shadow-sm">
            <table class="w-full text-sm">
              <caption class="sr-only">Tarifas do ferry de Caminha para A Guarda</caption>
              <thead>
                <tr class="bg-forest-900 text-white">
                  <th scope="col" class="text-left px-5 py-3.5 font-semibold text-xs uppercase tracking-wider">Tipo de Bilhete</th>
                  <th scope="col" class="text-left px-5 py-3.5 font-semibold text-xs uppercase tracking-wider">Preço</th>
                  <th scope="col" class="text-left px-5 py-3.5 font-semibold text-xs uppercase tracking-wider">Notas</th>
                </tr>
              </thead>
              <tbody>
                {fares.map((row, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-slate-50/70'}>
                    <td class="px-5 py-3 font-medium text-slate-800">{row.tipo}</td>
                    <td class="px-5 py-3 font-mono font-bold text-forest-700">{row.preco}</td>
                    <td class="px-5 py-3 text-slate-600">{row.nota}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        
        

        <!-- Assoreamento -->
        <PhotoFigure
          src={assoreamentoPhoto}
          alt="O estuário do Minho em maré baixa perto de Caminha, com bancos de areia a descoberto"
          caption="O estuário do Minho em maré baixa — os bancos de areia por trás do assoreamento que encalhou o antigo ferry"
        />
        <aside class="mb-10 rounded-2xl bg-forest-50 border border-forest-200 p-5 flex flex-col sm:flex-row sm:items-center gap-4">
          <p class="flex-1 text-sm text-slate-700 leading-relaxed">Chegas na véspera da travessia? Reserva cama em Caminha — ou um quarto privado em A Guarda para depois de cruzar.</p>
          <div class="flex flex-wrap gap-2 shrink-0">
            <a href="/pt/caminha/onde-ficar/" class="inline-flex items-center rounded-xl bg-forest-700 hover:bg-forest-800 text-white text-sm font-bold px-4 py-2.5 no-underline transition-colors">Ficar em Caminha</a>
            <a href={bookingSearch('A Guarda, Espanha', 'wtsg-ferry-pt-aguarda')} rel="nofollow noopener noreferrer sponsored" target="_blank" class="inline-flex items-center rounded-xl bg-earth-500 hover:bg-earth-600 text-white text-sm font-bold px-4 py-2.5 no-underline transition-colors">Hotéis em A Guarda</a>
          </div>
        </aside>

        <!-- Condições da travessia (fontes externas, sem rastreio) -->
        <section aria-labelledby="conditions-heading" class="mb-10">
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 id="conditions-heading" class="text-lg font-bold text-forest-900 mb-1 tracking-tight">Verifica as condições antes de cruzar</h2>
            <p class="text-sm text-slate-600 mb-4">A travessia depende da maré e do tempo — barcos pequenos sobre bancos de areia móveis. Verifica na véspera e na manhã da travessia.</p>
            <div class="grid sm:grid-cols-2 gap-3">
              <a href="https://pt.windfinder.com/tide/caminha" rel="noopener noreferrer" target="_blank" class="flex items-center gap-3 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 no-underline hover:bg-slate-100 hover:border-slate-300 transition-colors group">
                <svg class="h-6 w-6 shrink-0 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6c1.5 0 2.5 1.5 4 1.5S8.5 6 10 6s2.5 1.5 4 1.5S16.5 6 18 6s2.5 1.5 4 1.5M2 12c1.5 0 2.5 1.5 4 1.5s2.5-1.5 4-1.5 2.5 1.5 4 1.5 2.5-1.5 4-1.5 2.5 1.5 4 1.5M2 18c1.5 0 2.5 1.5 4 1.5s2.5-1.5 4-1.5 2.5 1.5 4 1.5 2.5-1.5 4-1.5 2.5 1.5 4 1.5"/></svg>
                <span><span class="block text-sm font-bold text-forest-900 group-hover:text-forest-700">Horário das marés em Caminha</span><span class="block text-xs text-slate-500">Preia-mar e baixa-mar · Windfinder</span></span>
              </a>
              <a href="https://www.windy.com/?41.877,-8.839,10" rel="noopener noreferrer" target="_blank" class="flex items-center gap-3 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 no-underline hover:bg-slate-100 hover:border-slate-300 transition-colors group">
                <svg class="h-6 w-6 shrink-0 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"/></svg>
                <span><span class="block text-sm font-bold text-forest-900 group-hover:text-forest-700">Vento, ondas e tempo</span><span class="block text-xs text-slate-500">Mapa em direto da travessia · Windy</span></span>
              </a>
            </div>
          </div>
        </section>

        <section id="assoreamento">
          <div class="rounded-2xl overflow-hidden shadow-lg border border-red-200">
            <div class="bg-gradient-to-r from-red-700 to-red-800 px-6 py-5 flex gap-4 items-start">
              <div class="shrink-0 flex h-12 w-12 items-center justify-center rounded-xl bg-red-900/50 border border-red-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-red-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                  <circle cx="12" cy="5" r="3"/>
                  <line x1="12" y1="22" x2="12" y2="8"/>
                  <path d="M5 12H2a10 10 0 0020 0h-3"/>
                </svg>
              </div>
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-xs font-bold uppercase tracking-widest text-red-300 bg-red-900/40 px-2 py-0.5 rounded-full border border-red-700">Contexto</span>
                </div>
                <h2 class="text-xl font-bold text-white">Assoreamento: Porque Parou o Ferry Antigo</h2>
                <p class="text-red-200 text-sm mt-1">A história do assoreamento explica porque mudou a travessia — e porque os barcos atuais são pequenos e de calado reduzido.</p>
              </div>
            </div>

            <div class="bg-red-50 border-t-0 p-6 space-y-4 text-slate-700 text-sm leading-relaxed">
              <p>
                O estuário do rio Minho está sujeito a <strong>assoreamento</strong> — a acumulação de areia e sedimentos na foz que periodicamente eleva o fundo perto dos cais. O ferry antigo, o <strong>Santa Rita de Cássia</strong> (em serviço desde 1995), era uma embarcação de calado médio que precisava de uma profundidade mínima para atracar. Parou de operar em <strong>2020</strong>; mesmo depois de concluídas as obras do cais galego em 2023, o assoreamento manteve-o parado, e o navio será desmantelado.
              </p>
              <p>
                É por isso que a travessia atual funciona com <strong>táxis fluviais pequenos e de calado reduzido</strong> — passam por cima dos bancos de areia que venceram o ferry — e por isso o substituto anunciado para 2026 é especificamente um desenho de calado reduzido. Os episódios de assoreamento continuam a afetar o estuário depois de verões secos e grandes tempestades atlânticas, pelo que partidas individuais podem ser canceladas com pouco aviso, mesmo na época alta.
              </p>
              <p>
                Conclusão prática: <strong>a travessia funciona diariamente, mas confirme sempre os barcos do dia</strong> — online com a Xacobeo Transfer, por telefone com a Taxi Boat Peregrinos, ou no seu albergue na véspera. Se o tempo ou o rio pararem tudo, o desvio terrestre abaixo está sempre disponível.
              </p>
            </div>
          </div>
        </section>

        <!-- Alternative crossings -->
        <section id="alternativas">
          <h2 class="text-2xl font-bold text-forest-900 mb-6 tracking-tight">Opções de Recurso Quando Nenhum Barco Atravessa</h2>

          <!-- Option 1: Xávegas -->
          <div class="bg-white border border-slate-200/80 rounded-2xl overflow-hidden mb-6 shadow-sm">
            <div class="bg-gradient-to-r from-forest-800 to-forest-900 text-white px-6 py-4 flex gap-3 items-start">
              <div class="shrink-0 flex h-9 w-9 items-center justify-center rounded-lg bg-forest-700/60">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-earth-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M22 18H2l4-8h12l4 8z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 2v8"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h8"/>
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold">Opção 1: Barcos de Pescadores Informais (Recurso Legado)</h3>
                <p class="text-forest-300 text-sm mt-0.5">Apenas relevante se ambos os operadores licenciados estiverem indisponíveis · ~€5–6 por pessoa</p>
              </div>
            </div>
            <div class="p-6 space-y-4 text-slate-700 text-sm leading-relaxed">
              <p>
                Antes de os táxis fluviais licenciados assumirem a travessia, os pescadores locais atravessavam o Minho em <strong>Xávegas</strong> (embarcações tradicionais de fundo plano) e barcos informais motorizados. Alguns ainda o fazem. Trate isto puramente como recurso: em 2026, a primeira opção é a <strong>Taxi Boat Peregrinos ou a Xacobeo Transfer</strong> (tabela acima) — os barcos de pescadores só importam no dia raro em que ambos os serviços regulares falham mas o rio continua navegável.
              </p>
              <p>
                <strong>Como encontrar um:</strong> pergunte ao hospitaleiro ou ao proprietário do alojamento na véspera, vá ao <strong>Cais da Rua dos Pescadores</strong> (o cais de pesca, adjacente ao cais principal) ou ligue ao Posto de Turismo de Caminha para os contactos atuais:
              </p>

              <div class="bg-slate-800 rounded-xl p-4">
                <h4 class="font-semibold text-white mb-3 text-xs uppercase tracking-wider flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-earth-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                  Operadores de Táxi Fluvial Conhecidos (Táxi-Marítimo)
                </h4>
                <p class="text-xs text-slate-400 mb-3 leading-relaxed">Os seguintes operadores aparecem regularmente em relatórios da comunidade de peregrinos no Gronze.com, fóruns do Caminho de Santiago e no boletim da Confraria de São Tiago. São pescadores locais que fazem travessias informais do rio — a sua disponibilidade é sazonal e sujeita às condições do rio. <strong class="text-slate-300">Os números de contacto mudam; verifique sempre através do seu alojamento ou do posto de turismo na noite anterior.</strong></p>
