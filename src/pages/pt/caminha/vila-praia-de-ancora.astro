---
import MainLayout from '../../../layouts/MainLayout.astro';

const restaurants = [
  {
    name: 'Fortaleza Restaurante',
    cuisine: 'Marisco · Mediterrânica',
    address: 'Avenida Dr. Ramos Pereira 81, Vila Praia de Âncora',
    locationContext: 'Avenida frente à praia em Vila Praia de Âncora',
    knownFor: 'Marisco atlântico fresco na principal avenida de restauração frente à praia',
    pilgrimContext: 'Jantar ou almoço frente à praia; prático se pernoitar aqui',
    mapsUrl: 'https://www.google.com/maps/search/?q=Fortaleza+Restaurante+Vila+Praia+de+Ancora',
  },
  {
    name: 'Restaurante Vitória Mar',
    cuisine: 'Marisco · Mediterrânica',
    address: 'Avenida Dr. Luis Ramos Pereira 100, Vila Praia de Âncora',
    locationContext: 'Avenida frente à praia em Vila Praia de Âncora',
    knownFor: 'Marisco na principal avenida frente à praia; com boas avaliações de forma consistente',
    pilgrimContext: 'Alternativa frente à praia; útil se pernoitar antes de seguir para Caminha',
    mapsUrl: 'https://www.google.com/maps/search/?q=Restaurante+Vitoria+Mar+Vila+Praia+de+Ancora',
  },
];

const hotels = [
  {
    name: 'BLUE ANCORA HOTEL',
    type: 'Hotel',
    positioning: 'Junto à costa, a 3 minutos a pé da praia de Vila Praia de Âncora',
    differentiators: ['Piscina exterior sazonal', 'Quartos com vista para o mar e varanda'],
    bookingUrl: 'https://www.booking.com/hotel/pt/blue-ancora.html?aid=7968251',
  },
  {
    name: 'Hotel Meira',
    type: 'Hotel — 4 estrelas',
    positioning: 'Perto da praia, num vale protegido do vento',
    differentiators: ['Piscina', 'Pequeno-almoço bufete incluído'],
    bookingUrl: 'https://www.booking.com/hotel/pt/hotelmeiravilapraiaancora.html?aid=7968251',
  },
];
---

<MainLayout
  title="Vila Praia de Âncora — Restaurantes e hotéis"
  description="Restaurantes e hotéis em Vila Praia de Âncora no Caminho de Santiago da Costa. Marisco frente à praia e hotéis junto ao mar, a 8 km a sul de Caminha."
  lang="pt"
  schemaType="webpage"
>

  <!-- ── PAGE HEADER ──────────────────────────────────────────────────────────── -->
  <div class="bg-gradient-to-b from-earth-50 to-white border-b border-earth-100/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <nav aria-label="Navegação estrutural" class="mb-5">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/pt/" class="hover:text-forest-700 no-underline hover:underline transition-colors">Início</a></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li><a href="/pt/guia-de-caminha/" class="hover:text-forest-700 no-underline hover:underline transition-colors">Caminha</a></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li aria-current="page" class="text-slate-700 font-medium">Vila Praia de Âncora</li>
        </ol>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold text-forest-900 mb-4 tracking-tight">Vila Praia de Âncora</h1>
      <p class="text-slate-600 max-w-2xl text-base leading-relaxed">
        Vila costeira a 8 km a sul de Caminha no Caminho da Costa. Os peregrinos que pernoitam aqui encontram restaurantes de marisco frente à praia e hotéis com piscina: uma alternativa mais tranquila do que Caminha antes do troço final até à travessia do Minho.
      </p>
      <div class="mt-6 flex flex-wrap gap-2.5">
        <a href="#restaurants" class="inline-flex items-center gap-1.5 bg-white border border-earth-200 text-earth-800 text-xs font-medium px-3.5 py-2 rounded-full hover:bg-earth-50 hover:border-earth-300 no-underline transition-all duration-200 shadow-sm cursor-pointer">
          Restaurantes
        </a>
        <a href="#hotels" class="inline-flex items-center gap-1.5 bg-white border border-forest-200 text-forest-800 text-xs font-medium px-3.5 py-2 rounded-full hover:bg-forest-50 hover:border-forest-300 no-underline transition-all duration-200 shadow-sm cursor-pointer">
          Hotéis
        </a>
      </div>
    </div>
  </div>



  <!-- ── RESTAURANTS ─────────────────────────────────────────────────────────── -->
  <div id="restaurants" class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-6 pb-4 border-b border-slate-200">
      <h2 class="text-2xl font-bold text-forest-900 tracking-tight">Restaurantes</h2>
      <p class="text-slate-600 text-sm mt-1 leading-relaxed max-w-2xl">
        Os dois restaurantes verificados ficam na principal avenida frente à praia. Não se incluem cafés nem pastelarias em VPA: os peregrinos que precisem de tomar o pequeno-almoço cedo antes de seguir para norte devem contar comer em Caminha.
      </p>
    </div>
    <div class="grid grid-cols-1 gap-5">
      {restaurants.map((r) => (
        <article class="bg-white rounded-2xl border border-slate-200/80 overflow-hidden hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 shadow-sm">
          <div class="p-6 sm:p-8">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-3">
              <div>
                <h3 class="text-xl font-bold text-forest-900 tracking-tight mb-0.5">{r.name}</h3>
                <p class="text-sm text-slate-500 font-medium">{r.cuisine}</p>
              </div>
              <span class="text-xs bg-forest-50 text-forest-700 px-3 py-1.5 rounded-full border border-forest-100 font-medium shrink-0 self-start whitespace-nowrap">{r.pilgrimContext}</span>
            </div>
            <p class="text-slate-700 text-sm leading-relaxed mb-4">{r.knownFor}</p>
            <div class="flex flex-wrap items-center gap-3 text-sm text-slate-500 pt-4 border-t border-slate-100">
              <span class="flex items-center gap-1.5">
                <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                {r.address}
              </span>
              <a href={r.mapsUrl} rel="noopener noreferrer" target="_blank" class="ml-auto inline-flex items-center gap-1.5 text-xs text-forest-600 hover:text-forest-800 font-medium no-underline hover:underline transition-colors">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
                Ver no mapa
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>



  <!-- ── HOTELS ──────────────────────────────────────────────────────────────── -->
  <div id="hotels" class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-6 pb-4 border-b border-slate-200">
      <h2 class="text-2xl font-bold text-forest-900 tracking-tight">Hotéis</h2>
      <p class="text-slate-600 text-sm mt-1 leading-relaxed max-w-2xl">
        Os dois hotéis podem ser reservados no Booking.com. Não existe albergue nem hostel municipal de peregrinos em Vila Praia de Âncora: os peregrinos com orçamento de albergue seguem para norte até Caminha ou para sul até à etapa seguinte.
      </p>
    </div>
    <div class="grid grid-cols-1 gap-5">
      {hotels.map((h) => (
        <article class="bg-white rounded-2xl border border-slate-200/80 overflow-hidden hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 shadow-sm">
          <div class="p-6 sm:p-8">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-4">
              <div>
                <h3 class="text-xl font-bold text-forest-900 tracking-tight mb-0.5">{h.name}</h3>
                <p class="text-sm text-slate-500 font-medium">{h.type}</p>
              </div>
            </div>
            <p class="text-sm text-slate-600 leading-relaxed mb-4">{h.positioning}</p>
            <div class="flex flex-wrap gap-2 mb-5">
              {h.differentiators.map((d) => (
                <span class="text-xs bg-forest-50 text-forest-700 px-3 py-1.5 rounded-full border border-forest-100 font-medium">{d}</span>
              ))}
            </div>
            <div class="pt-4 border-t border-slate-100">
              <a
                href={h.bookingUrl}
                rel="nofollow noopener noreferrer sponsored"
                target="_blank"
                class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-earth-500 to-earth-600 hover:from-earth-600 hover:to-earth-700 active:scale-[0.98] text-white font-bold text-sm px-6 py-3.5 rounded-xl transition-all duration-200 no-underline shadow-md hover:shadow-lg cursor-pointer group"
              >
                Consultar disponibilidade e preços
                <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>

  <!-- ── CTA: INTERNAL LOOP ─────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
      <a href="/pt/guia-de-caminha/" class="flex items-center gap-4 bg-white border border-forest-200 rounded-2xl p-5 hover:shadow-md hover:border-forest-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-forest-50 border border-forest-100">
          <svg class="h-5 w-5 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-forest-900 group-hover:text-forest-700">Guia de Caminha</p>
          <p class="text-xs text-slate-500">Visão completa — dormir, comer, ferry e serviços</p>
        </div>
      </a>
      <a href="/pt/caminha/seixas/" class="flex items-center gap-4 bg-white border border-forest-200 rounded-2xl p-5 hover:shadow-md hover:border-forest-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-forest-50 border border-forest-100">
          <svg class="h-5 w-5 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-forest-900 group-hover:text-forest-700">Seixas</p>
          <p class="text-xs text-slate-500">Etapa seguinte a norte — albergue e hotel</p>
        </div>
      </a>
      <a href="/pt/caminha/onde-comer/" class="flex items-center gap-4 bg-white border border-earth-200 rounded-2xl p-5 hover:shadow-md hover:border-earth-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-earth-50 border border-earth-100">
          <svg class="h-5 w-5 text-earth-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-earth-900 group-hover:text-earth-700">Onde Comer</p>
          <p class="text-xs text-slate-500">Todos os restaurantes em Caminha e VPA</p>
        </div>
      </a>
      <a href="/pt/caminha/ferry-e-logistica/" class="flex items-center gap-4 bg-white border border-slate-200 rounded-2xl p-5 hover:shadow-md hover:border-slate-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-slate-50 border border-slate-100">
          <svg class="h-5 w-5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-slate-900 group-hover:text-slate-700">Ferry e Logística</p>
          <p class="text-xs text-slate-500">Travessia do Minho — horários e alternativas</p>
        </div>
      </a>
      <a href="/pt/caminha/servicos-uteis/" class="flex items-center gap-4 bg-white border border-slate-200 rounded-2xl p-5 hover:shadow-md hover:border-slate-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-slate-50 border border-slate-100">
          <svg class="h-5 w-5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-slate-900 group-hover:text-slate-700">Serviços para Peregrinos</p>
          <p class="text-xs text-slate-500">Farmácias, equipamento e multibancos em Caminha</p>
        </div>
      </a>
    </div>
  </div>

  <!-- ── SCHEMA ───────────────────────────────────────────────────────────── -->
  <script type="application/ld+json" is:inline set:html={`
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "ItemList",
          "name": "Restaurantes em Vila Praia de Âncora — Caminho de Santiago da Costa",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "item": {
                "@type": "Restaurant",
                "name": "Fortaleza Restaurante",
                "address": { "@type": "PostalAddress", "streetAddress": "Avenida Dr. Ramos Pereira 81", "addressLocality": "Vila Praia de Âncora", "addressCountry": "PT" },
                "servesCuisine": ["Seafood", "Mediterranean"]
              }
            },
            {
              "@type": "ListItem",
              "position": 2,
              "item": {
                "@type": "Restaurant",
                "name": "Restaurante Vitória Mar",
                "address": { "@type": "PostalAddress", "streetAddress": "Avenida Dr. Luis Ramos Pereira 100", "addressLocality": "Vila Praia de Âncora", "addressCountry": "PT" },
                "servesCuisine": ["Seafood", "Mediterranean"]
              }
            }
          ]
        },
        {
          "@type": "ItemList",
          "name": "Hotéis em Vila Praia de Âncora — Caminho de Santiago da Costa",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "item": {
                "@type": "Hotel",
                "name": "BLUE ANCORA HOTEL",
                "address": { "@type": "PostalAddress", "addressLocality": "Vila Praia de Âncora", "addressCountry": "PT" }
              }
            },
            {
              "@type": "ListItem",
              "position": 2,
              "item": {
                "@type": "Hotel",
                "name": "Hotel Meira",
                "address": { "@type": "PostalAddress", "addressLocality": "Vila Praia de Âncora", "addressCountry": "PT" }
              }
            }
          ]
        },
        {
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "Há albergue em Vila Praia de Âncora para peregrinos?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Não. Vila Praia de Âncora não dispõe de albergue de peregrinos. As opções de alojamento são hotéis (BLUE ANCORA HOTEL, Hotel Meira — ambos reserváveis no Booking.com). Os peregrinos com orçamento de albergue seguem para Caminha (8 km a norte), onde estão disponíveis o albergue municipal e dois albergues privados."
              }
            },
            {
              "@type": "Question",
              "name": "Onde podem comer os peregrinos em Vila Praia de Âncora?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Há dois restaurantes verificados na avenida frente à praia: Fortaleza Restaurante (Avenida Dr. Ramos Pereira 81) e Restaurante Vitória Mar (Avenida Dr. Luis Ramos Pereira 100). Ambos servem marisco atlântico. Para o pequeno-almoço cedo antes de seguir para norte, os peregrinos costumam esperar até Caminha, onde as pastelarias abrem das 07:00 às 08:00."
              }
            }
          ]
        }
      ]
    }
  `} />

</MainLayout>
