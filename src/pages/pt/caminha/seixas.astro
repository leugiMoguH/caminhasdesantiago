---
import MainLayout from '../../../layouts/MainLayout.astro';

const accommodations = [
  {
    name: 'Albergue de São Bento',
    type: 'Albergue de Peregrinos',
    positioning: 'Frente ao mar na freguesia de Seixas, a 1 km da praia de Pedras Ruivas',
    differentiators: ['Localização frente ao mar', 'Jantares de peregrino disponíveis; cozinha partilhada'],
    bookingUrl: 'https://www.booking.com/hotel/pt/albergue-de-sao-bento.html',
  },
  {
    name: 'Rinoterra Minho',
    type: 'Hotel Rural',
    address: 'Rua da Costa 15, Seixas, Caminha',
    positioning: 'Rural, freguesia de Seixas, com vistas para o rio e a montanha',
    differentiators: ['Spa e centro de bem-estar', 'Ténis; restaurante português no estabelecimento'],
    bookingUrl: 'https://www.booking.com/hotel/pt/rinoterra-minho.html',
  },
];
---

<MainLayout
  title="Seixas — Alojamento e Informações para Peregrinos"
  description="Alojamento e informações para peregrinos na freguesia de Seixas, no Caminho de Santiago da Costa. Albergue frente ao mar e hotel rural, a 2 km a sul de Caminha."
  lang="pt"
  schemaType="webpage"
>

  <!-- ── PAGE HEADER ──────────────────────────────────────────────────────────── -->
  <div class="bg-gradient-to-b from-forest-50 to-white border-b border-forest-100/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <nav aria-label="Navegação estrutural" class="mb-5">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/pt/" class="hover:text-forest-700 no-underline hover:underline transition-colors">Início</a></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li><a href="/pt/guia-de-caminha/" class="hover:text-forest-700 no-underline hover:underline transition-colors">Caminha</a></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li aria-current="page" class="text-slate-700 font-medium">Seixas</li>
        </ol>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold text-forest-900 mb-4 tracking-tight">Seixas</h1>
      <p class="text-slate-600 max-w-2xl text-base leading-relaxed">
        A freguesia situada mesmo a sul da vila de Caminha, sobre o trilho sinalizado do Caminho da Costa. Baixa densidade — um albergue de peregrinos e um hotel rural, ambos reserváveis no Booking.com. Não há restaurantes em Seixas: os peregrinos caminham até Caminha (aproximadamente 15–20 minutos) para comer.
      </p>
      <div class="mt-6 flex flex-wrap gap-2.5">
        <a href="#accommodation" class="inline-flex items-center gap-1.5 bg-white border border-forest-200 text-forest-800 text-xs font-medium px-3.5 py-2 rounded-full hover:bg-forest-50 hover:border-forest-300 no-underline transition-all duration-200 shadow-sm cursor-pointer">
          Alojamento
        </a>
        <a href="#pharmacy" class="inline-flex items-center gap-1.5 bg-white border border-earth-200 text-earth-800 text-xs font-medium px-3.5 py-2 rounded-full hover:bg-earth-50 hover:border-earth-300 no-underline transition-all duration-200 shadow-sm cursor-pointer">
          Farmácia
        </a>
      </div>
    </div>
  </div>



  <!-- ── CALLOUT: NO RESTAURANTS ───────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-4">
    <div class="bg-amber-50 border border-amber-300/70 rounded-2xl p-5 flex gap-4 shadow-sm">
      <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-amber-100 border border-amber-200">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <div>
        <h2 class="font-bold text-amber-900 mb-1 text-sm">Não há restaurantes em Seixas</h2>
        <p class="text-sm text-amber-800 leading-relaxed">
          Seixas não dispõe de infraestrutura de restauração própria. Os peregrinos que ficam aqui caminham até Caminha (aproximadamente 15–20 minutos a pé) para todas as refeições. Tanto o albergue de peregrinos como o hotel rural oferecem opções de jantar no estabelecimento — confirme a disponibilidade ao reservar.
        </p>
      </div>
    </div>
  </div>

  <!-- ── ACCOMMODATION ──────────────────────────────────────────────────────── -->
  <div id="accommodation" class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-6 pb-4 border-b border-slate-200">
      <h2 class="text-2xl font-bold text-forest-900 tracking-tight">Alojamento em Seixas</h2>
      <p class="text-slate-600 text-sm mt-1 leading-relaxed max-w-2xl">
        Duas opções sobre o trilho sinalizado do Caminho da Costa: um albergue de peregrinos frente ao mar e um hotel rural com todos os serviços.
      </p>
    </div>
    <div class="grid grid-cols-1 gap-5">
      {accommodations.map((a) => (
        <article class="bg-white rounded-2xl border border-slate-200/80 overflow-hidden hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 shadow-sm">
          <div class="p-6 sm:p-8">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-4">
              <div>
                <h3 class="text-xl font-bold text-forest-900 tracking-tight mb-0.5">{a.name}</h3>
                <p class="text-sm text-slate-500 font-medium">{a.type}</p>
              </div>
            </div>
            <p class="text-sm text-slate-600 leading-relaxed mb-4">{a.positioning}</p>
            <div class="flex flex-wrap gap-2 mb-5">
              {a.differentiators.map((d) => (
                <span class="text-xs bg-forest-50 text-forest-700 px-3 py-1.5 rounded-full border border-forest-100 font-medium">{d}</span>
              ))}
            </div>
            <div class="pt-4 border-t border-slate-100 flex flex-col sm:flex-row sm:items-center gap-4">
              {a.address && (
                <div class="flex items-center gap-1.5 text-sm text-slate-500 flex-1">
                  <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  {a.address}
                </div>
              )}
              <a
                href={a.bookingUrl}
                rel="nofollow noopener noreferrer sponsored"
                target="_blank"
                class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-earth-600 to-earth-700 hover:from-earth-700 hover:to-earth-800 active:scale-[0.98] text-white font-bold text-sm px-6 py-3.5 rounded-xl transition-all duration-200 no-underline shrink-0 shadow-md hover:shadow-lg cursor-pointer group"
              >
                Ver Disponibilidade e Preços
                <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>

  <!-- ── PHARMACY NOTE ───────────────────────────────────────────────────────── -->
  <div id="pharmacy" class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-10">
    <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
      <h2 class="text-lg font-bold text-forest-900 mb-3 tracking-tight">Farmácia em Seixas</h2>
      <p class="text-slate-700 text-sm leading-relaxed mb-3">
        Seixas conta com uma farmácia que participa no turno de serviço do concelho de Caminha: <strong>Farmácia Sousa</strong>, na Avenida Joaquim Maria Portela, Seixas — aproximadamente a 2 km a sul do centro de Caminha (a pé).
      </p>
      <p class="text-slate-600 text-sm leading-relaxed">
        O turno de farmácia de serviço roda diariamente entre a vila de Caminha, Vila Praia de Âncora e Seixas. Para saber qual é a farmácia de serviço atual, pergunte no seu alojamento ou ligue para o <strong>SNS24: 808 24 24 24</strong>. Consulte o <a href="/pt/caminha/servicos-uteis/#farmacias" class="text-forest-700 hover:underline no-underline font-medium">guia completo dos turnos de farmácia</a> para mais detalhes.
      </p>
    </div>
  </div>

  <!-- ── CTA: INTERNAL LOOP ─────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
      <a href="/pt/caminha/vila-praia-de-ancora/" class="flex items-center gap-4 bg-white border border-earth-200 rounded-2xl p-5 hover:shadow-md hover:border-earth-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-earth-50 border border-earth-100">
          <svg class="h-5 w-5 text-earth-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-earth-900 group-hover:text-earth-700">Vila Praia de Âncora</p>
          <p class="text-xs text-slate-500">Etapa anterior a sul — restaurantes e hotéis</p>
        </div>
      </a>
      <a href="/pt/caminha/onde-comer/" class="flex items-center gap-4 bg-white border border-earth-200 rounded-2xl p-5 hover:shadow-md hover:border-earth-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-earth-50 border border-earth-100">
          <svg class="h-5 w-5 text-earth-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-earth-900 group-hover:text-earth-700">Onde Comer</p>
          <p class="text-xs text-slate-500">Restaurantes em Caminha — a 15 min a pé</p>
        </div>
      </a>
      <a href="/pt/caminha/onde-ficar/" class="flex items-center gap-4 bg-white border border-forest-200 rounded-2xl p-5 hover:shadow-md hover:border-forest-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-forest-50 border border-forest-100">
          <svg class="h-5 w-5 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-forest-900 group-hover:text-forest-700">Onde Ficar</p>
          <p class="text-xs text-slate-500">Todo o alojamento — Caminha, VPA e Seixas</p>
        </div>
      </a>
      <a href="/pt/caminha/ferry-e-logistica/" class="flex items-center gap-4 bg-white border border-slate-200 rounded-2xl p-5 hover:shadow-md hover:border-slate-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-slate-50 border border-slate-100">
          <svg class="h-5 w-5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-slate-900 group-hover:text-slate-700">Ferry e Logística</p>
          <p class="text-xs text-slate-500">Travessia do Minho — horários e alternativas</p>
        </div>
      </a>
      <a href="/pt/caminha/servicos-uteis/" class="flex items-center gap-4 bg-white border border-slate-200 rounded-2xl p-5 hover:shadow-md hover:border-slate-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-slate-50 border border-slate-100">
          <svg class="h-5 w-5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-slate-900 group-hover:text-slate-700">Serviços para Peregrinos</p>
          <p class="text-xs text-slate-500">Farmácias, equipamento e multibancos em Caminha</p>
        </div>
      </a>
    </div>
  </div>

  <!-- ── SCHEMA ─────────────────────────────────────────────────────────────── -->
  <script type="application/ld+json" is:inline set:html={`
    [
      {
        "@context": "https://schema.org",
        "@type": "ItemList",
        "name": "Alojamento em Seixas — Caminho de Santiago da Costa",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "item": {
              "@type": "Hostel",
              "name": "Albergue de São Bento",
              "description": "Albergue de peregrinos frente ao mar na freguesia de Seixas. Jantares de peregrino disponíveis, cozinha partilhada.",
              "address": { "@type": "PostalAddress", "addressLocality": "Seixas, Caminha", "addressCountry": "PT" }
            }
          },
          {
            "@type": "ListItem",
            "position": 2,
            "item": {
              "@type": "Hotel",
              "name": "Rinoterra Minho",
              "description": "Hotel rural na freguesia de Seixas com vistas para o rio e a montanha. Spa, ténis, restaurante português.",
              "address": { "@type": "PostalAddress", "streetAddress": "Rua da Costa 15", "addressLocality": "Seixas, Caminha", "addressCountry": "PT" }
            }
          }
        ]
      },
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Há restaurantes em Seixas no Caminho de Santiago da Costa?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Não. Seixas não dispõe de infraestrutura de restauração própria. Os peregrinos que ficam em Seixas caminham até Caminha (aproximadamente 15–20 minutos a pé) para todas as refeições. O Albergue de São Bento e o Rinoterra Minho oferecem opções de jantar no estabelecimento — confirme a disponibilidade ao reservar."
            }
          },
          {
            "@type": "Question",
            "name": "Que alojamento existe em Seixas para peregrinos?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Duas opções: Albergue de São Bento (albergue de peregrinos frente ao mar, reservável no Booking.com, jantares de peregrino disponíveis) e Rinoterra Minho (hotel rural com spa e restaurante). Ambos ficam sobre o trilho sinalizado do Caminho da Costa e são reserváveis online."
            }
          }
        ]
      }
    ]
  `} />

</MainLayout>
