---
import MainLayout from '../../../layouts/MainLayout.astro';
import PhotoFigure from '../../../components/PhotoFigure.astro';
import marginalPhoto from '../../../assets/photos/caminha-marginal-rio-minho.jpg';
import { bookingLink, bookingSearch, stayLabel } from '../../../lib/booking';

type Zona = 'caminha' | 'vpa' | 'seixas';
type Categoria = 'albergue' | 'hotel' | 'pensao';

interface Alojamento {
  nome: string;
  zona: Zona;
  categoria: Categoria;
  tipo: string;
  morada: string;
  localizacao: string;
  diferenciais: string[];
  reservaUrl: string | null;
  nota?: string;
}

const alojamentos: Alojamento[] = [
  // ── CAMINHA ────────────────────────────────────────────────────────────────────
  {
    nome: 'Albergue Municipal de Peregrinos de Caminha',
    zona: 'caminha',
    categoria: 'albergue',
    tipo: 'Albergue Municipal de Peregrinos',
    morada: 'Rua Ricardo Joaquim de Sousa, Caminha',
    localizacao: 'Centro urbano, a poucos minutos do cais do ferry',
    diferenciais: ['Albergue municipal oficial', 'Credencial de peregrino obrigatória'],
    reservaUrl: null,
    nota: 'Só admissão direta — sem reservas online. Abre às 14:00. Por ordem de chegada. Credencial válida obrigatória. Máximo 2 noites consecutivas.',
  },
  {
    nome: 'Albergue Santiago de Caminha',
    zona: 'caminha',
    categoria: 'albergue',
    tipo: 'Albergue Privado de Peregrinos',
    morada: '',
    localizacao: 'Centro de Caminha, na rota do Caminho junto ao rio',
    diferenciais: ['Reserva online antecipada disponível', 'Bar e cafetaria no alojamento'],
    reservaUrl: 'https://www.booking.com/hotel/pt/albergue-santiago-de-caminha.html',
  },
  {
    nome: 'Bom Caminha — Albergue Privado para Peregrinos',
    zona: 'caminha',
    categoria: 'albergue',
    tipo: 'Albergue Privado de Peregrinos',
    morada: '',
    localizacao: 'Centro histórico, casa histórica de 1882',
    diferenciais: ['Jantar de peregrinos opcional (suplemento de 12 €)', 'Cozinha comunitária; reserva antecipada disponível'],
    reservaUrl: 'https://www.booking.com/hotel/pt/bom-caminha-private-albergue-amp-guest-house.html',
  },
  {
    nome: 'Litos AL',
    zona: 'caminha',
    categoria: 'pensao',
    tipo: 'Casa de Hóspedes',
    morada: 'Largo Senhora da Agonia 13, Caminha',
    localizacao: 'Centro urbano, perto do passeio ribeirinho',
    diferenciais: ['Pequeno-almoço incluído', 'Quartos com ar condicionado'],
    reservaUrl: 'https://www.booking.com/hotel/pt/litos-al.html',
  },
  {
    nome: 'Donna Nega Alojamento Local',
    zona: 'caminha',
    categoria: 'pensao',
    tipo: 'Casa de Hóspedes',
    morada: '',
    localizacao: 'Centro de Caminha, terraço e cozinha partilhada',
    diferenciais: ['Cozinha e sala partilhadas', 'Terraço; estacionamento de bicicletas'],
    reservaUrl: 'https://www.booking.com/hotel/pt/patricia-lourenco.html',
  },
  {
    nome: 'Design & Wine Hotel',
    zona: 'caminha',
    categoria: 'hotel',
    tipo: 'Hotel',
    morada: '',
    localizacao: 'Centro urbano, edifício histórico do século XVIII',
    diferenciais: ['Piscina interior', 'Bar de vinhos e restaurante no hotel'],
    reservaUrl: 'https://www.booking.com/hotel/pt/design.html',
  },
  {
    nome: 'Hotel Porta do Sol Conference & SPA',
    zona: 'caminha',
    categoria: 'hotel',
    tipo: 'Hotel — 4 Estrelas',
    morada: '',
    localizacao: 'Perto da foz do rio e da praia atlântica',
    diferenciais: ['2 piscinas exteriores', 'Spa e instalações de bem-estar'],
    reservaUrl: 'https://www.booking.com/hotel/pt/porta-do-sol-caminha.html',
  },

  // ── VILA PRAIA DE ÂNCORA ───────────────────────────────────────────────────────
  {
    nome: 'BLUE ANCORA HOTEL',
    zona: 'vpa',
    categoria: 'hotel',
    tipo: 'Hotel',
    morada: '',
    localizacao: 'Zona costeira, a 3 minutos a pé da Praia de Vila Praia de Âncora',
    diferenciais: ['Piscina exterior de época', 'Quartos com vista para o mar e varanda'],
    reservaUrl: 'https://www.booking.com/hotel/pt/blue-ancora.html',
  },
  {
    nome: 'Hotel Meira',
    zona: 'vpa',
    categoria: 'hotel',
    tipo: 'Hotel — 4 Estrelas',
    morada: '',
    localizacao: 'Perto da praia, num vale protegido do vento',
    diferenciais: ['Piscina', 'Buffet de pequeno-almoço incluído'],
    reservaUrl: 'https://www.booking.com/hotel/pt/hotelmeiravilapraiaancora.html',
  },

  // ── SEIXAS ─────────────────────────────────────────────────────────────────────
  {
    nome: 'Albergue de São Bento',
    zona: 'seixas',
    categoria: 'albergue',
    tipo: 'Albergue de Peregrinos',
    morada: '',
    localizacao: 'Frente ao mar na freguesia de Seixas, a 1 km da Praia de Pedras Ruivas',
    diferenciais: ['Localização frente ao mar', 'Jantares de peregrinos disponíveis; cozinha comunitária'],
    reservaUrl: 'https://www.booking.com/hotel/pt/albergue-de-sao-bento.html',
  },
  {
    nome: 'Rinoterra Minho',
    zona: 'seixas',
    categoria: 'hotel',
    tipo: 'Hotel Rural',
    morada: 'Rua da Costa 15, Seixas, Caminha',
    localizacao: 'Rural, freguesia de Seixas, vistas para o rio e para a montanha',
    diferenciais: ['Spa e centro de bem-estar', 'Ténis; restaurante de cozinha portuguesa'],
    reservaUrl: 'https://www.booking.com/hotel/pt/rinoterra-minho.html',
  },
];

const zonas: { chave: Zona; etiqueta: string; intro: string }[] = [
  {
    chave: 'caminha',
    etiqueta: 'Caminha',
    intro: 'A principal localidade de travessia na Rota Costeira Portuguesa — última etapa antes de cruzar o rio Minho para a Galiza. Albergues, pensões e hotéis, todos a poucos minutos a pé do cais do ferry.',
  },
  {
    chave: 'vpa',
    etiqueta: 'Vila Praia de Âncora',
    intro: 'Localidade costeira a 8 km a sul de Caminha, na rota do Caminho. Hotéis de praia com piscinas — alternativa mais tranquila para peregrinos que preferem chegar cedo e continuar para norte na manhã seguinte.',
  },
  {
    chave: 'seixas',
    etiqueta: 'Seixas',
    intro: 'A freguesia imediatamente a sul do centro urbano de Caminha, no caminho sinalizado da Rota Costeira. Baixa densidade — um albergue de peregrinos e um hotel rural, ambos reserváveis no Booking.com.',
  },
];

const ordemCategorias: Categoria[] = ['albergue', 'pensao', 'hotel'];
const etiquetaCategoria: Record<Categoria, string> = {
  albergue: 'Albergues',
  pensao: 'Pensões',
  hotel: 'Hotéis',
};
---

<MainLayout
  title="Onde Ficar em Caminha, Vila Praia de Âncora e Seixas"
  description="Guia de alojamento verificado para peregrinos da Rota Costeira do Caminho de Santiago. Albergues, pensões e hotéis em Caminha, Vila Praia de Âncora e Seixas — todos reserváveis no Booking.com."
  lang="pt"
  schemaType="webpage"
>

  <!-- ── JSON-LD: ItemList de alojamentos (paridade com EN where-to-stay) ───── -->
  <script type="application/ld+json" is:inline set:html={`
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "ItemList",
          "@id": "https://waytosantiagoguide.com/pt/caminha/onde-ficar/#list",
          "mainEntityOfPage": { "@id": "https://waytosantiagoguide.com/pt/caminha/onde-ficar/#webpage" },
          "name": "Alojamento em Caminha, Vila Praia de Âncora e Seixas — Caminho de Santiago da Costa",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "item": { "@type": "Hostel", "name": "Albergue Municipal de Peregrinos de Caminha", "description": "Albergue municipal oficial de peregrinos no centro de Caminha, a poucos minutos do cais do ferry. Apenas admissão direta a partir das 14:00, com credencial.", "address": { "@type": "PostalAddress", "streetAddress": "Rua Ricardo Joaquim de Sousa", "addressLocality": "Caminha", "addressCountry": "PT" } } },
            { "@type": "ListItem", "position": 2, "item": { "@type": "Hostel", "name": "Albergue Santiago de Caminha", "description": "Albergue privado de peregrinos no centro de Caminha, reservável online. Bar e cafetaria no estabelecimento.", "address": { "@type": "PostalAddress", "addressLocality": "Caminha", "addressCountry": "PT" } } },
            { "@type": "ListItem", "position": 3, "item": { "@type": "Hostel", "name": "Bom Caminha — Albergue Privado para Peregrinos", "description": "Albergue privado numa casa senhorial restaurada de 1882 no centro histórico de Caminha. Jantar de peregrino opcional, cozinha comunitária, reserva antecipada disponível.", "address": { "@type": "PostalAddress", "addressLocality": "Caminha", "addressCountry": "PT" } } },
            { "@type": "ListItem", "position": 4, "item": { "@type": "LodgingBusiness", "name": "Litos AL", "description": "Casa de hóspedes no centro de Caminha, perto da marginal. Pequeno-almoço incluído, quartos com ar condicionado.", "address": { "@type": "PostalAddress", "streetAddress": "Largo Senhora da Agonia 13", "addressLocality": "Caminha", "addressCountry": "PT" } } },
            { "@type": "ListItem", "position": 5, "item": { "@type": "Hotel", "name": "Design & Wine Hotel", "description": "Hotel num edifício do século XVIII no centro de Caminha. Piscina interior, bar de vinhos.", "address": { "@type": "PostalAddress", "addressLocality": "Caminha", "addressCountry": "PT" } } },
            { "@type": "ListItem", "position": 6, "item": { "@type": "Hotel", "name": "Hotel Porta do Sol Conference & SPA", "description": "Hotel de 4 estrelas perto da foz do rio e da praia atlântica em Caminha. Duas piscinas exteriores, spa.", "address": { "@type": "PostalAddress", "addressLocality": "Caminha", "addressCountry": "PT" } } },
            { "@type": "ListItem", "position": 7, "item": { "@type": "Hotel", "name": "BLUE ANCORA HOTEL", "description": "Hotel em Vila Praia de Âncora, a 3 minutos a pé da praia. Piscina exterior sazonal, quartos com vista para o mar.", "address": { "@type": "PostalAddress", "addressLocality": "Vila Praia de Âncora", "addressCountry": "PT" } } },
            { "@type": "ListItem", "position": 8, "item": { "@type": "Hotel", "name": "Hotel Meira", "description": "Hotel de 4 estrelas em Vila Praia de Âncora, perto da praia. Piscina, pequeno-almoço bufete incluído.", "address": { "@type": "PostalAddress", "addressLocality": "Vila Praia de Âncora", "addressCountry": "PT" } } },
            { "@type": "ListItem", "position": 9, "item": { "@type": "Hostel", "name": "Albergue de São Bento", "description": "Albergue de peregrinos frente ao mar na freguesia de Seixas. Jantares de peregrino disponíveis, cozinha partilhada.", "address": { "@type": "PostalAddress", "addressLocality": "Seixas, Caminha", "addressCountry": "PT" } } },
            { "@type": "ListItem", "position": 10, "item": { "@type": "Hotel", "name": "Rinoterra Minho", "description": "Hotel rural na freguesia de Seixas com vistas para o rio e a montanha. Spa, ténis, restaurante português.", "address": { "@type": "PostalAddress", "streetAddress": "Rua da Costa 15", "addressLocality": "Seixas, Caminha", "addressCountry": "PT" } } }
          ]
        },
        {
          "@type": "FAQPage",
          "@id": "https://waytosantiagoguide.com/pt/caminha/onde-ficar/#faq",
          "mainEntityOfPage": { "@id": "https://waytosantiagoguide.com/pt/caminha/onde-ficar/#webpage" },
          "mainEntity": [
            { "@type": "Question", "name": "É possível reservar o albergue municipal de Caminha com antecedência?", "acceptedAnswer": { "@type": "Answer", "text": "Não. O Albergue Municipal de Peregrinos de Caminha é apenas de admissão direta, abrindo às 14:00 por ordem de chegada. É exigida uma credencial do peregrino válida. A estadia máxima é de 2 noites consecutivas. Os albergues privados (Albergue Santiago, Bom Caminha) podem ser reservados online com antecedência através do Booking.com." } },
            { "@type": "Question", "name": "Há alojamento perto do cais do ferry de Caminha?", "acceptedAnswer": { "@type": "Answer", "text": "Sim. O albergue municipal e a maioria das casas de hóspedes de Caminha ficam a 5–10 minutos a pé do cais do ferry (Cais de Caminha). O centro é compacto — todo o alojamento listado fica a curta distância a pé do ponto de partida." } },
            { "@type": "Question", "name": "Que tipos de alojamento existem em Caminha para peregrinos?", "acceptedAnswer": { "@type": "Answer", "text": "Caminha oferece: albergue municipal (admissão direta, com credencial), albergues privados (reserva antecipada disponível), casas de hóspedes e hotéis. A zona mais alargada inclui hotéis de praia em Vila Praia de Âncora (8 km a sul) e um albergue frente ao mar mais um hotel rural em Seixas." } },
            { "@type": "Question", "name": "Quando se deve reservar alojamento em Caminha para o Caminho da Costa?", "acceptedAnswer": { "@type": "Answer", "text": "O Caminho da Costa atinge o pico de maio a outubro. Os albergues privados e hotéis devem ser reservados com 1–2 semanas de antecedência na época alta (julho–agosto). O albergue municipal não pode ser reservado e enche nas tardes de verão — chegue antes das 15:00 na época alta." } }
          ]
        }
      ]
    }
  `} />

  <div class="bg-gradient-to-b from-forest-50 to-white border-b border-forest-100/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <nav aria-label="Rasto de navegação" class="mb-5">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/pt/" class="hover:text-forest-700 no-underline hover:underline transition-colors">Início</a></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li><span class="text-slate-500">Caminha</span></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li aria-current="page" class="text-slate-700 font-medium">Onde Ficar</li>
        </ol>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold text-forest-900 mb-4 tracking-tight">Onde Ficar</h1>
      <p class="text-slate-600 max-w-2xl text-base leading-relaxed">
        Alojamento verificado em três zonas da Rota Costeira Portuguesa: Caminha (localidade de travessia do rio), Vila Praia de Âncora (costeira, 8 km a sul) e Seixas (freguesia na rota a sul de Caminha). Todos os hotéis ligam diretamente ao Booking.com. Na época alta (maio–outubro) as camas em Caminha são limitadas, por isso reserva com antecedência.
      </p>
      <div class="mt-6 flex flex-wrap gap-2.5">
        {zonas.map((z) => (
          <a href={`#zona-${z.chave}`} class="inline-flex items-center gap-1.5 bg-white border border-forest-200 text-forest-800 text-xs font-medium px-3.5 py-2 rounded-full hover:bg-forest-50 hover:border-forest-300 no-underline transition-all duration-200 shadow-sm cursor-pointer">
            {z.etiqueta}
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- ── Foto da marginal de Caminha ───────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <PhotoFigure
      src={marginalPhoto}
      alt="A marginal de Caminha sobre o rio Minho — a frente ribeirinha onde se concentram os albergues e casas de hóspedes do centro"
      caption="A frente do rio Minho em Caminha — a maioria das camas centrais fica a poucos minutos"
      loading="eager"
    />
  </div>
  

  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-4">
    <div class="bg-amber-50 border border-amber-300/70 rounded-2xl p-6 shadow-sm">
      <div class="flex gap-4">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-amber-100 border border-amber-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
        </div>
        <div>
          <h2 class="font-bold text-amber-900 mb-2 text-base">Reserve com antecedência: época alta maio–outubro</h2>
          <p class="text-sm text-amber-800 leading-relaxed">
            A Rota Costeira atinge o seu pico entre maio e outubro. O albergue municipal de Caminha funciona apenas com admissão direta e esgota rapidamente nas tardes de verão. Os albergues privados e hotéis aceitam reservas antecipadas — use os links abaixo para verificar disponibilidade.
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 space-y-20">

    {zonas.map((zona, zonaIdx) => {
      const itemsZona = alojamentos.filter(a => a.zona === zona.chave);
      return (
        <section id={`zona-${zona.chave}`} aria-labelledby={`cabecalho-zona-${zona.chave}`}>
          <div class="mb-8 pb-4 border-b border-slate-200">
            <h2 id={`cabecalho-zona-${zona.chave}`} class="text-2xl font-bold text-forest-900 tracking-tight mb-1">
              {zona.etiqueta}
            </h2>
            <p class="text-slate-600 text-sm leading-relaxed max-w-2xl">{zona.intro}</p>
          </div>

          {ordemCategorias.map((cat) => {
            const catItems = itemsZona.filter(a => a.categoria === cat);
            if (catItems.length === 0) return null;
            return (
              <div class="mb-10">
                <h3 class="text-base font-semibold text-slate-500 uppercase tracking-widest mb-5">{etiquetaCategoria[cat]}</h3>
                <div class="grid grid-cols-1 gap-5">
                  {catItems.map((a) => (
                    <article class="bg-white rounded-2xl border border-slate-200/80 overflow-hidden hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 shadow-sm">
                      <div class="p-6 sm:p-8">
                        <div class="mb-4">
                          <h4 class="text-xl font-bold text-forest-900 tracking-tight mb-0.5">{a.nome}</h4>
                          <p class="text-sm text-slate-500 font-medium">{a.tipo}</p>
                        </div>

                        <div class="flex flex-wrap gap-2 mb-4">
                          {a.diferenciais.map((d) => (
                            <span class="text-xs bg-forest-50 text-forest-700 px-3 py-1.5 rounded-full border border-forest-100 font-medium">{d}</span>
                          ))}
                        </div>

                        {a.nota && (
                          <div class="bg-amber-50 border border-amber-200/70 rounded-xl px-4 py-3 mb-5 flex gap-2.5 text-xs text-amber-800">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-amber-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            <span>{a.nota}</span>
                          </div>
                        )}

                        <div class="pt-4 border-t border-slate-100 flex flex-col sm:flex-row sm:items-center gap-4">
                          {a.morada && (
                            <div class="flex items-center gap-1.5 text-sm text-slate-500 flex-1">
                              <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                              </svg>
                              {a.morada}
                            </div>
                          )}

                          {a.reservaUrl ? (
                            <a
                              href={bookingLink(a.reservaUrl, stayLabel(a.nome, 'pt'))}
                              rel="nofollow noopener noreferrer sponsored"
                              target="_blank"
                              class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-earth-600 to-earth-700 hover:from-earth-700 hover:to-earth-800 active:scale-[0.98] text-white font-bold text-sm px-6 py-3.5 rounded-xl transition-all duration-200 no-underline shrink-0 shadow-md hover:shadow-lg cursor-pointer group"
                            >
                              Ver Disponibilidade e Preços
                              <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                              </svg>
                            </a>
                          ) : (
                            <span class="inline-flex items-center gap-2 bg-slate-100 text-slate-600 font-semibold text-sm px-5 py-3 rounded-xl shrink-0">
                              Só admissão direta
                            </span>
                          )}
                        </div>
                      </div>
                    </article>
                  ))}
                </div>
              </div>
            );
          })}

          {zonaIdx === 1 && (
            <div class="mt-6">
              
            </div>
          )}
        </section>
      );
    })}
  </div>
  

  <!-- ── CTA: VER TODOS ──────────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-4">
    <div class="bg-forest-50 border border-forest-200 rounded-2xl p-6 flex flex-col sm:flex-row sm:items-center gap-4">
      <div class="flex-1">
        <h2 class="text-base font-bold text-forest-900 mb-1">Mais alojamentos em Caminha</h2>
        <p class="text-sm text-slate-600 leading-relaxed">Caminha tem também pensões, apartamentos e B&amp;B além dos listados acima — por exemplo a Residencial Galo d'Ouro na praça principal e apartamentos junto ao Minho. Consulte disponibilidade e preços de todos os alojamentos da vila.</p>
      </div>
