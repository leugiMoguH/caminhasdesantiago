---
import MainLayout from '../../../layouts/MainLayout.astro';

type Zona = 'caminha' | 'vpa';

interface Restaurante {
  nome: string;
  zona: Zona;
  cozinha: string;
  morada: string;
  contextoLocalizacao: string;
  conhecidoPor: string;
  contextoPeregrino: string;
  urlMaps: string;
}

interface Cafe {
  nome: string;
  morada: string;
  utilidade: string;
  urlMaps: string;
}

const restaurantes: Restaurante[] = [
  {
    nome: 'Restaurante Baptista',
    zona: 'caminha',
    cozinha: 'Portuguesa · Marisco',
    morada: 'Praça do Conselheiro Silva Torres 24/26, Caminha',
    contextoLocalizacao: 'Na praça principal (Praça Conselheiro Silva Torres)',
    conhecidoPor: 'Local histórico na praça principal; marisco português de época e cozinha tradicional',
    contextoPeregrino: 'Opção central para sentar; adequada para almoço ou jantar na praça principal',
    urlMaps: 'https://www.google.com/maps/search/?q=Restaurante+Baptista+Caminha',
  },
  {
    nome: 'Muralha de Caminha',
    zona: 'caminha',
    cozinha: 'Mediterrânea · Europeia',
    morada: 'Praça de Espanha, Caminha',
    contextoLocalizacao: 'Junto às muralhas medievais históricas',
    conhecidoPor: 'Esplanada exterior frente às muralhas da cidade; cozinha regional do Minho',
    contextoPeregrino: 'Esplanada exterior após a chegada; bom para jantar ao início da tarde',
    urlMaps: 'https://www.google.com/maps/search/?q=Muralha+de+Caminha',
  },
  {
    nome: 'Solar do Pescado',
    zona: 'caminha',
    cozinha: 'Marisco · Mediterrânea',
    morada: 'Rua Visconde Sousa Rego 85, Caminha',
    contextoLocalizacao: 'Rua principal em direção ao rio e ao cais do ferry',
    conhecidoPor: 'Marisco atlântico fresco na rota para o ferry',
    contextoPeregrino: 'Na rota para o cais do ferry; boa paragem para almoçar antes da travessia',
    urlMaps: 'https://www.google.com/maps/search/?q=Solar+do+Pescado+Caminha',
  },
  {
    nome: 'Casa Almeida',
    zona: 'caminha',
    cozinha: 'Café · Europeia · Portuguesa',
    morada: 'Praça Conselheiro Silva Torres, Caminha',
    contextoLocalizacao: 'Na praça principal',
    conhecidoPor: 'Café e restaurante na praça principal; menu português tradicional',
    contextoPeregrino: 'Paragem flexível na praça principal; adequada para refeições ligeiras ou café a qualquer hora',
    urlMaps: 'https://www.google.com/maps/search/?q=Casa+Almeida+Caminha',
  },
  {
    nome: 'O Chafariz',
    zona: 'caminha',
    cozinha: 'Europeia · Portuguesa',
    morada: '',
    contextoLocalizacao: 'Centro urbano',
    conhecidoPor: 'Cozinha portuguesa tradicional com numerosa clientela local',
    contextoPeregrino: 'Bom para um jantar tradicional no centro; popular entre os locais',
    urlMaps: 'https://www.google.com/maps/search/?q=O+Chafariz+Caminha',
  },
  {
    nome: 'Fortaleza Restaurante',
    zona: 'vpa',
    cozinha: 'Marisco · Mediterrânea',
    morada: 'Avenida Dr. Ramos Pereira 81, Vila Praia de Âncora',
    contextoLocalizacao: 'Passeio marítimo de Vila Praia de Âncora',
    conhecidoPor: 'Marisco atlântico fresco no principal passeio gastronómico frente ao mar',
    contextoPeregrino: 'Almoço ou jantar junto ao mar em Vila Praia de Âncora; conveniente se pernoitar aqui',
    urlMaps: 'https://www.google.com/maps/search/?q=Fortaleza+Restaurante+Vila+Praia+de+Ancora',
  },
  {
    nome: 'Restaurante Vitória Mar',
    zona: 'vpa',
    cozinha: 'Marisco · Mediterrânea',
    morada: 'Avenida Dr. Luis Ramos Pereira 100, Vila Praia de Âncora',
    contextoLocalizacao: 'Passeio marítimo de Vila Praia de Âncora',
    conhecidoPor: 'Marisco no principal passeio frente ao mar; consistentemente bem avaliado',
    contextoPeregrino: 'Alternativa junto ao mar em VPA; útil se o Fortaleza estiver cheio',
    urlMaps: 'https://www.google.com/maps/search/?q=Restaurante+Vitoria+Mar+Vila+Praia+de+Ancora',
  },
];

const cafes: Cafe[] = [
  {
    nome: 'Pastelaria Caminhense',
    morada: 'Rua São João 35, Caminha',
    utilidade: 'Localização central; pastelaria com serviço ao balcão, ideal para um café rápido antes da partida',
    urlMaps: 'https://www.google.com/maps/search/?q=Pastelaria+Caminhense+Caminha',
  },
  {
    nome: 'Pastelaria Riviera',
    morada: '',
    utilidade: 'Pastelaria no centro; café e pastéis para levar',
    urlMaps: 'https://www.google.com/maps/search/?q=Pastelaria+Riviera+Caminha',
  },
];

const etiquetasZona: Record<Zona, string> = {
  caminha: 'Caminha',
  vpa: 'Vila Praia de Âncora',
};
const zonas: Zona[] = ['caminha', 'vpa'];
---

<MainLayout
  title="Onde Comer em Caminha e Vila Praia de Âncora | Caminho de Santiago"
  description="Restaurantes e cafés verificados em Caminha e Vila Praia de Âncora para peregrinos da Rota Costeira do Caminho de Santiago. Marisco português tradicional, pequenos-almoços antecipados e gastronomia local."
  lang="pt"
  schemaType="webpage"
>

  <div class="bg-gradient-to-b from-earth-50 to-white border-b border-earth-100/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <nav aria-label="Rasto de navegação" class="mb-5">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/pt/" class="hover:text-forest-700 no-underline hover:underline transition-colors">Início</a></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li><span class="text-slate-400">Caminha</span></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li aria-current="page" class="text-slate-700 font-medium">Onde Comer</li>
        </ol>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold text-forest-900 mb-4 tracking-tight">Onde Comer</h1>
      <p class="text-slate-600 max-w-2xl text-base leading-relaxed">
        Restaurantes verificados em Caminha e Vila Praia de Âncora. Todos os estabelecimentos estão confirmados no Google Maps e TripAdvisor. Seixas não tem infraestrutura gastronómica própria — os peregrinos alojados lá vão a Caminha jantar.
      </p>
      <div class="mt-6 flex flex-wrap gap-2.5">
        <a href="#restaurantes" class="inline-flex items-center gap-1.5 bg-white border border-earth-200 text-earth-800 text-xs font-medium px-3.5 py-2 rounded-full hover:bg-earth-50 hover:border-earth-300 no-underline transition-all duration-200 shadow-sm cursor-pointer">
          Restaurantes
        </a>
        <a href="#pequeno-almoco" class="inline-flex items-center gap-1.5 bg-white border border-earth-200 text-earth-800 text-xs font-medium px-3.5 py-2 rounded-full hover:bg-earth-50 hover:border-earth-300 no-underline transition-all duration-200 shadow-sm cursor-pointer">
          Pequeno-Almoço Antecipado e Cafés
        </a>
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="my-6">
      <ins class="adsbygoogle w-full"
           style="display:block"
           data-ad-client="ca-pub-6529337148344504"
           data-ad-slot="2297179243"
           data-ad-format="auto"
           data-full-width-responsive="true"></ins>
    </div>
  </div>
  <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>

  <div id="restaurantes" class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 space-y-16">
    {zonas.map((zona) => {
      const items = restaurantes.filter(r => r.zona === zona);
      return (
        <section aria-labelledby={`cabecalho-${zona}`}>
          <div class="mb-6 pb-4 border-b border-slate-200">
            <h2 id={`cabecalho-${zona}`} class="text-2xl font-bold text-forest-900 tracking-tight">
              {etiquetasZona[zona]}
            </h2>
          </div>
          <div class="grid grid-cols-1 gap-5">
            {items.map((r) => (
              <article class="bg-white rounded-2xl border border-slate-200/80 overflow-hidden hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 shadow-sm">
                <div class="p-6 sm:p-8">
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-3">
                    <div class="min-w-0">
                      <h3 class="text-xl font-bold text-forest-900 tracking-tight mb-0.5">{r.nome}</h3>
                      <p class="text-sm text-slate-500 font-medium">{r.cozinha}</p>
                    </div>
                    <span class="text-xs bg-forest-50 text-forest-700 px-3 py-1.5 rounded-full border border-forest-100 font-medium self-start break-words sm:max-w-[13rem]">{r.contextoPeregrino}</span>
                  </div>
                  <p class="text-slate-700 text-sm leading-relaxed mb-4">{r.conhecidoPor}</p>
                  <div class="flex flex-wrap items-center gap-3 text-sm text-slate-500 pt-4 border-t border-slate-100">
                    {r.morada && (
                      <span class="flex items-center gap-1.5">
                        <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                        {r.morada}
                      </span>
                    )}
                    <span class="flex items-center gap-1.5 text-xs text-slate-400">
                      <svg class="h-4 w-4 shrink-0 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      </svg>
                      {r.contextoLocalizacao}
                    </span>
                    <a href={r.urlMaps} rel="noopener noreferrer" target="_blank" class="ml-auto inline-flex items-center gap-1.5 text-xs text-forest-600 hover:text-forest-800 font-medium no-underline hover:underline transition-colors">
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                      </svg>
                      Ver no Maps
                    </a>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>
      );
    })}
  </div>

  <!-- ── CTA: LOOP INTERNO ──────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-6">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href="/pt/caminha/onde-ficar/" class="flex items-center gap-4 bg-white border border-forest-200 rounded-2xl p-5 hover:shadow-md hover:border-forest-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-forest-50 border border-forest-100">
          <svg class="h-5 w-5 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        </div>
        <div>
          <p class="text-sm font-bold text-forest-900 group-hover:text-forest-700">Onde Ficar</p>
          <p class="text-xs text-slate-500">Albergues, pensões e hotéis em Caminha, VPA e Seixas</p>
        </div>
      </a>
      <a href="/pt/caminha/ferry-e-logistica/" class="flex items-center gap-4 bg-white border border-earth-200 rounded-2xl p-5 hover:shadow-md hover:border-earth-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-earth-50 border border-earth-100">
          <svg class="h-5 w-5 text-earth-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
        </div>
        <div>
          <p class="text-sm font-bold text-earth-900 group-hover:text-earth-700">Ferry e Logística</p>
          <p class="text-xs text-slate-500">Horários, tarifas e alternativas para a travessia do Minho</p>
        </div>
      </a>
      <a href="/pt/caminha/servicos-uteis/" class="flex items-center gap-4 bg-white border border-slate-200 rounded-2xl p-5 hover:shadow-md hover:border-slate-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-slate-50 border border-slate-100">
          <svg class="h-5 w-5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-slate-900 group-hover:text-slate-700">Serviços Úteis</p>
          <p class="text-xs text-slate-500">Farmácias de serviço, lojas de equipamento e multibanco</p>
        </div>
      </a>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-2">
    <ins class="adsbygoogle w-full"
         style="display:block"
         data-ad-client="ca-pub-6529337148344504"
         data-ad-slot="8017929699"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
  </div>
  <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>

  <div id="pequeno-almoco" class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-6 pb-4 border-b border-slate-200">
      <h2 class="text-2xl font-bold text-forest-900 tracking-tight mb-1">Pequeno-Almoço Antecipado e Cafés — Caminha</h2>
      <p class="text-slate-600 text-sm leading-relaxed max-w-2xl">
        Pastelarias no centro de Caminha úteis para saídas antes do ferry. Os horários podem variar consoante a época — confirme diretamente no estabelecimento ou pergunte no seu alojamento.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {cafes.map((c) => (
        <div class="bg-white rounded-2xl border border-slate-200/80 p-6 shadow-sm">
          <h3 class="text-base font-bold text-forest-900 mb-1">{c.nome}</h3>
          {c.morada && (
            <p class="text-xs text-slate-500 mb-3 flex items-center gap-1.5">
              <svg class="h-3.5 w-3.5 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              {c.morada}
            </p>
          )}
          <p class="text-xs text-amber-700 font-medium bg-amber-50 border border-amber-100 rounded-lg px-3 py-2 mb-3">
            Abre cedo (geralmente por volta das 07:00–08:00, pode variar)
          </p>
          <p class="text-sm text-slate-600 leading-relaxed mb-4">{c.utilidade}</p>
          <a href={c.urlMaps} rel="noopener noreferrer" target="_blank" class="mt-auto inline-flex items-center gap-1.5 text-xs text-forest-600 hover:text-forest-800 font-medium no-underline hover:underline transition-colors">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            Ver no Maps
          </a>
        </div>
      ))}
    </div>
    <p class="mt-6 text-xs text-slate-400 leading-relaxed max-w-xl">
      Os horários indicados são aproximados. Confirme sempre com o estabelecimento, especialmente fora da época alta (junho–setembro). Não há cafés em Seixas — os peregrinos alojados lá caminham até Caminha (aprox. 15–20 min) para o café da manhã.
    </p>
  </div>

  <aside class="bg-gradient-to-b from-forest-50 to-white border-y border-forest-100/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <div class="flex gap-4">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-forest-100 border border-forest-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-forest-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
        </div>
        <div>
          <h2 class="text-lg font-bold text-forest-900 mb-2 tracking-tight">Menus de Peregrino</h2>
          <p class="text-slate-700 text-sm leading-relaxed max-w-2xl">
            Em Portugal, o <em>menu do peregrino</em> serve-se normalmente apenas ao almoço (12:00–15:00) por 8–12 €. Inclui primeiro prato, segundo, sobremesa ou café e vinho ou água da casa. Mostrar uma <em>credencial do peregrino</em> pode confirmar a elegibilidade, embora a maioria dos restaurantes em Caminha não a exija. Muitos estabelecimentos pequenos fecham às segundas-feiras. Consulte o quadro do menu no exterior antes de se sentar.
          </p>
        </div>
      </div>
    </div>
  </aside>

  <!-- ── BOOKING CTA ────────────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10">
    <div class="bg-gradient-to-r from-earth-50 to-amber-50 border border-earth-200/60 rounded-2xl p-6 sm:p-8 flex flex-col sm:flex-row sm:items-center gap-6">
      <div class="flex-1">
        <h2 class="text-lg font-bold text-earth-900 mb-1 tracking-tight">Precisa de alojamento em Caminha?</h2>
        <p class="text-sm text-slate-600 leading-relaxed">Albergues a partir de 12 €, pensões e hotéis de 4 estrelas — tudo reservável no Booking.com. Verifique disponibilidade para as suas datas.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 shrink-0">
        <a
          href="https://www.booking.com/searchresults.html?ss=Caminha%2C+Portugal&aid=7968251"
          rel="nofollow noopener noreferrer sponsored"
          target="_blank"
          class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-earth-500 to-earth-600 hover:from-earth-600 hover:to-earth-700 active:scale-[0.98] text-white font-bold text-sm px-6 py-3.5 rounded-xl transition-all duration-200 no-underline shadow-md hover:shadow-lg cursor-pointer group"
        >
          Ver Disponibilidade
          <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
        <a href="/pt/caminha/onde-ficar/" class="inline-flex items-center justify-center gap-2 bg-white border border-earth-200 text-earth-800 font-semibold text-sm px-5 py-3.5 rounded-xl hover:bg-earth-50 hover:border-earth-300 no-underline transition-all duration-200">Ver todas as opções →</a>
      </div>
    </div>
  </div>

</MainLayout>
