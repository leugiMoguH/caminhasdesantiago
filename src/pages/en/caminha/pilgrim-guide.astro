---
import MainLayout from '../../../layouts/MainLayout.astro';

const faqItems = [
  {
    question: 'What route does the Camino de Santiago Coastal Route take through this area?',
    answer: 'The Coastal Route (Via da Costa) enters from Vila Praia de Âncora, passes through Seixas, and terminates at Caminha — the last Portuguese town before the Minho river crossing into Galicia, Spain. From Caminha, pilgrims cross by ferry (or water taxi) to A Guarda and continue north along the Galician coast.',
  },
  {
    question: 'Do I need a pilgrim credential (credencial do peregrino) to walk the Coastal Route?',
    answer: 'Yes. A credencial is required for the municipal albergue in Caminha (walk-in only, valid credential mandatory). It is also needed to collect stamps (sellos) at churches, albergues, and tourist offices along the route, which are required to obtain the Compostela certificate in Santiago. Private albergues in Caminha do not require a credential for booking but will stamp it if you have one.',
  },
  {
    question: 'When is the best time of year to walk the Coastal Route through Caminha?',
    answer: 'May to October offers the most reliable conditions: daily ferry service, long daylight hours, and open albergues. July and August are peak season — book private albergues and hotels in advance. The municipal albergue cannot be booked. November to March brings reduced ferry service (weekends and public holidays only) and a significant reduction in pilgrim infrastructure. Winter walkers should consider the Portuguese Interior Route via Valença–Tui as a more reliable crossing alternative.',
  },
  {
    question: 'How do I cross from Portugal to Spain on the Coastal Route?',
    answer: 'The primary crossing is by ferry from Cais de Caminha to A Guarda (€2.50 per adult, ~15 minutes). In summer (April–October) the ferry runs daily from 09:00 to 19:00. The ferry is subject to seasonal siltation (assoreamento) that can suspend service without notice — always verify the evening before. Alternatives: Xávegas water taxis (€5–6 per person, informal fishermen\'s boats) or the overland train from Caminha to Valença then walking across the Tui bridge. See the full ferry and logistics guide for details.',
  },
];
---

<MainLayout
  title="Pilgrim Guide to the Camino de Santiago Coastal Route via Caminha"
  description="Practical pilgrim guide for the Camino de Santiago Coastal Route through Caminha. Route context, credential requirements, seasonal timing, and the Minho river crossing into Spain."
  lang="en"
  schemaType="webpage"
>

  <!-- ── HERO HEADER ──────────────────────────────────────────────────────────── -->
  <div class="bg-gradient-to-br from-forest-900 via-forest-900 to-forest-950 text-white">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <nav aria-label="Breadcrumb" class="mb-5">
        <ol class="flex items-center gap-2 text-sm text-forest-300">
          <li><a href="/en/" class="hover:text-white no-underline hover:underline transition-colors">Home</a></li>
          <li aria-hidden="true" class="text-forest-600">›</li>
          <li><a href="/en/caminha-guide/" class="hover:text-white no-underline hover:underline transition-colors">Caminha</a></li>
          <li aria-hidden="true" class="text-forest-600">›</li>
          <li aria-current="page" class="text-forest-200 font-medium">Pilgrim Guide</li>
        </ol>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold mb-4 text-white tracking-tight">Pilgrim Guide — Coastal Route via Caminha</h1>
      <p class="text-forest-300 max-w-2xl text-base leading-relaxed">
        Practical preparation for the final Portuguese stages and the Minho river crossing. Route context, credential requirements, seasonal timing, and what to do when the ferry doesn't run.
      </p>

      <div class="mt-8 grid grid-cols-2 sm:grid-cols-4 gap-4">
        {[
          { value: 'VPA → Seixas → Caminha', label: 'Final Portugal stages' },
          { value: 'Apr – Oct', label: 'Daily ferry season' },
          { value: '€2.50', label: 'Ferry fare' },
          { value: '~15 min', label: 'Minho crossing' },
        ].map(({ value, label }) => (
          <div class="bg-white/10 backdrop-blur-sm border border-white/10 rounded-2xl p-4 text-center hover:bg-white/15 transition-colors">
            <div class="text-sm font-bold text-white leading-tight">{value}</div>
            <div class="text-xs text-forest-400 mt-1">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ── ANCHOR NAV ────────────────────────────────────────────────────────── -->
  <div class="border-b border-slate-100 bg-white sticky top-0 z-10">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <nav aria-label="Page sections" class="flex flex-wrap gap-x-6 gap-y-1 py-3 text-xs font-medium text-slate-500 overflow-x-auto">
        <a href="#route-context" class="hover:text-forest-700 no-underline whitespace-nowrap">Route Context</a>
        <a href="#preparation" class="hover:text-forest-700 no-underline whitespace-nowrap">Preparation</a>
        <a href="#crossing" class="hover:text-forest-700 no-underline whitespace-nowrap">Crossing Logistics</a>
        <a href="#faq" class="hover:text-forest-700 no-underline whitespace-nowrap">FAQ</a>
      </nav>
    </div>
  </div>

  <!-- ── ADSENSE SLOT 1 ──────────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="my-6">
      <ins class="adsbygoogle w-full"
           style="display:block"
           data-ad-client="ca-pub-6529337148344504"
           data-ad-slot="2297179243"
           data-ad-format="auto"
           data-full-width-responsive="true"></ins>
    </div>
  </div>
  <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>

  <!-- ── MAIN + SIDEBAR ─────────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

      <div class="lg:col-span-2 space-y-10">

        <!-- ── ROUTE CONTEXT ───────────────────────────────────────────────── -->
        <section id="route-context" aria-labelledby="route-heading">
          <h2 id="route-heading" class="text-2xl font-bold text-forest-900 mb-4 tracking-tight">Route Context</h2>
          <div class="space-y-4 text-slate-700 text-sm leading-relaxed">
            <p>
              The <strong>Camino de Santiago Coastal Route</strong> (Portuguese: <em>Caminho Português da Costa</em>) follows the Atlantic coast of Portugal from Porto north through Viana do Castelo, Vila Praia de Âncora, and Caminha before crossing the Minho river into Galicia, Spain.
            </p>
            <p>
              The final Portuguese stages before the crossing pass through three distinct zones covered by this guide:
            </p>
            <ul class="space-y-3 pl-0">
              <li class="flex items-start gap-3">
                <span class="shrink-0 h-6 w-6 flex items-center justify-center rounded-full bg-earth-100 text-earth-800 text-xs font-bold mt-0.5">1</span>
                <div>
                  <a href="/en/caminha/vila-praia-de-ancora/" class="font-bold text-forest-700 hover:underline no-underline">Vila Praia de Âncora</a> — coastal town 8 km south of Caminha. Beach hotels, beachfront restaurants. No albergue. Useful overnight stop for pilgrims who prefer to arrive in Caminha early on crossing day.
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="shrink-0 h-6 w-6 flex items-center justify-center rounded-full bg-earth-100 text-earth-800 text-xs font-bold mt-0.5">2</span>
                <div>
                  <a href="/en/caminha/seixas/" class="font-bold text-forest-700 hover:underline no-underline">Seixas</a> — parish immediately south of Caminha on the waymarked path. One beachfront albergue (Albergue de São Bento) and one country hotel (Rinoterra Minho). No restaurants — pilgrims walk to Caminha for meals.
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="shrink-0 h-6 w-6 flex items-center justify-center rounded-full bg-forest-700 text-white text-xs font-bold mt-0.5">3</span>
                <div>
                  <strong class="text-slate-800">Caminha</strong> — the crossing town. Municipal albergue, two private albergues, guesthouses, and hotels. Full restaurant infrastructure, pharmacies, gear shops, ATMs. The ferry to A Guarda departs from Cais de Caminha.
                </div>
              </li>
            </ul>
          </div>
        </section>

        <!-- ── PREPARATION ────────────────────────────────────────────────── -->
        <section id="preparation" aria-labelledby="prep-heading">
          <h2 id="prep-heading" class="text-2xl font-bold text-forest-900 mb-4 tracking-tight">Preparation</h2>

          <div class="space-y-4">

            <!-- Credential -->
            <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
              <h3 class="font-bold text-forest-900 text-base mb-3">Pilgrim Credential (Credencial do Peregrino)</h3>
              <div class="space-y-3 text-slate-700 text-sm leading-relaxed">
                <p>
                  A <em>credencial</em> is the pilgrim passport — a folded document stamped at albergues, churches, and tourist offices along the route. It serves two purposes: (1) proof of pilgrimage required to claim the Compostela in Santiago, and (2) access to municipal albergues that require it as a condition of entry.
                </p>
                <p>
                  The <strong>Albergue Municipal de Peregrinos de Caminha</strong> requires a valid credencial — walk-in only from 14:00. Private albergues do not require it for booking but will stamp it. Collect stamps at each overnight stop and at key churches along the route.
                </p>
                <div class="bg-forest-50 border border-forest-100 rounded-xl p-4 mt-2">
                  <p class="text-xs text-forest-800 leading-relaxed">Credentials can be obtained from pilgrim associations before departure (e.g., Confraternity of Saint James, Amigos del Camino de Santiago) or from the first albergue on your starting stage.</p>
                </div>
              </div>
            </div>

            <!-- Seasonal timing -->
            <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
              <h3 class="font-bold text-forest-900 text-base mb-3">Seasonal Timing</h3>
              <div class="grid sm:grid-cols-2 gap-4">
                <div class="bg-forest-50 border border-forest-100 rounded-xl p-4">
                  <p class="font-semibold text-forest-900 text-xs uppercase tracking-wider mb-2">May – October (Peak)</p>
                  <ul class="text-xs text-slate-700 space-y-1.5">
                    <li>• Daily ferry service (Apr–Oct)</li>
                    <li>• All albergues and hotels open</li>
                    <li>• Book private accommodation 1–2 weeks ahead in July–August</li>
                    <li>• Municipal albergue walk-in — arrive before 15:00 in peak season</li>
                  </ul>
                </div>
                <div class="bg-slate-50 border border-slate-100 rounded-xl p-4">
                  <p class="font-semibold text-slate-800 text-xs uppercase tracking-wider mb-2">November – March (Off-Peak)</p>
                  <ul class="text-xs text-slate-700 space-y-1.5">
                    <li>• Ferry weekends and public holidays only</li>
                    <li>• Reduced albergue availability</li>
                    <li>• Consider the Interior Route via Valença–Tui as a more reliable crossing</li>
                    <li>• Fewer pilgrims; some restaurants on reduced hours</li>
                  </ul>
                </div>
              </div>
            </div>

          </div>
        </section>

        <!-- ── CROSSING LOGISTICS ──────────────────────────────────────────── -->
        <section id="crossing" aria-labelledby="crossing-heading">
          <h2 id="crossing-heading" class="text-2xl font-bold text-forest-900 mb-4 tracking-tight">Crossing Logistics</h2>
          <div class="space-y-4 text-slate-700 text-sm leading-relaxed">
            <p>
              The Minho river crossing is the defining moment of this route — a 15-minute ferry ride from Caminha (Portugal) to A Guarda (Spain) that separates the Portuguese and Galician sections of the Coastal Camino.
            </p>

            <!-- Quick facts -->
            <div class="grid sm:grid-cols-3 gap-3">
              {[
                { label: 'Fare', value: '€2.50 adult one-way' },
                { label: 'Duration', value: '~15 min' },
                { label: 'Season', value: 'Daily Apr–Oct; weekends Nov–Mar' },
              ].map(({ label, value }) => (
                <div class="bg-slate-50 border border-slate-200 rounded-xl p-4 text-center">
                  <p class="text-xs text-slate-500 uppercase tracking-wider mb-1">{label}</p>
                  <p class="font-bold text-slate-800 text-sm">{value}</p>
                </div>
              ))}
            </div>

            <!-- Siltation warning -->
            <div class="bg-red-50 border border-red-200 rounded-2xl p-5">
              <div class="flex gap-3 items-start">
                <div class="shrink-0 flex h-9 w-9 items-center justify-center rounded-xl bg-red-100 border border-red-200">
                  <svg class="h-5 w-5 text-red-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-red-900 text-sm mb-1">Siltation Risk — Always Verify Before Crossing Day</h3>
                  <p class="text-xs text-red-800 leading-relaxed">
                    The ferry is subject to recurring <em>assoreamento</em> (river mouth siltation) that can suspend service without advance notice. This is not rare — it occurs in some form during most Camino seasons. Always ask at your accommodation the evening before whether the ferry is running. See the <a href="/en/caminha/ferry-and-logistics/" class="font-medium hover:underline no-underline text-red-900">full ferry and logistics guide</a> for water taxi alternatives and the overland detour via Valença–Tui.
                  </p>
                </div>
              </div>
            </div>

            <div class="bg-forest-50 border border-forest-100 rounded-2xl p-5">
              <h3 class="font-bold text-forest-900 text-sm mb-3">After the Crossing: A Guarda</h3>
              <p class="text-xs text-slate-700 leading-relaxed mb-3">
                You arrive in <strong>A Guarda</strong> (O Garda in Galician), a fishing town in Galicia, Spain. Yellow Camino arrows resume from the dock northward along the coast toward Oia and Baiona. Currency stays euros. Get your credential stamped at the A Guarda albergue or tourist office.
              </p>
              <a href="/en/caminha/ferry-and-logistics/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-forest-700 hover:underline no-underline">
                Full ferry guide — schedules, fares, alternatives
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </section>

        <!-- ── ADSENSE SLOT 2 ──────────────────────────────────────────────── -->
        <div>
          <ins class="adsbygoogle w-full"
               style="display:block"
               data-ad-client="ca-pub-6529337148344504"
               data-ad-slot="8017929699"
               data-ad-format="auto"
               data-full-width-responsive="true"></ins>
        </div>
        <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>

        <!-- ── FAQ ────────────────────────────────────────────────────────── -->
        <section id="faq" aria-labelledby="faq-heading">
          <h2 id="faq-heading" class="text-2xl font-bold text-forest-900 mb-6 tracking-tight">Frequently Asked Questions</h2>
          <div class="space-y-4">
            {faqItems.map((item) => (
              <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
                <h3 class="font-bold text-forest-900 text-sm mb-2 leading-snug">{item.question}</h3>
                <p class="text-sm text-slate-700 leading-relaxed">{item.answer}</p>
              </div>
            ))}
          </div>
        </section>

      </div>

      <!-- ── SIDEBAR ──────────────────────────────────────────────────────── -->
      <aside class="space-y-5">

        <!-- Quick checklist -->
        <div class="bg-forest-50 border border-forest-200 rounded-2xl p-5 shadow-sm">
          <h2 class="text-base font-bold text-forest-900 mb-3 tracking-tight">Pilgrim Checklist — Caminha</h2>
          <ul class="space-y-2.5 text-sm text-slate-700">
            {[
              'Credential stamped at each overnight stop',
              'Cash in euros — ferry kiosk may not accept cards',
              'Verify ferry status the evening before crossing',
              'Municipal albergue: arrive before 15:00 in peak season',
              'Prescription medications: stock up before crossing (Spanish pharmacies use different brands)',
              'Last ATMs before Spain: Praça do Conselho, Caminha',
            ].map((item) => (
              <li class="flex items-start gap-2.5">
                <svg class="h-4 w-4 text-forest-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="text-xs leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Key contacts -->
        <div class="bg-white border border-slate-200 rounded-2xl p-5 shadow-sm">
          <h2 class="text-base font-bold text-forest-900 mb-3 tracking-tight">Key Contacts</h2>
          <ul class="space-y-3 text-sm">
            <li>
              <p class="font-semibold text-slate-800 text-xs mb-0.5">Caminha Tourist Office</p>
              <a href="tel:+351258921952" class="text-forest-700 font-bold hover:underline no-underline">+351 258 921 952</a>
              <p class="text-xs text-slate-500 mt-0.5">Ferry status, water taxi contacts, local info</p>
            </li>
            <li>
              <p class="font-semibold text-slate-800 text-xs mb-0.5">SNS24 (Health / Pharmacy)</p>
              <a href="tel:80824242424" class="text-forest-700 font-bold hover:underline no-underline">808 24 24 24</a>
              <p class="text-xs text-slate-500 mt-0.5">Find the duty pharmacy; medical advice</p>
            </li>
            <li>
              <p class="font-semibold text-slate-800 text-xs mb-0.5">Emergency</p>
              <a href="tel:112" class="text-red-700 font-bold hover:underline no-underline">112</a>
              <p class="text-xs text-slate-500 mt-0.5">Police, ambulance, fire</p>
            </li>
          </ul>
        </div>

        <!-- Cluster links -->
        <div class="bg-forest-50 border border-forest-200 rounded-2xl p-5 shadow-sm">
          <h2 class="text-base font-bold text-forest-900 mb-3 tracking-tight">Caminha Guides</h2>
          <ul class="space-y-3 text-sm">
            {[
              { href: '/en/caminha-guide/', label: 'Caminha Overview', sub: 'All clusters' },
              { href: '/en/caminha/ferry-and-logistics/', label: 'Ferry & Logistics', sub: 'Schedule, fares, siltation, alternatives' },
              { href: '/en/caminha/where-to-stay/', label: 'Where to Stay', sub: 'Albergues, guesthouses, hotels' },
              { href: '/en/caminha/where-to-eat/', label: 'Where to Eat', sub: 'Restaurants and cafés' },
              { href: '/en/caminha/useful-services/', label: 'Pilgrim Services', sub: 'Pharmacies, gear shops, ATMs' },
              { href: '/en/caminha/vila-praia-de-ancora/', label: 'Vila Praia de Âncora', sub: 'Restaurants & hotels, 8 km south' },
              { href: '/en/caminha/seixas/', label: 'Seixas', sub: 'Albergue & country hotel on-route' },
            ].map(({ href, label, sub }) => (
              <li>
                <a href={href} class="text-forest-700 hover:underline no-underline font-medium cursor-pointer flex items-center gap-1 group">
                  {label}
                  <svg class="h-3.5 w-3.5 text-earth-500 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </a>
                <p class="text-xs text-slate-500 mt-0.5">{sub}</p>
              </li>
            ))}
          </ul>
        </div>

      </aside>
    </div>
  </div>

  <!-- ── SCHEMA: FAQPage ────────────────────────────────────────────────────── -->
  <script type="application/ld+json" is:inline>{`
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What route does the Camino de Santiago Coastal Route take through this area?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Coastal Route (Via da Costa) enters from Vila Praia de Âncora, passes through Seixas, and terminates at Caminha — the last Portuguese town before the Minho river crossing into Galicia, Spain. From Caminha, pilgrims cross by ferry (or water taxi) to A Guarda and continue north along the Galician coast."
          }
        },
        {
          "@type": "Question",
          "name": "Do I need a pilgrim credential (credencial do peregrino) to walk the Coastal Route?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. A credencial is required for the municipal albergue in Caminha (walk-in only, valid credential mandatory). It is also needed to collect stamps at churches, albergues, and tourist offices along the route, which are required to obtain the Compostela certificate in Santiago. Private albergues in Caminha do not require a credential for booking but will stamp it if you have one."
          }
        },
        {
          "@type": "Question",
          "name": "When is the best time of year to walk the Coastal Route through Caminha?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "May to October offers the most reliable conditions: daily ferry service, long daylight hours, and open albergues. July and August are peak season — book private albergues and hotels in advance. The municipal albergue cannot be booked. November to March brings reduced ferry service (weekends and public holidays only) and a significant reduction in pilgrim infrastructure."
          }
        },
        {
          "@type": "Question",
          "name": "How do I cross from Portugal to Spain on the Coastal Route?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The primary crossing is by ferry from Cais de Caminha to A Guarda (€2.50 per adult, approximately 15 minutes). In summer (April–October) the ferry runs daily from 09:00 to 19:00. The ferry is subject to seasonal siltation (assoreamento) that can suspend service without notice — always verify the evening before. Alternatives: Xávegas water taxis (€5–6 per person) or the overland train from Caminha to Valença then walking across the Tui bridge."
          }
        }
      ]
    }
  `}</script>

</MainLayout>
