---
import MainLayout from '../../../layouts/MainLayout.astro';

type Zone = 'caminha' | 'vpa' | 'seixas';
type Category = 'albergue' | 'hotel' | 'guesthouse';

interface Accommodation {
  name: string;
  zone: Zone;
  category: Category;
  type: string;
  address: string;
  positioning: string;
  differentiators: string[];
  bookingUrl: string | null;
  note?: string;
}

const accommodations: Accommodation[] = [
  // ── CAMINHA ────────────────────────────────────────────────────────────────────
  {
    name: 'Albergue Municipal de Peregrinos de Caminha',
    zone: 'caminha',
    category: 'albergue',
    type: 'Municipal Pilgrim Hostel',
    address: 'Rua Ricardo Joaquim de Sousa, Caminha',
    positioning: 'Town centre, minutes from the ferry dock',
    differentiators: ['Official municipal albergue', 'Pilgrim credential (credencial) required'],
    bookingUrl: null,
    note: 'Walk-in only — no online reservations. Opens at 14:00. First-come, first-served. Valid credencial do peregrino required. Maximum 2 consecutive nights.',
  },
  {
    name: 'Albergue Santiago de Caminha',
    zone: 'caminha',
    category: 'albergue',
    type: 'Private Pilgrim Hostel',
    address: 'Near Igreja Matriz de Caminha, riverside area',
    positioning: 'Central Caminha, on Camino route near waterfront',
    differentiators: ['Bookable online in advance', 'Bar and coffee shop on site'],
    bookingUrl: 'https://www.booking.com/hotel/pt/albergue-santiago-de-caminha.html?aid=7968251',
  },
  {
    name: 'Bom Caminha — Private Albergue for Pilgrims',
    zone: 'caminha',
    category: 'albergue',
    type: 'Private Pilgrim Hostel',
    address: 'Caminha town centre (450 m from Convento de Santo António)',
    positioning: 'Central old town, restored 1882 townhouse',
    differentiators: ['Optional pilgrim dinner (€12 supplement)', 'Communal kitchen; advance booking available'],
    bookingUrl: 'https://www.booking.com/hotel/pt/bom-caminha-private-albergue-amp-guest-house.html?aid=7968251',
  },
  {
    name: 'Litos AL',
    zone: 'caminha',
    category: 'guesthouse',
    type: 'Guest House',
    address: 'Largo Senhora da Agonia 13, Caminha',
    positioning: 'Central town, near waterfront',
    differentiators: ['Breakfast included', 'Air-conditioned rooms'],
    bookingUrl: 'https://www.booking.com/hotel/pt/litos-al.html?aid=7968251',
  },
  {
    name: 'Design & Wine Hotel',
    zone: 'caminha',
    category: 'hotel',
    type: 'Hotel',
    address: 'Caminha (1.5 km from Pedras Ruivas Beach)',
    positioning: 'Town centre, 18th-century building',
    differentiators: ['Indoor swimming pool', 'Wine bar and restaurant on site'],
    bookingUrl: 'https://www.booking.com/hotel/pt/design.html?aid=7968251',
  },
  {
    name: 'Hotel Porta do Sol Conference & SPA',
    zone: 'caminha',
    category: 'hotel',
    type: 'Hotel — 4 Star',
    address: 'Caminha (near Foz do Minho / Atlantic coast)',
    positioning: 'Near river mouth and Atlantic beach',
    differentiators: ['2 outdoor pools', 'Spa and wellness facilities'],
    bookingUrl: 'https://www.booking.com/hotel/pt/porta-do-sol-caminha.html?aid=7968251',
  },

  // ── VILA PRAIA DE ÂNCORA ───────────────────────────────────────────────────────
  {
    name: 'BLUE ANCORA HOTEL',
    zone: 'vpa',
    category: 'hotel',
    type: 'Hotel',
    address: 'Vila Praia de Âncora (3 min walk from beach)',
    positioning: 'Coastal, 3-minute walk from Vila Praia de Âncora beach',
    differentiators: ['Seasonal outdoor pool', 'Sea-view rooms with balconies'],
    bookingUrl: 'https://www.booking.com/hotel/pt/blue-ancora.html?aid=7968251',
  },
  {
    name: 'Hotel Meira',
    zone: 'vpa',
    category: 'hotel',
    type: 'Hotel — 4 Star',
    address: 'Vila Praia de Âncora (2 min walk from beach)',
    positioning: 'Near beach, wind-protected valley',
    differentiators: ['Swimming pool', 'Breakfast buffet included'],
    bookingUrl: 'https://www.booking.com/hotel/pt/hotelmeiravilapraiaancora.html?aid=7968251',
  },

  // ── SEIXAS ─────────────────────────────────────────────────────────────────────
  {
    name: 'Albergue de São Bento',
    zone: 'seixas',
    category: 'albergue',
    type: 'Pilgrim Hostel',
    address: 'Seixas, Caminha (near Pedras Ruivas Beach)',
    positioning: 'Beachfront in Seixas parish, 1 km from Pedras Ruivas Beach',
    differentiators: ['Beachfront setting', 'Pilgrim dinners available; shared kitchen'],
    bookingUrl: 'https://www.booking.com/hotel/pt/albergue-de-sao-bento.html?aid=7968251',
  },
  {
    name: 'Rinoterra Minho',
    zone: 'seixas',
    category: 'hotel',
    type: 'Country Hotel',
    address: 'Rua da Costa 15, Seixas, Caminha',
    positioning: 'Rural, Seixas parish, river and mountain views',
    differentiators: ['Spa and wellness centre', 'Tennis; Portuguese restaurant on site'],
    bookingUrl: 'https://www.booking.com/hotel/pt/rinoterra-minho.html?aid=7968251',
  },
];

const zones: { key: Zone; label: string; intro: string }[] = [
  {
    key: 'caminha',
    label: 'Caminha',
    intro: 'The main crossing town on the Portuguese Coastal Route — last stage before the Minho river crossing into Galicia. Albergues, guesthouses, and hotels are all within walking distance of the ferry dock.',
  },
  {
    key: 'vpa',
    label: 'Vila Praia de Âncora',
    intro: 'Coastal town 7 km south of Caminha on the Camino route. Beach hotels with pools, a quieter alternative to Caminha for pilgrims who prefer to arrive early and continue north the following morning.',
  },
  {
    key: 'seixas',
    label: 'Seixas',
    intro: 'The parish immediately south of Caminha town, on the Camino Coastal waymarked path. Low density — one pilgrim hostel and one country hotel, both bookable on Booking.com.',
  },
];

const categoryOrder: Category[] = ['albergue', 'guesthouse', 'hotel'];
const categoryLabel: Record<Category, string> = {
  albergue: 'Albergues',
  guesthouse: 'Guesthouses',
  hotel: 'Hotels',
};
---

<MainLayout
  title="Where to Stay in Caminha, Vila Praia de Âncora & Seixas | Caminho de Santiago"
  description="Verified accommodation guide for Camino de Santiago Coastal Route pilgrims. Albergues, guesthouses, and hotels in Caminha, Vila Praia de Âncora, and Seixas — all bookable on Booking.com."
  lang="en"
  schemaType="webpage"
>

  <!-- ── PAGE HEADER ──────────────────────────────────────────────────────────── -->
  <div class="bg-gradient-to-b from-forest-50 to-white border-b border-forest-100/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <nav aria-label="Breadcrumb" class="mb-5">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/en/" class="hover:text-forest-700 no-underline hover:underline transition-colors">Home</a></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li><span class="text-slate-400">Caminha</span></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li aria-current="page" class="text-slate-700 font-medium">Where to Stay</li>
        </ol>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold text-forest-900 mb-4 tracking-tight">Where to Stay</h1>
      <p class="text-slate-600 max-w-2xl text-base leading-relaxed">
        Verified accommodation across three zones on the Portuguese Coastal Camino: Caminha (river crossing town), Vila Praia de Âncora (coastal, 7 km south), and Seixas (on-route parish south of Caminha). All hotels link directly to Booking.com.
      </p>
      <div class="mt-6 flex flex-wrap gap-2.5">
        {zones.map((z) => (
          <a href={`#zone-${z.key}`} class="inline-flex items-center gap-1.5 bg-white border border-forest-200 text-forest-800 text-xs font-medium px-3.5 py-2 rounded-full hover:bg-forest-50 hover:border-forest-300 no-underline transition-all duration-200 shadow-sm cursor-pointer">
            {z.label}
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- ── ADSENSE SLOT 1 ──────────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="my-6">
      <ins class="adsbygoogle w-full"
           style="display:block"
           data-ad-client="ca-pub-6529337148344504"
           data-ad-slot="2297179243"
           data-ad-format="auto"
           data-full-width-responsive="true"></ins>
    </div>
  </div>
  <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>

  <!-- ── PEAK SEASON CALLOUT ─────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-4">
    <div class="bg-amber-50 border border-amber-300/70 rounded-2xl p-6 shadow-sm">
      <div class="flex gap-4">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-amber-100 border border-amber-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
        </div>
        <div>
          <h2 class="font-bold text-amber-900 mb-2 text-base">Book Ahead: May–October Peak Season</h2>
          <p class="text-sm text-amber-800 leading-relaxed">
            The Coastal Route peaks between May and October. The municipal albergue in Caminha operates walk-in only and fills quickly on summer afternoons. Private albergues and hotels are bookable in advance — use the links below to check availability.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- ── ZONE SECTIONS ──────────────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 space-y-20">

    {zones.map((zone, zoneIdx) => {
      const zoneItems = accommodations.filter(a => a.zone === zone.key);
      return (
        <section id={`zone-${zone.key}`} aria-labelledby={`heading-zone-${zone.key}`}>
          <div class="mb-8 pb-4 border-b border-slate-200">
            <h2 id={`heading-zone-${zone.key}`} class="text-2xl font-bold text-forest-900 tracking-tight mb-1">
              {zone.label}
            </h2>
            <p class="text-slate-600 text-sm leading-relaxed max-w-2xl">{zone.intro}</p>
          </div>

          {categoryOrder.map((cat) => {
            const catItems = zoneItems.filter(a => a.category === cat);
            if (catItems.length === 0) return null;
            return (
              <div class="mb-10">
                <h3 class="text-base font-semibold text-slate-500 uppercase tracking-widest mb-5">{categoryLabel[cat]}</h3>
                <div class="grid grid-cols-1 gap-5">
                  {catItems.map((a) => (
                    <article class="bg-white rounded-2xl border border-slate-200/80 overflow-hidden hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 shadow-sm">
                      <div class="p-6 sm:p-8">
                        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-4">
                          <div>
                            <h4 class="text-xl font-bold text-forest-900 tracking-tight mb-0.5">{a.name}</h4>
                            <p class="text-sm text-slate-500 font-medium">{a.type}</p>
                          </div>
                        </div>

                        <div class="flex flex-wrap gap-2 mb-4">
                          {a.differentiators.map((d) => (
                            <span class="text-xs bg-forest-50 text-forest-700 px-3 py-1.5 rounded-full border border-forest-100 font-medium">{d}</span>
                          ))}
                        </div>

                        {a.note && (
                          <div class="bg-amber-50 border border-amber-200/70 rounded-xl px-4 py-3 mb-5 flex gap-2.5 text-xs text-amber-800">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-amber-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            <span>{a.note}</span>
                          </div>
                        )}

                        <div class="pt-4 border-t border-slate-100 flex flex-col sm:flex-row sm:items-center gap-4">
                          <div class="flex items-center gap-1.5 text-sm text-slate-500 flex-1">
                            <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                            {a.address}
                          </div>

                          {a.bookingUrl ? (
                            <a
                              href={a.bookingUrl}
                              rel="nofollow noopener noreferrer sponsored"
                              target="_blank"
                              class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-earth-500 to-earth-600 hover:from-earth-600 hover:to-earth-700 active:scale-[0.98] text-white font-bold text-sm px-6 py-3.5 rounded-xl transition-all duration-200 no-underline shrink-0 shadow-md hover:shadow-lg cursor-pointer group"
                            >
                              Check Availability &amp; Prices
                              <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                              </svg>
                            </a>
                          ) : (
                            <span class="inline-flex items-center gap-2 bg-slate-100 text-slate-500 font-semibold text-sm px-5 py-3 rounded-xl shrink-0">
                              Walk-in only
                            </span>
                          )}
                        </div>
                      </div>
                    </article>
                  ))}
                </div>
              </div>
            );
          })}

          {zoneIdx === 0 && (
            <div class="mt-6">
              <ins class="adsbygoogle w-full"
                   style="display:block"
                   data-ad-client="ca-pub-6529337148344504"
                   data-ad-slot="8017929699"
                   data-ad-format="auto"
                   data-full-width-responsive="true"></ins>
            </div>
          )}
        </section>
      );
    })}
  </div>
  <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>

  <!-- ── BOOKING TIP ─────────────────────────────────────────────────────────── -->
  <aside class="bg-gradient-to-b from-forest-50 to-white border-y border-forest-100/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <div class="flex gap-4">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-forest-100 border border-forest-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-forest-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
        </div>
        <div>
          <h2 class="text-lg font-bold text-forest-900 mb-2 tracking-tight">Municipal Albergue vs. Private Hostels</h2>
          <p class="text-slate-700 text-sm leading-relaxed max-w-2xl">
            The municipal albergue is walk-in only from 14:00 and requires a valid <em>credencial do peregrino</em>. Both private albergues listed above (Albergue Santiago and Bom Caminha) are bookable in advance on Booking.com and do not require a credential — useful for late arrivals or pilgrims who have not yet started their credencial. The ferry and logistics page covers the crossing from Caminha to A Guarda: see <a href="/en/caminha/ferry-and-logistics/" class="text-forest-700 hover:underline no-underline font-medium">ferry schedule and logistics</a>.
          </p>
        </div>
      </div>
    </div>
  </aside>

</MainLayout>
