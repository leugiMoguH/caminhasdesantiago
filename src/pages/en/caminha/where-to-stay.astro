---
import MainLayout from '../../../layouts/MainLayout.astro';

const accommodation = [
  // ── ALBERGUES ────────────────────────────────────────────────────────────────
  {
    name: 'Albergue Municipal de Peregrinos de Caminha',
    type: 'Municipal Pilgrim Hostel',
    category: 'hostel',
    address: 'Rua Ricardo Joaquim de Sousa, Caminha',
    priceFrom: '€12',
    credential: true,
    beds: 28,
    phone: '+351 258 921 130',
    hours: 'Check-in from 14:00 · Check-out by 09:00',
    description: 'The official municipal albergue, managed by the local parish. Priority is given to pilgrims with a valid credencial do peregrino. Dormitory-style bunks with individual lockers, shared bathrooms, and a communal kitchen. The hospitalero (volunteer warden) can stamp your credential and advise on the next day\'s stage to A Guarda. In July and August, arrive by 13:30 to join the queue — the 28 beds are gone within an hour of opening.',
    amenities: ['Credential stamp', 'Communal kitchen', 'Luggage storage', 'Washing machines', 'Outdoor drying area', 'Wi-Fi'],
    notes: 'Pilgrim credential required. No private rooms. Maximum 2 consecutive nights. No online reservations — first-come, first-served only.',
    bookingUrl: null,
  },

  // ── GUESTHOUSES ──────────────────────────────────────────────────────────────
  {
    name: 'Casa de Santiago',
    type: 'Pilgrim Guesthouse',
    category: 'guesthouse',
    address: 'Rua da Corredoura 22, Caminha',
    priceFrom: '€25',
    credential: false,
    beds: null,
    phone: '+351 919 234 567',
    hours: 'Flexible check-in · Check-out by 11:00',
    description: 'A warmly run family guesthouse two blocks from the main square, very popular with Camino pilgrims doing the Coastal Route. Clean private rooms with en-suite bathrooms, a generous continental breakfast included, and hosts who are genuine Camino enthusiasts — they\'ve walked it themselves and know every silt-season ferry closure by heart. Some rooms have views over the castle tower. The owners are flexible about early drop-off of bags before you check in.',
    amenities: ['Breakfast included', 'En-suite bathrooms', 'Luggage transfer (ask in advance)', 'Credential stamp', 'Camino advice from hosts', 'Wi-Fi'],
    notes: 'Pilgrim discounts available — ask when booking. Cash or bank transfer preferred.',
    bookingUrl: 'https://www.booking.com/city/pt/caminha.html?aid=7968251',
  },
  {
    name: 'Pensão Galo d\'Ouro',
    type: 'Budget Guesthouse',
    category: 'guesthouse',
    address: 'Praça do Conselho 15, Caminha',
    priceFrom: '€35',
    credential: false,
    beds: null,
    phone: '+351 258 921 160',
    hours: 'Reception 08:00–22:00 · Flexible on request',
    description: 'Right on the main square, this old-fashioned pension offers unbeatable location at a mid-range price. Rooms are simple but very clean; several overlook the medieval granite fountain and the 16th-century Torre do Relógio. The downstairs café opens at 7:30 AM — ideal for an early-morning coffee before heading to the Cais for the first ferry. Best value private room in Caminha for the location.',
    amenities: ['Central location', 'Café/bar on-site', 'Breakfast available (not included)', 'Wi-Fi'],
    notes: 'Top-floor rooms require stair climbing — note if you have heavy packs or knee issues.',
    bookingUrl: 'https://www.booking.com/city/pt/caminha.html?aid=7968251',
  },
  {
    name: 'Parque de Campismo de Caminha',
    type: 'Camping Site',
    category: 'guesthouse',
    address: 'Mata Nacional, Caminha (1.2 km from town centre)',
    priceFrom: '€7',
    credential: false,
    beds: null,
    phone: '+351 258 921 295',
    hours: 'Reception 08:00–21:00',
    description: 'A well-maintained campsite within a national forest park on the outskirts of Caminha, close to the Atlantic beach. Facilities include tent and campervan pitches, a shared kitchen, hot showers, and a small shop. The cheapest overnight option in the area and perfectly pleasant for self-sufficient pilgrims with lightweight gear. One practical caution: the 1.2 km walk into town adds time before an early ferry departure — plan your morning accordingly.',
    amenities: ['Tent pitches', 'Hot showers', 'Shared kitchen', 'Small shop', 'Beach access (300m)', 'Bike racks'],
    notes: 'Open year-round. Pilgrim discount with credencial. The walk to the ferry dock adds approximately 1.5 km to your morning.',
    bookingUrl: 'https://www.booking.com/city/pt/caminha.html?aid=7968251',
  },

  // ── ADDITIONAL HOSTELS ────────────────────────────────────────────────────────
  {
    name: 'Pousada de Juventude de Caminha',
    type: 'Youth Hostel — Movijovem Network · Open to All Ages',
    category: 'hostel',
    address: 'Rua Visconde Sousa Rego, Caminha (near the waterfront)',
    priceFrom: '€15',
    credential: false,
    beds: 40,
    phone: '+351 707 203 030',
    hours: 'Reception 09:00–12:00 · 18:00–23:00 · Flexible for pilgrims in peak season',
    description: 'Part of the Movijovem national network of Portuguese youth hostels, Caminha\'s Pousada de Juventude welcomes pilgrims and travellers of all ages year-round. Unlike the municipal albergue, no pilgrim credential is required and online reservation is available through the Movijovem portal (+351 707 203 030) and major booking platforms. Facilities include gender-separated dormitories, a limited number of basic private rooms, shared kitchen, laundry, and a communal lounge. Situated near the riverfront, approximately 10 minutes on foot from the main square and 12 minutes from the Cais ferry dock. A practical option for non-pilgrim companions, late arrivals who missed the municipal albergue, or pilgrims who misplaced or have not yet obtained their credencial.',
    amenities: ['Online booking available', 'No credential required', 'Shared kitchen', 'Laundry', 'Common room', 'Private rooms available', 'Wi-Fi'],
    notes: 'Book ahead in July–August — the Movijovem network fills across northern Portugal in peak Camino season. Pilgrim credential stamp can be arranged informally — ask at reception.',
    bookingUrl: 'https://www.booking.com/city/pt/caminha.html?aid=7968251',
  },

  // ── ADDITIONAL GUESTHOUSES ────────────────────────────────────────────────────
  {
    name: 'Quinta do Deão — Turismo Rural',
    type: 'Rural Farmhouse Stay · Turismo de Habitação',
    category: 'guesthouse',
    address: 'Lugar de Vilar, Caminha (2.2 km from town centre, on the Camino waymarked path)',
    priceFrom: '€50',
    credential: false,
    beds: null,
    phone: '+351 258 722 190',
    hours: 'Flexible check-in · Check-out by 11:00',
    description: 'A traditional Minho stone farmhouse registered under Portugal\'s "Turismo de Habitação" scheme — the licensed rural accommodation category that combines authentic country character with home-hosted hospitality. Private rooms with en-suite bathrooms open onto a granite courtyard garden and small vineyard, with views across the Minho valley toward the Serra de Arga hills. The property lies directly on the Camino Coastal Route waymarked path between Moledo and Caminha — pilgrims can pick up or rejoin the yellow arrows from the gate without a detour. The owners are long-term Minho valley residents with deep knowledge of the Camino stages, the seasonal behaviour of the Minho estuary, and which water taxi operators are currently active. Continental breakfast with regional honey, local cheese, fresh bread, and homemade jams is included. Plan your morning carefully: the 2.2 km walk to the Cais ferry dock takes approximately 25–30 minutes — leave by 08:30 at the latest to catch the 09:00 departure.',
    amenities: ['Breakfast included', 'En-suite bathrooms', 'Camino waymarks from gate', 'Vineyard garden', 'Minho valley views', 'Local Camino expertise', 'Wi-Fi', 'Packed lunch on request'],
    notes: 'The walk into Caminha is along the Camino waymarked track — the 2.2 km is walked on-route, not as a detour. Book direct or via Booking.com. Cash and bank transfer preferred. Luggage storage before check-in available.',
    bookingUrl: 'https://www.booking.com/city/pt/caminha.html?aid=7968251',
  },

  // ── PREMIUM HOTELS ────────────────────────────────────────────────────────────
  {
    name: 'Design Wine Hotel',
    type: 'Boutique Wine Hotel',
    category: 'hotel',
    address: 'Rua Visconde Sousa Rego 20, Caminha',
    priceFrom: '€89',
    credential: false,
    beds: null,
    phone: '+351 258 922 500',
    hours: 'Check-in from 15:00 · Check-out by 12:00',
    description: 'The most stylish accommodation in Caminha, this boutique hotel celebrates the Minho\'s wine culture through architecture, art, and a curated cellar of local Vinho Verde producers. Contemporary rooms feature rainfall showers, premium linens, and artisanal toiletries. The rooftop terrace offers panoramic views toward the Spanish bank of the Minho — perfect for a restorative glass of Alvarinho after a long coastal stage. A wine bar on the ground floor serves charcuterie boards and paired flights nightly. Credential stamps available on request. Luggage transfer to A Guarda can be arranged.',
    amenities: ['Wine bar & cellar', 'Rooftop terrace with river views', 'Air conditioning', 'Rainfall shower', 'Luggage transfer to A Guarda (on request)', 'Credential stamp', 'Breakfast available (+€12)', 'Secure bike storage', 'Wi-Fi'],
    notes: 'Not pilgrim-focused but warmly pilgrim-friendly. Fills fast in July–August; book at least 3 weeks ahead for peak season.',
    bookingUrl: 'https://www.booking.com/city/pt/caminha.html?aid=7968251',
  },
];

const sections: { key: string; label: string; intro: string }[] = [
  {
    key: 'hostel',
    label: 'Albergues — Pilgrim Hostels',
    intro: 'Official pilgrim hostels (albergues) are the backbone of the Camino de Santiago experience. They operate on a pilgrim-credential system, keep prices at €10–€15, and create the nightly camaraderie that defines the walk. Caminha\'s municipal albergue sits minutes from the ferry dock.',
  },
  {
    key: 'guesthouse',
    label: 'Local Guesthouses & Camping',
    intro: 'Guesthouses (pensões and casas de hóspedes) offer private rooms without the pilgrim-hostel rules — no curfew, no credential requirement, flexible check-in. Prices from €25 per room. Ideal for pilgrims who value privacy or need to rest an extra day.',
  },
  {
    key: 'hotel',
    label: 'Premium Hotels',
    intro: 'For the pilgrim who wants full comfort at the end of a hard stage, Caminha\'s premium hotel options deliver beds, baths, and a glass of Vinho Verde that make the aches worthwhile. Book well ahead: peak season (June–September) sees high demand from Camino walkers and Minho Valley wine tourists alike.',
  },
];
---

<MainLayout
  title="Where to Stay in Caminha — Albergues, Guesthouses & Hotels | Caminho de Santiago"
  description="Complete guide to accommodation in Caminha for Camino de Santiago Coastal Route pilgrims. Municipal albergue from €12, pilgrim guesthouses from €25, boutique hotel from €89. Peak-season booking advice included."
  lang="en"
  schemaType="webpage"
>

  <!-- ── PAGE HEADER ──────────────────────────────────────────────────────────── -->
  <div class="bg-gradient-to-b from-forest-50 to-white border-b border-forest-100/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <nav aria-label="Breadcrumb" class="mb-5">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/en/" class="hover:text-forest-700 no-underline hover:underline transition-colors">Home</a></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li><span class="text-slate-400">Caminha</span></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li aria-current="page" class="text-slate-700 font-medium">Where to Stay</li>
        </ol>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold text-forest-900 mb-4 tracking-tight">Where to Stay in Caminha</h1>
      <p class="text-slate-600 max-w-2xl text-base leading-relaxed">
        Caminha sits at the Portuguese end of the Minho river crossing — the last stage before pilgrims on the Coastal Route enter Galicia. Whether you need a €12 bunk in a municipal albergue or a €89 boutique hotel with a rooftop wine bar, you'll find it here.
      </p>
      <!-- Section jump links -->
      <div class="mt-6 flex flex-wrap gap-2.5">
        {sections.map((s) => (
          <a href={`#${s.key}`} class="inline-flex items-center gap-1.5 bg-white border border-forest-200 text-forest-800 text-xs font-medium px-3.5 py-2 rounded-full hover:bg-forest-50 hover:border-forest-300 no-underline transition-all duration-200 shadow-sm cursor-pointer">
            {s.label.split('—')[0].trim()}
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- ── ADSENSE SLOT 1 ──────────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="my-6 adsense-placeholder">
      <ins class="adsbygoogle w-full"
           style="display:block"
           data-ad-client="ca-pub-6529337148344504"
           data-ad-slot="2297179243"
           data-ad-format="auto"
           data-full-width-responsive="true"></ins>
    </div>
  </div>
  <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>

  <!-- ── PEAK SEASON CALLOUT ─────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-4">
    <div class="bg-gradient-to-br from-amber-50 to-earth-50 border border-amber-300/70 rounded-2xl p-6 shadow-sm">
      <div class="flex gap-4">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-earth-100 border border-earth-200">
          <!-- Calendar SVG icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-earth-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
        </div>
        <div>
          <h2 class="font-bold text-amber-900 mb-2 text-base">Book Ahead: Peak Season May–October</h2>
          <p class="text-sm text-amber-800 leading-relaxed">
            The Camino de Santiago Coastal Route peaks between <strong>May and October</strong>. Caminha is the last Portuguese town before the Minho crossing — every Coastal Way pilgrim passes through. The municipal albergue's 28 beds fill by 14:30 in high summer. Private guesthouses sell out days ahead during Semana Santa and July–August.
          </p>
          <p class="text-sm text-amber-800 leading-relaxed mt-2">
            <strong>Practical rule:</strong> June–September, book guesthouses and hotels 5–7 days ahead. For the albergue, aim to arrive before the 13:00 ferry — the hospitalero opens at 14:00 and beds go immediately.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- ── ACCOMMODATION SECTIONS ─────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 space-y-16">

    {sections.map((section, sectionIdx) => {
      const sectionItems = accommodation.filter(a => a.category === section.key);
      return (
        <section id={section.key} aria-labelledby={`heading-${section.key}`}>
          <div class="mb-8">
            <h2 id={`heading-${section.key}`} class="text-2xl font-bold text-forest-900 tracking-tight">
              {section.label}
            </h2>
            <p class="mt-2 text-slate-600 text-sm leading-relaxed max-w-2xl">{section.intro}</p>
          </div>

          <div class="grid grid-cols-1 gap-6">
            {sectionItems.map((a) => (
              <article class="bg-white rounded-2xl border border-slate-200/80 overflow-hidden hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 shadow-sm">
                <div class="p-6 sm:p-8">
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-5">
                    <div>
                      <div class="flex flex-wrap items-center gap-2 mb-1.5">
                        <h3 class="text-xl font-bold text-forest-900 tracking-tight">{a.name}</h3>
                        {a.credential && (
                          <span class="inline-flex items-center gap-1 text-xs font-semibold bg-earth-100 text-earth-800 px-2.5 py-1 rounded-full border border-earth-200">
                            <!-- Credential checkmark -->
                            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            Credencial required
                          </span>
                        )}
                      </div>
                      <p class="text-sm text-slate-500 font-medium">{a.type}</p>
                    </div>
                    <div class="shrink-0 text-right">
                      <p class="text-xl font-bold text-forest-700">From {a.priceFrom}</p>
                      {a.beds && <p class="text-xs text-slate-400 mt-0.5">{a.beds} beds total</p>}
                    </div>
                  </div>

                  <p class="text-slate-700 leading-relaxed mb-6 text-sm sm:text-base">{a.description}</p>

                  <div class="mb-6">
                    <h4 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-3">Facilities</h4>
                    <ul class="flex flex-wrap gap-2">
                      {a.amenities.map((amenity) => (
                        <li class="text-xs bg-forest-50 text-forest-700 px-3 py-1.5 rounded-full border border-forest-100 font-medium">
                          {amenity}
                        </li>
                      ))}
                    </ul>
                  </div>

                  {a.notes && (
                    <div class="bg-earth-50 border border-earth-200/70 rounded-xl px-4 py-3 mb-6 flex gap-2.5 text-xs text-earth-800">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-earth-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                      <span><strong>Note:</strong> {a.notes}</span>
                    </div>
                  )}

                  <div class="pt-5 border-t border-slate-100 flex flex-col sm:flex-row sm:items-center gap-4">
                    <div class="flex flex-col sm:flex-row gap-3 text-sm text-slate-500 flex-1 flex-wrap">
                      <span class="flex items-center gap-1.5">
                        <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        {a.address}
                      </span>
                      <span class="flex items-center gap-1.5">
                        <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        {a.hours}
                      </span>
                      <a href={`tel:${a.phone}`} class="flex items-center gap-1.5 no-underline hover:text-forest-700 transition-colors cursor-pointer">
                        <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                        {a.phone}
                      </a>
                    </div>

                    {a.bookingUrl && (
                      <a
                        href={a.bookingUrl}
                        rel="nofollow noopener noreferrer sponsored"
                        target="_blank"
                        class="inline-flex items-center justify-center gap-2 bg-earth-500 hover:bg-earth-600 active:bg-earth-700 text-white font-semibold text-sm px-6 py-3 rounded-xl transition-all duration-200 no-underline shrink-0 shadow-sm hover:shadow-md cursor-pointer group"
                      >
                        Check Availability
                        <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                        </svg>
                      </a>
                    )}
                  </div>
                </div>
              </article>
            ))}
          </div>

          {/* AdSense slot 2 — between Albergues and Guesthouses */}
          {sectionIdx === 0 && (
            <div class="mt-10 adsense-placeholder">
              <ins class="adsbygoogle w-full"
                   style="display:block"
                   data-ad-client="ca-pub-6529337148344504"
                   data-ad-slot="8017929699"
                   data-ad-format="auto"
                   data-full-width-responsive="true"></ins>
            </div>
          )}
        </section>
      );
    })}
  </div>
  <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>

  <!-- ── PILGRIM SUPPORT SHOPS ─────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-12">
    <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
      <div class="bg-gradient-to-r from-slate-800 to-forest-900 px-6 py-5">
        <h2 class="text-lg font-bold text-white tracking-tight flex items-center gap-2.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-earth-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
          Pilgrim Supplies in Caminha Town Centre
        </h2>
        <p class="text-slate-300 text-sm mt-1">Essential shops within walking distance of the main square for pilgrims needing to resupply before or after the Minho crossing.</p>
      </div>
      <div class="p-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">

        <div class="bg-forest-50 border border-forest-100 rounded-xl p-4">
          <div class="flex items-center gap-2 mb-2">
            <div class="h-7 w-7 rounded-lg bg-forest-700 flex items-center justify-center shrink-0">
              <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            </div>
            <p class="font-bold text-forest-900 text-sm">Pingo Doce</p>
          </div>
          <p class="text-xs text-slate-600 leading-relaxed">Full supermarket — fresh fruit, deli counter, bread, sports drinks, trail food. Best resupply in town for self-catering pilgrims.</p>
          <p class="text-xs text-slate-500 mt-2 font-medium">Rua 5 de Outubro, Caminha · ~350m from main square</p>
          <p class="text-xs text-slate-400 mt-0.5">Mon–Sat 08:00–21:00 · Sun 09:00–19:00</p>
        </div>

        <div class="bg-slate-50 border border-slate-100 rounded-xl p-4">
          <div class="flex items-center gap-2 mb-2">
            <div class="h-7 w-7 rounded-lg bg-slate-700 flex items-center justify-center shrink-0">
              <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            </div>
            <p class="font-bold text-slate-800 text-sm">Lidl Caminha</p>
          </div>
          <p class="text-xs text-slate-600 leading-relaxed">Discount supermarket on the town outskirts. Good for bulk trail food, budget sunscreen, basic first aid, and energy bars at lower prices than central shops.</p>
          <p class="text-xs text-slate-500 mt-2 font-medium">EN-301, outskirts · ~1.1 km from main square</p>
