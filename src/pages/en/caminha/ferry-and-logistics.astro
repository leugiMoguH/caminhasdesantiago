const faqItems = [
  {
    question: 'How much does the Caminha to A Guarda ferry cost?',
    answer: 'The ferry from Caminha to A Guarda costs €2.50 per adult one-way. A return ticket is €5.00. Bicycles incur an additional €1.50 charge on top of the passenger fare. Children under 4 travel free; children 4–12 pay €1.50.',
  },
  {
    question: 'What are the ferry times from Caminha to A Guarda?',
    answer: 'In summer (April–October), the ferry runs approximately every 30–60 minutes from 09:00 to 19:00, daily in both directions. In winter (November–March), service is reduced to weekends and public holidays only, with departures around 10:00, 12:00, and 16:00. Always verify current times directly with the ferry operator before your crossing.',
  },
  {
    question: 'What is the assoreamento problem with the Caminha ferry?',
    answer: 'The Minho river estuary periodically suffers from assoreamento (siltation) — the gradual build-up of sand and sediment at the river mouth. When siltation is severe, the Santa Rita de Cássia ferry boat cannot approach the standard dock, causing service suspensions that can last days or weeks. When this happens, pilgrims can use Xávegas water taxis (€5–6 per person) or take the overland train to Valença and walk across the Tui bridge.',
  },
  {
    question: 'What are the alternatives if the Caminha ferry is not running?',
    answer: 'Two main alternatives exist: (1) Xávegas or taxi-marítimo: smaller water taxis operated by local fishermen, able to cross in shallower water. Rate approximately €5–6 per person. Contact the Caminha tourist office (+351 258 921 952) for current operator contacts. (2) Overland via Valença–Tui: take the CP Minho line train from Caminha to Valença (~35 minutes, ~€3.60), then walk 1.5 km across the international Tui–Valença bridge.',
  },
  {
    question: 'How do I get from Caminha to A Guarda by train?',
    answer: 'There is no direct train from Caminha to A Guarda. The overland alternative is: take the CP Minho line train from Caminha to Valença (~35 minutes, ~€3.60 one-way). From Valença station, walk to the Tui–Valença international bridge (approx 1 km) and cross on foot into Tui, Spain (~25 minutes walk). From Tui, follow the Camino Portugués Interior waymarks. Note: this route changes you from the Coastal Route to the Interior Route.',
  },
];
---

<MainLayout
  title="Caminha to A Guarda Ferry — Schedule, Alternatives & Siltation Warnings"
  description="Complete guide to the Caminha–A Guarda Minho river crossing. Summer/winter timetables, fare table, the real story on seasonal siltation (assoreamento), Xávegas water taxi alternatives, and the overland train detour via Valença–Tui."
  lang="en"
  schemaType="webpage"
>

  <!-- JSON-LD: FAQPage + TouristAttraction schema -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "TouristAttraction",
        "@id": "https://waytosantiagoguide.com/en/caminha/ferry-and-logistics/#ferry",
        "name": "Caminha to A Guarda Ferry Crossing — Minho River",
        "description": "The Caminha–A Guarda ferry crosses the Minho River, connecting Portugal and Spain on the Camino de Santiago Coastal Route. The crossing takes approximately 15 minutes. Operated seasonally (April–October daily service). Fare: €2.50 per adult one-way. Departure point: Cais de Caminha, 4910 Caminha, Portugal.",
        "url": "https://waytosantiagoguide.com/en/caminha/ferry-and-logistics/",
        "touristType": "Pilgrim",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Cais de Caminha",
          "addressLocality": "Caminha",
          "postalCode": "4910",
          "addressCountry": "PT"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 41.8734,
          "longitude": -8.8358
        },
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
            "opens": "09:00",
            "closes": "19:15",
            "validFrom": "2026-04-01",
            "validThrough": "2026-10-31"
          }
        ]
      },
      {
        "@type": "FAQPage",
        "@id": "https://waytosantiagoguide.com/en/caminha/ferry-and-logistics/#faq",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "How much does the Caminha to A Guarda ferry cost?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "The ferry from Caminha to A Guarda costs €2.50 per adult one-way. A return ticket is €5.00. Bicycles incur an additional €1.50 charge on top of the passenger fare. Children under 4 travel free; children 4–12 pay €1.50."
            }
          },
          {
            "@type": "Question",
            "name": "What are the ferry times from Caminha to A Guarda?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "In summer (April–October), the ferry runs approximately every 30–60 minutes from 09:00 to 19:00, daily in both directions between Caminha and A Guarda. In winter (November–March), service is reduced to weekends and public holidays only, with departures around 10:00, 12:00, and 16:00. Always verify current times directly with the ferry operator before your crossing."
            }
          },
          {
            "@type": "Question",
            "name": "What is the assoreamento problem with the Caminha ferry?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "The Minho river estuary periodically suffers from assoreamento (siltation) — the gradual build-up of sand and sediment at the river mouth. When siltation is severe, the Santa Rita de Cássia ferry boat cannot approach the standard dock, causing service suspensions that can last days or weeks. This typically occurs after dry periods (low river flow) or following major Atlantic storms that shift the estuary sandbanks. When this happens, pilgrims can use Xávegas water taxis (smaller flat-bottomed boats, €5–6 per person) or take the overland train to Valença and walk across the Tui bridge."
            }
          },
          {
            "@type": "Question",
            "name": "What are the alternatives if the Caminha ferry is not running?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Two main alternatives exist when the standard ferry is suspended: (1) Xávegas or taxi-marítimo: smaller water taxis operated by local fishermen, able to cross in shallower water. Rate approximately €5–6 per person. Contact the Caminha tourist office (+351 258 921 952) for current operator contacts. (2) Overland via Valença–Tui: take the CP Minho line train from Caminha to Valença (~35 minutes, ~€3.60), then walk 1.5 km across the international Tui–Valença bridge. This connects you to the Portuguese Interior Camino route."
            }
          },
          {
            "@type": "Question",
            "name": "How do I get from Caminha to A Guarda by train?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "There is no direct train from Caminha to A Guarda. The overland alternative is: take the CP Minho line train from Caminha to Valença (~35 minutes, ~€3.60 one-way). From Valença station, walk to the Tui–Valença international bridge (approx 1 km) and cross on foot into Tui, Spain (~25 minutes walk). From Tui, follow the Camino Portugués Interior waymarks, or take a taxi to A Guarda (approx 30 km by road). Note: this route changes you from the Coastal Route to the Interior Route."
            }
          }
        ]
      },
      {
        "@type": "SpecialAnnouncement",
        "@id": "https://waytosantiagoguide.com/en/caminha/ferry-and-logistics/#siltation-warning",
        "name": "Caminha–A Guarda Ferry: Seasonal Siltation (Assoreamento) Disruption Risk",
        "text": "The Caminha–A Guarda ferry (Santa Rita de Cássia) is subject to recurring seasonal assoreamento (river mouth siltation) that can suspend service without advance notice, including during peak pilgrim season (April–October). When the service is suspended, alternatives include Xávegas water taxis (€5–6 per person) operated by local fishermen, or the overland train from Caminha to Valença then walking across the Tui–Valença bridge. Pilgrims should verify crossing status the evening before departure.",
        "datePosted": "2026-01-01",
        "url": "https://waytosantiagoguide.com/en/caminha/ferry-and-logistics/#assoreamento",
        "spatialCoverage": {
          "@type": "Place",
          "name": "Caminha, Portugal",
          "geo": { "@type": "GeoCoordinates", "latitude": 41.8734, "longitude": -8.8358 }
        }
      }
    ]
  }
  </script>

  <!-- ── HERO HEADER ──────────────────────────────────────────────────────────── -->
  <div class="bg-gradient-to-br from-slate-800 via-slate-800 to-forest-950 text-white">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <nav aria-label="Breadcrumb" class="mb-5">
        <ol class="flex items-center gap-2 text-sm text-slate-400">
          <li><a href="/en/" class="hover:text-white no-underline hover:underline transition-colors">Home</a></li>
          <li aria-hidden="true" class="text-slate-600">›</li>
          <li><a href="/en/caminha-guide/" class="hover:text-white no-underline hover:underline transition-colors text-slate-500 hover:text-white">Caminha</a></li>
          <li aria-hidden="true" class="text-slate-600">›</li>
          <li aria-current="page" class="text-slate-200 font-medium">Ferry &amp; Logistics</li>
        </ol>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold mb-4 text-white tracking-tight">Caminha → A Guarda: Ferry, Siltation &amp; Alternatives</h1>
      <p class="text-slate-300 max-w-2xl text-base leading-relaxed">
        The Minho river crossing between Caminha (Portugal) and A Guarda (Spain) is one of the most memorable moments on the Coastal Route — and one of the most unpredictable. A 15-minute ferry ride in normal conditions; a full-day logistics problem when the estuary silts up.
      </p>

      <!-- Key facts strip with SVG icons -->
      <div class="mt-8 grid grid-cols-2 sm:grid-cols-4 gap-4">
        {[
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
            value: '~15 min',
            label: 'Crossing time',
          },
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`,
            value: '€2.50',
            label: 'One-way fare',
          },
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
            value: 'Apr–Oct',
            label: 'Daily service',
          },
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
            value: 'Cais de Caminha',
            label: 'Departure point',
          },
        ].map(({ icon, value, label }) => (
          <div class="bg-white/10 backdrop-blur-sm border border-white/10 rounded-2xl p-4 text-center hover:bg-white/15 transition-colors">
            <div class="flex justify-center mb-2 text-earth-400" aria-hidden="true" set:html={icon} />
            <div class="text-lg font-bold text-white">{value}</div>
            <div class="text-xs text-slate-400 mt-0.5">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

      <!-- ── MAIN CONTENT ────────────────────────────────────────────────────────── -->
      <div class="lg:col-span-2 space-y-10">

        <!-- Timetable disclaimer -->
        <div class="bg-amber-50 border border-amber-300/70 rounded-2xl p-5 flex gap-4 shadow-sm">
          <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-amber-100 border border-amber-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
          </div>
          <div>
            <h2 class="font-bold text-amber-900 mb-1.5">Timetable Disclaimer</h2>
            <p class="text-sm text-amber-800 leading-relaxed">
              The timetables below are indicative only and were last verified in the 2024 season. Ferry schedules change seasonally and without advance notice. <strong>Always verify the current timetable directly with the ferry operator before your crossing.</strong> This site is independently operated and accepts no liability for missed crossings.
            </p>
          </div>
        </div>

        <!-- Summer timetable -->
        <section>
          <h2 class="text-2xl font-bold text-forest-900 mb-2 tracking-tight">Summer Timetable (April – October)</h2>
          <p class="text-slate-600 text-sm mb-5 leading-relaxed">
            Daily service. Approximately every 30–60 minutes between 09:00 and 19:00. The gap between 12:30 and 14:00 is the operator's lunch break — plan your departure accordingly.
          </p>
          <div class="overflow-x-auto rounded-2xl border border-slate-200 shadow-sm">
            <table class="w-full text-sm">
              <caption class="sr-only">Summer ferry timetable, Caminha to A Guarda and return</caption>
              <thead>
                <tr class="bg-forest-900 text-white">
                  <th scope="col" class="text-left px-5 py-3.5 font-semibold text-xs uppercase tracking-wider">Departs</th>
                  <th scope="col" class="text-left px-5 py-3.5 font-semibold text-xs uppercase tracking-wider">Arrives</th>
                  <th scope="col" class="text-left px-5 py-3.5 font-semibold text-xs uppercase tracking-wider">Route</th>
                </tr>
              </thead>
              <tbody>
                {summerSchedule.map((row, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-slate-50/70'}>
                    <td class="px-5 py-3 font-mono font-bold text-forest-800 text-sm">{row.departs}</td>
                    <td class="px-5 py-3 font-mono text-slate-500 text-sm">{row.arrives}</td>
                    <td class="px-5 py-3 text-slate-700 text-sm">{row.direction}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        <!-- Winter timetable -->
        <section>
          <h2 class="text-2xl font-bold text-forest-900 mb-2 tracking-tight">Winter Timetable (November – March)</h2>
          <p class="text-slate-600 text-sm leading-relaxed">
            Reduced service in winter — typically weekends and public holidays only, with departures at approximately 10:00, 12:00, and 16:00 (Caminha → A Guarda) and corresponding return trips. Service may be suspended entirely during adverse weather. Contact the operator directly to confirm.
          </p>
          <div class="mt-4 bg-slate-100/80 border border-slate-200 rounded-2xl p-5 text-sm text-slate-700 leading-relaxed">
            <strong>Winter pilgrim note:</strong> Very few pilgrims walk the Coastal Route in winter due to the reduced ferry service. If you plan a winter Camino, consider the Portuguese Interior Route (via Tui/Valença) as a more reliable alternative — the Valença–Tui bridge operates 24/7 and is always accessible on foot.
          </div>
        </section>

        <!-- Fares -->
        <section>
          <h2 class="text-2xl font-bold text-forest-900 mb-5 tracking-tight">Fares &amp; Tickets</h2>
          <div class="overflow-x-auto rounded-2xl border border-slate-200 shadow-sm">
            <table class="w-full text-sm">
              <caption class="sr-only">Ferry fares from Caminha to A Guarda</caption>
              <thead>
                <tr class="bg-forest-900 text-white">
                  <th scope="col" class="text-left px-5 py-3.5 font-semibold text-xs uppercase tracking-wider">Ticket Type</th>
                  <th scope="col" class="text-left px-5 py-3.5 font-semibold text-xs uppercase tracking-wider">Price</th>
                  <th scope="col" class="text-left px-5 py-3.5 font-semibold text-xs uppercase tracking-wider">Notes</th>
                </tr>
              </thead>
              <tbody>
                {[
                  { type: 'Adult (one-way)', price: '€2.50', note: 'Pilgrims pay standard adult fare' },
                  { type: 'Child under 4', price: 'Free', note: 'No seat allocation' },
                  { type: 'Child 4–12', price: '€1.50', note: 'ID or passport may be requested' },
                  { type: 'Bicycle', price: '€1.50', note: 'Additional charge on top of passenger fare' },
                  { type: 'Return ticket', price: '€5.00', note: 'Slight saving vs two singles' },
                ].map((row, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-slate-50/70'}>
                    <td class="px-5 py-3 font-medium text-slate-800">{row.type}</td>
                    <td class="px-5 py-3 font-mono font-bold text-forest-700">{row.price}</td>
                    <td class="px-5 py-3 text-slate-600">{row.note}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="mt-3 text-xs text-slate-500">
            Prices are approximate and may have changed. Tickets purchased at the dock kiosk — cash (euros) accepted; card payment availability varies by season.
          </p>
        </section>

        <!-- ── THE ASSOREAMENTO PROBLEM — Status Warning Card ──────────────────── -->
        <section id="assoreamento">
          <!-- Dramatic warning card -->
          <div class="rounded-2xl overflow-hidden shadow-lg border border-red-200">
            <!-- Header band -->
            <div class="bg-gradient-to-r from-red-700 to-red-800 px-6 py-5 flex gap-4 items-start">
              <div class="shrink-0 flex h-12 w-12 items-center justify-center rounded-xl bg-red-900/50 border border-red-600">
                <!-- Anchor SVG -->
                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-red-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                  <circle cx="12" cy="5" r="3"/>
                  <line x1="12" y1="22" x2="12" y2="8"/>
                  <path d="M5 12H2a10 10 0 0020 0h-3"/>
                </svg>
              </div>
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-xs font-bold uppercase tracking-widest text-red-300 bg-red-900/40 px-2 py-0.5 rounded-full border border-red-700">Disruption Risk</span>
                </div>
                <h2 class="text-xl font-bold text-white">The Assoreamento Problem: When the Ferry Doesn't Run</h2>
                <p class="text-red-200 text-sm mt-1">This is the section no other Camino guide covers adequately — and it's the one most likely to affect your journey.</p>
              </div>
            </div>

            <!-- Body -->
            <div class="bg-red-50 border-t-0 p-6 space-y-4 text-slate-700 text-sm leading-relaxed">
              <p>
                The Minho river estuary is subject to a phenomenon called <strong>assoreamento</strong> (siltation) — the accumulation of sand and sediment at the river mouth that periodically raises the seabed near the ferry docks. The ferry vessel that operates this crossing, the <strong>Santa Rita de Cássia</strong>, is a medium-draught passenger boat that requires a minimum water depth to manoeuvre safely to the dock. When assoreamento is significant, the Santa Rita de Cássia cannot approach the standard berth, and the service is suspended.
              </p>
              <p>
                This is not a rare event. Siltation episodes typically occur during <strong>dry summer periods</strong> (low river discharge reduces the sediment-flushing effect, causing sandbanks to build up near the mouth) and following <strong>major Atlantic storm systems</strong> (wave action from the ocean pushes large volumes of sand into the estuary). In either case, the service can be suspended with zero advance notice — you may arrive at the dock to find a handwritten sign and no boat in sight.
              </p>
              <p>
                Historical pilgrim reports suggest that partial or full suspension occurs in <em>some</em> form during most Camino seasons, typically for periods ranging from 2–3 days to several weeks. <strong>You should always have a backup plan before reaching Caminha, regardless of what you read about the ferry schedule.</strong>
              </p>
            </div>
          </div>
        </section>

        <!-- ── ALTERNATIVE CROSSINGS ─────────────────────────────────────────── -->
        <section id="alternatives">
          <h2 class="text-2xl font-bold text-forest-900 mb-6 tracking-tight">Alternative Crossings When the Ferry is Suspended</h2>

          <!-- Option 1: Xávegas -->
          <div class="bg-white border border-slate-200/80 rounded-2xl overflow-hidden mb-6 shadow-sm">
            <div class="bg-gradient-to-r from-forest-800 to-forest-900 text-white px-6 py-4 flex gap-3 items-start">
              <div class="shrink-0 flex h-9 w-9 items-center justify-center rounded-lg bg-forest-700/60">
                <!-- Boat SVG -->
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-earth-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M22 18H2l4-8h12l4 8z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 2v8"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h8"/>
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold">Option 1: Xávegas / Taxi-Marítimo (Water Taxi)</h3>
                <p class="text-forest-300 text-sm mt-0.5">Fastest alternative · ~€5–6 per person · 20–30 min crossing</p>
              </div>
            </div>
            <div class="p-6 space-y-4 text-slate-700 text-sm leading-relaxed">
              <p>
                When the Santa Rita de Cássia cannot operate, local fishermen often run informal <strong>Xávegas</strong> (traditional flat-bottomed wooden fishing boats) or motorised water taxis across the Minho. These smaller vessels have a shallower draught and can navigate through the siltation that grounds the main ferry.
              </p>
              <p>
                <strong>How to find a water taxi:</strong> These are informal, unscheduled operations with no booking website. The most reliable method is to ask your hospitalero or guesthouse host the evening before — they will know which operators are currently active and can often make contact on your behalf. Alternatively, go directly to the <strong>Cais da Rua dos Pescadores</strong> (the fishing dock, adjacent to the main ferry berth) and ask the fishermen directly. The Caminha tourist office can also provide current operator contacts:
              </p>

              <!-- Named operators -->
