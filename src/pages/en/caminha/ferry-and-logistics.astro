      <!-- ── MAIN CONTENT ─────────────────────────────────────────────────────── -->
      <div class="lg:col-span-2 space-y-10">

        <!-- Timetable disclaimer -->
        <div class="bg-amber-50 border border-amber-300 rounded-xl p-5">
          <div class="flex gap-3">
            <span class="text-xl shrink-0" aria-hidden="true">⚠️</span>
            <div>
