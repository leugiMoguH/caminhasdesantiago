            <div class="flex items-center gap-2 text-slate-600">
              <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <span>Cais de Caminha, 4910 Caminha</span>
            </div>
          </div>
        </div>

        <!-- Tourist Office -->
        <div class="bg-white border border-slate-200 rounded-xl p-5">
          <h2 class="text-base font-bold text-forest-900 mb-3">Caminha Tourist Office</h2>
          <p class="text-sm text-slate-700 mb-2">Best source for real-time ferry status and water taxi operator contacts during disruptions.</p>
          <a href="tel:+351258921952" class="flex items-center gap-2 text-forest-700 hover:underline no-underline font-medium text-sm">
            <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            +351 258 921 952
          </a>
          <p class="text-xs text-slate-500 mt-1">Mon–Fri 09:00–17:30</p>
        </div>

        <!-- Quick tips -->
        <div class="bg-earth-50 border border-earth-200 rounded-xl p-5">
          <h2 class="text-base font-bold text-forest-900 mb-3">Pilgrim Tips</h2>
          <ul class="space-y-2.5 text-sm text-slate-700">
            <li class="flex items-start gap-2">
              <span class="text-earth-600 shrink-0 mt-0.5">→</span>
              Arrive 15 minutes early — the boat fills quickly in high season.
            </li>
            <li class="flex items-start gap-2">
              <span class="text-earth-600 shrink-0 mt-0.5">→</span>
              Carry small change in euros — the kiosk may not accept cards.
            </li>
            <li class="flex items-start gap-2">
              <span class="text-earth-600 shrink-0 mt-0.5">→</span>
              Crossing can be choppy in autumn — secure loose items on your pack.
            </li>
            <li class="flex items-start gap-2">
              <span class="text-earth-600 shrink-0 mt-0.5">→</span>
              Your credencial gets a special ferry stamp on request.
            </li>
            <li class="flex items-start gap-2">
              <span class="text-earth-600 shrink-0 mt-0.5">→</span>
              Check the ferry is running the evening before — ask at your albergue.
            </li>
            <li class="flex items-start gap-2">
              <span class="text-earth-600 shrink-0 mt-0.5">→</span>
              Last ferry from A Guarda back to Caminha is typically 19:30 — verify current times.
            </li>
          </ul>
