        </a>
      </div>
    </div>
  </div>

</MainLayout>

<script>
  // FAQ accordion with smooth CSS grid animation
  const buttons = document.querySelectorAll('[data-accordion-btn]');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const contentId = btn.getAttribute('aria-controls');
      const content = document.getElementById(contentId!);
      const chevron = btn.querySelector('[data-accordion-chevron]');

      // Close all others
      buttons.forEach((otherBtn) => {
        if (otherBtn === btn) return;
        const otherId = otherBtn.getAttribute('aria-controls');
        const otherContent = document.getElementById(otherId!);
        const otherChevron = otherBtn.querySelector('[data-accordion-chevron]');
        otherBtn.setAttribute('aria-expanded', 'false');
        otherContent?.classList.remove('open');
        otherChevron?.classList.remove('rotate-180');
      });

      // Toggle this one
      btn.setAttribute('aria-expanded', String(!expanded));
      content?.classList.toggle('open', !expanded);
      chevron?.classList.toggle('rotate-180', !expanded);
    });
  });
</script>
