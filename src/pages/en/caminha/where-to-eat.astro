---
import MainLayout from '../../../layouts/MainLayout.astro';

const restaurants = [
  // ── PILGRIM SET MENUS ──────────────────────────────────────────────────────
  {
    name: 'Tasca do Avô',
    type: 'Home-style Portuguese · Lunch Only',
    address: 'Rua da Corredoura 8, Caminha',
    priceRange: '€',
    priceDetail: '€8 set menu',
    pilgrimMenu: true,
    pilgrimMenuPrice: '€8',
    hours: 'Mon–Fri 12:00–15:00',
    walkingDistance: '280m from the Camino track (3 min walk from the main square)',
    vegetarianNote: 'One vegetarian main usually available on Fridays; limited other days — call ahead.',
    vegetarianLevel: 'limited',
    description: 'The best-value lunch in Caminha, full stop. A tiny, no-frills spot beloved by locals, fishermen, and pilgrims alike. The daily menu changes with whatever\'s fresh at the market — always one or two generous options with homemade bread and a half-litre of house wine included. At €8 for three courses with wine, this is the definitive pilgrim menu in town. Cash only, no card machine. Arrive before 12:30 or you will queue outside.',
    highlights: ['Cheapest pilgrim menu in town', 'Always full of locals — a quality signal', 'Cash only', 'Freshest daily market produce'],
    phone: null,
    section: 'budget',
  },
  {
    name: 'Restaurante O Barão',
    type: 'Traditional Portuguese / Seafood',
    address: 'Praça do Conselho, Caminha',
    priceRange: '€€',
    priceDetail: '€10 pilgrim menu / €18–28 à la carte',
    pilgrimMenu: true,
    pilgrimMenuPrice: '€10',
    hours: 'Mon–Sat 12:00–15:00, 19:00–22:00',
    walkingDistance: 'On the main square — 200m from the Camino waymarks, directly on route',
    vegetarianNote: 'Vegetarian-friendly: pasta and egg dishes always available as pilgrim menu alternatives on request.',
    vegetarianLevel: 'friendly',
    description: 'Set on Caminha\'s historic main square with outdoor terrace seating, O Barão is the most atmospheric place to eat a pilgrim lunch. The menú do peregrino includes a starter (often caldo verde soup or atum salad), a main course (bacalhau à brás or grilled sea bream), bread, house wine, and dessert. The grilled octopus (polvo grelhado) on the à la carte menu is exceptional — if you\'re treating yourself to a dinner, order that. Show your pilgrim credential to confirm the discounted menu price.',
    highlights: ['Pilgrim menu €10 with wine', 'Outdoor terrace on the historic square', 'Fresh Atlantic catch daily', 'Credencial accepted for discount'],
    phone: '+351 258 921 234',
    section: 'budget',
  },
  {
    name: 'Pastelaria Central',
    type: 'Café / Bakery',
    address: 'Rua Ricardo Joaquim de Sousa 3, Caminha',
    priceRange: '€',
    priceDetail: 'Under €5 for breakfast',
    pilgrimMenu: false,
    pilgrimMenuPrice: null,
    hours: 'Daily 07:00–19:00',
    walkingDistance: '150m from the Albergue Municipal, directly between the albergue and the ferry dock',
    vegetarianNote: 'All menu items are vegetarian-friendly. Vegan options: toasted baguettes without butter (ask at counter).',
    vegetarianLevel: 'vegan',
    description: 'The essential morning stop before boarding the ferry or resuming the Camino. Freshly baked pastéis de nata (custard tarts) that rival anything in Lisbon, strong galão coffee (Portuguese latte), and generously filled toasted sandwiches. Opens at 7:00 AM — early enough for a ferry departure at 9:00. They also assemble packed baguettes to take on the trail. The price for a coffee and two pastéis de nata is under €3.50.',
    highlights: ['Opens at 7:00 AM — pre-ferry essential', 'Best pastéis de nata in Caminha', 'Trail-ready packed lunches available', 'Under €4 for a full breakfast'],
    phone: '+351 258 921 100',
    section: 'budget',
  },

  // ── TRADITIONAL MINHO GASTRONOMY ──────────────────────────────────────────
  {
    name: 'Petisco & Companhia',
    type: 'Petiscos / Wine Bar',
    address: 'Rua Visconde Sousa Rego 14, Caminha',
    priceRange: '€€',
    priceDetail: '€25–35 per person',
    pilgrimMenu: false,
    pilgrimMenuPrice: null,
    hours: 'Tue–Sun 12:00–23:00 (kitchen closes 22:00)',
    walkingDistance: '320m from the Camino track, 5 min walk from the main square toward the river',
    vegetarianNote: 'Excellent for vegetarians: queijo da Serra, mushroom petiscos, and seasonal vegetable dishes. Vegan cheese boards available.',
    vegetarianLevel: 'vegan',
    description: 'A modern wine bar serving traditional Minho petiscos (Portuguese-style tapas) — ideal for a relaxed evening meal after a long day on the coastal trail. The philosophy here is pairing: every plate is built around a local Vinho Verde producer. Stand-outs include the presunto from Vinhais (cured mountain ham), alheira (smoked sausage), queijo da Serra with chestnut honey, and seasonal wild mushrooms with olive oil. The most social dining spot in Caminha — you\'ll meet other pilgrims planning their A Guarda crossing over a bottle of Alvarinho. Dog-friendly terrace.',
    highlights: ['Exceptional Vinho Verde selection', 'Perfect for sharing plates', 'Dog-friendly terrace', 'Vegetarian boards available'],
    phone: '+351 910 456 789',
    section: 'gastronomy',
  },
  {
    name: 'Marisqueira A Lagosta',
    type: 'Seafood Restaurant — Arroz de Debulho Specialist',
    address: 'Avenida Marginal, Caminha',
    priceRange: '€€€',
    priceDetail: '€35–55 per person',
    pilgrimMenu: false,
    pilgrimMenuPrice: null,
    hours: 'Tue–Sun 12:30–15:00, 19:30–22:30',
    walkingDistance: '600m from the Camino track, riverside along the Avenida Marginal toward the ferry dock',
    vegetarianNote: 'Limited vegetarian options — this is a dedicated seafood restaurant. Grilled vegetable plate available on request, rice dishes can be made without shellfish.',
    vegetarianLevel: 'limited',
    description: 'The splurge option in Caminha and a must-visit for anyone who loves Minho river gastronomy. This riverside marisqueira has been serving the region\'s finest seafood for over 30 years, with panoramic views of the Minho estuary and the Galician coast beyond. The signature dish is <strong>arroz de debulho</strong> — a dense, intensely flavoured rice cooked with fresh shellfish, a preparation specific to this stretch of the Minho coast that you won\'t find in Spanish Galicia. Order it for two and arrive hungry. Also outstanding: percebes (goose barnacles) when in season (autumn), amêijoas à bulhão pato (clams in garlic and white wine), and the arroz de marisco (seafood rice). Book for dinner — walk-in for lunch is usually possible on weekdays.',
    highlights: ['Signature arroz de debulho — a Minho-coast exclusive', 'Panoramic Minho estuary views', 'Live tank shellfish', 'Best occasion restaurant in Caminha', 'Percebes in season (autumn)'],
    phone: '+351 258 922 300',
    section: 'gastronomy',
  },
];

const sections = [
  {
    key: 'budget',
    label: 'Pilgrim Set Menus — Under €10',
    intro: 'These restaurants offer the classic Portuguese pilgrim menu: three courses with bread and wine, served at lunchtime (typically 12:00–15:00) for €8–10. Show your credencial do peregrino to confirm eligibility, though most places won\'t ask. All are within 350 metres of the Camino waymarks through Caminha.',
  },
  {
    key: 'gastronomy',
    label: 'Traditional Minho Gastronomy — Arroz de Debulho & Fresh Fish',
    intro: 'The Minho region has its own distinct cuisine, shaped by the Atlantic coast and the river valley. These options go beyond the pilgrim menu into the real cooking of the region — seafood rice, fresh percebes, Vinho Verde pairings, and the intensely savoury arroz de debulho that you will not find anywhere else on the Camino.',
  },
];

// Price badge colour by range
const priceBadgeClass: Record<string, string> = {
  '€':   'bg-forest-100 text-forest-800 border-forest-200',
  '€€':  'bg-earth-100 text-earth-800 border-earth-200',
  '€€€': 'bg-red-50 text-red-800 border-red-200',
};

// Vegetarian pill styling
const vegPillClass: Record<string, string> = {
  vegan:   'bg-forest-100 text-forest-800 border-forest-200',
  friendly:'bg-green-50 text-green-800 border-green-200',
  limited: 'bg-slate-100 text-slate-600 border-slate-200',
};
const vegPillLabel: Record<string, string> = {
  vegan:   'Vegan options',
  friendly:'Vegetarian-friendly',
  limited: 'Limited veg',
};
---

<MainLayout
  title="Where to Eat in Caminha — Pilgrim Menus, Minho Seafood & Vinho Verde"
  description="Best restaurants in Caminha for Camino de Santiago pilgrims. Pilgrim set menus from €8, arroz de debulho seafood rice, Vinho Verde wine bars, and early cafés near the ferry terminal. Walking distances included."
  lang="en"
  schemaType="webpage"
>

  <!-- ── PAGE HEADER ──────────────────────────────────────────────────────────── -->
  <div class="bg-gradient-to-b from-earth-50 to-white border-b border-earth-100/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <nav aria-label="Breadcrumb" class="mb-5">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/en/" class="hover:text-forest-700 no-underline hover:underline transition-colors">Home</a></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li><span class="text-slate-400">Caminha</span></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li aria-current="page" class="text-slate-700 font-medium">Where to Eat</li>
        </ol>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold text-forest-900 mb-4 tracking-tight">Where to Eat in Caminha</h1>
      <p class="text-slate-600 max-w-2xl text-base leading-relaxed">
        Caminha has a food scene that punches above its weight. From €8 pilgrim set menus to arroz de debulho — a shellfish rice unique to this stretch of the Minho coast — the town rewards pilgrims who take time to eat well. Walking distances from the main waymarks are included for each listing.
      </p>
      <div class="mt-6 flex flex-wrap gap-2.5">
        <span class="inline-flex items-center gap-1.5 bg-earth-100 text-earth-800 text-xs font-medium px-3.5 py-2 rounded-full border border-earth-200">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          {restaurants.filter(r => r.pilgrimMenu).length} restaurants with pilgrim menu
        </span>
        <span class="inline-flex items-center gap-1.5 bg-forest-100 text-forest-800 text-xs font-medium px-3.5 py-2 rounded-full border border-forest-200">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          Vegetarian notes on every listing
        </span>
        <span class="inline-flex items-center gap-1.5 bg-slate-100 text-slate-700 text-xs font-medium px-3.5 py-2 rounded-full border border-slate-200">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Walking distances from Camino track included
        </span>
      </div>
    </div>
  </div>

  <!-- ── ADSENSE SLOT 1 ──────────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="my-6 adsense-placeholder">
      <ins class="adsbygoogle w-full"
           style="display:block"
           data-ad-client="ca-pub-6529337148344504"
           data-ad-slot="2297179243"
           data-ad-format="auto"
           data-full-width-responsive="true"></ins>
    </div>
  </div>
  <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>

  <!-- ── RESTAURANT SECTIONS ─────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 space-y-16">

    {sections.map((section, sectionIdx) => {
      const items = restaurants.filter(r => r.section === section.key);
      return (
        <section id={section.key} aria-labelledby={`heading-${section.key}`}>
          <div class="mb-8">
            <h2 id={`heading-${section.key}`} class="text-2xl font-bold text-forest-900 tracking-tight">
              {section.label}
            </h2>
            <p class="mt-2 text-slate-600 text-sm leading-relaxed max-w-2xl">{section.intro}</p>
          </div>

          <div class="grid grid-cols-1 gap-6">
            {items.map((r) => (
              <article class="bg-white rounded-2xl border border-slate-200/80 overflow-hidden hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 shadow-sm">
                <div class="p-6 sm:p-8">
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-5">
                    <div>
                      <div class="flex flex-wrap items-center gap-2 mb-1.5">
                        <h3 class="text-xl font-bold text-forest-900 tracking-tight">{r.name}</h3>
                        {r.pilgrimMenu && (
                          <span class="inline-flex items-center gap-1.5 bg-earth-100 text-earth-800 text-xs font-semibold px-2.5 py-1 rounded-full border border-earth-200">
                            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                            </svg>
                            Pilgrim menu {r.pilgrimMenuPrice}
                          </span>
                        )}
                      </div>
                      <p class="text-sm text-slate-500 font-medium">{r.type}</p>
                    </div>

                    <!-- Price badge + Veg pill -->
                    <div class="flex flex-col items-end gap-2 shrink-0">
                      <span class={`font-mono text-sm font-bold px-3 py-1.5 rounded-lg border ${priceBadgeClass[r.priceRange]}`}>
                        {r.priceRange} <span class="font-normal text-xs">· {r.priceDetail}</span>
                      </span>
                      <span class={`inline-flex items-center gap-1.5 text-xs font-semibold px-2.5 py-1 rounded-full border ${vegPillClass[r.vegetarianLevel]}`}>
                        <!-- Leaf SVG -->
                        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
                        </svg>
                        {vegPillLabel[r.vegetarianLevel]}
                      </span>
                    </div>
                  </div>

                  <p class="text-slate-700 leading-relaxed mb-5 text-sm sm:text-base" set:html={r.description} />

                  <!-- Distance & Veg details -->
                  <div class="grid sm:grid-cols-2 gap-3 mb-5">
                    <div class="flex items-start gap-2.5 bg-slate-50 border border-slate-100 rounded-xl px-3.5 py-3 text-xs text-slate-700">
                      <svg class="h-4 w-4 text-slate-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                      <span><strong class="text-slate-800">From Camino:</strong> {r.walkingDistance}</span>
                    </div>
                    <div class={`flex items-start gap-2.5 rounded-xl px-3.5 py-3 text-xs border ${vegPillClass[r.vegetarianLevel]}`}>
                      <svg class="h-4 w-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
                      <span><strong>Veg/Vegan:</strong> {r.vegetarianNote}</span>
                    </div>
                  </div>

                  <!-- Highlight chips -->
                  <ul class="flex flex-wrap gap-2 mb-5">
                    {r.highlights.map((h) => (
                      <li class="text-xs bg-earth-50 text-earth-700 px-3 py-1.5 rounded-full border border-earth-100 font-medium">
                        {h}
                      </li>
                    ))}
                  </ul>

                  <div class="pt-4 border-t border-slate-100 flex flex-col sm:flex-row gap-3 text-sm text-slate-500 flex-wrap">
                    <span class="flex items-center gap-1.5">
                      <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                      {r.address}
                    </span>
                    <span class="flex items-center gap-1.5">
                      <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                      {r.hours}
                    </span>
                    {r.phone && (
                      <a href={`tel:${r.phone}`} class="flex items-center gap-1.5 no-underline hover:text-forest-700 transition-colors cursor-pointer">
                        <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                        {r.phone}
                      </a>
                    )}
                  </div>
                </div>
              </article>
            ))}
          </div>

          {/* AdSense slot 2 — between dining categories */}
          {sectionIdx === 0 && (
            <div class="mt-10 adsense-placeholder">
              <ins class="adsbygoogle w-full"
                   style="display:block"
                   data-ad-client="ca-pub-6529337148344504"
                   data-ad-slot="8017929699"
                   data-ad-format="auto"
                   data-full-width-responsive="true"></ins>
            </div>
          )}
        </section>
      );
    })}
  </div>
  <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>

  <!-- ── PILGRIM TIP CALLOUT ─────────────────────────────────────────────────── -->
  <aside class="bg-gradient-to-b from-forest-50 to-white border-y border-forest-100/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <div class="flex gap-4">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-forest-100 border border-forest-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-forest-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
        </div>
        <div>
          <h2 class="text-lg font-bold text-forest-900 mb-2 tracking-tight">Pilgrim Tip: How the Menú do Peregrino Works</h2>
          <p class="text-slate-700 text-sm leading-relaxed max-w-2xl">
            In Portugal, the <em>menú do peregrino</em> (pilgrim menu) is served at lunch only — typically 12:00 to 15:00. For €8–10 you receive three courses: a starter (soup or salad), a main course (fish or meat), dessert or coffee, and a half-litre of house wine or water. Bread is always included. Showing your <em>credencial do peregrino</em> confirms eligibility, though most restaurants in Caminha won't demand it — the worn boots tell the story. Always check the menu board posted outside before sitting. <strong>Monday is the worst day for pilgrim menus</strong> — many small restaurants are closed or serve reduced offerings.
          </p>
        </div>
      </div>
    </div>
  </aside>

</MainLayout>
