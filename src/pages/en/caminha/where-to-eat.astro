---
import MainLayout from '../../../layouts/MainLayout.astro';
import PhotoFigure from '../../../components/PhotoFigure.astro';
import pracaPhoto from '../../../assets/photos/caminha-centro-praca.jpg';
import { bookingSearch } from '../../../lib/booking';

type Zone = 'caminha' | 'vpa';

interface Restaurant {
  name: string;
  zone: Zone;
  cuisine: string;
  address: string;
  locationContext: string;
  knownFor: string;
  pilgrimContext: string;
  mapsUrl: string;
}

interface Cafe {
  name: string;
  address: string;
  useful: string;
  mapsUrl: string;
}

const restaurants: Restaurant[] = [
  // ── CAMINHA ────────────────────────────────────────────────────────────────────
  {
    name: 'Restaurante Baptista',
    zone: 'caminha',
    cuisine: 'Portuguese · Seafood',
    address: 'Praça do Conselheiro Silva Torres 24/26, Caminha',
    locationContext: 'On the main square (Praça Conselheiro Silva Torres)',
    knownFor: 'Historic venue on the main square; seasonal Portuguese seafood and traditional cuisine',
    pilgrimContext: 'Central sit-down option; suitable for lunch or dinner on the main square',
    mapsUrl: 'https://www.google.com/maps/search/?q=Restaurante+Baptista+Caminha',
  },
  {
    name: 'Muralha de Caminha',
    zone: 'caminha',
    cuisine: 'Mediterranean · European',
    address: 'Praça de Espanha, Caminha',
    locationContext: 'Near the historic medieval fortifications',
    knownFor: 'Outdoor terrace facing the town walls; Minho regional cooking',
    pilgrimContext: 'Outdoor terrace after arrival; good for an early evening dinner',
    mapsUrl: 'https://www.google.com/maps/search/?q=Muralha+de+Caminha',
  },
  {
    name: 'Solar do Pescado',
    zone: 'caminha',
    cuisine: 'Seafood · Mediterranean',
    address: 'Rua Visconde Sousa Rego 85, Caminha',
    locationContext: 'Main street toward the river and ferry dock',
    knownFor: 'Fresh Atlantic seafood on the route to the ferry',
    pilgrimContext: 'On the route to the ferry dock; good stop for a pre-crossing lunch',
    mapsUrl: 'https://www.google.com/maps/search/?q=Solar+do+Pescado+Caminha',
  },
  {
    name: 'Casa Almeida',
    zone: 'caminha',
    cuisine: 'Café · European · Portuguese',
    address: 'Praça Conselheiro Silva Torres, Caminha',
    locationContext: 'On the main square',
    knownFor: 'Café and restaurant on the main square; traditional Portuguese menu',
    pilgrimContext: 'Flexible stop on the main square; suitable for light meals or coffee at any hour',
    mapsUrl: 'https://www.google.com/maps/search/?q=Casa+Almeida+Caminha',
  },
  {
    name: 'O Chafariz',
    zone: 'caminha',
    cuisine: 'European · Portuguese',
    address: '',
    locationContext: 'Town centre',
    knownFor: 'Traditional Portuguese cooking with a large local following',
    pilgrimContext: 'Good for a traditional dinner in the centre; popular with locals',
    mapsUrl: 'https://www.google.com/maps/search/?q=O+Chafariz+Caminha',
  },
  {
    name: 'Restaurante Remo',
    zone: 'caminha',
    cuisine: 'Portuguese · Seafood · Sushi',
    address: 'Avenida Doutor Dantas Carneiro, Caminha',
    locationContext: 'Near the town centre, with Minho estuary views',
    knownFor: 'Traditional restaurant established 1981; cod, seafood rice, octopus and sushi, with river views',
    pilgrimContext: 'Riverside lunch or dinner near the centre; closed Tuesdays',
    mapsUrl: 'https://www.google.com/maps/search/?q=Restaurante+Remo+Caminha',
  },
  {
    name: 'Sebastião — Pizza, Pasta & Wine',
    zone: 'caminha',
    cuisine: 'Italian · Pizza · Pasta',
    address: 'Praça do Conselheiro Silva Torres 23, Caminha',
    locationContext: 'On the main square',
    knownFor: 'Italian restaurant on the main square; pizza, pasta and wine',
    pilgrimContext: 'Casual Italian option on the square; closed Mondays',
    mapsUrl: 'https://www.google.com/maps/search/?q=Sebastiao+Pizza+Caminha',
  },
  {
    name: 'Canto do Lobo',
    zone: 'caminha',
    cuisine: 'Portuguese · Petiscos · Craft Beer',
    address: 'Rua Ricardo Joaquim de Sousa 125, Caminha',
    locationContext: 'Old town, beside the medieval wall',
    knownFor: 'Gastropub petiscos with local craft beers and wines, in a stone building by the wall',
    pilgrimContext: 'Relaxed petiscos and craft beer near the wall; good for sharing plates',
    mapsUrl: 'https://www.google.com/maps/search/?q=Canto+do+Lobo+Caminha',
  },
  {
    name: 'Adega do Chico',
    zone: 'caminha',
    cuisine: 'Portuguese · Seafood',
    address: 'Rua Visconde Sousa Rego 30, Caminha',
    locationContext: 'Main street toward the river and ferry dock',
    knownFor: 'Traditional Portuguese cooking; bacalhau à Chico and Barrosã beef steak, with a partly open kitchen',
    pilgrimContext: 'Hearty traditional meal on the route to the ferry',
    mapsUrl: 'https://www.google.com/maps/search/?q=Adega+do+Chico+Caminha',
  },
  {
    name: 'A Torre',
    zone: 'caminha',
    cuisine: 'Portuguese · Grill',
    address: 'Largo Calouste Gulbenkian 7, Caminha',
    locationContext: 'Town centre',
    knownFor: 'Portuguese cooking; bacalhau à casa, veal dishes, wood-fired pizza and francesinhas',
    pilgrimContext: 'Central all-rounder; varied menu for lunch or dinner',
    mapsUrl: 'https://www.google.com/maps/search/?q=A+Torre+Restaurante+Caminha',
  },
  {
    name: 'Girassol',
    zone: 'caminha',
    cuisine: 'Portuguese · Traditional',
    address: 'Avenida de São Bento, Caminha',
    locationContext: 'Near Seixas station, southern edge of Caminha',
    knownFor: 'Traditional Portuguese home cooking near Seixas station',
    pilgrimContext: 'Handy for pilgrims staying in Seixas; traditional meals near the station',
    mapsUrl: 'https://www.google.com/maps/search/?q=Restaurante+Girassol+Caminha+Sao+Bento',
  },
  {
    name: 'Foz do Minho',
    zone: 'caminha',
    cuisine: 'Portuguese · Seafood',
    address: 'Lugar de Esteiró, Cristelo, Caminha',
    locationContext: 'At the Minho river mouth, ~1.5 km from the centre',
    knownFor: 'Long-established seafood restaurant with estuary views where the Minho meets the sea',
    pilgrimContext: 'Scenic seafood about 1.5 km from town; easier with transport',
    mapsUrl: 'https://www.google.com/maps/search/?q=Restaurante+Foz+do+Minho+Caminha',
  },

  // ── VILA PRAIA DE ÂNCORA ───────────────────────────────────────────────────────
  {
    name: 'Fortaleza Restaurante',
    zone: 'vpa',
    cuisine: 'Seafood · Mediterranean',
    address: 'Avenida Dr. Ramos Pereira 81, Vila Praia de Âncora',
    locationContext: 'Beachfront avenue in Vila Praia de Âncora',
    knownFor: 'Fresh Atlantic seafood on the main beachfront dining avenue',
    pilgrimContext: 'Beachfront dinner or lunch in Vila Praia de Âncora; convenient if stopping here overnight',
    mapsUrl: 'https://www.google.com/maps/search/?q=Fortaleza+Restaurante+Vila+Praia+de+Ancora',
  },
  {
    name: 'Restaurante Vitória Mar',
    zone: 'vpa',
    cuisine: 'Seafood · Mediterranean',
    address: 'Avenida Dr. Luis Ramos Pereira 100, Vila Praia de Âncora',
    locationContext: 'Beachfront avenue in Vila Praia de Âncora',
    knownFor: 'Seafood on the main beachfront avenue; consistently well-reviewed',
    pilgrimContext: 'Alternative beachfront option in VPA; useful if stopping overnight before continuing to Caminha',
    mapsUrl: 'https://www.google.com/maps/search/?q=Restaurante+Vitoria+Mar+Vila+Praia+de+Ancora',
  },
  {
    name: 'Restaurante Portobello',
    zone: 'vpa',
    cuisine: 'Seafood · Portuguese',
    address: 'Avenida Dr. Ramos Pereira, Vila Praia de Âncora',
    locationContext: 'Beachfront avenue in Vila Praia de Âncora',
    knownFor: 'Fresh fish and shellfish with beach views; reopened under new management',
    pilgrimContext: 'Highly rated beachfront seafood in VPA',
    mapsUrl: 'https://www.google.com/maps/search/?q=Restaurante+Portobello+Vila+Praia+de+Ancora',
  },
  {
    name: 'A Taberna 349',
    zone: 'vpa',
    cuisine: 'Seafood · Petiscos · Tapas',
    address: 'Avenida Dr. Ramos Pereira 349, Vila Praia de Âncora',
    locationContext: 'Beachfront avenue in Vila Praia de Âncora',
    knownFor: 'Shellfish, octopus and petiscos by the beach at modest prices',
    pilgrimContext: 'Budget-friendly seafood and sharing plates with sea views',
    mapsUrl: 'https://www.google.com/maps/search/?q=A+Taberna+349+Vila+Praia+de+Ancora',
  },
  {
    name: 'Restaurante Coral',
    zone: 'vpa',
    cuisine: 'Seafood · European',
    address: 'Avenida Campo do Castelo 74, Vila Praia de Âncora',
    locationContext: 'By Forte da Lagarteira, with sea views',
    knownFor: 'Seafood with sea views; known for sardines and sea bass',
    pilgrimContext: 'Sea-view seafood near the fort in VPA',
    mapsUrl: 'https://www.google.com/maps/search/?q=Restaurante+Coral+Vila+Praia+de+Ancora',
  },
  {
    name: 'Restaurante Camarão',
    zone: 'vpa',
    cuisine: 'Seafood · Mediterranean',
    address: 'Avenida Forte do Cão, Gelfa, Vila Praia de Âncora',
    locationContext: 'Gelfa, overlooking the Atlantic',
    knownFor: 'Premium fish and shellfish; lobster (lavagante) a speciality',
    pilgrimContext: 'Special-occasion seafood south of VPA at Gelfa',
    mapsUrl: 'https://www.google.com/maps/search/?q=Restaurante+Camarao+Vila+Praia+de+Ancora+Gelfa',
  },
];

const cafes: Cafe[] = [
  {
    name: 'Pastelaria Caminhense',
    address: 'Rua São João 35, Caminha',
    useful: 'Central location; pastelaria with counter service, suitable for a quick pre-departure coffee and pastry',
    mapsUrl: 'https://www.google.com/maps/search/?q=Pastelaria+Caminhense+Caminha',
  },
  {
    name: 'Pastelaria Riviera',
    address: '',
    useful: 'Town-centre pastelaria; takeaway coffee and pastries',
    mapsUrl: 'https://www.google.com/maps/search/?q=Pastelaria+Riviera+Caminha',
  },
  {
    name: 'Virgem de Fátima',
    address: 'Rua Barão São Roque 11, Caminha',
    useful: 'Bakery and pastelaria with fresh bread throughout the day; central, good for an early breakfast before the ferry',
    mapsUrl: 'https://www.google.com/maps/search/?q=Virgem+de+Fatima+Caminha',
  },
  {
    name: 'Trincaria Happy Food',
    address: 'Rua Condestável Dom Nuno Álvares Pereira 1, Caminha',
    useful: 'Artisan sourdough bakery and brunch spot in the centre; excellent coffee, croissants and juices — a quality breakfast option',
    mapsUrl: 'https://www.google.com/maps/search/?q=Trincaria+Happy+Food+Caminha',
  },
];

const zoneLabels: Record<Zone, string> = {
  caminha: 'Caminha',
  vpa: 'Vila Praia de Âncora',
};
const zones: Zone[] = ['caminha', 'vpa'];
---

<MainLayout
  title="Where to Eat in Caminha & Vila Praia de Âncora"
  description="Verified restaurants and cafés in Caminha and Vila Praia de Âncora for Camino de Santiago Coastal Route pilgrims. Traditional Portuguese seafood, early breakfast spots, and local dining."
  lang="en"
  schemaType="none"
>

  <!-- ── PAGE HEADER ──────────────────────────────────────────────────────────── -->
  <div class="bg-gradient-to-b from-earth-50 to-white border-b border-earth-100/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <nav aria-label="Breadcrumb" class="mb-5">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/en/" class="hover:text-forest-700 no-underline hover:underline transition-colors">Home</a></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li><a href="/en/caminha-guide/" class="hover:text-forest-700 no-underline hover:underline transition-colors">Caminha</a></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li aria-current="page" class="text-slate-700 font-medium">Where to Eat</li>
        </ol>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold text-forest-900 mb-4 tracking-tight">Where to Eat</h1>
      <p class="text-slate-600 max-w-2xl text-base leading-relaxed">
        Verified restaurants in Caminha and Vila Praia de Âncora. All venues are confirmed on Google Maps and TripAdvisor. Seixas has no dedicated restaurant infrastructure — pilgrims staying there walk to Caminha for dinner.
      </p>
      <div class="mt-6 flex flex-wrap gap-2.5">
        <a href="#restaurants" class="inline-flex items-center gap-1.5 bg-white border border-earth-200 text-earth-800 text-xs font-medium px-3.5 py-2 rounded-full hover:bg-earth-50 hover:border-earth-300 no-underline transition-all duration-200 shadow-sm cursor-pointer">
          Restaurants
        </a>
        <a href="#early-breakfast" class="inline-flex items-center gap-1.5 bg-white border border-earth-200 text-earth-800 text-xs font-medium px-3.5 py-2 rounded-full hover:bg-earth-50 hover:border-earth-300 no-underline transition-all duration-200 shadow-sm cursor-pointer">
          Early Breakfast &amp; Cafés
        </a>
      </div>
    </div>
  </div>

  

  <!-- ── Caminha town photo ─────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <PhotoFigure
      src={pracaPhoto}
      alt="Praça Conselheiro Silva Torres in Caminha — café and restaurant terraces below the medieval Clock Tower"
      caption="Praça Conselheiro Silva Torres — café terraces in the heart of Caminha"
      loading="eager"
    />
  </div>

  <!-- ── RESTAURANTS ─────────────────────────────────────────────────────────── -->
  <div id="restaurants" class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 space-y-16">

    {zones.map((zone) => {
      const items = restaurants.filter(r => r.zone === zone);
      return (
        <section aria-labelledby={`heading-${zone}`}>
          <div class="mb-6 pb-4 border-b border-slate-200">
            <h2 id={`heading-${zone}`} class="text-2xl font-bold text-forest-900 tracking-tight">
              {zoneLabels[zone]}
            </h2>
          </div>
          <div class="grid grid-cols-1 gap-5">
            {items.map((r) => (
              <article class="bg-white rounded-2xl border border-slate-200/80 overflow-hidden hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 shadow-sm">
                <div class="p-6 sm:p-8">
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-3">
                    <div class="min-w-0">
                      <h3 class="text-xl font-bold text-forest-900 tracking-tight mb-0.5">{r.name}</h3>
                      <p class="text-sm text-slate-500 font-medium">{r.cuisine}</p>
                    </div>
                    <span class="text-xs bg-forest-50 text-forest-700 px-3 py-1.5 rounded-full border border-forest-100 font-medium self-start break-words sm:max-w-[13rem]">{r.pilgrimContext}</span>
                  </div>

                  <p class="text-slate-700 text-sm leading-relaxed mb-4">{r.knownFor}</p>

                  <div class="flex flex-wrap items-center gap-3 text-sm text-slate-500 pt-4 border-t border-slate-100">
                    {r.address && (
                      <span class="flex items-center gap-1.5">
                        <svg class="h-4 w-4 shrink-0 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                        {r.address}
                      </span>
                    )}
                    <span class="flex items-center gap-1.5 text-xs text-slate-500">
                      <svg class="h-4 w-4 shrink-0 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      </svg>
                      {r.locationContext}
                    </span>
                    <a href={r.mapsUrl} rel="noopener noreferrer" target="_blank" class="ml-auto inline-flex items-center gap-1.5 text-xs text-forest-600 hover:text-forest-800 font-medium no-underline hover:underline transition-colors">
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                      </svg>
                      View on Maps
                    </a>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>
      );
    })}

  </div>

  <!-- ── CTA: INTERNAL LOOP ─────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-6">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href="/en/caminha/where-to-stay/" class="flex items-center gap-4 bg-white border border-forest-200 rounded-2xl p-5 hover:shadow-md hover:border-forest-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-forest-50 border border-forest-100">
          <svg class="h-5 w-5 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-forest-900 group-hover:text-forest-700">Where to Stay</p>
          <p class="text-xs text-slate-500">Albergues, guesthouses &amp; hotels in Caminha, VPA &amp; Seixas</p>
        </div>
      </a>
      <a href="/en/caminha/ferry-and-logistics/" class="flex items-center gap-4 bg-white border border-earth-200 rounded-2xl p-5 hover:shadow-md hover:border-earth-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-earth-50 border border-earth-100">
          <svg class="h-5 w-5 text-earth-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-earth-900 group-hover:text-earth-700">Ferry &amp; Logistics</p>
          <p class="text-xs text-slate-500">Schedule, fares, siltation warnings &amp; alternatives</p>
        </div>
      </a>
      <a href="/en/caminha/useful-services/" class="flex items-center gap-4 bg-white border border-slate-200 rounded-2xl p-5 hover:shadow-md hover:border-slate-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-slate-50 border border-slate-100">
          <svg class="h-5 w-5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-slate-900 group-hover:text-slate-700">Pilgrim Services</p>
          <p class="text-xs text-slate-500">Duty pharmacies, gear shops &amp; ATMs before the crossing</p>
        </div>
      </a>
    </div>
  </div>

  

  <!-- ── EARLY BREAKFAST & CAFÉS ────────────────────────────────────────────── -->
  <div id="early-breakfast" class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-6 pb-4 border-b border-slate-200">
      <h2 class="text-2xl font-bold text-forest-900 tracking-tight mb-1">Early Breakfast &amp; Cafés — Caminha</h2>
      <p class="text-slate-600 text-sm leading-relaxed max-w-2xl">
        Pastelarias in Caminha town centre useful for pre-ferry departures. Opening hours may vary by season — verify locally or check with your accommodation.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {cafes.map((c) => (
        <div class="bg-white rounded-2xl border border-slate-200/80 p-6 shadow-sm flex flex-col">
          <h3 class="text-base font-bold text-forest-900 mb-1">{c.name}</h3>
          {c.address && (
            <p class="text-xs text-slate-500 mb-3 flex items-center gap-1.5">
              <svg class="h-3.5 w-3.5 shrink-0 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              {c.address}
            </p>
          )}
          <p class="text-xs text-amber-700 font-medium bg-amber-50 border border-amber-100 rounded-lg px-3 py-2 mb-3">
            Opens early (typically around 07:00–08:00, may vary)
          </p>
          <p class="text-sm text-slate-600 leading-relaxed mb-4">{c.useful}</p>
          <a href={c.mapsUrl} rel="noopener noreferrer" target="_blank" class="mt-auto inline-flex items-center gap-1.5 text-xs text-forest-600 hover:text-forest-800 font-medium no-underline hover:underline transition-colors">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            View on Maps
          </a>
        </div>
      ))}
    </div>

    <p class="mt-6 text-xs text-slate-500 leading-relaxed max-w-xl">
      Hours listed are approximate. Always confirm with the venue directly, especially outside peak season (June–September). No cafés in Seixas — pilgrims staying there walk to Caminha (approx. 15–20 min) for morning coffee.
    </p>
  </div>

  <!-- ── PILGRIM TIP ─────────────────────────────────────────────────────────── -->
  <aside class="bg-gradient-to-b from-forest-50 to-white border-y border-forest-100/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <div class="flex gap-4">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-forest-100 border border-forest-200">
