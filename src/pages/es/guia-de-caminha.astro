---
import MainLayout from '../../layouts/MainLayout.astro';
import PhotoFigure from '../../components/PhotoFigure.astro';
import torrePhoto from '../../assets/photos/caminha-torre-relogio.jpg';

const SITE_URL = 'https://waytosantiagoguide.com';

const clusters = [
  {
    id: 'alojamiento',
    label: 'Alojamiento',
    href: '/es/caminha/donde-dormir/',
    icon: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12V7a2 2 0 012-2h14a2 2 0 012 2v5M3 12v5a1 1 0 001 1h16a1 1 0 001-1v-5M3 12h18M7 12V9h4v3"/></svg>`,
  },
  {
    id: 'comida',
    label: 'Dónde Comer',
    href: '/es/caminha/donde-comer/',
    icon: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2v20"/><path stroke-linecap="round" stroke-linejoin="round" d="M8 2c0 4 4 4 4 8s-4 4-4 8"/><path stroke-linecap="round" stroke-linejoin="round" d="M16 2v6a2 2 0 004 0V2M18 8v14"/></svg>`,
  },
  {
    id: 'ferry',
    label: 'Ferry y Logística',
    href: '/es/caminha/ferry-y-logistica/',
    icon: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M22 18H2l4-8h12l4 8z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 2v8"/></svg>`,
  },
  {
    id: 'servicios',
    label: 'Servicios Útiles',
    href: '/es/caminha/servicios-utiles/',
    icon: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
  },
];

const faqItems = [
  {
    q: '¿Dónde está Caminha en el Camino de Santiago?',
    a: 'Caminha es la última localidad portuguesa del Camino de Santiago de la Costa (Caminho da Costa), situada en la desembocadura del río Miño, 24 km al norte de Viana do Castelo. Está justo enfrente de A Guarda, Galicia (España), y los peregrinos cruzan en barco para continuar hacia el norte rumbo a Santiago de Compostela.',
  },
  {
    q: '¿Cómo cruzan los peregrinos de Caminha a España?',
    a: 'Los peregrinos cruzan el Miño en taxi acuático autorizado — unos 10 minutos sobre el agua, 6 € por persona (7–8 € con bicicleta). Varios servicios operan a diario, entre ellos Taxi Boat Peregrinos (cada 30 minutos aprox., abr–oct), Xacobeo Transfer (cada hora aprox., reserva online, todo el año), Taxi Mar Caminha y Popeye the Sailor Man. El antiguo ferry Santa Rita de Cássia dejó de operar en 2020 por el asoreamiento (assoreamento) de la desembocadura y será desguazado; hay un nuevo ferry municipal anunciado para el verano de 2026, pero aún no opera. Si no hay barco, toma el tren a Valença y cruza a pie el puente Tui–Valença.',
  },
  {
    q: '¿Hay albergue municipal en Caminha?',
    a: 'Sí. El Albergue Municipal de Peregrinos de Caminha está en el centro, a pocos minutos del embarcadero. Solo admisión directa (abre a las 14:00), requiere credencial do peregrino válida y funciona por orden de llegada, con un máximo de 2 noches consecutivas. Los albergues privados (Albergue Santiago, Bom Caminha) se reservan por adelantado en Booking.com.',
  },
  {
    q: '¿Qué servicios para peregrinos hay en Caminha antes de cruzar?',
    a: 'Caminha tiene un sistema rotatorio de farmacia de guardia (farmácia de serviço) — solo una farmacia abre por día; pregunta en tu albergue cuál está de guardia. Las tiendas de equipamiento están en el centro histórico. Los cajeros (Multibanco) están cerca de la Praça do Conselho. Emergencias: 112.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SITE_URL}/#organization`,
      name: 'Way to Santiago Guide',
      url: SITE_URL,
      logo: { '@type': 'ImageObject', url: `${SITE_URL}/logo.png` },
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE_URL}/#website`,
      url: SITE_URL,
      name: 'Way to Santiago Guide',
    },
    {
      '@type': 'WebPage',
      '@id': `${SITE_URL}/es/guia-de-caminha/#webpage`,
      url: `${SITE_URL}/es/guia-de-caminha/`,
      name: 'Guía de Caminha en el Camino de Santiago de la Costa — Alojamiento, Comida, Ferry y Servicios',
      description: 'Guía completa del peregrino para Caminha en el Camino de Santiago de la Costa. El cruce del río, dónde dormir, dónde comer y servicios para peregrinos — todo verificado y en un solo lugar.',
      inLanguage: 'es-ES',
      isPartOf: { '@id': `${SITE_URL}/#website` },
      about: { '@id': `${SITE_URL}/#organization` },
      breadcrumb: { '@id': `${SITE_URL}/es/guia-de-caminha/#breadcrumb` },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${SITE_URL}/es/guia-de-caminha/#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE_URL}/es/` },
        { '@type': 'ListItem', position: 2, name: 'Guía de Caminha', item: `${SITE_URL}/es/guia-de-caminha/` },
      ],
    },
    {
      '@type': 'TouristDestination',
      '@id': `${SITE_URL}/es/guia-de-caminha/#destination`,
      name: 'Caminha',
      description: 'Histórica localidad fronteriza del norte de Portugal en el Camino de Santiago de la Costa (Caminho da Costa). Los peregrinos cruzan el río Miño en taxi acuático hasta A Guarda, España. Última etapa portuguesa antes de Galicia.',
      url: `${SITE_URL}/es/guia-de-caminha/`,
      touristType: 'Peregrino',
      geo: { '@type': 'GeoCoordinates', latitude: 41.8772, longitude: -8.8389 },
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Caminha',
        addressRegion: 'Viana do Castelo',
        postalCode: '4910',
        addressCountry: 'PT',
      },
      includesAttraction: [
        {
          '@type': 'TouristAttraction',
          '@id': `${SITE_URL}/en/caminha/ferry-and-logistics/#ferry`,
          name: 'Cruce Caminha–A Guarda — río Miño',
        },
      ],
      containedInPlace: { '@type': 'Country', name: 'Portugal' },
    },
    {
      '@type': 'FAQPage',
      '@id': `${SITE_URL}/es/guia-de-caminha/#faq`,
      mainEntityOfPage: { '@id': `${SITE_URL}/es/guia-de-caminha/#webpage` },
      mainEntity: faqItems.map((item) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: { '@type': 'Answer', text: item.a },
      })),
    },
  ],
};
---

<MainLayout
  title="Guía de Caminha en el Camino de Santiago de la Costa — Alojamiento, Comida, Ferry y Servicios"
  description="Guía completa del peregrino para Caminha en el Camino de Santiago de la Costa. El cruce del río, dónde dormir, dónde comer y servicios — todo verificado y en un solo lugar."
  lang="es"
  schemaType="none"
>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')} />

  <!-- ── HERO ──────────────────────────────────────────────────────────────────── -->
  <div class="bg-gradient-to-b from-forest-50 to-white border-b border-forest-100/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <nav aria-label="Ruta de navegación" class="mb-5">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/es/" class="hover:text-forest-700 no-underline hover:underline transition-colors">Inicio</a></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li aria-current="page" class="text-slate-700 font-medium">Guía de Caminha</li>
        </ol>
      </nav>

      <p class="text-earth-700 text-xs font-bold uppercase tracking-widest mb-3">
        Camino de Santiago · Ruta de la Costa · Caminha, Portugal
      </p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-forest-900 mb-4 tracking-tight leading-tight max-w-3xl">
        Caminha — La Guía Completa del Camino de la Costa
      </h1>
      <p class="text-slate-600 max-w-2xl text-base leading-relaxed mb-8">
        La última localidad portuguesa antes de España. El cruce del río, alojamiento, restauración y servicios para peregrinos — todo verificado para el Caminho da Costa.
      </p>

      <dl class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {[
          { value: '~10 min', label: 'Barco a España' },
          { value: '€6', label: 'Tarifa del taxi acuático' },
          { value: '24 km', label: 'Desde Viana do Castelo' },
          { value: 'Diario', label: 'Cruces en taxi acuático' },
        ].map(({ value, label }) => (
          <div class="bg-white border border-forest-100 rounded-2xl px-4 py-4 text-center shadow-sm">
            <dt class="text-xl font-bold text-forest-700">{value}</dt>
            <dd class="text-xs text-slate-600 mt-0.5">{label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>

  <!-- Foto de Caminha -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pt-8">
    <PhotoFigure
      src={torrePhoto}
      alt="La Torre del Reloj medieval de Caminha sobre el centro histórico"
      caption="La Torre del Reloj — emblema de Caminha en el centro histórico"
      loading="eager"
      class="!my-0"
    />
  </div>

  <!-- ── NAVEGACIÓN POR CLÚSTERES ──────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-4 border-b border-slate-100">
    <div class="flex flex-wrap gap-2">
      {clusters.map((c) => (
        <a href={`#cluster-${c.id}`} class="inline-flex items-center gap-1.5 bg-white border border-forest-200 text-forest-800 text-xs font-medium px-3.5 py-2 rounded-full hover:bg-forest-50 hover:border-forest-300 no-underline transition-all duration-200 shadow-sm">
          {c.label}
        </a>
      ))}
    </div>
  </div>

  <!-- ── AVISO DE ASOREAMIENTO ─────────────────────────────────────────────────── -->
  <div class="bg-gradient-to-r from-amber-600 to-orange-600 text-white" role="alert">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-3 flex items-center gap-3">
      <svg class="h-5 w-5 shrink-0 text-white/90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
      </svg>
      <p class="text-sm text-white/95 leading-relaxed">
        <strong>Riesgo de asoreamiento:</strong> el cruce de Caminha puede suspenderse sin previo aviso por <em>assoreamento</em>. Confirma el estado la noche anterior.
        <a href="/es/caminha/ferry-y-logistica/" class="underline font-semibold ml-1 hover:text-white/80">Más detalles →</a>
      </p>
    </div>
  </div>

  <!-- ── SECCIONES DE CLÚSTERES ────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-14 space-y-16">

    <!-- CLÚSTER A: Alojamiento -->
    <section id="cluster-alojamiento" aria-labelledby="cluster-alojamiento-heading">
      <div class="flex items-center gap-3 mb-6">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-forest-100 border border-forest-200 text-forest-700">
          <Fragment set:html={clusters[0].icon} />
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-forest-600">Clúster A</p>
          <h2 id="cluster-alojamiento-heading" class="text-2xl font-bold text-forest-900 tracking-tight">Alojamiento en Caminha</h2>
        </div>
      </div>
      <p class="text-slate-600 text-sm leading-relaxed mb-6 max-w-2xl">
        Tres zonas de alojamiento en la Ruta de la Costa: Caminha (punto de cruce, la mayoría de albergues), Vila Praia de Âncora (8 km al sur, hoteles de playa) y Seixas (parroquia en ruta, hostal junto a la playa). El albergue municipal es solo admisión directa desde las 14:00 — las opciones privadas se reservan por adelantado.
      </p>
      <a
        href="/es/caminha/donde-dormir/"
        class="group inline-flex items-center gap-3 bg-gradient-to-br from-forest-800 to-forest-950 text-white rounded-2xl px-7 py-4 no-underline shadow-xl hover:shadow-2xl hover:-translate-y-0.5 transition-all duration-200 font-bold"
      >
        <svg class="h-5 w-5 text-earth-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12V7a2 2 0 012-2h14a2 2 0 012 2v5M3 12v5a1 1 0 001 1h16a1 1 0 001-1v-5M3 12h18M7 12V9h4v3"/>
        </svg>
        Dónde Dormir — Todas las Opciones
        <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
      <div class="mt-4 flex flex-wrap gap-4 text-sm">
        <a href="/es/caminha/vila-praia-de-ancora/" class="text-forest-700 hover:underline no-underline font-medium flex items-center gap-1">Vila Praia de Âncora <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></a>
        <a href="/es/caminha/seixas/" class="text-forest-700 hover:underline no-underline font-medium flex items-center gap-1">Seixas <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></a>
      </div>
    </section>

    <hr class="border-slate-100" />

    <!-- CLÚSTER B: Comida -->
    <section id="cluster-comida" aria-labelledby="cluster-comida-heading">
      <div class="flex items-center gap-3 mb-6">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-earth-100 border border-earth-200 text-earth-700">
          <Fragment set:html={clusters[1].icon} />
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-earth-700">Clúster B</p>
          <h2 id="cluster-comida-heading" class="text-2xl font-bold text-forest-900 tracking-tight">Dónde Comer en Caminha</h2>
        </div>
      </div>
      <p class="text-slate-600 text-sm leading-relaxed mb-6 max-w-2xl">
        Restaurantes en Caminha y Vila Praia de Âncora. Menús de peregrino (menú do peregrino) al mediodía por 8–12 €, con entrante, plato principal y vino de la casa. Marisco atlántico fresco en la ruta al embarcadero. Pastelerías abiertas desde las 07:00 para las salidas antes del barco. Seixas no tiene restaurantes — los peregrinos van a pie a Caminha (~15 min).
      </p>
      <a
        href="/es/caminha/donde-comer/"
        class="group inline-flex items-center gap-3 bg-gradient-to-br from-earth-700 to-earth-900 text-white rounded-2xl px-7 py-4 no-underline shadow-xl hover:shadow-2xl hover:-translate-y-0.5 transition-all duration-200 font-bold"
      >
        <svg class="h-5 w-5 text-earth-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 2v20"/><path stroke-linecap="round" stroke-linejoin="round" d="M8 2c0 4 4 4 4 8s-4 4-4 8"/><path stroke-linecap="round" stroke-linejoin="round" d="M16 2v6a2 2 0 004 0V2M18 8v14"/>
        </svg>
        Dónde Comer — Todos los Restaurantes
        <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
    </section>

    <hr class="border-slate-100" />

    <!-- CLÚSTER C: Ferry -->
    <section id="cluster-ferry" aria-labelledby="cluster-ferry-heading">
      <div class="flex items-center gap-3 mb-6">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-slate-100 border border-slate-200 text-slate-700">
          <Fragment set:html={clusters[2].icon} />
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-slate-500">Clúster C</p>
          <h2 id="cluster-ferry-heading" class="text-2xl font-bold text-forest-900 tracking-tight">Ferry y Logística</h2>
        </div>
      </div>
      <p class="text-slate-600 text-sm leading-relaxed mb-6 max-w-2xl">
        El cruce del río Miño entre Caminha (Portugal) y A Guarda (España) es un breve trayecto en barco — y un posible problema logístico de todo un día cuando el estuario se llena de sedimentos. Cubre los taxis acuáticos diarios (6 €, ~10 min) que sustituyeron al ferry Santa Rita de Cássia suspendido, los dos operadores y cómo reservar, la trampa del huso horario Portugal–España y la alternativa terrestre por el puente Valença–Tui. Para el contexto de la ruta, la credencial y la planificación estacional, consulta la <a href="/es/caminha/guia-del-peregrino/" class="text-forest-700 hover:underline no-underline font-medium">guía del peregrino de la Ruta de la Costa</a>.
      </p>
      <a
        href="/es/caminha/ferry-y-logistica/"
        class="group inline-flex items-center gap-3 bg-gradient-to-br from-slate-800 to-slate-900 text-white rounded-2xl px-7 py-4 no-underline shadow-xl hover:shadow-2xl hover:-translate-y-0.5 transition-all duration-200 font-bold"
      >
        <svg class="h-5 w-5 text-earth-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M22 18H2l4-8h12l4 8z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 2v8"/>
        </svg>
        Ferry y Logística — Guía Completa
        <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
    </section>

    <hr class="border-slate-100" />

    <!-- CLÚSTER D: Servicios -->
    <section id="cluster-servicios" aria-labelledby="cluster-servicios-heading">
      <div class="flex items-center gap-3 mb-6">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-slate-100 border border-slate-200 text-slate-700">
          <Fragment set:html={clusters[3].icon} />
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-slate-500">Clúster D</p>
          <h2 id="cluster-servicios-heading" class="text-2xl font-bold text-forest-900 tracking-tight">Servicios para Peregrinos</h2>
        </div>
      </div>
      <p class="text-slate-600 text-sm leading-relaxed mb-6 max-w-2xl">
        Infraestructura práctica para la última etapa portuguesa: farmacia de guardia rotatoria (solo una farmacia abre por día — la <em>farmácia de serviço</em>), tiendas de equipamiento y botas en el centro histórico, cajeros Multibanco cerca de la Praça do Conselho y contactos de emergencia, incluidos el SNS24 y la oficina de turismo de Caminha.
      </p>
      <a
        href="/es/caminha/servicios-utiles/"
        class="group inline-flex items-center gap-3 bg-gradient-to-br from-slate-600 to-slate-900 text-white rounded-2xl px-7 py-4 no-underline shadow-xl hover:shadow-2xl hover:-translate-y-0.5 transition-all duration-200 font-bold"
      >
        <svg class="h-5 w-5 text-slate-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
        </svg>
        Servicios — Farmacias, Equipamiento y Cajeros
        <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
    </section>

  </div>

  <!-- ── SOBRE CAMINHA ─────────────────────────────────────────────────────────── -->
  <section class="bg-forest-50 border-y border-forest-100">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-14">
      <div class="max-w-3xl">
        <h2 class="text-2xl sm:text-3xl font-bold text-forest-900 mb-5">Sobre Caminha en el Camino de la Costa</h2>
        <div class="space-y-4 text-slate-700 text-base leading-relaxed">
          <p>
            Caminha (unos 7.000 habitantes) se sitúa en la confluencia de los ríos Coura y Miño, frente a la localidad española de A Guarda. Sus murallas del siglo XIV, la torre del reloj fortificada y la elegante Praça do Conselho la convierten en una de las paradas más distintivas del Camino Portugués de la Costa.
          </p>
          <p>
            Para los peregrinos que recorren el <strong>Caminho da Costa</strong>, Caminha marca la transición de Portugal a Galicia. El cruce del río —un trayecto breve pero memorable de unos 10 minutos en barco— ha unido las dos orillas durante siglos; hoy se hace en taxi acuático autorizado mientras se espera un nuevo ferry municipal. Tras cruzar, los peregrinos continúan hacia el norte por A Guarda a lo largo de la costa gallega rumbo a Santiago de Compostela.
          </p>
          <p>
            Es una parada práctica para pasar la noche antes del cruce, con albergue municipal de peregrinos, albergues privados, pensiones y restaurantes suficientes para reponerse tras la larga etapa costera desde Viana do Castelo (24 km).
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FAQ ───────────────────────────────────────────────────────────────────── -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-14" aria-labelledby="guide-faq-heading">
    <h2 id="guide-faq-heading" class="text-2xl font-bold text-forest-900 mb-6 tracking-tight">Preguntas Frecuentes</h2>
    <div class="space-y-3 max-w-3xl">
      {faqItems.map((item) => (
        <details class="group bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
          <summary class="flex items-center justify-between gap-4 px-6 py-4 cursor-pointer hover:bg-forest-50/50 transition-colors list-none">
            <span class="text-sm font-semibold text-forest-900 leading-snug">{item.q}</span>
            <svg class="h-5 w-5 text-slate-400 shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 pb-5 pt-1 text-sm text-slate-700 leading-relaxed border-t border-slate-100">
            {item.a}
          </div>
        </details>
      ))}
    </div>
  </section>

</MainLayout>
