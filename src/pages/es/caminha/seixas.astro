---
import MainLayout from '../../../layouts/MainLayout.astro';

const accommodations = [
  {
    name: 'Albergue de São Bento',
    type: 'Albergue de Peregrinos',
    positioning: 'Frente al mar en la parroquia de Seixas, a 1 km de la playa de Pedras Ruivas',
    differentiators: ['Ubicación frente al mar', 'Cenas de peregrino disponibles; cocina compartida'],
    bookingUrl: 'https://www.booking.com/hotel/pt/albergue-de-sao-bento.html?aid=7968251',
  },
  {
    name: 'Rinoterra Minho',
    type: 'Hotel Rural',
    address: 'Rua da Costa 15, Seixas, Caminha',
    positioning: 'Rural, parroquia de Seixas, con vistas al río y a la montaña',
    differentiators: ['Spa y centro de bienestar', 'Tenis; restaurante portugués en el establecimiento'],
    bookingUrl: 'https://www.booking.com/hotel/pt/rinoterra-minho.html?aid=7968251',
  },
];
---

<MainLayout
  title="Seixas — Alojamiento e Información para Peregrinos"
  description="Alojamiento e información para peregrinos en la parroquia de Seixas, en el Camino de Santiago de la Costa. Albergue frente al mar y hotel rural, a 2 km al sur de Caminha."
  lang="es"
  schemaType="webpage"
>

  <!-- ── PAGE HEADER ──────────────────────────────────────────────────────────── -->
  <div class="bg-gradient-to-b from-forest-50 to-white border-b border-forest-100/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <nav aria-label="Ruta de navegación" class="mb-5">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/es/" class="hover:text-forest-700 no-underline hover:underline transition-colors">Inicio</a></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li><a href="/es/guia-de-caminha/" class="hover:text-forest-700 no-underline hover:underline transition-colors">Caminha</a></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li aria-current="page" class="text-slate-700 font-medium">Seixas</li>
        </ol>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold text-forest-900 mb-4 tracking-tight">Seixas</h1>
      <p class="text-slate-600 max-w-2xl text-base leading-relaxed">
        La parroquia situada justo al sur del pueblo de Caminha, sobre el sendero señalizado del Camino de la Costa. Baja densidad — un albergue de peregrinos y un hotel rural, ambos reservables en Booking.com. No hay restaurantes en Seixas: los peregrinos caminan hasta Caminha (aproximadamente 15–20 minutos) para comer.
      </p>
      <div class="mt-6 flex flex-wrap gap-2.5">
        <a href="#accommodation" class="inline-flex items-center gap-1.5 bg-white border border-forest-200 text-forest-800 text-xs font-medium px-3.5 py-2 rounded-full hover:bg-forest-50 hover:border-forest-300 no-underline transition-all duration-200 shadow-sm cursor-pointer">
          Alojamiento
        </a>
        <a href="#pharmacy" class="inline-flex items-center gap-1.5 bg-white border border-earth-200 text-earth-800 text-xs font-medium px-3.5 py-2 rounded-full hover:bg-earth-50 hover:border-earth-300 no-underline transition-all duration-200 shadow-sm cursor-pointer">
          Farmacia
        </a>
      </div>
    </div>
  </div>



  <!-- ── CALLOUT: NO RESTAURANTS ───────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-4">
    <div class="bg-amber-50 border border-amber-300/70 rounded-2xl p-5 flex gap-4 shadow-sm">
      <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-amber-100 border border-amber-200">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <div>
        <h2 class="font-bold text-amber-900 mb-1 text-sm">No hay restaurantes en Seixas</h2>
        <p class="text-sm text-amber-800 leading-relaxed">
          Seixas no dispone de infraestructura gastronómica propia. Los peregrinos que se alojan aquí caminan hasta Caminha (aproximadamente 15–20 minutos a pie) para todas las comidas. Tanto el albergue de peregrinos como el hotel rural ofrecen opciones de cena en el establecimiento — confirma la disponibilidad al reservar.
        </p>
      </div>
    </div>
  </div>

  <!-- ── ACCOMMODATION ──────────────────────────────────────────────────────── -->
  <div id="accommodation" class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-6 pb-4 border-b border-slate-200">
      <h2 class="text-2xl font-bold text-forest-900 tracking-tight">Alojamiento en Seixas</h2>
      <p class="text-slate-600 text-sm mt-1 leading-relaxed max-w-2xl">
        Dos opciones sobre el sendero señalizado del Camino de la Costa: un albergue de peregrinos frente al mar y un hotel rural con todos los servicios.
      </p>
    </div>
    <div class="grid grid-cols-1 gap-5">
      {accommodations.map((a) => (
        <article class="bg-white rounded-2xl border border-slate-200/80 overflow-hidden hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 shadow-sm">
          <div class="p-6 sm:p-8">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-4">
              <div>
                <h3 class="text-xl font-bold text-forest-900 tracking-tight mb-0.5">{a.name}</h3>
                <p class="text-sm text-slate-500 font-medium">{a.type}</p>
              </div>
            </div>
            <p class="text-sm text-slate-600 leading-relaxed mb-4">{a.positioning}</p>
            <div class="flex flex-wrap gap-2 mb-5">
              {a.differentiators.map((d) => (
                <span class="text-xs bg-forest-50 text-forest-700 px-3 py-1.5 rounded-full border border-forest-100 font-medium">{d}</span>
              ))}
            </div>
            <div class="pt-4 border-t border-slate-100 flex flex-col sm:flex-row sm:items-center gap-4">
              {a.address && (
                <div class="flex items-center gap-1.5 text-sm text-slate-500 flex-1">
                  <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  {a.address}
                </div>
              )}
              <a
                href={a.bookingUrl}
                rel="nofollow noopener noreferrer sponsored"
                target="_blank"
                class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-earth-600 to-earth-700 hover:from-earth-700 hover:to-earth-800 active:scale-[0.98] text-white font-bold text-sm px-6 py-3.5 rounded-xl transition-all duration-200 no-underline shrink-0 shadow-md hover:shadow-lg cursor-pointer group"
              >
                Ver Disponibilidad y Precios
                <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>

  <!-- ── PHARMACY NOTE ───────────────────────────────────────────────────────── -->
  <div id="pharmacy" class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-10">
    <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
      <h2 class="text-lg font-bold text-forest-900 mb-3 tracking-tight">Farmacia en Seixas</h2>
      <p class="text-slate-700 text-sm leading-relaxed mb-3">
        Seixas cuenta con una farmacia que participa en el turno de guardia del municipio de Caminha: <strong>Farmácia Sousa</strong>, en la Avenida Joaquim Maria Portela, Seixas — aproximadamente a 2 km al sur del centro de Caminha (a pie).
      </p>
      <p class="text-slate-600 text-sm leading-relaxed">
        El turno de farmacia de guardia rota a diario entre el pueblo de Caminha, Vila Praia de Âncora y Seixas. Para saber cuál es la farmacia de guardia actual, pregunta en tu albergue o llama al <strong>SNS24: 808 24 24 24</strong>. Consulta la <a href="/es/caminha/servicios-utiles/#farmacias" class="text-forest-700 hover:underline no-underline font-medium">guía completa de turnos de farmacia</a> para más detalles.
      </p>
    </div>
  </div>

  <!-- ── CTA: INTERNAL LOOP ─────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
      <a href="/es/caminha/vila-praia-de-ancora/" class="flex items-center gap-4 bg-white border border-earth-200 rounded-2xl p-5 hover:shadow-md hover:border-earth-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-earth-50 border border-earth-100">
          <svg class="h-5 w-5 text-earth-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-earth-900 group-hover:text-earth-700">Vila Praia de Âncora</p>
          <p class="text-xs text-slate-500">Etapa anterior al sur — restaurantes y hoteles</p>
        </div>
      </a>
      <a href="/es/caminha/donde-comer/" class="flex items-center gap-4 bg-white border border-earth-200 rounded-2xl p-5 hover:shadow-md hover:border-earth-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-earth-50 border border-earth-100">
          <svg class="h-5 w-5 text-earth-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-earth-900 group-hover:text-earth-700">Dónde Comer</p>
          <p class="text-xs text-slate-500">Restaurantes en Caminha — a 15 min a pie</p>
        </div>
      </a>
      <a href="/es/caminha/donde-dormir/" class="flex items-center gap-4 bg-white border border-forest-200 rounded-2xl p-5 hover:shadow-md hover:border-forest-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-forest-50 border border-forest-100">
          <svg class="h-5 w-5 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-forest-900 group-hover:text-forest-700">Dónde Dormir</p>
          <p class="text-xs text-slate-500">Todo el alojamiento — Caminha, VPA y Seixas</p>
        </div>
      </a>
      <a href="/es/caminha/ferry-y-logistica/" class="flex items-center gap-4 bg-white border border-slate-200 rounded-2xl p-5 hover:shadow-md hover:border-slate-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-slate-50 border border-slate-100">
          <svg class="h-5 w-5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-slate-900 group-hover:text-slate-700">Ferry y Logística</p>
          <p class="text-xs text-slate-500">Cruce del Miño — horarios y alternativas</p>
        </div>
      </a>
      <a href="/es/caminha/servicios-utiles/" class="flex items-center gap-4 bg-white border border-slate-200 rounded-2xl p-5 hover:shadow-md hover:border-slate-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-slate-50 border border-slate-100">
          <svg class="h-5 w-5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-slate-900 group-hover:text-slate-700">Servicios para Peregrinos</p>
          <p class="text-xs text-slate-500">Farmacias, equipamiento y cajeros en Caminha</p>
        </div>
      </a>
    </div>
  </div>

  <!-- ── SCHEMA ─────────────────────────────────────────────────────────────── -->
  <script type="application/ld+json" is:inline set:html={`
    [
      {
        "@context": "https://schema.org",
        "@type": "ItemList",
        "name": "Alojamiento en Seixas — Camino de Santiago de la Costa",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "item": {
              "@type": "Hostel",
              "name": "Albergue de São Bento",
              "description": "Albergue de peregrinos frente al mar en la parroquia de Seixas. Cenas de peregrino disponibles, cocina compartida.",
              "address": { "@type": "PostalAddress", "addressLocality": "Seixas, Caminha", "addressCountry": "PT" }
            }
          },
          {
            "@type": "ListItem",
            "position": 2,
            "item": {
              "@type": "Hotel",
              "name": "Rinoterra Minho",
              "description": "Hotel rural en la parroquia de Seixas con vistas al río y a la montaña. Spa, tenis, restaurante portugués.",
              "address": { "@type": "PostalAddress", "streetAddress": "Rua da Costa 15", "addressLocality": "Seixas, Caminha", "addressCountry": "PT" }
            }
          }
        ]
      },
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "¿Hay restaurantes en Seixas en el Camino de Santiago de la Costa?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "No. Seixas no dispone de infraestructura gastronómica propia. Los peregrinos que se alojan en Seixas caminan hasta Caminha (aproximadamente 15–20 minutos a pie) para todas las comidas. El Albergue de São Bento y el Rinoterra Minho ofrecen opciones de cena en el establecimiento — confirma la disponibilidad al reservar."
            }
          },
          {
            "@type": "Question",
            "name": "¿Qué alojamiento hay disponible en Seixas para peregrinos?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dos opciones: Albergue de São Bento (albergue de peregrinos frente al mar, reservable en Booking.com, cenas de peregrino disponibles) y Rinoterra Minho (hotel rural con spa y restaurante). Ambos están sobre el sendero señalizado del Camino de la Costa y reservables en línea."
            }
          }
        ]
      }
    ]
  `} />

</MainLayout>
