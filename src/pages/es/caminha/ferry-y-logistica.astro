---
import MainLayout from '../../../layouts/MainLayout.astro';
import PhotoFigure from '../../../components/PhotoFigure.astro';
import { bookingSearch } from '../../../lib/booking';
import assoreamentoPhoto from '../../../assets/photos/caminha-rio-assoreamento.jpg';
import { getEntry } from 'astro:content';
import { buildFerryGraph } from '../../../lib/ferrySchema';

const LANG = 'es' as const;
const PAGE_PATH = '/es/caminha/ferry-y-logistica/';

// Single source of truth — all ferry facts come from src/content/crossing/ferry.yml
const entry = await getEntry('crossing', 'caminha-a-guarda');
const f = entry!.data;
const t = f.i18n[LANG];

const ol = t.operatorLabels;
const operadores = f.scheduledOperators.map((op) => ({
  nombre: op.name,
  frecuencia: ol[op.frequency] ?? op.frequency,
  horario: op.hours,
  precio: `${op.adultEUR} €`,
  bici: `${op.bikeEUR} €`,
  reserva: ol[op.booking] ?? op.booking,
  telefono: op.phone,
  url: op.url,
}));
const trenAlternativo = t.trainDetour.map((r) => ({ desde: r.from, hasta: r.to, duracion: r.duration, tarifa: r.fare, frecuencia: r.frequency }));
const preguntasFrecuentes = t.faq.map((x) => ({ pregunta: x.q, respuesta: x.a }));
const fares = f.officialFerry.fares.map((row) => ({
  tipo: t.fareLabels[row.key],
  precio: row.priceEUR === 0 ? 'Gratis' : `${row.priceEUR.toFixed(2).replace('.', ',')} €`,
  nota: t.fareNotes[row.key],
}));

const DATOS_ICONS = [
  `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
];
const datosClave = t.keyFacts.map((kf, i) => ({ icono: DATOS_ICONS[i], valor: kf.value, etiqueta: kf.label }));

const ferryGraph = buildFerryGraph(f, LANG, PAGE_PATH);
---
<MainLayout
  title={t.metaTitle}
  description={t.metaDescription}
  lang="es"
  schemaType="none"
>

    <!-- JSON-LD: generated from ferry.yml (single source of truth) -->
  <script type="application/ld+json" set:html={JSON.stringify(ferryGraph)} />

  <!-- ── ENCABEZADO ──────────────────────────────────────────────────────────── -->
  <div class="bg-gradient-to-br from-slate-800 via-slate-800 to-forest-950 text-white">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <nav aria-label="Ruta de navegación" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-slate-400">
          <li><a href="/es/" class="hover:text-white no-underline transition-colors duration-150">Inicio</a></li>
          <li aria-hidden="true" class="text-slate-600">›</li>
          <li><span class="text-slate-500">Caminha</span></li>
          <li aria-hidden="true" class="text-slate-600">›</li>
          <li aria-current="page" class="text-slate-200 font-medium">Ferry y Logística</li>
        </ol>
      </nav>

      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-forest-700/40 border border-forest-600/40 text-forest-200 text-xs font-semibold uppercase tracking-wider px-3 py-1.5 rounded-full mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
          Camino de la Costa
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold mb-4 text-white leading-tight">Caminha → A Guarda: Ferry y Taxi-Barco — Qué Funciona en 2026</h1>
        <p class="text-slate-300 text-base leading-relaxed">
          El cruce del río Miño entre Caminha (Portugal) y A Guarda (España) funciona a diario. Dos servicios de taxi-barco autorizados sustituyeron al antiguo ferry: hay salidas cada 30 minutos en temporada, la travesía dura unos 10 minutos y hay un nuevo ferry municipal previsto para el verano de 2026. Esta página cubre operadores, precios, reservas y la alternativa terrestre.
        </p>
      </div>

      <!-- Datos clave con SVG -->
      <div class="mt-10 grid grid-cols-2 sm:grid-cols-4 gap-3">
        {datosClave.map(({ icono, valor, etiqueta }) => (
          <div class="bg-white/10 hover:bg-white/15 transition-colors duration-200 rounded-2xl p-4 text-center">
            <div class="flex justify-center mb-2 text-forest-300" set:html={icono} />
            <div class="text-lg font-bold text-white">{valor}</div>
            <div class="text-xs text-slate-400 mt-0.5">{etiqueta}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  

  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

      <!-- ── CONTENIDO PRINCIPAL ───────────────────────────────────────────── -->
      <div class="lg:col-span-2 space-y-12">

        <!-- Aviso sobre horarios -->
        <div class="bg-amber-50 border border-amber-200 rounded-2xl p-5">
          <div class="flex gap-3">
            <div class="shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            </div>
            <div>
              <h2 class="font-bold text-amber-900 mb-1">Verificado en junio de 2026</h2>
              <p class="text-sm text-amber-800 leading-relaxed">
                Los horarios de los operadores reflejan la temporada 2026 y varían con la marea y el tiempo. <strong>Confirma las salidas del día directamente con el operador antes de tu travesía</strong> — por teléfono, online o en el muelle. Este sitio es independiente y no asume responsabilidad por travesías perdidas.
              </p>
            </div>
          </div>
        </div>

        <!-- Operadores -->
        <section id="operators">
          <h2 class="text-2xl font-bold text-forest-900 mb-2">Quién Opera el Cruce Hoy</h2>
          <p class="text-slate-600 text-sm mb-5 leading-relaxed">
            Dos servicios de taxi-barco autorizados operan el cruce Caminha–A Guarda a diario. Los meses más fiables son de abril a octubre; fuera de esa ventana hay menos salidas y se cancelan con más facilidad por el tiempo. Los barcos son pequeños — a veces unos seis pasajeros — así que reserva con antelación en los meses de mayor afluencia.
          </p>
          <div class="overflow-x-auto rounded-2xl border border-slate-200 shadow-sm">
            <table class="w-full text-sm">
              <caption class="sr-only">Operadores de taxi-barco del cruce Caminha–A Guarda</caption>
              <thead>
                <tr class="bg-slate-800 text-white">
                  <th scope="col" class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider">Operador</th>
                  <th scope="col" class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider">Frecuencia</th>
                  <th scope="col" class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider">Horario</th>
                  <th scope="col" class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider">Precio</th>
                  <th scope="col" class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider">Con bici</th>
                  <th scope="col" class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider">Reserva</th>
                </tr>
              </thead>
              <tbody>
                {operadores.map((fila, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-slate-50/70'}>
                    <td class="px-4 py-2.5 font-medium text-slate-800">
                      {fila.url ? <a href={fila.url} rel="noopener" target="_blank" class="text-forest-700 hover:underline no-underline font-semibold">{fila.nombre}</a> : fila.nombre}
                    </td>
                    <td class="px-4 py-2.5 text-slate-700">{fila.frecuencia}</td>
                    <td class="px-4 py-2.5 font-mono text-slate-700">{fila.horario}</td>
                    <td class="px-4 py-2.5 font-mono font-semibold text-forest-700">{fila.precio}</td>
                    <td class="px-4 py-2.5 font-mono text-slate-700">{fila.bici}</td>
                    <td class="px-4 py-2.5 text-slate-600 text-xs">
                      {fila.reserva}
                      {fila.telefono && <a href={`tel:${fila.telefono}`} class="block text-forest-700 font-semibold no-underline hover:underline mt-0.5">{fila.telefono}</a>}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="mt-3 text-xs text-slate-500">
            Los barcos funcionan con hora portuguesa. España va una hora por delante — una salida a las 10:00 llega hacia las 11:10 hora local española. Los horarios se ajustan a la marea; los operadores publican las salidas del día en sus webs y en el muelle.
          </p>
        </section>

        <!-- Nuevo ferry oficial -->
        <section id="new-ferry">
          <h2 class="text-2xl font-bold text-forest-900 mb-2">Nuevo Ferry Oficial (Verano 2026)</h2>
          <div class="bg-forest-50 border border-forest-200 rounded-2xl p-5 text-sm text-slate-700 leading-relaxed space-y-3">
            <p>
              La Câmara Municipal de Caminha ha anunciado un <strong>nuevo ferry municipal para el verano de 2026</strong>: una embarcación de poco calado con capacidad para unos <strong>50–60 pasajeros</strong>, diseñada para el estuario sedimentado que dejó fuera de servicio al barco antiguo. El municipio ha presupuestado la reparación del muelle y el dragado (~30.000–40.000 €).
            </p>
            <p>
              <strong>Estado: anunciado, aún no operativo.</strong> El ferry histórico, el <em>Santa Rita de Cássia</em>, dejó de operar en 2020 y será desguazado. Hasta que el nuevo barco entre en servicio, los taxi-barco de la tabla anterior son el cruce operativo.
            </p>
          </div>
        </section>

        <!-- Tarifas -->
        <section>
          <h2 class="text-2xl font-bold text-forest-900 mb-4">Tarifas Históricas del Ferry Oficial (Referencia)</h2>
          <p class="text-slate-600 text-sm mb-4 leading-relaxed">
            Solo como referencia — eran las tarifas del Santa Rita de Cássia antes de dejar de operar en 2020. Los precios actuales del taxi-barco están en la tabla de operadores. Las tarifas del nuevo ferry de 2026 no se han anunciado.
          </p>
          <div class="overflow-x-auto rounded-2xl border border-slate-200 shadow-sm">
            <table class="w-full text-sm">
              <caption class="sr-only">Tarifas del ferry de Caminha a A Guarda</caption>
              <thead>
                <tr class="bg-forest-900 text-white">
                  <th scope="col" class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider">Tipo de billete</th>
                  <th scope="col" class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider">Precio</th>
                  <th scope="col" class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider">Notas</th>
                </tr>
              </thead>
              <tbody>
                {fares.map((fila, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-slate-50/70'}>
                    <td class="px-4 py-2.5 font-medium text-slate-800">{fila.tipo}</td>
                    <td class="px-4 py-2.5 font-mono font-bold text-forest-700">{fila.precio}</td>
                    <td class="px-4 py-2.5 text-slate-600">{fila.nota}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        

        <!-- ── EL PROBLEMA DEL ASSOREAMENTO ────────────────────────────────── -->
        <PhotoFigure
          src={assoreamentoPhoto}
          alt="El estuario del Miño en marea baja cerca de Caminha, con bancos de arena al descubierto"
          caption="El estuario del Miño en marea baja — los bancos de arena tras la sedimentación que dejó varado el viejo ferry"
        />
        <aside class="mb-10 rounded-2xl bg-forest-50 border border-forest-200 p-5 flex flex-col sm:flex-row sm:items-center gap-4">
          <p class="flex-1 text-sm text-slate-700 leading-relaxed">¿Llegas la tarde anterior al cruce? Reserva cama en Caminha — o una habitación privada en A Guarda para después de cruzar.</p>
          <div class="flex flex-wrap gap-2 shrink-0">
            <a href="/es/caminha/donde-dormir/" class="inline-flex items-center rounded-xl bg-forest-700 hover:bg-forest-800 text-white text-sm font-bold px-4 py-2.5 no-underline transition-colors">Alojarse en Caminha</a>
            <a href={bookingSearch('A Guarda, España', 'wtsg-ferry-es-aguarda')} rel="nofollow noopener noreferrer sponsored" target="_blank" class="inline-flex items-center rounded-xl bg-earth-500 hover:bg-earth-600 text-white text-sm font-bold px-4 py-2.5 no-underline transition-colors">Hoteles en A Guarda</a>
          </div>
        </aside>

        <!-- Condiciones del cruce (fuentes externas, sin rastreo) -->
        <section aria-labelledby="conditions-heading" class="mb-10">
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 id="conditions-heading" class="text-lg font-bold text-forest-900 mb-1 tracking-tight">Comprueba las condiciones antes de cruzar</h2>
            <p class="text-sm text-slate-600 mb-4">El cruce depende de la marea y el tiempo — barcas pequeñas sobre bancos de arena cambiantes. Comprueba la víspera y la mañana de tu cruce.</p>
            <div class="grid sm:grid-cols-2 gap-3">
              <a href="https://es.windfinder.com/tide/caminha" rel="noopener noreferrer" target="_blank" class="flex items-center gap-3 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 no-underline hover:bg-slate-100 hover:border-slate-300 transition-colors group">
                <svg class="h-6 w-6 shrink-0 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6c1.5 0 2.5 1.5 4 1.5S8.5 6 10 6s2.5 1.5 4 1.5S16.5 6 18 6s2.5 1.5 4 1.5M2 12c1.5 0 2.5 1.5 4 1.5s2.5-1.5 4-1.5 2.5 1.5 4 1.5 2.5-1.5 4-1.5 2.5 1.5 4 1.5M2 18c1.5 0 2.5 1.5 4 1.5s2.5-1.5 4-1.5 2.5 1.5 4 1.5 2.5-1.5 4-1.5 2.5 1.5 4 1.5"/></svg>
                <span><span class="block text-sm font-bold text-forest-900 group-hover:text-forest-700">Horario de mareas en Caminha</span><span class="block text-xs text-slate-500">Pleamar y bajamar · Windfinder</span></span>
              </a>
              <a href="https://www.windy.com/?41.877,-8.839,10" rel="noopener noreferrer" target="_blank" class="flex items-center gap-3 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 no-underline hover:bg-slate-100 hover:border-slate-300 transition-colors group">
                <svg class="h-6 w-6 shrink-0 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"/></svg>
                <span><span class="block text-sm font-bold text-forest-900 group-hover:text-forest-700">Viento, olas y tiempo</span><span class="block text-xs text-slate-500">Mapa en vivo del cruce · Windy</span></span>
              </a>
            </div>
          </div>
        </section>

        <section id="assoreamento">
          <!-- Tarjeta dramática con cabecera roja -->
          <div class="rounded-2xl overflow-hidden shadow-md border border-red-200">
            <div class="bg-gradient-to-r from-red-700 to-red-800 px-6 py-5 flex items-start gap-4">
              <div class="shrink-0 bg-white/15 rounded-xl p-2.5 mt-0.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4a8 8 0 100 16A8 8 0 0012 4zm0 0v4m0 4h.01M9.172 9.172a4 4 0 015.656 5.656"/></svg>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-1">
                  <h2 class="text-xl font-bold text-white">Assoreamento: Por Qué Paró el Ferry Antiguo</h2>
                  <span class="inline-flex items-center gap-1 bg-red-900/60 border border-red-400/40 text-red-100 text-xs font-semibold px-2.5 py-0.5 rounded-full">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                    Contexto
                  </span>
                </div>
                <p class="text-red-100 text-sm">La historia de la sedimentación explica por qué cambió el cruce — y por qué los barcos actuales son pequeños y de poco calado.</p>
              </div>
            </div>
            <div class="bg-white p-6 space-y-4 text-slate-700 text-sm leading-relaxed">
              <p>
                El estuario del río Miño sufre <strong>assoreamento</strong> (sedimentación) — la acumulación de arena y sedimentos en la desembocadura que periódicamente eleva el fondo cerca de los muelles. El ferry antiguo, el <strong>Santa Rita de Cássia</strong> (en servicio desde 1995), era un barco de calado medio que necesitaba una profundidad mínima para atracar. Dejó de operar en <strong>2020</strong>; incluso tras finalizar las obras del muelle gallego en 2023, la sedimentación lo mantuvo parado, y el barco será desguazado.
              </p>
              <p>
                Por eso el cruce actual funciona con <strong>taxi-barcos pequeños y de poco calado</strong> — pasan sobre los bancos de arena que vencieron al ferry — y por eso el sustituto anunciado para 2026 es específicamente un diseño de calado reducido. Los episodios de sedimentación siguen afectando al estuario tras veranos secos y grandes temporales atlánticos, así que salidas concretas pueden cancelarse con poco aviso incluso en temporada.
              </p>
              <p>
                Conclusión práctica: <strong>el cruce funciona a diario, pero confirma siempre los barcos del día</strong> — online con Xacobeo Transfer, por teléfono con Taxi Boat Peregrinos, o en tu albergue la noche anterior. Si el tiempo o el río detienen todo, el desvío terrestre de más abajo siempre está disponible.
              </p>
            </div>
          </div>
        </section>

        <!-- ── CRUCES ALTERNATIVOS ────────────────────────────────────────── -->
        <section id="alternativas">
          <h2 class="text-2xl font-bold text-forest-900 mb-6">Opciones de Respaldo Cuando Ningún Barco Cruza</h2>

          <!-- Opción 1: Xávegas / Taxi-marítimo -->
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 mb-6">
            <div class="bg-forest-800 text-white px-6 py-5">
              <h3 class="text-lg font-bold flex items-center gap-3">
                <div class="shrink-0 bg-white/15 rounded-xl p-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19c-2.667-1.333-4-3-4-5 0-2 .667-3.333 2-4"/></svg>
                </div>
                Opción 1: Barcas de Pescadores Informales (Recurso Heredado)
              </h3>
              <p class="text-forest-200 text-sm mt-2 ml-11">Solo relevante si ambos operadores autorizados no están disponibles · ~5–6 € por persona</p>
            </div>
            <div class="p-6 space-y-4 text-slate-700 text-sm leading-relaxed">
              <p>
                Antes de que los taxi-barco autorizados asumieran el cruce, los pescadores locales cruzaban el Miño en <strong>xávegas</strong> (embarcaciones tradicionales de fondo plano) y motoras informales. Algunos todavía lo hacen. Trátalo como un recurso de respaldo: en 2026, tu primera opción es <strong>Taxi Boat Peregrinos o Xacobeo Transfer</strong> (tabla anterior) — las barcas de pescadores solo importan el día excepcional en que ambos servicios regulares fallen pero el río siga siendo navegable.
              </p>
              <p>
                <strong>Cómo encontrar una:</strong> pregunta al hospitalero o al dueño de tu alojamiento la noche anterior, acércate al <strong>Cais da Rua dos Pescadores</strong> (el muelle de los pescadores, contiguo al embarcadero principal) o llama a la oficina de turismo de Caminha para los contactos actuales:
              </p>

