---
import MainLayout from '../../../layouts/MainLayout.astro';

const horarioVerano = [
  { salida: '09:00', llegada: '09:15', ruta: 'Caminha → A Guarda' },
  { salida: '09:30', llegada: '09:45', ruta: 'A Guarda → Caminha' },
  { salida: '10:00', llegada: '10:15', ruta: 'Caminha → A Guarda' },
  { salida: '10:30', llegada: '10:45', ruta: 'A Guarda → Caminha' },
  { salida: '11:00', llegada: '11:15', ruta: 'Caminha → A Guarda' },
  { salida: '11:30', llegada: '11:45', ruta: 'A Guarda → Caminha' },
  { salida: '12:00', llegada: '12:15', ruta: 'Caminha → A Guarda' },
  { salida: '12:30', llegada: '12:45', ruta: 'A Guarda → Caminha' },
  { salida: '14:00', llegada: '14:15', ruta: 'Caminha → A Guarda' },
  { salida: '14:30', llegada: '14:45', ruta: 'A Guarda → Caminha' },
  { salida: '15:00', llegada: '15:15', ruta: 'Caminha → A Guarda' },
  { salida: '15:30', llegada: '15:45', ruta: 'A Guarda → Caminha' },
  { salida: '16:00', llegada: '16:15', ruta: 'Caminha → A Guarda' },
  { salida: '16:30', llegada: '16:45', ruta: 'A Guarda → Caminha' },
  { salida: '17:00', llegada: '17:15', ruta: 'Caminha → A Guarda' },
  { salida: '18:00', llegada: '18:15', ruta: 'Caminha → A Guarda' },
  { salida: '18:30', llegada: '18:45', ruta: 'A Guarda → Caminha' },
  { salida: '19:00', llegada: '19:15', ruta: 'Caminha → A Guarda' },
];

const trenAlternativo = [
  { desde: 'Caminha', hasta: 'Viana do Castelo', duracion: '~20 min', tarifa: '~2,50 €', frecuencia: 'Cada hora (días laborables)' },
  { desde: 'Viana do Castelo', hasta: 'Valença', duracion: '~55 min', tarifa: '~3,60 € (Caminha→Valença directo)', frecuencia: 'Aprox. cada hora; reducido fines de semana' },
  { desde: 'Valença', hasta: 'Tui (a pie)', duracion: '~25 min a pie', tarifa: 'Gratis', frecuencia: 'Puente abierto 24h' },
];

const preguntasFrecuentes = [
  {
    pregunta: '¿Cuánto cuesta el ferry de Caminha a A Guarda?',
    respuesta: 'El ferry cuesta 2,50 € por adulto (ida). Billete de vuelta: 5,00 €. Las bicicletas tienen un cargo adicional de 1,50 € sobre la tarifa de pasajero. Niños menores de 4 años: gratis. Niños 4–12 años: 1,50 €.',
  },
  {
    pregunta: '¿Cuáles son los horarios del ferry?',
    respuesta: 'En verano (abril–octubre) el ferry funciona cada 30–60 minutos de 09:00 a 19:00, todos los días, en ambas direcciones. En invierno (noviembre–marzo) el servicio se reduce a fines de semana y festivos, con salidas aproximadas a las 10:00, 12:00 y 16:00. Confirma siempre los horarios actuales directamente con el operador.',
  },
  {
    pregunta: '¿Qué es el assoreamento y cómo afecta al ferry?',
    respuesta: 'El assoreamento es la sedimentación de arena en la desembocadura del río Miño. Cuando la acumulación es importante, la embarcación Santa Rita de Cássia no puede atracar y el servicio queda suspendido, a veces durante días o semanas. Ocurre principalmente en sequías estivales y tras grandes temporales atlánticos. Siempre debes tener un plan alternativo.',
  },
  {
    pregunta: '¿Qué alternativas hay si el ferry no funciona?',
    respuesta: 'Existen dos opciones: (1) Xávegas o taxi-marítimo — embarcaciones de menor calado que pueden cruzar cuando el ferry no puede; coste aproximado 5–6 € por persona. Contacta con la oficina de turismo de Caminha (+351 258 921 952) para los operadores actuales. (2) Desvío terrestre por Valença–Tui — toma el tren CP de Caminha a Valença (~35 min, ~3,60 €) y cruza a pie el puente internacional hasta Tui.',
  },
  {
    pregunta: '¿Puedo ir de Caminha a A Guarda en tren?',
    respuesta: 'No hay tren directo. La alternativa es tomar el CP Linha do Minho de Caminha a Valença (~35 min, ~3,60 €), cruzar a pie el Puente Internacional Valença–Tui (~1,5 km) y llegar a Tui (España). Desde allí puedes continuar por el Camino Portugués Interior o tomar un taxi ~30 km hasta A Guarda.',
  },
];

const datosClave = [
  {
    icono: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    valor: '~15 min',
    etiqueta: 'Tiempo de travesía',
  },
  {
    icono: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    valor: '2,50 €',
    etiqueta: 'Tarifa de ida',
  },
  {
    icono: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`,
    valor: 'Abr–Oct',
    etiqueta: 'Servicio diario',
  },
  {
    icono: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    valor: 'Cais de Caminha',
    etiqueta: 'Punto de salida',
  },
];
---

<MainLayout
  title="Ferry Caminha–A Guarda — Horario, Assoreamento y Alternativas"
  description="Guía completa del cruce del río Miño entre Caminha y A Guarda. Horarios de verano e invierno, tabla de tarifas, el problema real del assoreamento (sedimentación), alternativas con taxi-marítimo y el desvío terrestre por Valença–Tui."
  lang="es"
  schemaType="none"
>

  <!-- JSON-LD: unified @graph -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://waytosantiagoguide.com/#organization",
        "name": "Way to Santiago Guide",
        "url": "https://waytosantiagoguide.com",
        "logo": { "@type": "ImageObject", "url": "https://waytosantiagoguide.com/logo.png" }
      },
      {
        "@type": "WebSite",
        "@id": "https://waytosantiagoguide.com/#website",
        "url": "https://waytosantiagoguide.com",
        "name": "Way to Santiago Guide"
      },
      {
        "@type": "WebPage",
        "@id": "https://waytosantiagoguide.com/es/caminha/ferry-y-logistica/#webpage",
        "url": "https://waytosantiagoguide.com/es/caminha/ferry-y-logistica/",
        "name": "Ferry Caminha–A Guarda — Horario, Assoreamento y Alternativas | Guía Camino de Santiago",
        "description": "Guía completa del cruce del río Miño entre Caminha y A Guarda. Horarios de verano e invierno, tabla de tarifas, el problema real del assoreamento (sedimentación), alternativas con taxi-marítimo y el desvío terrestre por Valença–Tui.",
        "inLanguage": "es-ES",
        "isPartOf": { "@id": "https://waytosantiagoguide.com/#website" },
        "about": { "@id": "https://waytosantiagoguide.com/#organization" },
        "breadcrumb": { "@id": "https://waytosantiagoguide.com/es/caminha/ferry-y-logistica/#breadcrumb" }
      },
      {
        "@type": "BreadcrumbList",
        "@id": "https://waytosantiagoguide.com/es/caminha/ferry-y-logistica/#breadcrumb",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://waytosantiagoguide.com/es/" },
          { "@type": "ListItem", "position": 2, "name": "Ferry y Logística", "item": "https://waytosantiagoguide.com/es/caminha/ferry-y-logistica/" }
        ]
      },
      {
        "@type": "TouristAttraction",
        "@id": "https://waytosantiagoguide.com/es/caminha/ferry-y-logistica/#ferry",
        "name": "Cruce en Ferry Caminha–A Guarda — Río Miño",
        "description": "El ferry Caminha–A Guarda cruza el río Miño, conectando Portugal y España en el Camino de Santiago de la Costa. La travesía dura aproximadamente 15 minutos. Servicio de temporada (diario abril–octubre). Tarifa: 2,50 € por adulto. Punto de salida: Cais de Caminha, 4910 Caminha, Portugal.",
        "url": "https://waytosantiagoguide.com/es/caminha/ferry-y-logistica/",
        "touristType": "Peregrino",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Cais de Caminha",
          "addressLocality": "Caminha",
          "postalCode": "4910",
          "addressCountry": "PT"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 41.8734,
          "longitude": -8.8358
        },
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
            "opens": "09:00",
            "closes": "19:15",
            "validFrom": "2026-04-01",
            "validThrough": "2026-10-31"
          }
        ]
      },
      {
        "@type": "FAQPage",
        "@id": "https://waytosantiagoguide.com/es/caminha/ferry-y-logistica/#faq",
        "mainEntityOfPage": { "@id": "https://waytosantiagoguide.com/es/caminha/ferry-y-logistica/#webpage" },
        "mainEntity": [
          {
            "@type": "Question",
            "name": "¿Cuánto cuesta el ferry de Caminha a A Guarda?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "El ferry de Caminha a A Guarda cuesta 2,50 € por adulto (ida). Un billete de vuelta son 5,00 €. Las bicicletas tienen un cargo adicional de 1,50 € sobre la tarifa de pasajero. Los niños menores de 4 años viajan gratis; los niños de 4 a 12 años pagan 1,50 €."
            }
          },
          {
            "@type": "Question",
            "name": "¿Cuáles son los horarios del ferry de Caminha a A Guarda?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "En verano (abril–octubre), el ferry funciona aproximadamente cada 30–60 minutos desde las 09:00 hasta las 19:00, todos los días en ambas direcciones entre Caminha y A Guarda. En invierno (noviembre–marzo), el servicio se reduce a fines de semana y festivos, con salidas aproximadas a las 10:00, 12:00 y 16:00. Confirma siempre los horarios actuales directamente con el operador antes de cruzar."
            }
          },
          {
            "@type": "Question",
            "name": "¿Qué es el problema del assoreamento en el ferry de Caminha?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "El estuario del río Miño sufre periódicamente assoreamento (sedimentación) — la acumulación de arena y sedimentos en la desembocadura del río que eleva el fondo marino cerca de los muelles. Cuando la sedimentación es importante, el barco ferry Santa Rita de Cássia no puede atracar en el embarcadero habitual, causando suspensiones de servicio que pueden durar días o semanas. Esto ocurre normalmente en períodos de sequía estival o tras grandes temporales atlánticos. Cuando sucede, los peregrinos pueden usar taxis acuáticos (xávegas, unos 5–6 € por persona) o tomar el tren hasta Valença y cruzar a pie el puente de Tui."
            }
          },
          {
            "@type": "Question",
            "name": "¿Qué alternativas hay si el ferry de Caminha no funciona?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Existen dos alternativas principales cuando el ferry está suspendido: (1) Xávegas o taxi-marítimo: pequeñas embarcaciones operadas por pescadores locales, capaces de cruzar en aguas menos profundas. Tarifa aproximada 5–6 € por persona. Contacta con la oficina de turismo de Caminha (+351 258 921 952) para los contactos actuales del operador. (2) Desvío terrestre por Valença–Tui: toma el tren CP Linha do Minho de Caminha a Valença (~35 minutos, ~3,60 €), luego camina 1,5 km por el puente internacional Tui–Valença. Esto te conecta con el Camino Portugués Interior."
            }
          },
          {
            "@type": "Question",
            "name": "¿Cómo ir de Caminha a A Guarda en tren?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "No hay tren directo de Caminha a A Guarda. La alternativa terrestre es: toma el tren CP Linha do Minho de Caminha a Valença (~35 minutos, ~3,60 € de ida). Desde la estación de Valença, camina hacia el norte a través del casco amurallado medieval (~20 min) hasta el puente internacional. Cruza el Puente Internacional Valença–Tui a pie (~1,5 km, ~20 min). Llegas a Tui (España). La moneda sigue siendo el euro."
            }
          }
        ]
      }
    ]
  }
  </script>

  <!-- ── ENCABEZADO ──────────────────────────────────────────────────────────── -->
  <div class="bg-gradient-to-br from-slate-800 via-slate-800 to-forest-950 text-white">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <nav aria-label="Ruta de navegación" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-slate-400">
          <li><a href="/es/" class="hover:text-white no-underline transition-colors duration-150">Inicio</a></li>
          <li aria-hidden="true" class="text-slate-600">›</li>
          <li><span class="text-slate-500">Caminha</span></li>
          <li aria-hidden="true" class="text-slate-600">›</li>
          <li aria-current="page" class="text-slate-200 font-medium">Ferry y Logística</li>
        </ol>
      </nav>

      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-forest-700/40 border border-forest-600/40 text-forest-200 text-xs font-semibold uppercase tracking-wider px-3 py-1.5 rounded-full mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
          Camino de la Costa
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold mb-4 text-white leading-tight">Caminha → A Guarda: Ferry, Assoreamento y Alternativas</h1>
        <p class="text-slate-300 text-base leading-relaxed">
          El cruce del río Miño entre Caminha (Portugal) y A Guarda (España) es uno de los momentos más memorables del Camino de la Costa — y uno de los más impredecibles. Un viaje en ferry de 15 minutos en condiciones normales; un problema logístico de un día entero cuando el estuario se sedimenta. Esta página cubre ambas realidades.
        </p>
      </div>

      <!-- Datos clave con SVG -->
      <div class="mt-10 grid grid-cols-2 sm:grid-cols-4 gap-3">
        {datosClave.map(({ icono, valor, etiqueta }) => (
          <div class="bg-white/10 hover:bg-white/15 transition-colors duration-200 rounded-2xl p-4 text-center">
            <div class="flex justify-center mb-2 text-forest-300" set:html={icono} />
            <div class="text-lg font-bold text-white">{valor}</div>
            <div class="text-xs text-slate-400 mt-0.5">{etiqueta}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ── ADSENSE RANURA 1 ────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="my-6 adsense-placeholder">
      <ins class="adsbygoogle w-full"
           style="display:block"
           data-ad-client="ca-pub-6529337148344504"
           data-ad-slot="2297179243"
           data-ad-format="auto"
           data-full-width-responsive="true"></ins>
    </div>
  </div>
  <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>

  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

      <!-- ── CONTENIDO PRINCIPAL ───────────────────────────────────────────── -->
      <div class="lg:col-span-2 space-y-12">

        <!-- Aviso sobre horarios -->
        <div class="bg-amber-50 border border-amber-200 rounded-2xl p-5">
          <div class="flex gap-3">
            <div class="shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            </div>
            <div>
              <h2 class="font-bold text-amber-900 mb-1">Aviso sobre Horarios</h2>
              <p class="text-sm text-amber-800 leading-relaxed">
                Los horarios que se muestran son orientativos y se verificaron por última vez en la temporada 2024. Los horarios del ferry cambian por temporada y sin previo aviso. <strong>Confirma siempre el horario actual directamente con la naviera antes de tu travesía.</strong> Consulta también la sección de assoreamento más abajo para entender los riesgos específicos de este cruce.
              </p>
            </div>
          </div>
        </div>

        <!-- Horario de verano -->
        <section>
          <h2 class="text-2xl font-bold text-forest-900 mb-2">Horario de Verano (Abril – Octubre)</h2>
          <p class="text-slate-600 text-sm mb-5 leading-relaxed">
            Servicio diario. Aproximadamente cada 30–60 minutos entre las 09:00 y las 19:00. El servicio funciona en ambas direcciones. El intervalo entre las 12:30 y las 14:00 corresponde al descanso del operador — planifica tu salida para evitar esperas innecesarias.
          </p>
          <div class="overflow-x-auto rounded-2xl border border-slate-200 shadow-sm">
            <table class="w-full text-sm">
              <caption class="sr-only">Horario del ferry de verano, Caminha a A Guarda y vuelta</caption>
              <thead>
                <tr class="bg-slate-800 text-white">
                  <th scope="col" class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider">Salida</th>
                  <th scope="col" class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider">Llegada</th>
                  <th scope="col" class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider">Ruta</th>
                </tr>
              </thead>
              <tbody>
                {horarioVerano.map((fila, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-slate-50/70'}>
                    <td class="px-4 py-2.5 font-mono font-semibold text-forest-800">{fila.salida}</td>
                    <td class="px-4 py-2.5 font-mono text-slate-600">{fila.llegada}</td>
                    <td class="px-4 py-2.5 text-slate-700">{fila.ruta}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        <!-- Horario de invierno -->
        <section>
          <h2 class="text-2xl font-bold text-forest-900 mb-2">Horario de Invierno (Noviembre – Marzo)</h2>
          <p class="text-slate-600 text-sm leading-relaxed mb-4">
            Servicio reducido — normalmente solo fines de semana y festivos, con salidas aproximadas a las 10:00, 12:00 y 16:00 (Caminha → A Guarda) y viajes de vuelta correspondientes. El servicio puede suspenderse por condiciones meteorológicas adversas en el estuario del Miño.
          </p>
          <div class="bg-slate-50 border border-slate-200 rounded-2xl p-5 text-sm text-slate-700 leading-relaxed">
            <strong>Nota para peregrinos en invierno:</strong> Muy pocos peregrinos realizan el Camino de la Costa en invierno debido al servicio reducido del ferry. Si planeas un Camino invernal, considera el Camino Portugués Interior (por Tui/Valença) como alternativa más fiable — el puente Valença–Tui está operativo 24/7.
          </div>
        </section>

        <!-- Tarifas -->
        <section>
          <h2 class="text-2xl font-bold text-forest-900 mb-4">Tarifas y Billetes</h2>
          <div class="overflow-x-auto rounded-2xl border border-slate-200 shadow-sm">
            <table class="w-full text-sm">
              <caption class="sr-only">Tarifas del ferry de Caminha a A Guarda</caption>
              <thead>
                <tr class="bg-forest-900 text-white">
                  <th scope="col" class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider">Tipo de billete</th>
                  <th scope="col" class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider">Precio</th>
                  <th scope="col" class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider">Notas</th>
                </tr>
              </thead>
              <tbody>
                {[
                  { tipo: 'Adulto (ida)', precio: '2,50 €', nota: 'Los peregrinos pagan tarifa adulta estándar' },
                  { tipo: 'Niño menor de 4 años', precio: 'Gratis', nota: 'Sin asignación de asiento' },
                  { tipo: 'Niño 4–12 años', precio: '1,50 €', nota: 'Puede solicitarse DNI o pasaporte' },
                  { tipo: 'Bicicleta', precio: '1,50 €', nota: 'Cargo adicional sobre la tarifa de pasajero' },
                  { tipo: 'Billete de vuelta', precio: '5,00 €', nota: 'Ligero ahorro respecto a dos billetes de ida' },
                ].map((fila, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-slate-50/70'}>
                    <td class="px-4 py-2.5 font-medium text-slate-800">{fila.tipo}</td>
                    <td class="px-4 py-2.5 font-mono font-bold text-forest-700">{fila.precio}</td>
                    <td class="px-4 py-2.5 text-slate-600">{fila.nota}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
