---
import MainLayout from '../../../layouts/MainLayout.astro';

const alojamientos = [
  // ── ALBERGUES ────────────────────────────────────────────────────────────────
  {
    name: 'Albergue Municipal de Peregrinos de Caminha',
    tipo: 'Albergue Municipal de Peregrinos',
    categoria: 'albergue',
    direccion: 'Rua Ricardo Joaquim de Sousa, Caminha',
    precioDesde: '12 €',
    credencial: true,
    camas: 28,
    telefono: '+351 258 921 130',
    horario: 'Entrada desde las 14:00 · Salida antes de las 09:00',
    descripcion: 'El albergue municipal oficial, gestionado por la parroquia local. Se da prioridad a los peregrinos con credencial válida. Literas en dormitorios compartidos con taquillas individuales, baños compartidos y cocina comunitaria. El hospitalero puede sellar tu credencial y orientarte sobre la etapa del día siguiente hasta A Guarda. En julio y agosto, llega antes de las 13:30 para hacer cola — las 28 camas se agotan en menos de una hora tras la apertura.',
    servicios: ['Sello de credencial', 'Cocina comunitaria', 'Consigna de equipaje', 'Lavadoras', 'Tendedero exterior', 'Wi-Fi'],
    notas: 'Credencial de peregrino obligatoria. Sin habitaciones privadas. Máximo 2 noches consecutivas. Sin reservas online — solo por orden de llegada.',
    reservaUrl: null,
  },

  // ── PENSIONES / CASAS DE HUÉSPEDES ───────────────────────────────────────────
  {
    name: 'Casa de Santiago',
    tipo: 'Pensión para Peregrinos',
    categoria: 'pension',
    direccion: 'Rua da Corredoura 22, Caminha',
    precioDesde: '25 €',
    credencial: false,
    camas: null,
    telefono: '+351 919 234 567',
    horario: 'Entrada flexible · Salida antes de las 11:00',
    descripcion: 'Una acogedora casa de huéspedes familiar a dos manzanas de la plaza mayor, muy popular entre los peregrinos del Camino de la Costa. Habitaciones privadas limpias con baño en suite, desayuno continental incluido y unos anfitriones que han caminado ellos mismos el Camino — conocen de primera mano cada cierre del ferry por assoreamiento. Algunas habitaciones tienen vistas a la torre del castillo. Muy flexibles con la entrega anticipada del equipaje.',
    servicios: ['Desayuno incluido', 'Baño en suite', 'Traslado de equipaje (preguntar antes)', 'Sello de credencial', 'Consejos del Camino de los anfitriones', 'Wi-Fi'],
    notas: 'Descuentos para peregrinos disponibles — preguntar al reservar. Se prefiere efectivo o transferencia bancaria.',
    reservaUrl: 'https://www.booking.com/city/pt/caminha.html?aid=7968251',
  },
  {
    name: 'Pensão Galo d\'Ouro',
    tipo: 'Pensión Económica',
    categoria: 'pension',
    direccion: 'Praça do Conselho 15, Caminha',
    precioDesde: '35 €',
    credencial: false,
    camas: null,
    telefono: '+351 258 921 160',
    horario: 'Recepción 08:00–22:00 · Flexible bajo petición',
    descripcion: 'Justo en la plaza mayor, esta pensión de estilo tradicional ofrece una ubicación inmejorable a precio asequible. Las habitaciones son sencillas pero muy limpias; varias dan a la fuente de granito medieval y a la Torre do Relógio del siglo XVI. El café de la planta baja abre a las 7:30 — ideal para un café tempranero antes de ir al Cais para tomar el primer ferry del día. La mejor relación calidad-precio para habitación privada en Caminha.',
    servicios: ['Ubicación central', 'Café/bar en el local', 'Desayuno disponible (no incluido)', 'Wi-Fi'],
    notas: 'Las habitaciones en el último piso requieren subir escaleras — ten en cuenta si llevas mochila pesada o tienes problemas en las rodillas.',
    reservaUrl: 'https://www.booking.com/city/pt/caminha.html?aid=7968251',
  },
  {
    name: 'Parque de Campismo de Caminha',
    tipo: 'Área de Camping',
    categoria: 'pension',
    direccion: 'Mata Nacional, Caminha (1,2 km del centro)',
    precioDesde: '7 €',
    credencial: false,
    camas: null,
    telefono: '+351 258 921 295',
    horario: 'Recepción 08:00–21:00',
    descripcion: 'Un bien mantenido camping en un parque forestal nacional a las afueras de Caminha, cerca de la playa atlántica. Las instalaciones incluyen parcelas para tiendas y autocaravanas, cocina compartida, duchas calientes y una pequeña tienda. La opción de alojamiento más económica de la zona, perfecta para peregrinos autosuficientes con equipo ligero. Una consideración práctica: los 1,2 km de caminata hasta el pueblo añaden tiempo antes de la salida matutina del ferry.',
    servicios: ['Parcelas para tiendas', 'Duchas calientes', 'Cocina compartida', 'Pequeña tienda', 'Acceso a la playa (300m)', 'Aparcabicicletas'],
    notas: 'Abierto todo el año. Descuento para peregrinos con credencial. El camino al embarcadero añade aproximadamente 1,5 km a tu mañana.',
    reservaUrl: 'https://www.booking.com/city/pt/caminha.html?aid=7968251',
  },

  // ── ALBERGUES ADICIONALES ─────────────────────────────────────────────────────
  {
    name: 'Pousada de Juventude de Caminha',
    tipo: 'Albergue Juvenil — Red Movijovem · Abierto a Todas las Edades',
    categoria: 'albergue',
    direccion: 'Rua Visconde Sousa Rego, Caminha (cerca del paseo fluvial)',
    precioDesde: '15 €',
    credencial: false,
    camas: 40,
    telefono: '+351 707 203 030',
    horario: 'Recepción 09:00–12:00 · 18:00–23:00 · Flexible para peregrinos en temporada alta',
    descripcion: 'Parte de la red nacional Movijovem de albergues juveniles portugueses, la Pousada de Juventude de Caminha acoge peregrinos y viajeros de todas las edades durante todo el año. A diferencia del albergue municipal, no se exige credencial de peregrino y la reserva online está disponible a través del portal Movijovem (+351 707 203 030) y las principales plataformas de reserva. Las instalaciones incluyen dormitorios separados por género, un número limitado de habitaciones privadas básicas, cocina compartida, lavandería y salón comunitario. Situada cerca del paseo fluvial, a unos 10 minutos a pie de la plaza mayor y 12 minutos del embarcadero del Cais. Una opción práctica para acompañantes no peregrinos, llegadas tardías que perdieron plaza en el albergue municipal, o peregrinos sin credencial.',
    servicios: ['Reserva online disponible', 'Sin credencial obligatoria', 'Cocina compartida', 'Lavandería', 'Salón comunitario', 'Habitaciones privadas disponibles', 'Wi-Fi'],
    notas: 'Reserva con antelación en julio–agosto — la red Movijovem se llena en todo el norte de Portugal en temporada alta. Sello de credencial disponible informalmente — preguntar en recepción.',
    reservaUrl: 'https://www.booking.com/city/pt/caminha.html?aid=7968251',
  },

  // ── ALOJAMIENTOS ADICIONALES ──────────────────────────────────────────────────
  {
    name: 'Quinta do Deão — Turismo Rural',
    tipo: 'Casa Rural · Turismo de Habitação',
    categoria: 'pension',
    direccion: 'Lugar de Vilar, Caminha (2,2 km del centro, en el trazado señalizado del Camino)',
    precioDesde: '50 €',
    credencial: false,
    camas: null,
    telefono: '+351 258 722 190',
    horario: 'Entrada flexible · Salida antes de las 11:00',
    descripcion: 'Una tradicional casa de piedra del Miño registrada bajo el esquema portugués de "Turismo de Habitação" — la categoría de alojamiento rural que combina el carácter auténtico del campo con la hospitalidad de los anfitriones. Las habitaciones privadas con baño en suite dan a un patio de granito con jardín y pequeño viñedo, con vistas al valle del Miño y las colinas de la Serra de Arga. La propiedad se encuentra directamente en el trazado señalizado del Camino de la Costa entre Moledo y Caminha — los peregrinos pueden incorporarse o retomar las flechas amarillas desde la misma puerta. Los propietarios son residentes veteranos del valle del Miño con profundo conocimiento de las etapas del Camino, el comportamiento estacional del estuario del Miño y qué operadores de taxi acuático están activos. El desayuno continental con miel regional, queso local, pan fresco y mermeladas caseras está incluido. Planifica bien la mañana: los 2,2 km hasta el embarcadero del Cais tardan unos 25–30 minutos — sal antes de las 08:30 para tomar el ferry de las 09:00.',
    servicios: ['Desayuno incluido', 'Baño en suite', 'Señales del Camino desde la puerta', 'Jardín con viñedo', 'Vistas al valle del Miño', 'Asesoramiento local sobre el Camino', 'Wi-Fi', 'Almuerzo para llevar bajo petición'],
    notas: 'La caminata hasta Caminha es por el trazado señalizado del Camino — los 2,2 km se hacen en ruta, sin desvío. Reserva directa o a través de Booking.com. Se prefiere efectivo o transferencia bancaria.',
    reservaUrl: 'https://www.booking.com/city/pt/caminha.html?aid=7968251',
  },

  // ── HOTELES DE CATEGORÍA ──────────────────────────────────────────────────────
  {
    name: 'Design Wine Hotel',
    tipo: 'Hotel Boutique del Vino',
    categoria: 'hotel',
    direccion: 'Rua Visconde Sousa Rego 20, Caminha',
    precioDesde: '89 €',
    credencial: false,
    camas: null,
    telefono: '+351 258 922 500',
    horario: 'Entrada desde las 15:00 · Salida antes de las 12:00',
    descripcion: 'El alojamiento más estiloso de Caminha, este hotel boutique celebra la cultura vinícola del Miño a través de la arquitectura, el arte y una bodega curada con productores locales de Vinho Verde. Las habitaciones contemporáneas tienen duchas tipo lluvia, ropa de cama premium y artículos de aseo artesanales. La terraza panorámica ofrece vistas hacia la orilla española del Miño — perfecta para un reparador vaso de Alvarinho tras una larga etapa costera. Un bar de vinos sirve tablas de charcutería y maridajes cada noche. Sellos de credencial disponibles bajo petición. Se puede organizar traslado de equipaje a A Guarda.',
    servicios: ['Bar de vinos y bodega', 'Terraza panorámica con vistas al río', 'Aire acondicionado', 'Ducha tipo lluvia', 'Traslado de equipaje a A Guarda (bajo petición)', 'Sello de credencial', 'Desayuno disponible (+12 €)', 'Almacenamiento seguro de bicicletas', 'Wi-Fi'],
    notas: 'No está orientado específicamente a peregrinos, pero es muy cordial con ellos. Se llena rápido en julio–agosto; reserva con al menos 3 semanas de antelación en temporada alta.',
    reservaUrl: 'https://www.booking.com/city/pt/caminha.html?aid=7968251',
  },
];

const secciones: { key: string; etiqueta: string; intro: string }[] = [
  {
    key: 'albergue',
    etiqueta: 'Albergues de Peregrinos',
    intro: 'Los albergues oficiales de peregrinos son el corazón de la experiencia del Camino de Santiago. Funcionan con el sistema de credencial, mantienen precios de 10–15 € y crean la camaradería nocturna que define el camino. El albergue municipal de Caminha está a pocos minutos del embarcadero del ferry.',
  },
  {
    key: 'pension',
    etiqueta: 'Pensiones y Alojamientos Económicos',
    intro: 'Las pensiones y casas de huéspedes ofrecen habitaciones privadas sin las normas del albergue — sin toque de queda, sin credencial obligatoria, entrada flexible. Precios desde 25 € por habitación. Ideales para peregrinos que valoran la privacidad o necesitan descansar un día extra.',
  },
  {
    key: 'hotel',
    etiqueta: 'Hoteles de Categoría',
    intro: 'Para el peregrino que quiere comodidad plena al final de una etapa dura, los hoteles de categoría de Caminha ofrecen camas, baños y una copa de Vinho Verde que hacen que los dolores merezcan la pena. Reserva con antelación: la temporada alta (junio–septiembre) tiene alta demanda tanto de peregrinos del Camino como de turistas del Valle del Miño.',
  },
];
---

<MainLayout
  title="Dónde Dormir en Caminha — Albergues, Pensiones y Hoteles | Caminho de Santiago"
  description="Guía completa de alojamiento en Caminha para peregrinos del Camino de Santiago de la Costa. Albergue municipal desde 12 €, pensiones desde 25 €, hotel boutique desde 89 €. Incluye consejos de reserva para temporada alta."
  lang="es"
  schemaType="webpage"
>

  <!-- ── ENCABEZADO DE PÁGINA ─────────────────────────────────────────────────── -->
  <div class="bg-gradient-to-b from-forest-50 to-white border-b border-forest-100/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <nav aria-label="Ruta de navegación" class="mb-5">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/es/" class="hover:text-forest-700 no-underline hover:underline transition-colors">Inicio</a></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li><span class="text-slate-400">Caminha</span></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li aria-current="page" class="text-slate-700 font-medium">Dónde Dormir</li>
        </ol>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold text-forest-900 mb-4 tracking-tight">Dónde Dormir en Caminha</h1>
      <p class="text-slate-600 max-w-2xl text-base leading-relaxed">
        Caminha es el último pueblo portugués antes del cruce del Miño — la etapa final antes de que los peregrinos del Camino de la Costa entren en Galicia. Aquí encontrarás desde una litera en albergue municipal por 12 € hasta un hotel boutique con bar de vinos y terraza panorámica por 89 €.
      </p>
      <div class="mt-6 flex flex-wrap gap-2.5">
        {secciones.map((s) => (
          <a href={`#${s.key}`} class="inline-flex items-center gap-1.5 bg-white border border-forest-200 text-forest-800 text-xs font-medium px-3.5 py-2 rounded-full hover:bg-forest-50 hover:border-forest-300 no-underline transition-all duration-200 shadow-sm cursor-pointer">
            {s.etiqueta.split('—')[0].trim()}
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- ── ADSENSE RANURA 1 ───────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="my-6 adsense-placeholder">
      <ins class="adsbygoogle w-full"
           style="display:block"
           data-ad-client="ca-pub-6529337148344504"
           data-ad-slot="2297179243"
           data-ad-format="auto"
           data-full-width-responsive="true"></ins>
    </div>
  </div>
  <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>

  <!-- ── AVISO DE RESERVA EN TEMPORADA ALTA ──────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-4">
    <div class="bg-gradient-to-br from-amber-50 to-earth-50 border border-amber-300/70 rounded-2xl p-6 shadow-sm">
      <div class="flex gap-4">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-earth-100 border border-earth-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-earth-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
        </div>
        <div>
          <h2 class="font-bold text-amber-900 mb-2 text-base">Reserva con Antelación: Temporada Alta Mayo–Octubre</h2>
          <p class="text-sm text-amber-800 leading-relaxed">
            El Camino de Santiago de la Costa alcanza su máximo tráfico entre <strong>mayo y octubre</strong>. Las 28 camas del albergue municipal son por orden de llegada y habitualmente se agotan antes de las 14:30 en julio y agosto. Las pensiones privadas suelen completarse días antes de Semana Santa y en los meses de verano.
          </p>
          <p class="text-sm text-amber-800 leading-relaxed mt-2">
            <strong>Norma práctica:</strong> Si llegas entre junio y septiembre, reserva tu pensión u hotel con al menos 5–7 días de antelación. Para el albergue, intenta llegar al embarcadero antes del ferry de las 13:00 — el hospitalero abre a las 14:00 y las camas se asignan al momento.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- ── SECCIONES DE ALOJAMIENTO ─────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 space-y-16">

    {secciones.map((seccion, seccionIdx) => {
      const items = alojamientos.filter(a => a.categoria === seccion.key);
      return (
        <section id={seccion.key} aria-labelledby={`heading-${seccion.key}`}>
          <div class="mb-8">
            <h2 id={`heading-${seccion.key}`} class="text-2xl font-bold text-forest-900 tracking-tight">
              {seccion.etiqueta}
            </h2>
            <p class="mt-2 text-slate-600 text-sm leading-relaxed max-w-2xl">{seccion.intro}</p>
          </div>

          <div class="grid grid-cols-1 gap-6">
            {items.map((a) => (
              <article class="bg-white rounded-2xl border border-slate-200/80 overflow-hidden hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 shadow-sm">
                <div class="p-6 sm:p-8">
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-5">
                    <div>
                      <div class="flex flex-wrap items-center gap-2 mb-1.5">
                        <h3 class="text-xl font-bold text-forest-900 tracking-tight">{a.name}</h3>
                        {a.credencial && (
                          <span class="inline-flex items-center gap-1 text-xs font-semibold bg-earth-100 text-earth-800 px-2.5 py-1 rounded-full border border-earth-200">
                            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            Credencial obligatoria
                          </span>
                        )}
                      </div>
                      <p class="text-sm text-slate-500 font-medium">{a.tipo}</p>
                    </div>
                    <div class="shrink-0 text-right">
                      <p class="text-xl font-bold text-forest-700">Desde {a.precioDesde}</p>
                      {a.camas && <p class="text-xs text-slate-400 mt-0.5">{a.camas} camas en total</p>}
                    </div>
                  </div>

                  <p class="text-slate-700 leading-relaxed mb-6 text-sm sm:text-base">{a.descripcion}</p>

                  <div class="mb-6">
                    <h4 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-3">Servicios</h4>
                    <ul class="flex flex-wrap gap-2">
                      {a.servicios.map((s) => (
                        <li class="text-xs bg-forest-50 text-forest-700 px-3 py-1.5 rounded-full border border-forest-100 font-medium">
                          {s}
                        </li>
                      ))}
                    </ul>
                  </div>

                  {a.notas && (
                    <div class="bg-earth-50 border border-earth-200/70 rounded-xl px-4 py-3 mb-6 flex gap-2.5 text-xs text-earth-800">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-earth-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                      <span><strong>Nota:</strong> {a.notas}</span>
                    </div>
                  )}

                  <div class="pt-5 border-t border-slate-100 flex flex-col sm:flex-row sm:items-center gap-4">
                    <div class="flex flex-col sm:flex-row gap-3 text-sm text-slate-500 flex-1 flex-wrap">
                      <span class="flex items-center gap-1.5">
                        <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        {a.direccion}
                      </span>
                      <span class="flex items-center gap-1.5">
                        <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        {a.horario}
                      </span>
                      <a href={`tel:${a.telefono}`} class="flex items-center gap-1.5 no-underline hover:text-forest-700 transition-colors cursor-pointer">
                        <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                        {a.telefono}
                      </a>
                    </div>

                    {a.reservaUrl && (
                      <a
                        href={a.reservaUrl}
                        rel="nofollow noopener noreferrer sponsored"
                        target="_blank"
                        class="inline-flex items-center justify-center gap-2 bg-earth-500 hover:bg-earth-600 active:bg-earth-700 text-white font-semibold text-sm px-6 py-3 rounded-xl transition-all duration-200 no-underline shrink-0 shadow-sm hover:shadow-md cursor-pointer group"
                      >
                        Comprobar Disponibilidad
                        <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                        </svg>
                      </a>
                    )}
                  </div>
                </div>
              </article>
            ))}
          </div>

          {/* AdSense ranura 2 — entre Albergues y Pensiones */}
          {seccionIdx === 0 && (
            <div class="mt-10 adsense-placeholder">
              <ins class="adsbygoogle w-full"
                   style="display:block"
                   data-ad-client="ca-pub-6529337148344504"
                   data-ad-slot="8017929699"
                   data-ad-format="auto"
                   data-full-width-responsive="true"></ins>
            </div>
          )}
        </section>
      );
    })}
  </div>
  <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>

  <!-- ── TIENDAS ESENCIALES PARA PEREGRINOS ─────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-12">
    <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
      <div class="bg-gradient-to-r from-slate-800 to-forest-900 px-6 py-5">
        <h2 class="text-lg font-bold text-white tracking-tight flex items-center gap-2.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-earth-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
          Tiendas Esenciales en el Centro de Caminha
        </h2>
        <p class="text-slate-300 text-sm mt-1">Establecimientos a distancia a pie de la plaza mayor para peregrinos que necesitan reabastecerse antes o después del cruce del Miño.</p>
      </div>
      <div class="p-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">

        <div class="bg-forest-50 border border-forest-100 rounded-xl p-4">
          <div class="flex items-center gap-2 mb-2">
            <div class="h-7 w-7 rounded-lg bg-forest-700 flex items-center justify-center shrink-0">
              <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            </div>
            <p class="font-bold text-forest-900 text-sm">Pingo Doce</p>
          </div>
          <p class="text-xs text-slate-600 leading-relaxed">Supermercado completo — fruta fresca, charcutería, pan, bebidas isotónicas y comida para el camino. Mejor opción de reabastecimiento del pueblo para peregrinos autosuficientes.</p>
          <p class="text-xs text-slate-500 mt-2 font-medium">Rua 5 de Outubro, Caminha · ~350m de la plaza mayor</p>
          <p class="text-xs text-slate-400 mt-0.5">Lun–Sáb 08:00–21:00 · Dom 09:00–19:00</p>
        </div>

        <div class="bg-slate-50 border border-slate-100 rounded-xl p-4">
          <div class="flex items-center gap-2 mb-2">
            <div class="h-7 w-7 rounded-lg bg-slate-700 flex items-center justify-center shrink-0">
              <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            </div>
            <p class="font-bold text-slate-800 text-sm">Lidl Caminha</p>
          </div>
          <p class="text-xs text-slate-600 leading-relaxed">Supermercado de descuento en las afueras. Ideal para comida energética a granel, protector solar económico, botiquín básico y barritas de energía a mejor precio que las tiendas del centro.</p>
          <p class="text-xs text-slate-500 mt-2 font-medium">EN-301, afueras · ~1,1 km de la plaza mayor</p>
          <p class="text-xs text-slate-400 mt-0.5">Lun–Sáb 08:00–21:00 · Dom 09:00–19:00</p>
        </div>

        <div class="bg-red-50 border border-red-100 rounded-xl p-4">
          <div class="flex items-center gap-2 mb-2">
            <div class="h-7 w-7 rounded-lg bg-red-600 flex items-center justify-center shrink-0">
              <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <p class="font-bold text-red-900 text-sm">Farmácia Central</p>
          </div>
          <p class="text-xs text-slate-600 leading-relaxed">Farmacia central para kits anti-ampollas, ibuprofeno, sobres de electrolitos, vendas compresivas, crema antifúngica y protector solar. Se habla inglés y español en temporada alta.</p>
          <p class="text-xs text-slate-500 mt-2 font-medium">Praça do Conselho, Caminha · En la plaza mayor</p>
          <p class="text-xs text-slate-400 mt-0.5">Lun–Vie 09:00–19:00 · Sáb 09:00–13:00</p>
        </div>

        <div class="bg-earth-50 border border-earth-100 rounded-xl p-4">
          <div class="flex items-center gap-2 mb-2">
            <div class="h-7 w-7 rounded-lg bg-earth-600 flex items-center justify-center shrink-0">
              <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            </div>
            <p class="font-bold text-earth-900 text-sm">Equipamiento</p>
          </div>
          <p class="text-xs text-slate-600 leading-relaxed">Para calcetines de emergencia, chubasqueros y bastones de marcha, busca las tiendas de artículos deportivos en Rua Visconde Sousa Rego. Surtido completo en Viana do Castelo (25 km al sur) si las tiendas de Caminha no tienen tu talla.</p>
          <p class="text-xs text-slate-500 mt-2 font-medium">Rua Visconde Sousa Rego · Centro histórico</p>
          <p class="text-xs text-slate-400 mt-0.5">Horario variable · La mayoría Lun–Sáb</p>
        </div>

      </div>
    </div>
  </div>

