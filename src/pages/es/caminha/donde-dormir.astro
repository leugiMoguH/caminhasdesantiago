---
import MainLayout from '../../../layouts/MainLayout.astro';
import PhotoFigure from '../../../components/PhotoFigure.astro';
import marginalPhoto from '../../../assets/photos/caminha-marginal-rio-minho.jpg';
import { bookingLink, bookingSearch, stayLabel } from '../../../lib/booking';

type Zona = 'caminha' | 'vpa' | 'seixas';
type Categoria = 'albergue' | 'hotel' | 'pension';

interface Alojamiento {
  nombre: string;
  zona: Zona;
  categoria: Categoria;
  tipo: string;
  direccion: string;
  ubicacion: string;
  diferenciadores: string[];
  reservaUrl: string | null;
  nota?: string;
}

const alojamientos: Alojamiento[] = [
  // ── CAMINHA ────────────────────────────────────────────────────────────────────
  {
    nombre: 'Albergue Municipal de Peregrinos de Caminha',
    zona: 'caminha',
    categoria: 'albergue',
    tipo: 'Albergue Municipal de Peregrinos',
    direccion: 'Rua Ricardo Joaquim de Sousa, Caminha',
    ubicacion: 'Centro urbano, a pocos minutos del embarcadero del ferry',
    diferenciadores: ['Albergue municipal oficial', 'Credencial de peregrino obligatoria'],
    reservaUrl: null,
    nota: 'Solo admisión directa — sin reservas online. Abre a las 14:00. Por orden de llegada. Se requiere credencial válida. Máximo 2 noches consecutivas.',
  },
  {
    nombre: 'Albergue Santiago de Caminha',
    zona: 'caminha',
    categoria: 'albergue',
    tipo: 'Albergue Privado de Peregrinos',
    direccion: '',
    ubicacion: 'Centro de Caminha, en la ruta del Camino junto al río',
    diferenciadores: ['Reserva online anticipada disponible', 'Bar y cafetería en el alojamiento'],
    reservaUrl: 'https://www.booking.com/hotel/pt/albergue-santiago-de-caminha.html',
  },
  {
    nombre: 'Bom Caminha — Albergue Privado para Peregrinos',
    zona: 'caminha',
    categoria: 'albergue',
    tipo: 'Albergue Privado de Peregrinos',
    direccion: '',
    ubicacion: 'Casco antiguo, casa histórica de 1882',
    diferenciadores: ['Cena de peregrinos opcional (suplemento de 12 €)', 'Cocina comunitaria; reserva anticipada disponible'],
    reservaUrl: 'https://www.booking.com/hotel/pt/bom-caminha-private-albergue-amp-guest-house.html',
  },
  {
    nombre: 'Litos AL',
    zona: 'caminha',
    categoria: 'pension',
    tipo: 'Casa de Huéspedes',
    direccion: 'Largo Senhora da Agonia 13, Caminha',
    ubicacion: 'Centro urbano, cerca del paseo fluvial',
    diferenciadores: ['Desayuno incluido', 'Habitaciones con aire acondicionado'],
    reservaUrl: 'https://www.booking.com/hotel/pt/litos-al.html',
  },
  {
    nombre: 'Donna Nega Alojamento Local',
    zona: 'caminha',
    categoria: 'pension',
    tipo: 'Casa de Huéspedes',
    direccion: '',
    ubicacion: 'Centro de Caminha, terraza solárium y cocina compartida',
    diferenciadores: ['Cocina y salón compartidos', 'Terraza; aparcamiento de bicicletas'],
    reservaUrl: 'https://www.booking.com/hotel/pt/patricia-lourenco.html',
  },
  {
    nombre: 'Design & Wine Hotel',
    zona: 'caminha',
    categoria: 'hotel',
    tipo: 'Hotel',
    direccion: '',
    ubicacion: 'Centro urbano, edificio histórico del siglo XVIII',
    diferenciadores: ['Piscina interior', 'Bar de vinos y restaurante en el hotel'],
    reservaUrl: 'https://www.booking.com/hotel/pt/design.html',
  },
  {
    nombre: 'Hotel Porta do Sol Conference & SPA',
    zona: 'caminha',
    categoria: 'hotel',
    tipo: 'Hotel — 4 Estrellas',
    direccion: '',
    ubicacion: 'Cerca de la desembocadura del río y la playa atlántica',
    diferenciadores: ['2 piscinas exteriores', 'Spa y instalaciones de bienestar'],
    reservaUrl: 'https://www.booking.com/hotel/pt/porta-do-sol-caminha.html',
  },

  // ── VILA PRAIA DE ÂNCORA ───────────────────────────────────────────────────────
  {
    nombre: 'BLUE ANCORA HOTEL',
    zona: 'vpa',
    categoria: 'hotel',
    tipo: 'Hotel',
    direccion: '',
    ubicacion: 'Zona costera, a 3 minutos a pie de la Playa de Vila Praia de Âncora',
    diferenciadores: ['Piscina exterior de temporada', 'Habitaciones con vistas al mar y balcón'],
    reservaUrl: 'https://www.booking.com/hotel/pt/blue-ancora.html',
  },
  {
    nombre: 'Hotel Meira',
    zona: 'vpa',
    categoria: 'hotel',
    tipo: 'Hotel — 4 Estrellas',
    direccion: '',
    ubicacion: 'Cerca de la playa, en un valle protegido del viento',
    diferenciadores: ['Piscina', 'Buffet de desayuno incluido'],
    reservaUrl: 'https://www.booking.com/hotel/pt/hotelmeiravilapraiaancora.html',
  },

  // ── SEIXAS ─────────────────────────────────────────────────────────────────────
  {
    nombre: 'Albergue de São Bento',
    zona: 'seixas',
    categoria: 'albergue',
    tipo: 'Albergue de Peregrinos',
    direccion: '',
    ubicacion: 'Frente al mar en la parroquia de Seixas, a 1 km de la Playa de Pedras Ruivas',
    diferenciadores: ['Ubicación frente al mar', 'Cenas de peregrinos disponibles; cocina comunitaria'],
    reservaUrl: 'https://www.booking.com/hotel/pt/albergue-de-sao-bento.html',
  },
  {
    nombre: 'Rinoterra Minho',
    zona: 'seixas',
    categoria: 'hotel',
    tipo: 'Hotel Rural',
    direccion: 'Rua da Costa 15, Seixas, Caminha',
    ubicacion: 'Rural, parroquia de Seixas, vistas al río y a la montaña',
    diferenciadores: ['Spa y centro de bienestar', 'Tenis; restaurante de cocina portuguesa'],
    reservaUrl: 'https://www.booking.com/hotel/pt/rinoterra-minho.html',
  },
];

const zonas: { clave: Zona; etiqueta: string; intro: string }[] = [
  {
    clave: 'caminha',
    etiqueta: 'Caminha',
    intro: 'La principal localidad de cruce en la Ruta Costera Portuguesa — última etapa antes de cruzar el río Miño hacia Galicia. Albergues, pensiones y hoteles, todos a poca distancia a pie del embarcadero del ferry.',
  },
  {
    clave: 'vpa',
    etiqueta: 'Vila Praia de Âncora',
    intro: 'Localidad costera a 8 km al sur de Caminha, en la ruta del Camino. Hoteles de playa con piscinas — alternativa más tranquila para peregrinos que prefieren llegar pronto y continuar hacia el norte a la mañana siguiente.',
  },
  {
    clave: 'seixas',
    etiqueta: 'Seixas',
    intro: 'La parroquia inmediatamente al sur del casco urbano de Caminha, en el camino señalizado de la Ruta Costera. Densidad baja — un albergue de peregrinos y un hotel rural, ambos reservables en Booking.com.',
  },
];

const ordenCategorias: Categoria[] = ['albergue', 'pension', 'hotel'];
const etiquetaCategoria: Record<Categoria, string> = {
  albergue: 'Albergues',
  pension: 'Pensiones',
  hotel: 'Hoteles',
};
---

<MainLayout
  title="Dónde Dormir en Caminha, Vila Praia de Âncora y Seixas"
  description="Guía de alojamiento verificado para peregrinos de la Ruta Costera del Camino de Santiago. Albergues, pensiones y hoteles en Caminha, Vila Praia de Âncora y Seixas — todos reservables en Booking.com."
  lang="es"
  schemaType="webpage"
>

  <!-- ── JSON-LD: ItemList de alojamientos (paridad con EN where-to-stay) ───── -->
  <script type="application/ld+json" is:inline set:html={`
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "ItemList",
          "@id": "https://waytosantiagoguide.com/es/caminha/donde-dormir/#list",
          "mainEntityOfPage": { "@id": "https://waytosantiagoguide.com/es/caminha/donde-dormir/#webpage" },
          "name": "Alojamiento en Caminha, Vila Praia de Âncora y Seixas — Camino de Santiago de la Costa",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "item": { "@type": "Hostel", "name": "Albergue Municipal de Peregrinos de Caminha", "description": "Albergue municipal oficial de peregrinos en el centro de Caminha, a pocos minutos del embarcadero del ferry. Solo admisión directa desde las 14:00, con credencial.", "address": { "@type": "PostalAddress", "streetAddress": "Rua Ricardo Joaquim de Sousa", "addressLocality": "Caminha", "addressCountry": "PT" } } },
            { "@type": "ListItem", "position": 2, "item": { "@type": "Hostel", "name": "Albergue Santiago de Caminha", "description": "Albergue privado de peregrinos en el centro de Caminha, reservable en línea. Bar y cafetería en el establecimiento.", "address": { "@type": "PostalAddress", "addressLocality": "Caminha", "addressCountry": "PT" } } },
            { "@type": "ListItem", "position": 3, "item": { "@type": "Hostel", "name": "Bom Caminha — Albergue Privado para Peregrinos", "description": "Albergue privado en una casa señorial restaurada de 1882 en el casco antiguo de Caminha. Cena de peregrino opcional, cocina comunitaria, reserva anticipada disponible.", "address": { "@type": "PostalAddress", "addressLocality": "Caminha", "addressCountry": "PT" } } },
            { "@type": "ListItem", "position": 4, "item": { "@type": "LodgingBusiness", "name": "Litos AL", "description": "Casa de huéspedes en el centro de Caminha, cerca del paseo fluvial. Desayuno incluido, habitaciones con aire acondicionado.", "address": { "@type": "PostalAddress", "streetAddress": "Largo Senhora da Agonia 13", "addressLocality": "Caminha", "addressCountry": "PT" } } },
            { "@type": "ListItem", "position": 5, "item": { "@type": "Hotel", "name": "Design & Wine Hotel", "description": "Hotel en un edificio del siglo XVIII en el centro de Caminha. Piscina cubierta, bar de vinos.", "address": { "@type": "PostalAddress", "addressLocality": "Caminha", "addressCountry": "PT" } } },
            { "@type": "ListItem", "position": 6, "item": { "@type": "Hotel", "name": "Hotel Porta do Sol Conference & SPA", "description": "Hotel de 4 estrellas cerca de la desembocadura del río y de la playa atlántica en Caminha. Dos piscinas exteriores, spa.", "address": { "@type": "PostalAddress", "addressLocality": "Caminha", "addressCountry": "PT" } } },
            { "@type": "ListItem", "position": 7, "item": { "@type": "Hotel", "name": "BLUE ANCORA HOTEL", "description": "Hotel en Vila Praia de Âncora, a 3 minutos a pie de la playa. Piscina exterior de temporada, habitaciones con vistas al mar.", "address": { "@type": "PostalAddress", "addressLocality": "Vila Praia de Âncora", "addressCountry": "PT" } } },
            { "@type": "ListItem", "position": 8, "item": { "@type": "Hotel", "name": "Hotel Meira", "description": "Hotel de 4 estrellas en Vila Praia de Âncora, cerca de la playa. Piscina, desayuno bufé incluido.", "address": { "@type": "PostalAddress", "addressLocality": "Vila Praia de Âncora", "addressCountry": "PT" } } },
            { "@type": "ListItem", "position": 9, "item": { "@type": "Hostel", "name": "Albergue de São Bento", "description": "Albergue de peregrinos frente al mar en la parroquia de Seixas. Cenas de peregrino disponibles, cocina compartida.", "address": { "@type": "PostalAddress", "addressLocality": "Seixas, Caminha", "addressCountry": "PT" } } },
            { "@type": "ListItem", "position": 10, "item": { "@type": "Hotel", "name": "Rinoterra Minho", "description": "Hotel rural en la parroquia de Seixas con vistas al río y a la montaña. Spa, tenis, restaurante portugués.", "address": { "@type": "PostalAddress", "streetAddress": "Rua da Costa 15", "addressLocality": "Seixas, Caminha", "addressCountry": "PT" } } }
          ]
        },
        {
          "@type": "FAQPage",
          "@id": "https://waytosantiagoguide.com/es/caminha/donde-dormir/#faq",
          "mainEntityOfPage": { "@id": "https://waytosantiagoguide.com/es/caminha/donde-dormir/#webpage" },
          "mainEntity": [
            { "@type": "Question", "name": "¿Se puede reservar con antelación el albergue municipal de Caminha?", "acceptedAnswer": { "@type": "Answer", "text": "No. El Albergue Municipal de Peregrinos de Caminha es solo de admisión directa, abre a las 14:00 por orden de llegada. Se exige una credencial del peregrino válida. La estancia máxima es de 2 noches consecutivas. Los albergues privados (Albergue Santiago, Bom Caminha) sí se pueden reservar en línea con antelación a través de Booking.com." } },
            { "@type": "Question", "name": "¿Hay alojamiento cerca del embarcadero del ferry de Caminha?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. El albergue municipal y la mayoría de las pensiones de Caminha están a 5–10 minutos a pie del embarcadero del ferry (Cais de Caminha). El centro es compacto — todo el alojamiento listado está a poca distancia a pie del punto de salida." } },
            { "@type": "Question", "name": "¿Qué tipos de alojamiento hay en Caminha para peregrinos?", "acceptedAnswer": { "@type": "Answer", "text": "Caminha ofrece: albergue municipal (admisión directa, con credencial), albergues privados (reserva anticipada disponible), pensiones y hoteles. La zona más amplia incluye hoteles de playa en Vila Praia de Âncora (8 km al sur) y un albergue frente al mar más un hotel rural en Seixas." } },
            { "@type": "Question", "name": "¿Cuándo conviene reservar alojamiento en Caminha para el Camino de la Costa?", "acceptedAnswer": { "@type": "Answer", "text": "La Ruta de la Costa alcanza su punto álgido de mayo a octubre. Los albergues privados y hoteles deberían reservarse con 1–2 semanas de antelación en temporada alta (julio–agosto). El albergue municipal no se puede reservar y se llena las tardes de verano — llega antes de las 15:00 en temporada alta." } }
          ]
        }
      ]
    }
  `} />

  <div class="bg-gradient-to-b from-forest-50 to-white border-b border-forest-100/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <nav aria-label="Ruta de navegación" class="mb-5">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/es/" class="hover:text-forest-700 no-underline hover:underline transition-colors">Inicio</a></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li><span class="text-slate-500">Caminha</span></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li aria-current="page" class="text-slate-700 font-medium">Dónde Dormir</li>
        </ol>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold text-forest-900 mb-4 tracking-tight">Dónde Dormir</h1>
      <p class="text-slate-600 max-w-2xl text-base leading-relaxed">
        Alojamiento verificado en tres zonas de la Ruta Costera Portuguesa: Caminha (localidad de cruce del río), Vila Praia de Âncora (costera, 8 km al sur) y Seixas (parroquia en ruta al sur de Caminha). Todos los hoteles enlazan directamente con Booking.com. En temporada alta (mayo–octubre) las camas en Caminha son limitadas, así que reserva con antelación.
      </p>
      <div class="mt-6 flex flex-wrap gap-2.5">
        {zonas.map((z) => (
          <a href={`#zona-${z.clave}`} class="inline-flex items-center gap-1.5 bg-white border border-forest-200 text-forest-800 text-xs font-medium px-3.5 py-2 rounded-full hover:bg-forest-50 hover:border-forest-300 no-underline transition-all duration-200 shadow-sm cursor-pointer">
            {z.etiqueta}
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- ── Foto de la ribera de Caminha ──────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <PhotoFigure
      src={marginalPhoto}
      alt="La ribera de Caminha sobre el río Miño — el paseo fluvial donde se concentran los albergues y casas de huéspedes del centro"
      caption="La ribera del río Miño en Caminha — la mayoría de las camas céntricas están a pocos minutos"
      loading="eager"
    />
  </div>
  

  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-4">
    <div class="bg-amber-50 border border-amber-300/70 rounded-2xl p-6 shadow-sm">
      <div class="flex gap-4">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-amber-100 border border-amber-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
        </div>
        <div>
          <h2 class="font-bold text-amber-900 mb-2 text-base">Reserva con antelación: temporada alta mayo–octubre</h2>
          <p class="text-sm text-amber-800 leading-relaxed">
            La Ruta Costera alcanza su punto álgido entre mayo y octubre. El albergue municipal de Caminha funciona solo con admisión directa y se llena rápidamente en las tardes de verano. Los albergues privados y hoteles admiten reservas anticipadas — usa los enlaces que aparecen a continuación para comprobar disponibilidad.
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 space-y-20">

    {zonas.map((zona, zonaIdx) => {
      const itemsZona = alojamientos.filter(a => a.zona === zona.clave);
      return (
        <section id={`zona-${zona.clave}`} aria-labelledby={`encabezado-zona-${zona.clave}`}>
          <div class="mb-8 pb-4 border-b border-slate-200">
            <h2 id={`encabezado-zona-${zona.clave}`} class="text-2xl font-bold text-forest-900 tracking-tight mb-1">
              {zona.etiqueta}
            </h2>
            <p class="text-slate-600 text-sm leading-relaxed max-w-2xl">{zona.intro}</p>
          </div>

          {ordenCategorias.map((cat) => {
            const catItems = itemsZona.filter(a => a.categoria === cat);
            if (catItems.length === 0) return null;
            return (
              <div class="mb-10">
                <h3 class="text-base font-semibold text-slate-500 uppercase tracking-widest mb-5">{etiquetaCategoria[cat]}</h3>
                <div class="grid grid-cols-1 gap-5">
                  {catItems.map((a) => (
                    <article class="bg-white rounded-2xl border border-slate-200/80 overflow-hidden hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 shadow-sm">
                      <div class="p-6 sm:p-8">
                        <div class="mb-4">
                          <h4 class="text-xl font-bold text-forest-900 tracking-tight mb-0.5">{a.nombre}</h4>
                          <p class="text-sm text-slate-500 font-medium">{a.tipo}</p>
                        </div>

                        <div class="flex flex-wrap gap-2 mb-4">
                          {a.diferenciadores.map((d) => (
                            <span class="text-xs bg-forest-50 text-forest-700 px-3 py-1.5 rounded-full border border-forest-100 font-medium">{d}</span>
                          ))}
                        </div>

                        {a.nota && (
                          <div class="bg-amber-50 border border-amber-200/70 rounded-xl px-4 py-3 mb-5 flex gap-2.5 text-xs text-amber-800">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-amber-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            <span>{a.nota}</span>
                          </div>
                        )}

                        <div class="pt-4 border-t border-slate-100 flex flex-col sm:flex-row sm:items-center gap-4">
                          {a.direccion && (
                            <div class="flex items-center gap-1.5 text-sm text-slate-500 flex-1">
                              <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                              </svg>
                              {a.direccion}
                            </div>
                          )}

                          {a.reservaUrl ? (
                            <a
                              href={bookingLink(a.reservaUrl, stayLabel(a.nombre, 'es'))}
                              rel="nofollow noopener noreferrer sponsored"
                              target="_blank"
                              class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-earth-600 to-earth-700 hover:from-earth-700 hover:to-earth-800 active:scale-[0.98] text-white font-bold text-sm px-6 py-3.5 rounded-xl transition-all duration-200 no-underline shrink-0 shadow-md hover:shadow-lg cursor-pointer group"
                            >
                              Consultar Disponibilidad y Precios
                              <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                              </svg>
                            </a>
                          ) : (
                            <span class="inline-flex items-center gap-2 bg-slate-100 text-slate-600 font-semibold text-sm px-5 py-3 rounded-xl shrink-0">
                              Solo admisión directa
                            </span>
                          )}
                        </div>
                      </div>
                    </article>
                  ))}
                </div>
              </div>
            );
          })}

          {zonaIdx === 1 && (
            <div class="mt-6">
              
            </div>
          )}
        </section>
      );
    })}
  </div>
  

  <!-- ── CTA: VER TODOS ──────────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-4">
    <div class="bg-forest-50 border border-forest-200 rounded-2xl p-6 flex flex-col sm:flex-row sm:items-center gap-4">
      <div class="flex-1">
        <h2 class="text-base font-bold text-forest-900 mb-1">Más alojamientos en Caminha</h2>
        <p class="text-sm text-slate-600 leading-relaxed">Caminha también tiene pensiones, apartamentos y B&amp;B además de los listados arriba — por ejemplo la Residencial Galo d'Ouro en la plaza principal y apartamentos junto al Miño. Consulta disponibilidad y precios de todos los alojamientos de la villa.</p>
      </div>
