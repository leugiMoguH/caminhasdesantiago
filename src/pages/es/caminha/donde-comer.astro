---
import MainLayout from '../../../layouts/MainLayout.astro';

type Zona = 'caminha' | 'vpa';

interface Restaurante {
  nombre: string;
  zona: Zona;
  cocina: string;
  direccion: string;
  contextoUbicacion: string;
  conocidoPor: string;
  contextoPeregrino: string;
  urlMaps: string;
}

interface Cafe {
  nombre: string;
  direccion: string;
  utilidad: string;
  urlMaps: string;
}

const restaurantes: Restaurante[] = [
  {
    nombre: 'Restaurante Baptista',
    zona: 'caminha',
    cocina: 'Portuguesa · Marisco',
    direccion: 'Praça do Conselheiro Silva Torres 24/26, Caminha',
    contextoUbicacion: 'En la plaza principal (Praça Conselheiro Silva Torres)',
    conocidoPor: 'Local histórico en la plaza principal; marisco portugués de temporada y cocina tradicional',
    contextoPeregrino: 'Opción central para sentarse; adecuado para almorzar o cenar en la plaza mayor',
    urlMaps: 'https://www.google.com/maps/search/?q=Restaurante+Baptista+Caminha',
  },
  {
    nombre: 'Muralha de Caminha',
    zona: 'caminha',
    cocina: 'Mediterránea · Europea',
    direccion: 'Praça de Espanha, Caminha',
    contextoUbicacion: 'Junto a las murallas medievales históricas',
    conocidoPor: 'Terraza exterior frente a las murallas de la ciudad; cocina regional del Miño',
    contextoPeregrino: 'Terraza exterior tras la llegada; ideal para cenar al principio de la tarde',
    urlMaps: 'https://www.google.com/maps/search/?q=Muralha+de+Caminha',
  },
  {
    nombre: 'Solar do Pescado',
    zona: 'caminha',
    cocina: 'Marisco · Mediterránea',
    direccion: 'Rua Visconde Sousa Rego 85, Caminha',
    contextoUbicacion: 'Calle principal hacia el río y el embarcadero del ferry',
    conocidoPor: 'Marisco atlántico fresco en la ruta hacia el ferry',
    contextoPeregrino: 'En la ruta al embarcadero del ferry; buena parada para comer antes del cruce',
    urlMaps: 'https://www.google.com/maps/search/?q=Solar+do+Pescado+Caminha',
  },
  {
    nombre: 'Casa Almeida',
    zona: 'caminha',
    cocina: 'Café · Europea · Portuguesa',
    direccion: 'Praça Conselheiro Silva Torres, Caminha',
    contextoUbicacion: 'En la plaza principal',
    conocidoPor: 'Café y restaurante en la plaza principal; menú portugués tradicional',
    contextoPeregrino: 'Parada flexible en la plaza mayor; apta para comidas ligeras o café a cualquier hora',
    urlMaps: 'https://www.google.com/maps/search/?q=Casa+Almeida+Caminha',
  },
  {
    nombre: 'O Chafariz',
    zona: 'caminha',
    cocina: 'Europea · Portuguesa',
    direccion: '',
    contextoUbicacion: 'Centro urbano',
    conocidoPor: 'Cocina portuguesa tradicional con numerosa clientela local',
    contextoPeregrino: 'Buena opción para una cena tradicional en el centro; popular entre los locales',
    urlMaps: 'https://www.google.com/maps/search/?q=O+Chafariz+Caminha',
  },
  {
    nombre: 'Fortaleza Restaurante',
    zona: 'vpa',
    cocina: 'Marisco · Mediterránea',
    direccion: 'Avenida Dr. Ramos Pereira 81, Vila Praia de Âncora',
    contextoUbicacion: 'Paseo marítimo de Vila Praia de Âncora',
    conocidoPor: 'Marisco atlántico fresco en el principal paseo gastronómico frente al mar',
    contextoPeregrino: 'Comida o cena junto al mar en Vila Praia de Âncora; conveniente si se pernocta aquí',
    urlMaps: 'https://www.google.com/maps/search/?q=Fortaleza+Restaurante+Vila+Praia+de+Ancora',
  },
  {
    nombre: 'Restaurante Vitória Mar',
    zona: 'vpa',
    cocina: 'Marisco · Mediterránea',
    direccion: 'Avenida Dr. Luis Ramos Pereira 100, Vila Praia de Âncora',
    contextoUbicacion: 'Paseo marítimo de Vila Praia de Âncora',
    conocidoPor: 'Marisco en el principal paseo frente al mar; valorado de forma consistente',
    contextoPeregrino: 'Alternativa frente al mar en VPA; útil si Fortaleza está lleno',
    urlMaps: 'https://www.google.com/maps/search/?q=Restaurante+Vitoria+Mar+Vila+Praia+de+Ancora',
  },
];

const cafes: Cafe[] = [
  {
    nombre: 'Pastelaria Caminhense',
    direccion: 'Rua São João 35, Caminha',
    utilidad: 'Ubicación central; pastelería con servicio en mostrador, ideal para un café rápido antes de la salida',
    urlMaps: 'https://www.google.com/maps/search/?q=Pastelaria+Caminhense+Caminha',
  },
  {
    nombre: 'Pastelaria Riviera',
    direccion: '',
    utilidad: 'Pastelería en el centro; café y pasteles para llevar',
    urlMaps: 'https://www.google.com/maps/search/?q=Pastelaria+Riviera+Caminha',
  },
];

const etiquetasZona: Record<Zona, string> = {
  caminha: 'Caminha',
  vpa: 'Vila Praia de Âncora',
};
const zonas: Zona[] = ['caminha', 'vpa'];
---

<MainLayout
  title="Dónde Comer en Caminha y Vila Praia de Âncora | Camino de Santiago"
  description="Restaurantes y cafeterías verificados en Caminha y Vila Praia de Âncora para peregrinos de la Ruta Costera del Camino de Santiago. Marisco portugués tradicional, desayunos tempranos y gastronomía local."
  lang="es"
  schemaType="webpage"
>

  <div class="bg-gradient-to-b from-earth-50 to-white border-b border-earth-100/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <nav aria-label="Ruta de navegación" class="mb-5">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/es/" class="hover:text-forest-700 no-underline hover:underline transition-colors">Inicio</a></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li><span class="text-slate-400">Caminha</span></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li aria-current="page" class="text-slate-700 font-medium">Dónde Comer</li>
        </ol>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold text-forest-900 mb-4 tracking-tight">Dónde Comer</h1>
      <p class="text-slate-600 max-w-2xl text-base leading-relaxed">
        Restaurantes verificados en Caminha y Vila Praia de Âncora. Todos los establecimientos están confirmados en Google Maps y TripAdvisor. Seixas no dispone de infraestructura gastronómica propia — los peregrinos que se alojan allí van a Caminha a cenar.
      </p>
      <div class="mt-6 flex flex-wrap gap-2.5">
        <a href="#restaurantes" class="inline-flex items-center gap-1.5 bg-white border border-earth-200 text-earth-800 text-xs font-medium px-3.5 py-2 rounded-full hover:bg-earth-50 hover:border-earth-300 no-underline transition-all duration-200 shadow-sm cursor-pointer">
          Restaurantes
        </a>
        <a href="#desayuno-temprano" class="inline-flex items-center gap-1.5 bg-white border border-earth-200 text-earth-800 text-xs font-medium px-3.5 py-2 rounded-full hover:bg-earth-50 hover:border-earth-300 no-underline transition-all duration-200 shadow-sm cursor-pointer">
          Desayuno Temprano y Cafeterías
        </a>
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="my-6">
      <ins class="adsbygoogle w-full"
           style="display:block"
           data-ad-client="ca-pub-6529337148344504"
           data-ad-slot="2297179243"
           data-ad-format="auto"
           data-full-width-responsive="true"></ins>
    </div>
  </div>
  <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>

  <div id="restaurantes" class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 space-y-16">
    {zonas.map((zona) => {
      const items = restaurantes.filter(r => r.zona === zona);
      return (
        <section aria-labelledby={`encabezado-${zona}`}>
          <div class="mb-6 pb-4 border-b border-slate-200">
            <h2 id={`encabezado-${zona}`} class="text-2xl font-bold text-forest-900 tracking-tight">
              {etiquetasZona[zona]}
            </h2>
          </div>
          <div class="grid grid-cols-1 gap-5">
            {items.map((r) => (
              <article class="bg-white rounded-2xl border border-slate-200/80 overflow-hidden hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 shadow-sm">
                <div class="p-6 sm:p-8">
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-3">
                    <div class="min-w-0">
                      <h3 class="text-xl font-bold text-forest-900 tracking-tight mb-0.5">{r.nombre}</h3>
                      <p class="text-sm text-slate-500 font-medium">{r.cocina}</p>
                    </div>
                    <span class="text-xs bg-forest-50 text-forest-700 px-3 py-1.5 rounded-full border border-forest-100 font-medium self-start break-words sm:max-w-[13rem]">{r.contextoPeregrino}</span>
                  </div>
                  <p class="text-slate-700 text-sm leading-relaxed mb-4">{r.conocidoPor}</p>
                  <div class="flex flex-wrap items-center gap-3 text-sm text-slate-500 pt-4 border-t border-slate-100">
                    {r.direccion && (
                      <span class="flex items-center gap-1.5">
                        <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                        {r.direccion}
                      </span>
                    )}
                    <span class="flex items-center gap-1.5 text-xs text-slate-400">
                      <svg class="h-4 w-4 shrink-0 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      </svg>
                      {r.contextoUbicacion}
                    </span>
                    <a href={r.urlMaps} rel="noopener noreferrer" target="_blank" class="ml-auto inline-flex items-center gap-1.5 text-xs text-forest-600 hover:text-forest-800 font-medium no-underline hover:underline transition-colors">
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                      </svg>
                      Ver en Maps
                    </a>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>
      );
    })}
  </div>

  <!-- ── CTA: BUCLE INTERNO ─────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-6">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href="/es/caminha/donde-dormir/" class="flex items-center gap-4 bg-white border border-forest-200 rounded-2xl p-5 hover:shadow-md hover:border-forest-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-forest-50 border border-forest-100">
          <svg class="h-5 w-5 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-forest-900 group-hover:text-forest-700">Dónde Dormir</p>
          <p class="text-xs text-slate-500">Albergues, pensiones y hoteles en Caminha, VPA y Seixas</p>
        </div>
      </a>
      <a href="/es/caminha/ferry-y-logistica/" class="flex items-center gap-4 bg-white border border-earth-200 rounded-2xl p-5 hover:shadow-md hover:border-earth-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-earth-50 border border-earth-100">
          <svg class="h-5 w-5 text-earth-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-earth-900 group-hover:text-earth-700">Ferry y Logística</p>
          <p class="text-xs text-slate-500">Horarios, tarifas y alternativas para el cruce del Miño</p>
        </div>
      </a>
      <a href="/es/caminha/servicios-utiles/" class="flex items-center gap-4 bg-white border border-slate-200 rounded-2xl p-5 hover:shadow-md hover:border-slate-300 transition-all no-underline group">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-slate-50 border border-slate-100">
          <svg class="h-5 w-5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-slate-900 group-hover:text-slate-700">Servicios Útiles</p>
          <p class="text-xs text-slate-500">Farmacias de guardia, tiendas de equipamiento y cajeros</p>
        </div>
      </a>
    </div>
  </div>

  <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>

  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-2">
    <ins class="adsbygoogle w-full"
         style="display:block"
         data-ad-client="ca-pub-6529337148344504"
         data-ad-slot="8017929699"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
  </div>
  <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>

  <div id="desayuno-temprano" class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-6 pb-4 border-b border-slate-200">
      <h2 class="text-2xl font-bold text-forest-900 tracking-tight mb-1">Desayuno Temprano y Cafeterías — Caminha</h2>
      <p class="text-slate-600 text-sm leading-relaxed max-w-2xl">
        Pastelerías en el centro de Caminha útiles para salidas antes del ferry. Los horarios pueden variar según la temporada — confirma directamente en el establecimiento o pregunta en tu alojamiento.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {cafes.map((c) => (
        <div class="bg-white rounded-2xl border border-slate-200/80 p-6 shadow-sm">
          <h3 class="text-base font-bold text-forest-900 mb-1">{c.nombre}</h3>
          {c.direccion && (
            <p class="text-xs text-slate-500 mb-3 flex items-center gap-1.5">
              <svg class="h-3.5 w-3.5 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              {c.direccion}
            </p>
          )}
          <p class="text-xs text-amber-700 font-medium bg-amber-50 border border-amber-100 rounded-lg px-3 py-2 mb-3">
            Abre pronto (generalmente hacia las 07:00–08:00, puede variar)
          </p>
          <p class="text-sm text-slate-600 leading-relaxed mb-4">{c.utilidad}</p>
          <a href={c.urlMaps} rel="noopener noreferrer" target="_blank" class="mt-auto inline-flex items-center gap-1.5 text-xs text-forest-600 hover:text-forest-800 font-medium no-underline hover:underline transition-colors">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            Ver en Maps
          </a>
        </div>
      ))}
    </div>
    <p class="mt-6 text-xs text-slate-400 leading-relaxed max-w-xl">
      Los horarios indicados son aproximados. Confirma siempre con el establecimiento, especialmente fuera de temporada alta (junio–septiembre). No hay cafeterías en Seixas — los peregrinos alojados allí caminan hasta Caminha (aprox. 15–20 min) para el café de la mañana.
    </p>
  </div>

  <aside class="bg-gradient-to-b from-forest-50 to-white border-y border-forest-100/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <div class="flex gap-4">
        <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl bg-forest-100 border border-forest-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-forest-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
        </div>
        <div>
          <h2 class="text-lg font-bold text-forest-900 mb-2 tracking-tight">Menús de Peregrino</h2>
          <p class="text-slate-700 text-sm leading-relaxed max-w-2xl">
            En Portugal, el <em>menú do peregrino</em> se sirve normalmente solo en el almuerzo (12:00–15:00) por 8–12 €. Incluye primer plato, segundo, postre o café y vino o agua de la casa. Mostrar una <em>credencial do peregrino</em> puede confirmar la elegibilidad, aunque la mayoría de restaurantes en Caminha no la exigen. Muchos locales pequeños cierran los lunes. Consulta la pizarra del menú en el exterior antes de sentarte.
          </p>
        </div>
      </div>
    </div>
  </aside>

  <!-- ── BOOKING CTA ────────────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10">
    <div class="bg-gradient-to-r from-earth-50 to-amber-50 border border-earth-200/60 rounded-2xl p-6 sm:p-8 flex flex-col sm:flex-row sm:items-center gap-6">
      <div class="flex-1">
        <h2 class="text-lg font-bold text-earth-900 mb-1 tracking-tight">¿Necesitas alojamiento en Caminha?</h2>
        <p class="text-sm text-slate-600 leading-relaxed">Albergues desde 12 €, pensiones y hoteles de 4 estrellas — todo reservable en Booking.com.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 shrink-0">
        <a href="https://www.booking.com/searchresults.html?ss=Caminha%2C+Portugal&aid=7968251" rel="nofollow noopener noreferrer sponsored" target="_blank" class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-earth-500 to-earth-600 hover:from-earth-600 hover:to-earth-700 active:scale-[0.98] text-white font-bold text-sm px-6 py-3.5 rounded-xl transition-all duration-200 no-underline shadow-md hover:shadow-lg cursor-pointer group">
          Ver Disponibilidad
          <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
        <a href="/es/caminha/donde-dormir/" class="inline-flex items-center justify-center gap-2 bg-white border border-earth-200 text-earth-800 font-semibold text-sm px-5 py-3.5 rounded-xl hover:bg-earth-50 hover:border-earth-300 no-underline transition-all duration-200">Ver todas las opciones →</a>
      </div>
    </div>
  </div>

</MainLayout>
