---
import MainLayout from '../../../layouts/MainLayout.astro';

const restaurantes = [
  {
    name: 'Tasca do Avô',
    tipo: 'Cocina Casera Portuguesa · Solo Almuerzos',
    direccion: 'Rua da Corredoura 8, Caminha',
    precio: '€',
    precioDetalle: 'Menú por 8 €',
    menuPeregrino: true,
    precioMenu: '8 €',
    horario: 'Lun–Vie 12:00–15:00',
    distanciaCamino: '280m del Camino (3 min a pie desde la plaza mayor)',
    notaVegetariana: 'Habitualmente hay un plato principal vegetariano los viernes; limitado otros días — llamar con antelación.',
    nivelVegetariano: 'limited',
    descripcion: 'El mejor almuerzo económico de Caminha, sin discusión. Un local pequeño y sin pretensiones muy apreciado por lugareños, pescadores y peregrinos. El menú del día cambia según lo que haya fresco en el mercado — siempre una o dos opciones generosas con pan casero y medio litro de vino de la casa incluido. A 8 € por tres platos con vino, este es el menú del peregrino definitivo de la villa. Solo efectivo, sin datáfono. Llega antes de las 12:30 o tendrás que hacer cola en la calle.',
    destacados: ['El menú del peregrino más económico de la villa', 'Siempre lleno de lugareños — señal de calidad', 'Solo efectivo', 'Producto del mercado más fresco'],
    telefono: null,
    seccion: 'economico',
  },
  {
    name: 'Restaurante O Barão',
    tipo: 'Cocina Portuguesa Tradicional / Mariscos',
    direccion: 'Praça do Conselho, Caminha',
    precio: '€€',
    precioDetalle: 'Menú 10 € / Carta 18–28 €',
    menuPeregrino: true,
    precioMenu: '10 €',
    horario: 'Lun–Sáb 12:00–15:00, 19:00–22:00',
    distanciaCamino: 'En la plaza mayor — 200m de las señales del Camino, directamente en ruta',
    notaVegetariana: 'Apto para vegetarianos: pasta y platos de huevo siempre disponibles como alternativa al menú del peregrino bajo petición.',
    nivelVegetariano: 'friendly',
    descripcion: 'Situado en la histórica plaza mayor con terraza exterior, O Barão es el lugar más atmosférico para el almuerzo del peregrino en Caminha. El menú do peregrino incluye entrante (caldo verde o ensalada de atún), plato principal (bacalhau à brás o besugo a la plancha), pan, vino de la casa y postre. El pulpo a la plancha (polvo grelhado) de la carta es excepcional. Muestra tu credencial para confirmar el precio del menú con descuento.',
    destacados: ['Menú del peregrino 10 € con vino', 'Terraza exterior en la plaza histórica', 'Pescado fresco del Atlántico a diario', 'Credencial aceptada para descuento'],
    telefono: '+351 258 921 234',
    seccion: 'economico',
  },
  {
    name: 'Pastelaria Central',
    tipo: 'Café / Panadería',
    direccion: 'Rua Ricardo Joaquim de Sousa 3, Caminha',
    precio: '€',
    precioDetalle: 'Menos de 5 € el desayuno',
    menuPeregrino: false,
    precioMenu: null,
    horario: 'Todos los días 07:00–19:00',
    distanciaCamino: '150m del Albergue Municipal, directamente entre el albergue y el embarcadero del ferry',
    notaVegetariana: 'Todos los artículos del menú son aptos para vegetarianos. Opciones veganas: baguettes tostadas sin mantequilla (preguntar en el mostrador).',
    nivelVegetariano: 'vegan',
    descripcion: 'La parada matutina imprescindible antes de embarcar en el ferry o reanudar el Camino. Pastéis de nata recién horneados que rivalizan con cualquier cosa de Lisboa, café galão bien cargado y bocadillos tostados bien rellenos. Abre a las 7:00 — suficientemente temprano para la salida del ferry a las 9:00. También preparan baguettes empaquetadas para llevar al camino.',
    destacados: ['Abre a las 7:00 — imprescindible antes del ferry', 'Mejores pastéis de nata de Caminha', 'Bocadillos preparados para el Camino', 'Desayuno completo por menos de 4 €'],
    telefono: '+351 258 921 100',
    seccion: 'economico',
  },
  {
    name: 'Petisco & Companhia',
    tipo: 'Petiscos / Bar de Vinos',
    direccion: 'Rua Visconde Sousa Rego 14, Caminha',
    precio: '€€',
    precioDetalle: '25–35 € por persona',
    menuPeregrino: false,
    precioMenu: null,
    horario: 'Mar–Dom 12:00–23:00 (cocina cierra a las 22:00)',
    distanciaCamino: '320m del Camino, 5 min a pie desde la plaza mayor hacia el río',
    notaVegetariana: 'Excelente para vegetarianos: queijo da Serra, petiscos de setas y platos de verdura de temporada. Tablas de queso vegano disponibles.',
    nivelVegetariano: 'vegan',
    descripcion: 'Un moderno bar de vinos que sirve petiscos tradicionales del Miño (tapas portuguesas) — ideal para una cena tranquila tras un largo día en la ruta costera. La filosofía aquí es el maridaje: cada plato se construye alrededor de un productor local de Vinho Verde. Destacan el presunto de Vinhais (jamón curado de montaña), la alheira (embutido ahumado), el queijo da Serra con miel de castaño y las setas silvestres de temporada con aceite. El lugar más social de Caminha. Terraza para perros.',
    destacados: ['Excepcional selección de Vinho Verde', 'Perfecto para compartir', 'Terraza para perros', 'Tablas vegetarianas disponibles'],
    telefono: '+351 910 456 789',
    seccion: 'gastronomia',
  },
  {
    name: 'Marisqueira A Lagosta',
    tipo: 'Restaurante de Mariscos — Especialista en Arroz de Debulho',
    direccion: 'Avenida Marginal, Caminha',
    precio: '€€€',
    precioDetalle: '35–55 € por persona',
    menuPeregrino: false,
    precioMenu: null,
    horario: 'Mar–Dom 12:30–15:00, 19:30–22:30',
    distanciaCamino: '600m del Camino, ribereño por la Avenida Marginal hacia el embarcadero del ferry',
    notaVegetariana: 'Opciones vegetarianas limitadas — es un restaurante de mariscos dedicado. Plato de verduras a la plancha disponible bajo petición.',
    nivelVegetariano: 'limited',
    descripcion: 'La opción de lujo en Caminha y visita obligada para quienes aman la gastronomía del río Miño. Esta marisquería ribereña lleva más de 30 años sirviendo los mejores mariscos de la región, con vistas panorámicas al estuario del Miño. El plato estrella es el <strong>arroz de debulho</strong> — un arroz denso y de sabor intensísimo cocinado con marisco fresco, una elaboración propia de este tramo de la costa del Miño que no encontrarás en la Galicia española. Pídelo para dos y llega con hambre.',
    destacados: ['Arroz de debulho exclusivo de la costa del Miño', 'Vistas panorámicas al estuario del Miño', 'Marisco vivo en vivero', 'Mejor restaurante de ocasiones especiales en Caminha', 'Percebes en temporada (otoño)'],
    telefono: '+351 258 922 300',
    seccion: 'gastronomia',
  },

  // ── LOCALES ADICIONALES ───────────────────────────────────────────────────────
  {
    name: 'Retiro da Foz',
    tipo: 'Restaurante Ribereño · Mariscos y Parrilla',
    direccion: 'Foz do Minho, Caminha (en la desembocadura del río, 700m al norte del embarcadero por el paseo marítimo)',
    precio: '€€',
    precioDetalle: '18–30 € por persona',
    menuPeregrino: false,
    precioMenu: null,
    horario: 'Mar–Dom 12:00–22:00 (cocina cierra a las 21:30)',
    distanciaCamino: '700m del Camino ribereño, 9 min al norte del embarcadero del ferry por la Avenida Marginal',
    notaVegetariana: 'Platos de verduras a la plancha y tortillas bajo petición. Opciones veganas muy limitadas — es un especialista en pescado de río y mar.',
    nivelVegetariano: 'limited',
    descripcion: 'Un favorito local escondido en la propia desembocadura del Miño (Foz do Minho), donde el río se fusiona con el Atlántico. El entorno es la razón para venir: las mesas exteriores dan directamente al canal del Miño con las colinas gallegas al otro lado del agua — el mismo cruce que todos los peregrinos del Camino de la Costa harán al día siguiente en ferry. El menú es sencillo y estacional: lamprea de río a la brasa en temporada (enero–abril), lubina fresca del Atlántico, calamar a la plancha y robustas sopas de pescado. Las raciones son generosas. Los peregrinos que llegan tarde tras una larga etapa desde Moledo suelen encontrar aquí una recompensadora cena final con vistas. Recomendable reservar para las mesas de la terraza en julio y agosto.',
    destacados: ['Vistas a la desembocadura del Miño', 'Lamprea de temporada (ene–abr)', 'Terraza exterior', 'Sopa de pescado destacada', 'A pasos del Camino ribereño'],
    telefono: '+351 258 921 610',
    seccion: 'gastronomia',
  },
  {
    name: 'Tasquinha da Foz',
    tipo: 'Tasca de Barrio · Menú del Peregrino',
    direccion: 'Largo da Foz, Caminha (cerca de la desembocadura del río)',
    precio: '€',
    precioDetalle: 'Menú 9 € / menos de 15 € a la carta',
    menuPeregrino: true,
    precioMenu: '9 €',
    horario: 'Lun–Sáb 12:00–15:30',
    distanciaCamino: '650m del Camino ribereño, 8 min a pie por el paseo norte desde la plaza mayor',
    notaVegetariana: 'La sopa del día siempre es vegetariana. Plato principal vegetariano bajo petición (tortilla o verduras a la plancha). Muy limitado — llamar con antelación.',
    nivelVegetariano: 'limited',
    descripcion: 'Una pequeña e informal tasca de barrio cerca de la Foz do Minho que pocos peregrinos encuentran precisamente porque requiere 5 minutos de desvío desde la plaza mayor — y eso es exactamente lo que la hace buena. Los habituales son pescadores y trabajadores del muelle, las raciones están pensadas para personas que hacen trabajo físico, y el menú del día a 9 € incluye pan fresco, una generosa sopa, un plato principal de pescado o carne con patatas y ensalada, y una copa de vino de la casa. El caldo de peixe (caldo de pescado) y el bacalhau assado (bacalao al horno) son las razones para sentarse. Sin artificios, solo ambiente auténticamente local, y efectivo únicamente. Ideal para peregrinos que quieren un almuerzo contundente antes de los últimos preparativos para el cruce matutino.',
    destacados: ['Auténticamente local — tasca de pescadores', 'Menú del día 9 € con vino', 'Caldo de pescado generoso', 'Solo efectivo', 'Pocos peregrinos lo conocen — sin colas'],
    telefono: null,
    seccion: 'economico',
  },
];

const secciones = [
  {
    key: 'economico',
    etiqueta: 'Menús del Peregrino — Menos de 10 €',
    intro: 'Estos restaurantes ofrecen el clásico menú do peregrino portugués: tres platos con pan y vino, servido al mediodía (normalmente 12:00–15:00) por 8–10 €. Muestra tu credencial do peregrino para confirmar la elegibilidad, aunque la mayoría no la pedirá. Todos están a menos de 350 metros de las señales del Camino en Caminha.',
  },
  {
    key: 'gastronomia',
    etiqueta: 'Gastronomía Tradicional del Miño — Arroz de Debulho y Pescado Fresco',
    intro: 'La región del Miño tiene su propia cocina, moldeada por la costa atlántica y el valle del río. Estas opciones van más allá del menú del peregrino y entran en la cocina auténtica de la zona — arroz de marisco, percebes frescos, maridajes con Vinho Verde y el intensamente sabroso arroz de debulho que no encontrarás en ningún otro lugar del Camino.',
  },
];

const precioBadgeClass: Record<string, string> = {
  '€':   'bg-forest-100 text-forest-800 border-forest-200',
  '€€':  'bg-earth-100 text-earth-800 border-earth-200',
  '€€€': 'bg-red-50 text-red-800 border-red-200',
};

const vegPillClass: Record<string, string> = {
  vegan:   'bg-forest-100 text-forest-800 border-forest-200',
  friendly:'bg-green-50 text-green-800 border-green-200',
  limited: 'bg-slate-100 text-slate-600 border-slate-200',
};
const vegPillLabel: Record<string, string> = {
  vegan:   'Opciones veganas',
  friendly:'Apto vegetarianos',
  limited: 'Veg. limitado',
};
---

<MainLayout
  title="Dónde Comer en Caminha — Menús del Peregrino, Mariscos del Miño y Vinho Verde"
  description="Los mejores restaurantes en Caminha para peregrinos del Camino de Santiago. Menús del peregrino desde 8 €, arroz de debulho, bares de Vinho Verde y cafeterías con apertura temprana cerca del ferry. Incluye distancias al Camino."
  lang="es"
  schemaType="webpage"
>

  <!-- ── ENCABEZADO ──────────────────────────────────────────────────────────── -->
  <div class="bg-gradient-to-b from-earth-50 to-white border-b border-earth-100/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <nav aria-label="Ruta de navegación" class="mb-5">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/es/" class="hover:text-forest-700 no-underline hover:underline transition-colors">Inicio</a></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li><span class="text-slate-400">Caminha</span></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li aria-current="page" class="text-slate-700 font-medium">Dónde Comer</li>
        </ol>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold text-forest-900 mb-4 tracking-tight">Dónde Comer en Caminha</h1>
      <p class="text-slate-600 max-w-2xl text-base leading-relaxed">
        Caminha tiene una oferta gastronómica que supera las expectativas para una villa de su tamaño. Desde menús del peregrino por 8 € hasta el arroz de debulho — un arroz con marisco único en esta franja de la costa del Miño. Se incluye la distancia desde las señales de ruta para cada local.
      </p>
      <div class="mt-6 flex flex-wrap gap-2.5">
        <span class="inline-flex items-center gap-1.5 bg-earth-100 text-earth-800 text-xs font-medium px-3.5 py-2 rounded-full border border-earth-200">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          {restaurantes.filter(r => r.menuPeregrino).length} restaurantes con menú del peregrino
        </span>
        <span class="inline-flex items-center gap-1.5 bg-forest-100 text-forest-800 text-xs font-medium px-3.5 py-2 rounded-full border border-forest-200">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          Notas vegetarianas en cada local
        </span>
        <span class="inline-flex items-center gap-1.5 bg-slate-100 text-slate-700 text-xs font-medium px-3.5 py-2 rounded-full border border-slate-200">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Distancias al Camino incluidas
        </span>
      </div>
    </div>
  </div>

  <!-- ── ADSENSE RANURA 1 ───────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="my-6 adsense-placeholder">
      <ins class="adsbygoogle w-full"
           style="display:block"
           data-ad-client="ca-pub-6529337148344504"
           data-ad-slot="2297179243"
           data-ad-format="auto"
           data-full-width-responsive="true"></ins>
    </div>
  </div>
  <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>

  <!-- ── SECCIONES DE RESTAURANTES ──────────────────────────────────────────── -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 space-y-16">

    {secciones.map((seccion, seccionIdx) => {
      const items = restaurantes.filter(r => r.seccion === seccion.key);
      return (
        <section id={seccion.key} aria-labelledby={`heading-${seccion.key}`}>
          <div class="mb-8">
            <h2 id={`heading-${seccion.key}`} class="text-2xl font-bold text-forest-900 tracking-tight">
              {seccion.etiqueta}
            </h2>
            <p class="mt-2 text-slate-600 text-sm leading-relaxed max-w-2xl">{seccion.intro}</p>
          </div>

          <div class="grid grid-cols-1 gap-6">
            {items.map((r) => (
              <article class="bg-white rounded-2xl border border-slate-200/80 overflow-hidden hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 shadow-sm">
                <div class="p-6 sm:p-8">
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-5">
                    <div>
                      <div class="flex flex-wrap items-center gap-2 mb-1.5">
                        <h3 class="text-xl font-bold text-forest-900 tracking-tight">{r.name}</h3>
                        {r.menuPeregrino && (
                          <span class="inline-flex items-center gap-1.5 bg-earth-100 text-earth-800 text-xs font-semibold px-2.5 py-1 rounded-full border border-earth-200">
                            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                            Menú peregrino {r.precioMenu}
                          </span>
                        )}
                      </div>
                      <p class="text-sm text-slate-500 font-medium">{r.tipo}</p>
                    </div>
                    <div class="flex flex-col items-end gap-2 shrink-0">
                      <span class={`font-mono text-sm font-bold px-3 py-1.5 rounded-lg border ${precioBadgeClass[r.precio]}`}>
                        {r.precio} <span class="font-normal text-xs">· {r.precioDetalle}</span>
                      </span>
                      <span class={`inline-flex items-center gap-1.5 text-xs font-semibold px-2.5 py-1 rounded-full border ${vegPillClass[r.nivelVegetariano]}`}>
                        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
                        {vegPillLabel[r.nivelVegetariano]}
                      </span>
                    </div>
                  </div>

                  <p class="text-slate-700 leading-relaxed mb-5 text-sm sm:text-base" set:html={r.descripcion} />

                  <div class="grid sm:grid-cols-2 gap-3 mb-5">
                    <div class="flex items-start gap-2.5 bg-slate-50 border border-slate-100 rounded-xl px-3.5 py-3 text-xs text-slate-700">
                      <svg class="h-4 w-4 text-slate-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                      <span><strong class="text-slate-800">Desde el Camino:</strong> {r.distanciaCamino}</span>
                    </div>
                    <div class={`flex items-start gap-2.5 rounded-xl px-3.5 py-3 text-xs border ${vegPillClass[r.nivelVegetariano]}`}>
                      <svg class="h-4 w-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
                      <span><strong>Veg/Vegano:</strong> {r.notaVegetariana}</span>
                    </div>
                  </div>

                  <ul class="flex flex-wrap gap-2 mb-5">
                    {r.destacados.map((d) => (
                      <li class="text-xs bg-earth-50 text-earth-700 px-3 py-1.5 rounded-full border border-earth-100 font-medium">
                        {d}
                      </li>
                    ))}
                  </ul>

                  <div class="pt-4 border-t border-slate-100 flex flex-col sm:flex-row gap-3 text-sm text-slate-500 flex-wrap">
                    <span class="flex items-center gap-1.5">
                      <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                      {r.direccion}
                    </span>
                    <span class="flex items-center gap-1.5">
                      <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                      {r.horario}
                    </span>
                    {r.telefono && (
                      <a href={`tel:${r.telefono}`} class="flex items-center gap-1.5 no-underline hover:text-forest-700 transition-colors cursor-pointer">
                        <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                        {r.telefono}
                      </a>
                    )}
                  </div>
                </div>
              </article>
            ))}
          </div>

          {seccionIdx === 0 && (
            <div class="mt-10 adsense-placeholder">
              <ins class="adsbygoogle w-full"
                   style="display:block"
                   data-ad-client="ca-pub-6529337148344504"
                   data-ad-slot="8017929699"
                   data-ad-format="auto"
