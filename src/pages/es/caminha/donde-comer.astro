  <!-- ── JSON-LD: FAQPage (paridad con EN where-to-eat) ──────────────────────── -->
  <script type="application/ld+json" is:inline set:html={`
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "@id": "https://waytosantiagoguide.com/es/caminha/donde-comer/#faq",
      "mainEntityOfPage": { "@id": "https://waytosantiagoguide.com/es/caminha/donde-comer/#webpage" },
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Hay menú del peregrino en los restaurantes de Caminha?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí. La mayoría de los restaurantes de Caminha sirven un menú do peregrino al almuerzo (12:00–15:00), normalmente por 8–12 €, que incluye primer plato, segundo, postre o café y vino o agua de la casa. Muchos restaurantes pequeños cierran los lunes."
          }
        },
        {
          "@type": "Question",
          "name": "¿Hay restaurantes en Seixas en el Camino de Santiago de la Costa?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Seixas no dispone de infraestructura gastronómica propia. Los peregrinos alojados en Seixas caminan hasta Caminha (aproximadamente 15–20 minutos) para comer."
          }
        },
        {
          "@type": "Question",
          "name": "¿Dónde pueden desayunar temprano los peregrinos cerca del ferry de Caminha?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Las pastelerías del centro de Caminha abren hacia las 07:00–08:00 (los horarios varían según la temporada). La Pastelaria Caminhense, en Rua São João 35, está ubicada en el centro. Confirma siempre los horarios localmente, especialmente fuera de temporada alta."
          }
        },
        {
          "@type": "Question",
          "name": "¿Exigen credencial de peregrino los restaurantes de Caminha?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "La mayoría de los restaurantes de Caminha no exigen una credencial do peregrino para servir el menú del peregrino. Mostrarla puede confirmar la elegibilidad, pero por lo general no es obligatorio."
          }
        }
      ]
    }
  `} />

  <div class="bg-gradient-to-b from-earth-50 to-white border-b border-earth-100/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <nav aria-label="Ruta de navegación" class="mb-5">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/es/" class="hover:text-forest-700 no-underline hover:underline transition-colors">Inicio</a></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li><span class="text-slate-300">Caminha</span></li>
          <li aria-hidden="true" class="text-slate-300">›</li>
          <li aria-current="page" class="text-slate-700 font-medium">Dónde Comer</li>
        </ol>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold text-forest-900 mb-4 tracking-tight">Dónde Comer</h1>
      <p class="text-slate-600 max-w-2xl text-base leading-relaxed">
        Restaurantes verificados en Caminha y Vila Praia de Âncora. Todos los establecimientos están confirmados en Google Maps y TripAdvisor. Seixas no dispone de infraestructura gastronómica propia — los peregrinos que se alojan allí van a Caminha a cenar.
      </p>
      <div class="mt-6 flex flex-wrap gap-2.5">
        <a href="#restaurantes" class="inline-flex items-center gap-1.5 bg-white border border-earth-200 text-earth-800 text-xs font-medium px-3.5 py-2 rounded-full hover:bg-earth-50 hover:border-earth-300 no-underline transition-all duration-200 shadow-sm cursor-pointer">
          Restaurantes
        </a>
        <a href="#desayuno-temprano" class="inline-flex items-center gap-1.5 bg-white border border-earth-200 text-earth-800 text-xs font-medium px-3.5 py-2 rounded-full hover:bg-earth-50 hover:border-earth-300 no-underline transition-all duration-200 shadow-sm cursor-pointer">
          Desayuno Temprano y Cafeterías
        </a>
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <PhotoFigure
      src={pracaPhoto}
      alt="Plaza Conselheiro Silva Torres en Caminha — terrazas de cafés y restaurantes bajo la Torre del Reloj medieval"
      caption="Plaza Conselheiro Silva Torres — terrazas en el corazón de Caminha"
      loading="eager"
    />
  </div>
  

  <div id="restaurantes" class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 space-y-16">
    {zonas.map((zona) => {
      const items = restaurantes.filter(r => r.zona === zona);
