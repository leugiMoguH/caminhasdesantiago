---
import MainLayout from '../layouts/MainLayout.astro';

const links = [
  { href: '/en/', label: 'Home', desc: 'Start here' },
  { href: '/en/caminha-guide/', label: 'Caminha Guide', desc: 'Complete coastal Camino guide' },
  { href: '/en/caminha/ferry-and-logistics/', label: 'Ferry & Logistics', desc: 'Minho crossing schedules & alternatives' },
  { href: '/en/caminha/where-to-stay/', label: 'Where to Stay', desc: 'Albergues, guesthouses & hotels' },
  { href: '/en/caminha/where-to-eat/', label: 'Where to Eat', desc: 'Restaurants & pilgrim menus' },
  { href: '/en/caminha/useful-services/', label: 'Useful Services', desc: 'Pharmacies, ATMs & emergencies' },
];
---

<MainLayout
  title="Page Not Found (404)"
  description="The page you were looking for could not be found. Return to the Way to Santiago Guide for the Camino de Santiago Coastal Route through Caminha, Portugal."
  lang="en"
  schemaType="webpage"
  noindex={true}
>

  <section class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-20 md:py-28 text-center">
    <p class="text-earth-600 text-xs font-bold uppercase tracking-widest mb-3">Error 404</p>
    <h1 class="text-4xl sm:text-5xl font-bold text-forest-900 mb-4 tracking-tight">Page Not Found</h1>
    <p class="text-slate-600 text-base leading-relaxed max-w-xl mx-auto mb-10">
      The page you were looking for doesn't exist or may have moved. Use the links below to find your way back on the Camino.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-left">
      {links.map(({ href, label, desc }) => (
        <a
          href={href}
          class="group flex items-start gap-3 bg-white border border-slate-200 rounded-2xl p-5 hover:border-forest-300 hover:shadow-md transition-all no-underline"
        >
          <span class="shrink-0 mt-0.5 flex h-9 w-9 items-center justify-center rounded-xl bg-forest-50 border border-forest-100 text-forest-700">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </span>
          <span>
            <span class="block text-sm font-bold text-forest-900 group-hover:text-forest-700">{label}</span>
            <span class="block text-xs text-slate-500 mt-0.5">{desc}</span>
          </span>
        </a>
      ))}
    </div>
  </section>

</MainLayout>
