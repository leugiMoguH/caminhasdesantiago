---
/**
 * EmailSignup — first-party audience capture (audit H1).
 *
 * DISABLED by design: a static site has no backend to receive the POST, so
 * exposing a form that submits to a non-functional endpoint = a dead feature.
 * The component renders NOTHING until BOTH are true:
 *   1. ENABLED = true
 *   2. ENDPOINT = a real provider form-action URL (Buttondown / MailerLite),
 *      which accepts a plain POST `email` and sets no third-party cookie.
 * Placements stay wired across pages; flip ENABLED when the list is live.
 */
const ENABLED = false;
const ENDPOINT = ''; // real provider form-action URL (required when ENABLED)
const SHOW = ENABLED && ENDPOINT.length > 0;

interface Props {
  lang: 'en' | 'es' | 'pt';
}
const { lang } = Astro.props;

const t = {
  en: {
    title: 'Coastal Camino checklist + ferry-status updates',
    body: 'One email before you walk: the pre-Camino checklist, plus a heads-up if the Caminha crossing changes. No spam, unsubscribe anytime.',
    placeholder: 'your@email.com',
    cta: 'Send me the checklist',
  },
  es: {
    title: 'Checklist del Camino de la Costa + avisos del ferry',
    body: 'Un correo antes de caminar: la checklist previa al Camino y un aviso si cambia el cruce de Caminha. Sin spam, te das de baja cuando quieras.',
    placeholder: 'tu@email.com',
    cta: 'Enviarme la checklist',
  },
  pt: {
    title: 'Checklist do Caminho da Costa + avisos do ferry',
    body: 'Um email antes de caminhares: a checklist pré-Caminho e um aviso se a travessia de Caminha mudar. Sem spam, cancelas quando quiseres.',
    placeholder: 'teu@email.com',
    cta: 'Enviar-me a checklist',
  },
}[lang];
---
{SHOW && (
  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="rounded-3xl bg-forest-50 border border-forest-100 p-7 sm:p-9">
      <h2 class="text-xl sm:text-2xl font-bold text-forest-900 mb-2">{t.title}</h2>
      <p class="text-slate-700 leading-relaxed mb-5 max-w-2xl">{t.body}</p>
      <form action={ENDPOINT} method="post" class="flex flex-col sm:flex-row gap-3 max-w-lg">
        <label for="email-signup" class="sr-only">{t.placeholder}</label>
        <input
          id="email-signup"
          type="email"
          name="email"
          required
          autocomplete="email"
          placeholder={t.placeholder}
          class="flex-1 rounded-xl border border-slate-300 bg-white px-4 py-3 text-base text-slate-900 placeholder:text-slate-400 focus:border-forest-500 focus:outline-none focus:ring-2 focus:ring-forest-200"
        />
        {/* Honeypot — bots fill it, humans never see it. */}
        <input type="text" name="hp" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
        <button
          type="submit"
          class="rounded-xl bg-forest-700 px-6 py-3 text-base font-bold text-white transition-colors hover:bg-forest-800 cursor-pointer"
        >
          {t.cta}
        </button>
      </form>
    </div>
  </section>
)}
