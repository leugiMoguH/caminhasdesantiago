---
/**
 * BaseSEO — global meta, OG, Twitter Card, hreflang, and JSON-LD.
 *
 * schemaType controls JSON-LD output:
 *   'website'      → WebSite (use on homepages only)
 *   'localbusiness'→ LocalBusiness (restaurants, hostels)
 *   'webpage'      → WebPage (default for all other pages)
 */

interface AlternateLang {
  lang: string;   // e.g. 'en', 'es', 'x-default'
  href: string;   // absolute URL
}

interface LocalBusinessData {
  name: string;
  description: string;
  address: string;
  telephone?: string;
  url?: string;
  priceRange?: string;
  servesCuisine?: string;
  openingHours?: string[];
}

interface Props {
  title: string;
  description: string;
  language: 'en' | 'es' | 'pt';
  canonicalURL: string;
  ogImage?: string;
  alternateLanguages: AlternateLang[];
  schemaType?: 'website' | 'webpage' | 'localbusiness' | 'none';
  localBusinessData?: LocalBusinessData;
}

const {
  title,
  description,
  language,
  canonicalURL,
  ogImage = '/images/og-default.png',
  alternateLanguages,
  schemaType = 'webpage',
  localBusinessData,
} = Astro.props;

const SITE_URL = 'https://waytosantiagoguide.com';
const SITE_NAME_EN = 'Way to Santiago Guide';
const SITE_NAME_ES = 'Guía Camino de Santiago';
const SITE_NAME_PT = 'Guia Caminho de Santiago';
const siteName = language === 'en' ? SITE_NAME_EN : language === 'es' ? SITE_NAME_ES : SITE_NAME_PT;
const fullTitle = (title === siteName || title.startsWith(siteName + ' |') || title.startsWith(siteName + '|'))
  ? title
  : `${title} | ${siteName}`;
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `${SITE_URL}${ogImage}`;
const htmlLang = language === 'en' ? 'en-GB' : language === 'es' ? 'es-ES' : 'pt-PT';

const ORG_ID = `${SITE_URL}/#organization`;
const WEBSITE_ID = `${SITE_URL}/#website`;

const orgNode = {
  '@type': 'Organization',
  '@id': ORG_ID,
  name: SITE_NAME_EN,
  url: SITE_URL,
  logo: {
    '@type': 'ImageObject',
    url: `${SITE_URL}/logo.png`,
  },
};

const websiteNode = {
  '@type': 'WebSite',
  '@id': WEBSITE_ID,
  url: SITE_URL,
  name: SITE_NAME_EN,
};

// SEGMENT_URL_OVERRIDES maps path segments with no real page to a real URL.
// Segments present but with no entry for the current language are skipped.
const SEGMENT_URL_OVERRIDES: Record<string, Partial<Record<string, string>>> = {
  caminha: { en: `${SITE_URL}/en/caminha-guide/` },
};
const pathSegments = canonicalURL.replace(SITE_URL, '').split('/').filter(Boolean);
const resolvedSegments = pathSegments.slice(1).flatMap((seg, i) => {
  if (seg in SEGMENT_URL_OVERRIDES) {
    const override = SEGMENT_URL_OVERRIDES[seg][language];
    if (!override) return [];
    return [{ name: 'Caminha Guide', item: override }];
  }
  return [{
    name: seg.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase()),
    item: `${SITE_URL}/${pathSegments.slice(0, i + 2).join('/')}/`,
  }];
});
const breadcrumbItems = [
  { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE_URL}/${language}/` },
  ...resolvedSegments.map((seg, i) => ({ '@type': 'ListItem', position: i + 2, ...seg })),
];

// Build JSON-LD schema object based on page type
let jsonLd: Record<string, unknown> | undefined;

if (schemaType === 'none') {
  // Page manages its own JSON-LD — BaseSEO emits nothing
} else if (schemaType === 'website') {
  const navItems = language === 'es'
    ? [
        { name: 'Dónde Comer',       url: `${SITE_URL}/es/caminha/donde-comer/` },
        { name: 'Dónde Dormir',      url: `${SITE_URL}/es/caminha/donde-dormir/` },
        { name: 'Ferry y Logística', url: `${SITE_URL}/es/caminha/ferry-y-logistica/` },
        { name: 'Servicios Útiles',  url: `${SITE_URL}/es/caminha/servicios-utiles/` },
      ]
    : language === 'pt'
    ? [
        { name: 'Onde Comer',        url: `${SITE_URL}/pt/caminha/onde-comer/` },
        { name: 'Onde Ficar',        url: `${SITE_URL}/pt/caminha/onde-ficar/` },
        { name: 'Ferry e Logística', url: `${SITE_URL}/pt/caminha/ferry-e-logistica/` },
        { name: 'Serviços Úteis',    url: `${SITE_URL}/pt/caminha/servicos-uteis/` },
      ]
    : [
        { name: 'Caminha Guide',     url: `${SITE_URL}/en/caminha-guide/` },
        { name: 'Where to Eat',      url: `${SITE_URL}/en/caminha/where-to-eat/` },
        { name: 'Where to Stay',     url: `${SITE_URL}/en/caminha/where-to-stay/` },
        { name: 'Ferry & Logistics', url: `${SITE_URL}/en/caminha/ferry-and-logistics/` },
        { name: 'Useful Services',   url: `${SITE_URL}/en/caminha/useful-services/` },
      ];

  jsonLd = {
    '@context': 'https://schema.org',
    '@graph': [
      orgNode,
      {
        '@type': 'WebSite',
        '@id': WEBSITE_ID,
        url: SITE_URL,
        name: SITE_NAME_EN,
        description,
        inLanguage: htmlLang,
        publisher: { '@id': ORG_ID },
        hasPart: navItems.map((item) => ({
          '@type': 'SiteNavigationElement',
          name: item.name,
          url: item.url,
        })),
      },
      {
        '@type': 'WebPage',
        '@id': `${canonicalURL}#webpage`,
        url: canonicalURL,
        name: fullTitle,
        inLanguage: htmlLang,
        isPartOf: { '@id': WEBSITE_ID },
        about: { '@id': ORG_ID },
      },
    ],
  };
} else if (schemaType === 'localbusiness' && localBusinessData) {
  jsonLd = {
    '@context': 'https://schema.org',
    '@graph': [
      orgNode,
      websiteNode,
      {
        '@type': 'WebPage',
        '@id': `${canonicalURL}#webpage`,
        url: canonicalURL,
        name: fullTitle,
        description,
        inLanguage: htmlLang,
        isPartOf: { '@id': WEBSITE_ID },
        about: { '@id': ORG_ID },
        breadcrumb: { '@id': `${canonicalURL}#breadcrumb` },
      },
      {
        '@type': 'BreadcrumbList',
        '@id': `${canonicalURL}#breadcrumb`,
        itemListElement: breadcrumbItems,
      },
      {
        '@type': 'LocalBusiness',
        name: localBusinessData.name,
        description: localBusinessData.description,
        url: localBusinessData.url ?? canonicalURL,
        address: {
          '@type': 'PostalAddress',
          streetAddress: localBusinessData.address,
          addressLocality: 'Caminha',
          addressRegion: 'Viana do Castelo',
          postalCode: '4910',
          addressCountry: 'PT',
        },
        ...(localBusinessData.telephone ? { telephone: localBusinessData.telephone } : {}),
        ...(localBusinessData.priceRange ? { priceRange: localBusinessData.priceRange } : {}),
        ...(localBusinessData.servesCuisine ? { servesCuisine: localBusinessData.servesCuisine } : {}),
        ...(localBusinessData.openingHours ? { openingHours: localBusinessData.openingHours } : {}),
        geo: {
          '@type': 'GeoCoordinates',
          latitude: 41.8772,
          longitude: -8.8389,
        },
        containedInPlace: {
          '@type': 'TouristDestination',
          name: 'Caminha',
          description: language === 'en'
            ? 'Historic border town on the Camino de Santiago Coastal Route, northern Portugal.'
            : 'Histórica ciudad fronteriza en el Camino de Santiago de la Costa, norte de Portugal.',
        },
      },
    ],
  };
} else {
  // Default: Organization + WebSite + WebPage + BreadcrumbList
  jsonLd = {
    '@context': 'https://schema.org',
    '@graph': [
      orgNode,
      websiteNode,
      {
        '@type': 'WebPage',
        '@id': `${canonicalURL}#webpage`,
        url: canonicalURL,
        name: fullTitle,
        description,
        inLanguage: htmlLang,
        isPartOf: { '@id': WEBSITE_ID },
        about: { '@id': ORG_ID },
        breadcrumb: { '@id': `${canonicalURL}#breadcrumb` },
      },
      {
        '@type': 'BreadcrumbList',
        '@id': `${canonicalURL}#breadcrumb`,
        itemListElement: breadcrumbItems,
      },
    ],
  };
}

const jsonLdString = jsonLd ? JSON.stringify(jsonLd) : undefined;
---

<!-- Primary meta -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<meta name="generator" content={Astro.generator} />

<!-- Canonical & hreflang -->
<link rel="canonical" href={canonicalURL} />
{alternateLanguages.map(({ lang, href }) => (
  <link rel="alternate" hreflang={lang} href={href} />
))}

<!-- OpenGraph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={ogImageAbsolute} />
<meta property="og:image:width" content="1424" />
<meta property="og:image:height" content="752" />
<meta property="og:image:alt" content="Scenic view of Caminha, Portugal — Camino de Santiago Coastal Route" />
<meta property="og:locale" content={htmlLang.replace('-', '_')} />
{alternateLanguages
  .filter(({ lang, href }) => {
    if (lang === 'x-default' || lang === language) return false;
    // Skip when this alternate points to a home-page fallback (no real translation exists)
    return href !== `${SITE_URL}/en/` && href !== `${SITE_URL}/es/` && href !== `${SITE_URL}/pt/`;
  })
  .map(({ lang }) => (
    <meta property="og:locale:alternate" content={lang === 'en' ? 'en_GB' : lang === 'es' ? 'es_ES' : 'pt_PT'} />
  ))
}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageAbsolute} />
<meta name="twitter:image:alt" content="Scenic view of Caminha, Portugal — Camino de Santiago Coastal Route" />

<!-- Favicons -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=2" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#174d2b" />

<!-- GEO / AI discovery hints -->
<meta name="geo.region" content="PT-VC" />
<meta name="geo.placename" content="Caminha, Portugal" />
<meta name="geo.position" content="41.8772;-8.8389" />
<meta name="ICBM" content="41.8772, -8.8389" />

<!-- JSON-LD Structured Data -->
{jsonLdString && <script type="application/ld+json" set:html={jsonLdString} />}
