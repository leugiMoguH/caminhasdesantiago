---
import { SOCIAL_LINKS } from '../lib/social';

interface Props {
  lang: 'en' | 'es' | 'pt';
}

const { lang } = Astro.props;

const year = new Date().getFullYear();

const t = {
  en: {
    tagline: 'Your independent guide for pilgrims and travellers on the Camino de Santiago Coastal Route through Caminha, Portugal.',
    explore: 'Explore Caminha',
    home: 'Home',
    guide: 'Caminha Guide',
    eat: 'Where to Eat',
    stay: 'Where to Stay',
    ferry: 'Ferry & Logistics',
    services: 'Useful Services',
    coastalRoute: 'Coastal Route Stages',
    crossing: 'Caminha → A Guarda Crossing',
    essentials: 'Pilgrim Essentials Guide',
    languages: 'Languages',
    english: 'English',
    spanish: 'Español',
    portuguese: 'Português',
    legal: 'Legal',
    privacy: 'Privacy Policy',
    disclaimer: 'Disclaimer',
    copyright: `© ${year} Caminha Guide. All rights reserved.`,
    ferryDisclaimerLabel: 'Ferry Timetable Notice',
    ferryDisclaimer: 'Ferry timetables and prices are subject to change without notice. Always verify schedules directly with the ferry operator before your crossing. This site is independently operated and has no affiliation with any transport provider.',
    independentNote: 'Independent guide — not affiliated with any Camino organisation or tourism board.',
    quickGuide: 'See the best places to stay (quick guide)',
  },
  es: {
    tagline: 'Tu guía independiente para peregrinos y viajeros en el Camino de Santiago de la Costa, a través de Caminha, Portugal.',
    explore: 'Explorar Caminha',
    home: 'Inicio',
    guide: 'Guía de Caminha',
    eat: 'Dónde Comer',
    stay: 'Dónde Dormir',
    ferry: 'Ferry y Logística',
    services: 'Servicios Útiles',
    coastalRoute: 'Etapas del Camino de la Costa',
    crossing: 'Cruce Caminha → A Guarda',
    essentials: 'Guía Esencial del Peregrino',
    languages: 'Idiomas',
    english: 'English',
    spanish: 'Español',
    portuguese: 'Português',
    legal: 'Legal',
    privacy: 'Política de Privacidad',
    disclaimer: 'Aviso Legal',
    copyright: `© ${year} Guía de Caminha. Todos los derechos reservados.`,
    ferryDisclaimerLabel: 'Aviso Horarios del Ferry',
    ferryDisclaimer: 'Los horarios y precios del ferry están sujetos a cambios sin previo aviso. Confirma siempre los horarios directamente con la naviera antes de tu travesía. Este sitio es independiente y no tiene ninguna afiliación con ningún proveedor de transporte.',
    independentNote: 'Guía independiente — sin afiliación con ninguna organización del Camino ni junta de turismo.',
    quickGuide: 'Mira los mejores sitios para dormir (guía rápida)',
  },
  pt: {
    tagline: 'O seu guia independente para peregrinos e viajantes na Rota Costeira do Caminho de Santiago, através de Caminha, Portugal.',
    explore: 'Explorar Caminha',
    home: 'Início',
    guide: 'Guia de Caminha',
    eat: 'Onde Comer',
    stay: 'Onde Ficar',
    ferry: 'Ferry e Logística',
    services: 'Serviços Úteis',
    coastalRoute: 'Etapas do Caminho da Costa',
    crossing: 'Travessia Caminha → A Guarda',
    essentials: 'Guia Essencial do Peregrino',
    languages: 'Idiomas',
    english: 'English',
    spanish: 'Español',
    portuguese: 'Português',
    legal: 'Legal',
    privacy: 'Política de Privacidade',
    disclaimer: 'Aviso Legal',
    copyright: `© ${year} Guia de Caminha. Todos os direitos reservados.`,
    ferryDisclaimerLabel: 'Aviso sobre Horários do Ferry',
    ferryDisclaimer: 'Os horários e preços do ferry estão sujeitos a alterações sem aviso prévio. Verifique sempre os horários diretamente com o operador do ferry antes da sua travessia. Este site é operado de forma independente e não tem qualquer afiliação com nenhum fornecedor de transporte.',
    independentNote: 'Guia independente — sem afiliação com nenhuma organização do Caminho ou junta de turismo.',
    quickGuide: 'Vê os melhores sítios para ficar (guia rápido)',
  },
} as const;

const text = t[lang];

const navLinks =
  lang === 'en'
    ? [
        { href: '/en/', label: text.home },
        { href: '/en/caminha-guide/', label: text.guide },
        { href: '/en/caminha/where-to-eat/', label: text.eat },
        { href: '/en/caminha/where-to-stay/', label: text.stay },
        { href: '/en/caminha/ferry-and-logistics/', label: text.ferry },
        { href: '/en/caminha/useful-services/', label: text.services },
        { href: '/en/caminho-da-costa/', label: text.coastalRoute },
        { href: '/en/caminho-da-costa/caminha-a-guarda/', label: text.crossing },
        { href: '/camino-portugues-guide/', label: text.essentials },
      ]
    : lang === 'es'
    ? [
        { href: '/es/', label: text.home },
        { href: '/es/guia-de-caminha/', label: text.guide },
        { href: '/es/caminha/donde-comer/', label: text.eat },
        { href: '/es/caminha/donde-dormir/', label: text.stay },
        { href: '/es/caminha/ferry-y-logistica/', label: text.ferry },
        { href: '/es/caminha/servicios-utiles/', label: text.services },
        { href: '/es/caminho-da-costa/', label: text.coastalRoute },
        { href: '/es/caminho-da-costa/caminha-a-guarda/', label: text.crossing },
        { href: '/camino-portugues-guide/', label: text.essentials },
      ]
    : [
        { href: '/pt/', label: text.home },
        { href: '/pt/guia-de-caminha/', label: text.guide },
        { href: '/pt/caminha/onde-comer/', label: text.eat },
        { href: '/pt/caminha/onde-ficar/', label: text.stay },
        { href: '/pt/caminha/ferry-e-logistica/', label: text.ferry },
        { href: '/pt/caminha/servicos-uteis/', label: text.services },
        { href: '/pt/caminho-da-costa/', label: text.coastalRoute },
        { href: '/pt/caminho-da-costa/caminha-a-guarda/', label: text.crossing },
        { href: '/camino-portugues-guide/', label: text.essentials },
      ];
---

<footer class="bg-forest-950 text-slate-300 mt-auto">

  <!-- Sitewide quick-guide CTA → conversion landing page -->
  <div class="bg-earth-600">
    <a
      href="/camino-portugues-where-to-stay/"
      class="mx-auto flex max-w-6xl items-center justify-center gap-2 px-4 py-3 text-center text-sm font-bold text-white no-underline hover:bg-earth-700 transition-colors sm:text-base"
    >
      👉 {text.quickGuide}
      <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    </a>
  </div>

  <!-- Main footer content -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand column -->
      <div class="lg:col-span-2">
        <a href={`/${lang}/`} class="flex items-center gap-3 no-underline mb-5 group cursor-pointer">
          <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-forest-600 group-hover:bg-forest-500 transition-colors shrink-0">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <g stroke="#da9a4d" stroke-width="1.4" stroke-linecap="round">
                <line x1="12" y1="18" x2="12" y2="5"/>
                <line x1="12" y1="18" x2="7.5" y2="5.5"/>
                <line x1="12" y1="18" x2="4" y2="8.5"/>
                <line x1="12" y1="18" x2="16.5" y2="5.5"/>
                <line x1="12" y1="18" x2="20" y2="8.5"/>
              </g>
              <path d="M4 8.5 Q5 3.5 12 3.5 Q19 3.5 20 8.5" stroke="#da9a4d" stroke-width="1.4" fill="none"/>
              <circle cx="12" cy="18" r="1.5" fill="#da9a4d"/>
            </svg>
          </span>
          <span class="font-bold text-white text-lg tracking-tight">Caminha Guide</span>
        </a>
        <p class="text-sm leading-relaxed text-slate-400 max-w-sm">
          {text.tagline}
        </p>
        <p class="mt-3 text-xs text-slate-400 italic">{text.independentNote}</p>

        <!-- Social media -->
        <div class="mt-6 flex items-center gap-3">
          <a
            href={SOCIAL_LINKS.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="flex h-10 w-10 items-center justify-center rounded-xl bg-forest-900 border border-forest-800 text-slate-400 hover:text-white hover:bg-forest-600 hover:border-forest-500 transition-all duration-200 cursor-pointer"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a
            href={SOCIAL_LINKS.facebook}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="flex h-10 w-10 items-center justify-center rounded-xl bg-forest-900 border border-forest-800 text-slate-400 hover:text-white hover:bg-forest-600 hover:border-forest-500 transition-all duration-200 cursor-pointer"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation column -->
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-5">
          {text.explore}
        </h2>
        <ul class="space-y-3" role="list">
          {navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="text-sm text-slate-400 hover:text-white transition-colors duration-200 no-underline hover:translate-x-0.5 inline-flex items-center gap-1.5 group cursor-pointer"
              >
                <svg class="h-3 w-3 text-earth-500 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                </svg>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Languages + Legal column -->
      <div class="space-y-8">
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-5">
            {text.languages}
          </h2>
          <ul class="space-y-3" role="list">
            <li>
              <a href="/en/" hreflang="en" class="text-sm text-slate-400 hover:text-white transition-colors duration-200 no-underline flex items-center gap-2.5 cursor-pointer group">
                <svg width="20" height="14" viewBox="0 0 60 40" xmlns="http://www.w3.org/2000/svg" class="rounded-sm shrink-0 opacity-80 group-hover:opacity-100 transition-opacity" aria-hidden="true">
                  <rect width="60" height="40" fill="#012169"/>
                  <path d="M0,0 L60,40 M60,0 L0,40" stroke="white" stroke-width="8"/>
                  <path d="M0,0 L60,40 M60,0 L0,40" stroke="#C8102E" stroke-width="5"/>
                  <path d="M30,0 V40 M0,20 H60" stroke="white" stroke-width="12"/>
                  <path d="M30,0 V40 M0,20 H60" stroke="#C8102E" stroke-width="7"/>
                </svg>
                {text.english}
              </a>
            </li>
            <li>
              <a href="/es/" hreflang="es" class="text-sm text-slate-400 hover:text-white transition-colors duration-200 no-underline flex items-center gap-2.5 cursor-pointer group">
                <svg width="20" height="14" viewBox="0 0 60 40" xmlns="http://www.w3.org/2000/svg" class="rounded-sm shrink-0 opacity-80 group-hover:opacity-100 transition-opacity" aria-hidden="true">
                  <rect width="60" height="40" fill="#c60b1e"/>
                  <rect y="10" width="60" height="20" fill="#ffc400"/>
                </svg>
                {text.spanish}
              </a>
            </li>
            <li>
              <a href="/pt/" hreflang="pt" class="text-sm text-slate-400 hover:text-white transition-colors duration-200 no-underline flex items-center gap-2.5 cursor-pointer group">
                <svg width="20" height="14" viewBox="0 0 60 40" xmlns="http://www.w3.org/2000/svg" class="rounded-sm shrink-0 opacity-80 group-hover:opacity-100 transition-opacity" aria-hidden="true">
                  <rect width="60" height="40" fill="#006600"/>
                  <rect x="18" width="42" height="40" fill="#FF0000"/>
                  <circle cx="18" cy="20" r="8" fill="#FFD700" stroke="#003399" stroke-width="1.5"/>
                </svg>
                {text.portuguese}
              </a>
            </li>
          </ul>
        </div>

        <div>
          <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-5">
            {text.legal}
          </h2>
          <ul class="space-y-3" role="list">
            <li>
              <a href={lang === 'en' ? '/en/privacy-policy/' : lang === 'es' ? '/es/politica-de-privacidad/' : '/pt/politica-de-privacidade/'} class="text-sm text-slate-400 hover:text-white transition-colors duration-200 no-underline cursor-pointer">
                {text.privacy}
              </a>
            </li>
          </ul>
        </div>
      </div>

    </div>

    <!-- Ferry disclaimer -->
    <div class="mt-12 pt-8 border-t border-forest-900/80">
      <div class="rounded-xl bg-forest-900/60 border border-forest-800/60 p-5 flex gap-3">
        <!-- Warning triangle SVG -->
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-earth-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
        </svg>
        <p class="text-xs text-slate-400 leading-relaxed">
          <strong class="text-slate-300 font-semibold">{text.ferryDisclaimerLabel}:</strong>{' '}
          {text.ferryDisclaimer}
        </p>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-6">
      <p class="text-xs text-slate-400">{text.copyright}</p>
    </div>

  </div>


</footer>
