---
interface Props {
  lang: 'en' | 'es' | 'pt';
  enUrl: string;
  esUrl: string;
  ptUrl: string;
}

const { lang, enUrl, esUrl, ptUrl } = Astro.props;

const t = {
  en: {
    home: 'Home',
    guide: 'Caminha Guide',
    whereToEat: 'Where to Eat',
    whereToStay: 'Where to Stay',
    ferry: 'Ferry & Logistics',
    usefulServices: 'Useful Services',
    menuLabel: 'Open navigation menu',
    skipNav: 'Skip to main content',
  },
  es: {
    home: 'Inicio',
    guide: 'Guía de Caminha',
    whereToEat: 'Dónde Comer',
    whereToStay: 'Dónde Dormir',
    ferry: 'Ferry y Logística',
    usefulServices: 'Servicios Útiles',
    menuLabel: 'Abrir menú de navegación',
    skipNav: 'Saltar al contenido principal',
  },
  pt: {
    home: 'Início',
    guide: 'Guia de Caminha',
    whereToEat: 'Onde Comer',
    whereToStay: 'Onde Ficar',
    ferry: 'Ferry e Logística',
    usefulServices: 'Serviços Úteis',
    menuLabel: 'Abrir menu de navegação',
    skipNav: 'Saltar para o conteúdo principal',
  },
} as const;

const text = t[lang];

const baseNav =
  lang === 'en'
    ? [
        { href: '/en/', label: text.home },
        { href: '/en/caminha-guide/', label: text.guide },
        { href: '/en/caminha/where-to-eat/', label: text.whereToEat },
        { href: '/en/caminha/where-to-stay/', label: text.whereToStay },
        { href: '/en/caminha/ferry-and-logistics/', label: text.ferry },
        { href: '/en/caminha/useful-services/', label: text.usefulServices },
      ]
    : lang === 'es'
    ? [
        { href: '/es/', label: text.home },
        { href: '/es/caminha/donde-comer/', label: text.whereToEat },
        { href: '/es/caminha/donde-dormir/', label: text.whereToStay },
        { href: '/es/caminha/ferry-y-logistica/', label: text.ferry },
        { href: '/es/caminha/servicios-utiles/', label: text.usefulServices },
      ]
    : [
        { href: '/pt/', label: text.home },
        { href: '/pt/caminha/onde-comer/', label: text.whereToEat },
        { href: '/pt/caminha/onde-ficar/', label: text.whereToStay },
        { href: '/pt/caminha/ferry-e-logistica/', label: text.ferry },
        { href: '/pt/caminha/servicos-uteis/', label: text.usefulServices },
      ];

const currentPath = Astro.url.pathname;

const langOptions = [
  { code: 'EN', href: enUrl, hreflang: 'en', active: lang === 'en' },
  { code: 'ES', href: esUrl, hreflang: 'es', active: lang === 'es' },
  { code: 'PT', href: ptUrl, hreflang: 'pt', active: lang === 'pt' },
];
---

<a
  href="#main-content"
  class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:rounded-lg focus:bg-forest-700 focus:px-4 focus:py-2 focus:text-white focus:text-sm focus:font-medium"
>
  {text.skipNav}
</a>

<header class="sticky top-0 z-40 px-3 pt-3 pb-0">
  <div class="mx-auto max-w-6xl bg-white/85 backdrop-blur-md border border-slate-200/60 shadow-lg shadow-slate-900/5 rounded-2xl">
    <div class="flex h-14 items-center justify-between px-4 sm:px-5">

      <a
        href={`/${lang}/`}
        class="flex items-center gap-2.5 no-underline group cursor-pointer"
        aria-label="Caminha Guide — home"
      >
        <span
          class="flex h-8 w-8 items-center justify-center rounded-xl bg-forest-700 shrink-0 shadow-sm group-hover:bg-forest-600 transition-colors duration-200"
          aria-hidden="true"
        >
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" xmlns="http://www.w3.org/2000/svg">
            <g stroke="#da9a4d" stroke-width="1.4" stroke-linecap="round">
              <line x1="12" y1="18" x2="12" y2="5"/>
              <line x1="12" y1="18" x2="7.5" y2="5.5"/>
              <line x1="12" y1="18" x2="4" y2="8.5"/>
              <line x1="12" y1="18" x2="16.5" y2="5.5"/>
              <line x1="12" y1="18" x2="20" y2="8.5"/>
            </g>
            <path d="M4 8.5 Q5 3.5 12 3.5 Q19 3.5 20 8.5" stroke="#da9a4d" stroke-width="1.4" fill="none"/>
            <circle cx="12" cy="18" r="1.5" fill="#da9a4d"/>
          </svg>
        </span>
        <span class="font-bold text-forest-900 text-sm leading-tight">
          Caminha<br />
          <span class="text-xs font-normal text-slate-400 tracking-widest uppercase">
            Camino de Santiago
          </span>
        </span>
      </a>

      <nav aria-label="Main navigation" class="hidden md:flex items-center gap-0.5">
        {baseNav.map(({ href, label }) => {
          const isActive = currentPath === href || (currentPath.startsWith(href) && href !== `/${lang}/`);
          return (
            <a
              href={href}
              aria-current={isActive ? 'page' : undefined}
              class={[
                'relative px-3.5 py-2 rounded-xl text-sm font-medium transition-all duration-200 no-underline cursor-pointer group',
                isActive
                  ? 'text-forest-800 bg-forest-50/80'
                  : 'text-slate-600 hover:text-forest-800 hover:bg-forest-50/60',
              ].join(' ')}
            >
              {label}
              {isActive && (
                <span class="absolute bottom-1 left-1/2 -translate-x-1/2 h-0.5 w-4 bg-earth-500 rounded-full" aria-hidden="true" />
              )}
            </a>
          );
        })}
      </nav>

      <div class="flex items-center gap-2">
        <div class="flex items-center rounded-full border border-slate-200 overflow-hidden text-xs font-semibold shadow-sm">
          {langOptions.map(({ code, href, hreflang, active }) => (
            active
              ? (
                <span
                  class="flex items-center gap-1 px-2.5 py-1.5 bg-forest-700 text-white select-none"
                  aria-label={`Current language: ${code}`}
                >
                  {code}
                </span>
              )
              : (
                <a
                  href={href}
                  hreflang={hreflang}
                  class="px-2.5 py-1.5 text-slate-600 hover:text-forest-700 hover:bg-forest-50 transition-colors no-underline cursor-pointer border-l border-slate-200"
                  aria-label={`Switch to ${code}`}
                >
                  {code}
                </a>
              )
          ))}
        </div>

        <button
          id="mobile-menu-btn"
          type="button"
          aria-controls="mobile-menu"
          aria-expanded="false"
          aria-label={text.menuLabel}
          class="md:hidden flex items-center justify-center h-9 w-9 rounded-xl text-slate-600 hover:text-forest-700 hover:bg-forest-50 transition-colors cursor-pointer"
        >
          <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <nav
      id="mobile-menu"
      aria-label="Mobile navigation"
      class="hidden md:hidden border-t border-slate-100/80"
    >
      <div class="px-3 py-3 flex flex-col gap-1">
        {baseNav.map(({ href, label }) => {
          const isActive = currentPath === href || (currentPath.startsWith(href) && href !== `/${lang}/`);
          return (
            <a
              href={href}
              aria-current={isActive ? 'page' : undefined}
              class={[
                'block px-4 py-2.5 rounded-xl text-sm font-medium transition-colors no-underline cursor-pointer',
                isActive
                  ? 'bg-forest-50 text-forest-800 font-semibold'
                  : 'text-slate-700 hover:text-forest-700 hover:bg-forest-50',
              ].join(' ')}
            >
              {label}
            </a>
          );
        })}
      </div>
    </nav>
  </div>
  <div class="h-3" aria-hidden="true"></div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
    iconMenu?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });

  document.addEventListener('click', (e) => {
    if (!btn?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
      menu?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
      iconMenu?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    }
  });
</script>
