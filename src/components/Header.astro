---
interface Props {
  lang: 'en' | 'es';
  enUrl: string;
  esUrl: string;
}

const { lang, enUrl, esUrl } = Astro.props;

const t = {
  en: {
    home: 'Home',
    whereToEat: 'Where to Eat',
    whereToStay: 'Where to Stay',
    ferry: 'Ferry & Logistics',
    menuLabel: 'Open navigation menu',
    langSwitch: 'Español',
    skipNav: 'Skip to main content',
  },
  es: {
    home: 'Inicio',
    whereToEat: 'Dónde Comer',
    whereToStay: 'Dónde Dormir',
    ferry: 'Ferry y Logística',
    menuLabel: 'Abrir menú de navegación',
    langSwitch: 'English',
    skipNav: 'Saltar al contenido principal',
  },
} as const;

const text = t[lang];

const baseNav =
  lang === 'en'
    ? [
        { href: '/en/', label: text.home },
        { href: '/en/caminha/where-to-eat/', label: text.whereToEat },
        { href: '/en/caminha/where-to-stay/', label: text.whereToStay },
        { href: '/en/caminha/ferry-and-logistics/', label: text.ferry },
      ]
    : [
        { href: '/es/', label: text.home },
        { href: '/es/caminha/donde-comer/', label: text.whereToEat },
        { href: '/es/caminha/donde-dormir/', label: text.whereToStay },
        { href: '/es/caminha/ferry-y-logistica/', label: text.ferry },
      ];

const currentPath = Astro.url.pathname;
const altLangHref = lang === 'en' ? esUrl : enUrl;
const altLangLabel = text.langSwitch;
const altLangCode = lang === 'en' ? 'ES' : 'EN';
const currentLangCode = lang === 'en' ? 'EN' : 'ES';
---

<!-- Skip-to-content for keyboard/screen-reader users -->
<a
  href="#main-content"
  class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:rounded focus:bg-forest-700 focus:px-4 focus:py-2 focus:text-white focus:text-sm focus:font-medium"
>
  {text.skipNav}
</a>

<header class="sticky top-0 z-40 bg-white/95 backdrop-blur-sm border-b border-slate-200 shadow-sm">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">

      <!-- Logo -->
      <a
        href={`/${lang}/`}
        class="flex items-center gap-2.5 no-underline group"
        aria-label="Caminha Guide — home"
      >
        <span
          class="flex h-8 w-8 items-center justify-center rounded-lg bg-forest-700 text-white font-bold text-sm select-none"
          aria-hidden="true"
        >
          C
        </span>
        <span class="font-bold text-forest-900 text-base leading-tight">
          Caminha<br />
          <span class="text-xs font-normal text-slate-500 tracking-wide uppercase">
            Camino de Santiago
          </span>
        </span>
      </a>

      <!-- Desktop nav -->
      <nav aria-label="Main navigation" class="hidden md:flex items-center gap-1">
        {baseNav.map(({ href, label }) => {
          const isActive = currentPath === href || currentPath.startsWith(href) && href !== `/${lang}/`;
          return (
            <a
              href={href}
              aria-current={isActive ? 'page' : undefined}
              class={[
                'px-3 py-2 rounded-md text-sm font-medium transition-colors duration-150 no-underline',
                isActive
                  ? 'bg-forest-50 text-forest-800 font-semibold'
                  : 'text-slate-600 hover:text-forest-700 hover:bg-forest-50',
              ].join(' ')}
            >
              {label}
            </a>
          );
        })}
      </nav>

      <!-- Right side: lang switcher + mobile menu button -->
      <div class="flex items-center gap-2">

        <!-- Language switcher -->
        <div class="flex items-center rounded-full border border-slate-200 overflow-hidden text-xs font-semibold">
          <span
            class="px-2.5 py-1 bg-forest-700 text-white select-none"
            aria-label={`Current language: ${currentLangCode}`}
          >
            {currentLangCode}
          </span>
          <a
            href={altLangHref}
            hreflang={lang === 'en' ? 'es' : 'en'}
            class="px-2.5 py-1 text-slate-600 hover:text-forest-700 hover:bg-forest-50 transition-colors no-underline"
            aria-label={`Switch to ${altLangLabel}`}
          >
            {altLangCode}
          </a>
        </div>

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          type="button"
          aria-controls="mobile-menu"
          aria-expanded="false"
          aria-label={text.menuLabel}
          class="md:hidden flex items-center justify-center h-9 w-9 rounded-md text-slate-600 hover:text-forest-700 hover:bg-forest-50 transition-colors"
        >
          <!-- Hamburger icon -->
          <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <!-- Close icon (hidden by default) -->
          <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>

      </div>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <nav
    id="mobile-menu"
    aria-label="Mobile navigation"
    class="hidden md:hidden border-t border-slate-100 bg-white"
  >
    <div class="mx-auto max-w-6xl px-4 py-3 flex flex-col gap-1">
      {baseNav.map(({ href, label }) => {
        const isActive = currentPath === href || currentPath.startsWith(href) && href !== `/${lang}/`;
        return (
          <a
            href={href}
            aria-current={isActive ? 'page' : undefined}
            class={[
              'block px-3 py-2.5 rounded-md text-sm font-medium transition-colors no-underline',
              isActive
                ? 'bg-forest-50 text-forest-800 font-semibold'
                : 'text-slate-700 hover:text-forest-700 hover:bg-forest-50',
            ].join(' ')}
          >
            {label}
          </a>
        );
      })}
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
    iconMenu?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!btn?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
      menu?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
      iconMenu?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    }
  });
</script>
