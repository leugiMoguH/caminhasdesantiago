---
import BaseSEO from '../components/BaseSEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

/**
 * Path-to-alternate URL mapping.
 * Add new routes here when creating new pages.
 */
const PATH_MAP: Record<string, { en: string; es: string; pt: string }> = {
  '/en/':                                    { en: '/en/',                                    es: '/es/',                                    pt: '/pt/' },
  '/es/':                                    { en: '/en/',                                    es: '/es/',                                    pt: '/pt/' },
  '/pt/':                                    { en: '/en/',                                    es: '/es/',                                    pt: '/pt/' },
  '/en/caminha/where-to-eat/':               { en: '/en/caminha/where-to-eat/',               es: '/es/caminha/donde-comer/',               pt: '/pt/caminha/onde-comer/' },
  '/es/caminha/donde-comer/':                { en: '/en/caminha/where-to-eat/',               es: '/es/caminha/donde-comer/',               pt: '/pt/caminha/onde-comer/' },
  '/pt/caminha/onde-comer/':                 { en: '/en/caminha/where-to-eat/',               es: '/es/caminha/donde-comer/',               pt: '/pt/caminha/onde-comer/' },
  '/en/caminha/where-to-stay/':              { en: '/en/caminha/where-to-stay/',              es: '/es/caminha/donde-dormir/',              pt: '/pt/caminha/onde-ficar/' },
  '/es/caminha/donde-dormir/':               { en: '/en/caminha/where-to-stay/',              es: '/es/caminha/donde-dormir/',              pt: '/pt/caminha/onde-ficar/' },
  '/pt/caminha/onde-ficar/':                 { en: '/en/caminha/where-to-stay/',              es: '/es/caminha/donde-dormir/',              pt: '/pt/caminha/onde-ficar/' },
  '/en/caminha/ferry-and-logistics/':        { en: '/en/caminha/ferry-and-logistics/',        es: '/es/caminha/ferry-y-logistica/',         pt: '/pt/caminha/ferry-e-logistica/' },
  '/es/caminha/ferry-y-logistica/':          { en: '/en/caminha/ferry-and-logistics/',        es: '/es/caminha/ferry-y-logistica/',         pt: '/pt/caminha/ferry-e-logistica/' },
  '/pt/caminha/ferry-e-logistica/':          { en: '/en/caminha/ferry-and-logistics/',        es: '/es/caminha/ferry-y-logistica/',         pt: '/pt/caminha/ferry-e-logistica/' },
  '/en/caminha/useful-services/':            { en: '/en/caminha/useful-services/',            es: '/es/caminha/servicios-utiles/',          pt: '/pt/caminha/servicos-uteis/' },
  '/es/caminha/servicios-utiles/':           { en: '/en/caminha/useful-services/',            es: '/es/caminha/servicios-utiles/',          pt: '/pt/caminha/servicos-uteis/' },
  '/pt/caminha/servicos-uteis/':             { en: '/en/caminha/useful-services/',            es: '/es/caminha/servicios-utiles/',          pt: '/pt/caminha/servicos-uteis/' },
  '/en/caminha-guide/':                      { en: '/en/caminha-guide/',                      es: '/es/guia-de-caminha/',                    pt: '/pt/guia-de-caminha/' },
  '/es/guia-de-caminha/':                    { en: '/en/caminha-guide/',                      es: '/es/guia-de-caminha/',                    pt: '/pt/guia-de-caminha/' },
  '/pt/guia-de-caminha/':                    { en: '/en/caminha-guide/',                      es: '/es/guia-de-caminha/',                    pt: '/pt/guia-de-caminha/' },
  '/en/caminha/vila-praia-de-ancora/':       { en: '/en/caminha/vila-praia-de-ancora/',        es: '/es/',                                    pt: '/pt/' },
  '/en/caminha/seixas/':                     { en: '/en/caminha/seixas/',                      es: '/es/',                                    pt: '/pt/' },
  '/en/caminha/pilgrim-guide/':              { en: '/en/caminha/pilgrim-guide/',               es: '/es/caminha/guia-del-peregrino/',         pt: '/pt/caminha/guia-do-peregrino/' },
  '/es/caminha/guia-del-peregrino/':         { en: '/en/caminha/pilgrim-guide/',               es: '/es/caminha/guia-del-peregrino/',         pt: '/pt/caminha/guia-do-peregrino/' },
  '/pt/caminha/guia-do-peregrino/':          { en: '/en/caminha/pilgrim-guide/',               es: '/es/caminha/guia-del-peregrino/',         pt: '/pt/caminha/guia-do-peregrino/' },
  '/en/sitemap/':                            { en: '/en/sitemap/',                             es: '/es/',                                    pt: '/pt/' },
  '/en/caminha-ferry-status/':               { en: '/en/caminha-ferry-status/',                es: '/es/',                                    pt: '/pt/' },
  '/en/privacy-policy/':                     { en: '/en/privacy-policy/',                      es: '/es/politica-de-privacidad/',             pt: '/pt/politica-de-privacidade/' },
  '/es/politica-de-privacidad/':             { en: '/en/privacy-policy/',                      es: '/es/politica-de-privacidad/',             pt: '/pt/politica-de-privacidade/' },
  '/pt/politica-de-privacidade/':            { en: '/en/privacy-policy/',                      es: '/es/politica-de-privacidad/',             pt: '/pt/politica-de-privacidade/' },
};

interface AlternateLang {
  lang: string;
  href: string;
}

interface LocalBusinessData {
  name: string;
  description: string;
  address: string;
  telephone?: string;
  url?: string;
  priceRange?: string;
  servesCuisine?: string;
  openingHours?: string[];
}

interface Props {
  title: string;
  description: string;
  lang: 'en' | 'es' | 'pt';
  schemaType?: 'website' | 'webpage' | 'localbusiness' | 'none';
  localBusinessData?: LocalBusinessData;
  ogImage?: string;
  noindex?: boolean;
  // Override hreflang + language-switcher URLs for routes not in PATH_MAP
  // (dynamic cluster pages supply their own en/es/pt absolute URLs).
  i18nUrls?: { en: string; es: string; pt: string };
}

const { title, description, lang, schemaType = 'webpage', localBusinessData, ogImage, noindex = false, i18nUrls } = Astro.props;

const SITE_URL = 'https://waytosantiagoguide.com';
const currentPath = Astro.url.pathname;
const canonicalURL = `${SITE_URL}${currentPath}`;

// Resolve alternate URLs from the path map (fall back to lang roots)
const pathEntry = PATH_MAP[currentPath];
const enPath = pathEntry?.en ?? '/en/';
const esPath = pathEntry?.es ?? '/es/';
const ptPath = pathEntry?.pt ?? '/pt/';

// EN-only pages have no real ES/PT equivalent. They must NOT emit es/pt
// hreflang (would be non-reciprocal — /es/ and /pt/ do not point back).
// Emit only self en + x-default for these.
const NO_TRANSLATION = new Set([
  '/en/caminha/vila-praia-de-ancora/',
  '/en/caminha/seixas/',
  '/en/caminha-ferry-status/',
  '/en/sitemap/',
  '/404/',
  '/404',
]);
// 404 is a non-indexed utility route (served with HTTP 404). It has no
// canonical translations — emit no hreflang at all to avoid a non-reciprocal
// pair pointing at a home page.
const isUtilityRoute = currentPath === '/404/' || currentPath === '/404';
const hasTranslations = !NO_TRANSLATION.has(currentPath);

const enUrlFull = i18nUrls?.en ?? `${SITE_URL}${enPath}`;
const esUrlFull = i18nUrls?.es ?? `${SITE_URL}${esPath}`;
const ptUrlFull = i18nUrls?.pt ?? `${SITE_URL}${ptPath}`;

const alternateLanguages: AlternateLang[] = isUtilityRoute
  ? []
  : i18nUrls
  ? [
      { lang: 'en', href: i18nUrls.en },
      { lang: 'es', href: i18nUrls.es },
      { lang: 'pt', href: i18nUrls.pt },
      { lang: 'x-default', href: i18nUrls.en },
    ]
  : hasTranslations
  ? [
      { lang: 'en', href: `${SITE_URL}${enPath}` },
      { lang: 'es', href: `${SITE_URL}${esPath}` },
      { lang: 'pt', href: `${SITE_URL}${ptPath}` },
      { lang: 'x-default', href: `${SITE_URL}${enPath}` },
    ]
  : [
      { lang: 'en', href: `${SITE_URL}${enPath}` },
      { lang: 'x-default', href: `${SITE_URL}${enPath}` },
    ];

const htmlLang = lang === 'en' ? 'en' : lang === 'es' ? 'es' : 'pt';
---

<!doctype html>
<html lang={htmlLang} dir="ltr">
  <head>
    <BaseSEO
      title={title}
      description={description}
      language={lang}
      canonicalURL={canonicalURL}
      alternateLanguages={alternateLanguages}
      schemaType={schemaType}
      localBusinessData={localBusinessData}
      ogImage={ogImage}
      noindex={noindex}
    />

    <!-- Google Analytics 4 — G-GF2GHM795M -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-GF2GHM795M"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-GF2GHM795M');
    </script>

    <!-- Google AdSense -->
    

    <!-- Preconnect + DM Sans font (non-blocking: load async, swap on load) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" media="print" onload="this.media='all'" />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" />
    </noscript>
  </head>
  <body>

    <Header lang={lang} enUrl={enUrlFull} esUrl={esUrlFull} ptUrl={ptUrlFull} />

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <Footer lang={lang} />

  </body>
</html>
