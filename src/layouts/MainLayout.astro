---
import BaseSEO from '../components/BaseSEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

/**
 * Path-to-alternate URL mapping.
 * Add new routes here when creating new pages.
 */
const PATH_MAP: Record<string, { en: string; es: string }> = {
  '/en/':                                    { en: '/en/',                                    es: '/es/' },
  '/es/':                                    { en: '/en/',                                    es: '/es/' },
  '/en/caminha/where-to-eat/':               { en: '/en/caminha/where-to-eat/',               es: '/es/caminha/donde-comer/' },
  '/es/caminha/donde-comer/':                { en: '/en/caminha/where-to-eat/',               es: '/es/caminha/donde-comer/' },
  '/en/caminha/where-to-stay/':              { en: '/en/caminha/where-to-stay/',              es: '/es/caminha/donde-dormir/' },
  '/es/caminha/donde-dormir/':               { en: '/en/caminha/where-to-stay/',              es: '/es/caminha/donde-dormir/' },
  '/en/caminha/ferry-and-logistics/':        { en: '/en/caminha/ferry-and-logistics/',        es: '/es/caminha/ferry-y-logistica/' },
  '/es/caminha/ferry-y-logistica/':          { en: '/en/caminha/ferry-and-logistics/',        es: '/es/caminha/ferry-y-logistica/' },
  '/en/caminha/useful-services/':            { en: '/en/caminha/useful-services/',            es: '/es/caminha/servicios-utiles/' },
  '/es/caminha/servicios-utiles/':           { en: '/en/caminha/useful-services/',            es: '/es/caminha/servicios-utiles/' },
  '/en/privacy-policy/':                     { en: '/en/privacy-policy/',                     es: '/es/politica-de-privacidad/' },
  '/es/politica-de-privacidad/':             { en: '/en/privacy-policy/',                     es: '/es/politica-de-privacidad/' },
};

interface AlternateLang {
  lang: string;
  href: string;
}

interface LocalBusinessData {
  name: string;
  description: string;
  address: string;
  telephone?: string;
  url?: string;
  priceRange?: string;
  servesCuisine?: string;
  openingHours?: string[];
}

interface Props {
  title: string;
  description: string;
  lang: 'en' | 'es';
  schemaType?: 'website' | 'webpage' | 'localbusiness';
  localBusinessData?: LocalBusinessData;
  ogImage?: string;
}

const { title, description, lang, schemaType = 'webpage', localBusinessData, ogImage } = Astro.props;

const SITE_URL = 'https://waytosantiagoguide.com';
const currentPath = Astro.url.pathname;
const canonicalURL = `${SITE_URL}${currentPath}`;

// Resolve alternate URLs from the path map (fall back to lang roots)
const pathEntry = PATH_MAP[currentPath];
const enPath = pathEntry?.en ?? '/en/';
const esPath = pathEntry?.es ?? '/es/';

const alternateLanguages: AlternateLang[] = [
  { lang: 'en', href: `${SITE_URL}${enPath}` },
  { lang: 'es', href: `${SITE_URL}${esPath}` },
  { lang: 'x-default', href: `${SITE_URL}${enPath}` },
];

const htmlLang = lang === 'en' ? 'en' : 'es';
---

<!doctype html>
<html lang={htmlLang} dir="ltr">
  <head>
    <BaseSEO
      title={title}
      description={description}
      language={lang}
      canonicalURL={canonicalURL}
      alternateLanguages={alternateLanguages}
      schemaType={schemaType}
      localBusinessData={localBusinessData}
      ogImage={ogImage}
    />

    <!-- Google Analytics 4 — G-GF2GHM795M -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-GF2GHM795M"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-GF2GHM795M');
    </script>

    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6529337148344504" crossorigin="anonymous"></script>

    <!-- Preconnect + DM Sans font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" />
  </head>
  <body>

    <Header lang={lang} enUrl={`${SITE_URL}${enPath}`} esUrl={`${SITE_URL}${esPath}`} />

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <Footer lang={lang} />

  </body>
</html>
